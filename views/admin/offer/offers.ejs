<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zyrox – Offers Management</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=3">
    <meta name="description"
        content="Manage product-specific and category-wide offers, discounts, and promotional campaigns on Zyrox.">
    <!-- Google Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Syne:wght@700;800&display=swap"
        rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <style>
        :root {
            --brand: #6366f1;
            --brand-soft: rgba(99, 102, 241, 0.1);
            --bg-glass: rgba(255, 255, 255, 0.7);
            --border-glass: rgba(255, 255, 255, 0.3);
            --text-main: #1e293b;
            --text-muted: #64748b;
            --card-radius: 24px;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --surface: #ffffff;
            --surface-alt: #f8fafc;
            --primary-black: #1a1a1a;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            background-attachment: fixed;
            color: var(--text-main);
            overflow-x: hidden;
            min-height: 100vh;
        }

        .main-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            padding: 2.5rem;
            background: var(--bg-glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            margin: 1.5rem;
            border-radius: var(--card-radius);
            border: 1px solid var(--border-glass);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            min-height: 0;
            animation: slideUp 0.6s ease-out;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header-section {
            margin-bottom: 2.5rem;
            flex-shrink: 0;
        }

        .header-section h1 {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 2.75rem;
            letter-spacing: -1px;
            background: linear-gradient(90deg, #1e293b, #6366f1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .header-section p {
            font-size: 1.1rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* ── FILTER BAR ── */
        .filter-bar {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 16px;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .filter-bar:focus-within {
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.1);
            background: white;
        }

        .search-wrapper {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            position: relative;
        }

        .search-wrapper i {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        .search-wrapper input {
            border: none;
            background: transparent;
            outline: none;
            width: 100%;
            font-size: 1rem;
            font-weight: 500;
            color: var(--text-main);
        }

        .search-wrapper input::placeholder {
            color: #cbd5e1;
        }

        /* ── TABLE STYLING ── */
        .table-responsive {
            flex: 1;
            overflow-y: auto;
            min-height: 0;
            border-radius: 16px;
            background: white;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
            border: 1px solid #f1f5f9;
        }

        .offer-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }

        .offer-table th {
            background: #f8fafc;
            padding: 14px 20px;
            font-weight: 700;
            color: var(--text-muted);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            border-bottom: 1px solid #f1f5f9;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .offer-table td {
            padding: 16px 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            font-size: 14px;
            color: var(--text-main);
            transition: all 0.2s;
        }

        .offer-table tbody tr {
            transition: all 0.3s;
        }

        .offer-table tbody tr:hover {
            background: #f8fafc;
            transform: scale(1.002);
        }

        .offer-table tbody tr:last-child td {
            border-bottom: none;
        }

        .badge-pill-custom {
            padding: 3px 9px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 11px;
            border: 1px solid transparent;
        }

        .badge-category {
            background: #eef2ff;
            color: #4f46e5;
            border-color: #e0e7ff;
        }

        .badge-product {
            background: #fff7ed;
            color: #ea580c;
            border-color: #ffedd5;
        }

        .badge-status-active {
            background: #ecfdf5;
            color: #059669;
        }

        .badge-status-inactive {
            background: #fef2f2;
            color: #dc2626;
        }

        .btn-add-offer {
            background: var(--brand);
            color: #fff;
            padding: 0.8rem 2rem;
            border-radius: 16px;
            font-weight: 700;
            border: none;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }

        .btn-add-offer:hover {
            background: #4f46e5;
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4);
            color: #fff;
        }

        .btn-add-offer:active {
            transform: translateY(0);
        }

        /* ── MODAL STYLING ── */
        .modal-content {
            border-radius: 28px;
            border: none;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        }

        .modal-header {
            border-bottom: 1px solid #f1f1f1;
            padding: 2rem 2.5rem 1rem;
        }

        .modal-title {
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 1.75rem;
        }

        .modal-body {
            padding: 2rem 2.5rem;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.9rem;
            color: #374151;
            margin-bottom: 0.5rem;
        }

        .form-label span {
            color: #ef4444;
        }

        .zyrax-input-group {
            margin-bottom: 1.5rem;
        }

        .zyrax-input {
            border: 1.5px solid #e5e7eb;
            border-radius: 14px;
            padding: 0.75rem 1rem;
            font-size: 0.95rem;
            color: #1f2937;
            transition: all 0.2s;
            background: #f9fafb;
        }

        .zyrax-input:focus {
            background: #fff;
            border-color: var(--primary-black);
            box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.05);
            outline: none;
        }

        .option-card-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .option-card {
            position: relative;
            background: #f9fafb;
            border: 1.5px solid #e5e7eb;
            border-radius: 14px;
            padding: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .option-card:hover {
            border-color: #d1d5db;
        }

        .option-card input[type="radio"] {
            position: absolute;
            opacity: 0;
        }

        .option-card .radio-indicator {
            width: 20px;
            height: 20px;
            border: 2px solid #d1d5db;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .option-card input[type="radio"]:checked+.radio-indicator {
            border-color: var(--primary-black);
            background: var(--primary-black);
        }

        .option-card input[type="radio"]:checked+.radio-indicator::after {
            content: "";
            width: 8px;
            height: 8px;
            background: #fff;
            border-radius: 50%;
        }

        .option-card.active {
            border-color: var(--primary-black);
            background: #fff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .date-input-wrapper {
            position: relative;
        }

        .date-input-wrapper i {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            pointer-events: none;
        }

        .gray-box {
            background: #f9fafb;
            border-radius: 16px;
            padding: 1.5rem;
            border: 1px solid #f1f1f1;
        }

        .btn-submit {
            background: var(--primary-black);
            color: white;
            border: none;
            padding: 1rem;
            width: 100%;
            border-radius: 14px;
            font-weight: 600;
            font-size: 1rem;
            margin-top: 1rem;
            transition: all 0.2s;
        }

        .btn-submit:hover {
            background: #000;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .status-switch {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.25rem;
            background: #fff;
            border-radius: 12px;
            border: 1.5px solid #e5e7eb;
        }

        .form-switch .form-check-input {
            width: 3rem;
            height: 1.5rem;
            cursor: pointer;
        }

        .form-switch .form-check-input:checked {
            background-color: var(--primary-black);
            border-color: var(--primary-black);
        }

        /* ── ACTION BUTTONS ── */
        .offer-edit-btn {
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
            padding: 4px 10px;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all 0.18s;
            font-family: 'Inter', sans-serif;
        }

        .offer-edit-btn:hover {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

        .offer-delete-btn {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
            padding: 4px 10px;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all 0.18s;
            font-family: 'Inter', sans-serif;
        }

        .offer-delete-btn:hover {
            background: #dc2626;
            color: #fff;
            border-color: #dc2626;
        }

        .offer-status-btn {
            background: #fff7ed;
            color: #ea580c;
            border: 1px solid #ffedd5;
            padding: 4px 10px;
            border-radius: 7px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.18s;
            font-family: 'Inter', sans-serif;
        }

        .offer-status-btn.active {
            background: #ecfdf5;
            color: #059669;
            border: 1px solid #d1fae5;
        }

        .offer-status-btn:hover {
            background: #ea580c;
            color: #fff;
            border-color: #ea580c;
        }

        .offer-status-btn.active:hover {
            background: #059669;
            color: #fff;
            border-color: #059669;
        }

        /* ── BADGES & PILLS ── */
        .type-badge {
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .type-badge.product { background: #fff7ed; color: #ea580c; border: 1px solid #ffedd5; }
        .type-badge.category { background: #eef2ff; color: #4f46e5; border: 1px solid #e0e7ff; }
        .type-badge.referral { background: #f0fdf4; color: #16a34a; border: 1px solid #dcfce7; }
        .type-badge.all { background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0; }

        .status-pill {
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 700;
        }
        .status-pill.active { background: #ecfdf5; color: #059669; }
        .status-pill.inactive { background: #fef2f2; color: #dc2626; }

        .btn-action {
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
            transition: all 0.2s;
            cursor: pointer;
        }
        .btn-action:hover { transform: translateY(-2px); }
        .btn-action.edit:hover { background: #eff6ff; color: #2563eb; border-color: #bfdbfe; }
        .btn-action.toggle.active { background: #ecfdf5; color: #059669; border-color: #d1fae5; }
        .btn-action.toggle.inactive { background: #fff7ed; color: #ea580c; border-color: #ffedd5; }
        .btn-action.delete:hover { background: #fef2f2; color: #dc2626; border-color: #fecaca; }

        .empty-state {
            padding: 5rem 2rem;
            text-align: center;
            background: white;
            border-radius: var(--card-radius);
            margin-top: 2rem;
            border: 1px dashed #ddd;
        }

        /* Validation Styles */
        .zyrax-input.is-invalid {
            border-color: #ef4444 !important;
            background-color: #fef2f2 !important;
        }

        .error-message {
            color: #ef4444;
            font-size: 0.75rem;
            margin-top: 0.25rem;
            font-weight: 500;
            display: none;
        }

        .zyrax-input.is-invalid+.error-message,
        .input-group+.error-message,
        .date-input-wrapper+.error-message {
            display: block;
        }

        /* Pagination Styles */
        .pagination-container {
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border-color);
        }

        .pagination {
            gap: 0.5rem;
        }

        .page-link {
            border-radius: 8px !important;
            color: var(--primary-black);
            border: 1px solid var(--border-color);
            padding: 0.5rem 1rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .page-link:hover {
            background: #f3f4f6;
            color: #000;
        }

        .page-item.active .page-link {
            background: var(--primary-black);
            border-color: var(--primary-black);
            color: #fff;
        }

        .page-item.disabled .page-link {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Loading Overlay */
        .table-responsive {
            position: relative;
        }

        .table-loading-overlay {
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100;
            backdrop-filter: blur(1px);
        }

        .table-loading-overlay.active {
            display: flex;
        }

        .spinner-sm {
            width: 24px;
            height: 24px;
            border: 3px solid #f3f4f6;
            border-top-color: var(--primary-black);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>

<body class="admin-body">
    <%- include('../../partials/admin/sidebar', { currentPage: 'offers' ,currentUser:admin }) %>

        <main class="admin-main">
            <div class="main-content">
                <div class="header-section d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1>Offers</h1>
                        <p class="text-muted">Manage discounts, coupons, and special product offers.</p>
                    </div>
                    <button class="btn-add-offer" onclick="openAddModal()">
                        <i class="bi bi-plus-circle-fill"></i> Add Offer
                    </button>
                </div>

                <div class="filter-bar">
                    <div class="search-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" id="offerSearchInput" placeholder="Search offers by name..." value="<%= search %>" autocomplete="off">
                        <div id="searchingIndicator" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); display: none;">
                            <div class="spinner-sm" style="width: 14px; height: 14px; border-width: 2px;"></div>
                        </div>
                    </div>
                    <div class="d-flex gap-3">
                        <select id="typeFilter" class="form-select" style="width: 150px; height: 42px; border-radius: 12px; border: 1px solid #e2e8f0; font-size: 0.9rem; font-weight: 600; color: var(--text-main); cursor: pointer; transition: all 0.3s;">
                            <option value="all" <%= typeFilter === 'all' ? 'selected' : '' %>>All Types</option>
                            <option value="product" <%= typeFilter === 'product' ? 'selected' : '' %>>Product</option>
                            <option value="category" <%= typeFilter === 'category' ? 'selected' : '' %>>Category</option>
                            <option value="referral" <%= typeFilter === 'referral' ? 'selected' : '' %>>Referral</option>
                        </select>
                        <select id="statusFilter" class="form-select" style="width: 140px; height: 42px; border-radius: 12px; border: 1px solid #e2e8f0; font-size: 0.9rem; font-weight: 600; color: var(--text-main); cursor: pointer; transition: all 0.3s;">
                            <option value="all" <%= statusFilter === 'all' ? 'selected' : '' %>>All Status</option>
                            <option value="active" <%= statusFilter === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="inactive" <%= statusFilter === 'inactive' ? 'selected' : '' %>>Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="table-responsive <%= totalOffers === 0 ? 'd-none' : '' %>" id="offersTableContainer">
                    <div class="table-loading-overlay" id="tableLoadingOverlay">
                        <div class="spinner-sm"></div>
                    </div>
                    <table class="offer-table" id="offerTable">
                        <thead>
                            <tr>
                                <th>Offer Name</th>
                                <th>Type</th>
                                <th>Target</th>
                                <th>Discount</th>
                                <th>Base Price</th>
                                <th>Discount Amt</th>
                                <th>Validity</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="offerTableBody">
                            <% offers.forEach(offer=> { %>
                                <tr>
                                    <td>
                                        <div class="offer-name">
                                            <%= offer.offerName %>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="type-badge <%= offer.offerType %>">
                                            <%= offer.offerType.charAt(0).toUpperCase() + offer.offerType.slice(1) %>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="target-info">
                                            <% if (offer.offerType==='product' ) { %>
                                                <i class="bi bi-box-seam me-1"></i>
                                                <%= offer.productId?.productName || 'Unknown Product' %>
                                                    <% } else if (offer.offerType==='category' ) { %>
                                                        <i class="bi bi-tag me-1"></i>
                                                        <%= offer.categoryId?.categoryName || 'Unknown Category' %>
                                                            <% } else if (offer.offerType==='referral' ) { %>
                                                                <i class="bi bi-people me-1"></i> Referral System
                                                                <% } else { %>
                                                                    <i class="bi bi-globe me-1"></i> Store-wide
                                                                    <% } %>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="discount-val">
                                            <%= offer.discountType==='percentage' ? offer.discountValue + '%' : '₹' +
                                                offer.discountValue %>
                                        </div>
                                        <div class="small text-muted">
                                            <%= offer.discountType.charAt(0).toUpperCase() + offer.discountType.slice(1)
                                                %>
                                        </div>
                                    </td>
                                    <td>
                                        <% if (offer.offerType === 'product') { %>
                                            <div class="base-price fw-600">
                                                <%= offer.basePrice ? '₹' + offer.basePrice : '—' %>
                                            </div>
                                        <% } else { %>
                                            <div style="color:#cbd5e1; text-decoration:line-through; font-size:13px;">N/A</div>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (offer.offerType === 'product') { %>
                                            <div class="discount-amt text-danger fw-600">
                                                <%= offer.discountAmount ? '- ₹' + Math.floor(offer.discountAmount) : '—' %>
                                            </div>
                                        <% } else { %>
                                            <div style="color:#cbd5e1; text-decoration:line-through; font-size:13px;">N/A</div>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="date-range">
                                            <%= new Date(offer.startDate).toLocaleDateString('en-US', { month: 'short' ,
                                                day: '2-digit' }) %> -
                                                <%= new Date(offer.endDate).toLocaleDateString('en-US', { month: 'short'
                                                    , day: '2-digit' }) %>
                                        </div>
                                        <div class="small <%= new Date(offer.endDate) < new Date() ? 'text-danger' : 'text-success' %>">
                                            <%= new Date(offer.endDate) < new Date() ? 'Expired' : 'Active' %>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="status-pill <%= offer.isActive ? 'active' : 'inactive' %>">
                                            <%= offer.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn-action edit" onclick="editOffer('<%= offer._id %>')"
                                                title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <% const isOffExpired = new Date(offer.endDate) < new Date(); %>
                                            <button
                                                class="btn-action toggle <%= offer.isActive ? 'active' : 'inactive' %>"
                                                onclick="<%= isOffExpired ? '' : `toggleOfferStatus('${offer._id}')` %>"
                                                title="<%= isOffExpired ? 'Cannot toggle expired offer' : (offer.isActive ? 'Deactivate' : 'Activate') %>"
                                                style="<%= isOffExpired ? 'opacity: 0.5; cursor: not-allowed;' : '' %>">
                                                <i
                                                    class="bi <%= offer.isActive ? 'bi-toggle-on' : 'bi-toggle-off' %>"></i>
                                            </button>
                                            <button class="btn-action delete" onclick="deleteOffer('<%= offer._id %>')"
                                                title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>

                    <!-- Pagination -->
                    <div id="paginationContainer">
                        <% if (totalPages > 1) { %>
                            <div class="pagination-container">
                                <nav aria-label="Offers Pagination">
                                    <ul class="pagination justify-content-center mb-0">
                                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                            <a class="page-link" href="javascript:void(0)" onclick="changePage(<%= currentPage - 1 %>)" aria-label="Previous">
                                                <i class="bi bi-chevron-left"></i>
                                            </a>
                                        </li>
                                        
                                        <% for(let i = 1; i <= totalPages; i++) { %>
                                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                <a class="page-link" href="javascript:void(0)" onclick="changePage(<%= i %>)"><%= i %></a>
                                            </li>
                                        <% } %>

                                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                            <a class="page-link" href="javascript:void(0)" onclick="changePage(<%= currentPage + 1 %>)" aria-label="Next">
                                                <i class="bi bi-chevron-right"></i>
                                            </a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Empty State -->
                <div id="noOffersState" class="empty-state <%= totalOffers === 0 ? '' : 'd-none' %>">
                    <i class="bi bi-search" id="emptyIcon"
                        style="font-size: 4rem; color: #e5e7eb; display: block; margin-bottom: 1rem;"></i>
                    <h3 id="emptyTitle">No Offers Yet</h3>
                    <p id="emptyText" class="text-muted">It looks like you haven't created any offers. Start by adding a new one to
                        drive more sales!</p>
                    <div id="emptyAction" class="mt-3"></div>
                </div>
            </div>
        </main>

        <!-- IMPROVED MODAL -->
        <div class="modal fade" id="zyraxOfferModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalTitle">Add New Offer</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="offerForm">
                            <input type="hidden" name="offerId" id="offerId">

                            <div class="row">
                                <div class="col-md-12">
                                    <div class="zyrax-input-group">
                                        <label class="form-label">Offer Name <span>*</span></label>
                                        <input type="text" name="offerName" id="offerName"
                                            class="form-control zyrax-input" placeholder="e.g. Summer Sale 2024">
                                        <div class="error-message" id="error-offerName">Please enter a valid offer
                                            name.
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label class="form-label">Discount Type <span>*</span></label>
                                    <div class="option-card-group">
                                        <label class="option-card" data-radio-group="discountType">
                                            <input type="radio" name="discountType" value="percentage" checked
                                                onclick="toggleValFields()">
                                            <div class="radio-indicator"></div>
                                            <span>Percentage (%)</span>
                                        </label>
                                        <label class="option-card" data-radio-group="discountType">
                                            <input type="radio" name="discountType" value="flat"
                                                onclick="toggleValFields()">
                                            <div class="radio-indicator"></div>
                                            <span>Flat Amount (₹)</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Apply To <span>*</span></label>
                                    <div class="option-card-group" style="grid-template-columns: repeat(2, 1fr);">
                                        <label class="option-card" data-radio-group="offerType">
                                            <input type="radio" name="offerType" value="product" checked
                                                onclick="toggleApplyFields()">
                                            <div class="radio-indicator"></div>
                                            <span>Product</span>
                                        </label>
                                        <label class="option-card" data-radio-group="offerType">
                                            <input type="radio" name="offerType" value="category"
                                                onclick="toggleApplyFields()">
                                            <div class="radio-indicator"></div>
                                            <span>Category</span>
                                        </label>
                                        <label class="option-card" data-radio-group="offerType">
                                            <input type="radio" name="offerType" value="all"
                                                onclick="toggleApplyFields()">
                                            <div class="radio-indicator"></div>
                                            <span>Global</span>
                                        </label>
                                        <label class="option-card" data-radio-group="offerType">
                                            <input type="radio" name="offerType" value="referral"
                                                onclick="toggleApplyFields()">
                                            <div class="radio-indicator"></div>
                                            <span>Referral</span>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="zyrax-input-group">
                                        <label class="form-label" id="targetLabel">Select Product
                                            <span>*</span></label>
                                        <select name="targetId" id="targetId" class="form-select zyrax-input">
                                            <option value="" disabled selected>Choose target...</option>
                                        </select>
                                        <div class="error-message" id="error-targetId">Please select a product or
                                            category.
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="zyrax-input-group">
                                        <label class="form-label">Discount Value <span>*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-transparent border-end-0" id="unitSymbol"
                                                style="border-radius: 14px 0 0 14px; border: 1.5px solid #e5e7eb; border-right: none;">%</span>
                                            <input type="number" name="discountValue" id="discountValue"
                                                class="form-control zyrax-input" style="border-radius: 0 14px 14px 0;"
                                                placeholder="0.00" step="0.01" min="0">
                                        </div>
                                        <div class="error-message" id="error-discountValue">Discount value must be a
                                            positive number.</div>
                                    </div>
                                </div>
                            </div>

                            <div class="gray-box mb-4">
                                <div class="row">
                                    <div class="col-md-12" id="maxDiscountWrapper">
                                        <label class="form-label">Max Discount Amount (₹)</label>
                                        <input type="number" name="maxDiscountAmount" id="maxDiscountAmount"
                                            class="form-control zyrax-input" placeholder="0.00" step="0.01" min="0">
                                        <div class="error-message" id="error-maxDiscountAmount">Max discount must be
                                            non-negative.</div>
                                        <small class="text-muted" style="font-size: 0.75rem;">Capped discount for
                                            percentage
                                            offers</small>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="zyrax-input-group">
                                        <label class="form-label">Start Date <span>*</span></label>
                                        <div class="date-input-wrapper">
                                            <input type="date" name="startDate" id="startDate"
                                                class="form-control zyrax-input">
                                            <i class="bi bi-calendar-event"></i>
                                        </div>
                                        <div class="error-message" id="error-startDate">Please select a valid start
                                            date.
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="zyrax-input-group">
                                        <label class="form-label">End Date <span>*</span></label>
                                        <div class="date-input-wrapper">
                                            <input type="date" name="endDate" id="endDate"
                                                class="form-control zyrax-input">
                                            <i class="bi bi-calendar-check"></i>
                                        </div>
                                        <div class="error-message" id="error-endDate">Please select a valid end
                                            date.</div>
                                    </div>
                                </div>
                            </div>

                            <div class="status-switch mb-4">
                                <div>
                                    <div class="fw-600">Offer Visibility</div>
                                    <div class="text-muted small">Active offers are applied instantly to targets.
                                    </div>
                                </div>
                                <div class="form-switch">
                                    <input class="form-check-input" type="checkbox" name="isActive" id="isActive"
                                        checked>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-light py-3 flex-grow-1"
                                    style="border-radius: 14px; font-weight: 600;"
                                    data-bs-dismiss="modal">Discard</button>
                                <button type="submit" class="btn-submit py-3 flex-grow-2 mt-0" id="saveBtn">Save
                                    Offer</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <script id="offers-data" type="application/json">
        <%- JSON.stringify({ products, categories, currentOffers: offers }) %>
    </script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let { products, categories, currentOffers } = JSON.parse(document.getElementById('offers-data').textContent);
            const offerModal = new bootstrap.Modal(document.getElementById('zyraxOfferModal'));

            // Handle Option Card Active States
            function updateOptionCards() {
                document.querySelectorAll('.option-card').forEach(card => {
                    const input = card.querySelector('input');
                    if (input.checked) {
                        card.classList.add('active');
                    } else {
                        card.classList.remove('active');
                    }
                });
            }

            document.querySelectorAll('.option-card input').forEach(input => {
                input.addEventListener('change', updateOptionCards);
            });

            // AJAX and Live Search Logic
            let currentState = {
                page: '<%= currentPage %>',
                search: '<%= search %>',
                type: '<%= typeFilter %>',
                status: '<%= statusFilter %>'
            };

            const offerTableBody = document.getElementById('offerTableBody');
            const offerSearchInput = document.getElementById('offerSearchInput');
            const typeFilterSelect = document.getElementById('typeFilter');
            const statusFilterSelect = document.getElementById('statusFilter');
            const tableLoadingOverlay = document.getElementById('tableLoadingOverlay');
            const searchingIndicator = document.getElementById('searchingIndicator');
            const paginationContainer = document.getElementById('paginationContainer');
            const offersTableContainer = document.getElementById('offersTableContainer');
            const noOffersState = document.getElementById('noOffersState');

            function debounce(func, timeout = 500) {
                let timer;
                return (...args) => {
                    clearTimeout(timer);
                    timer = setTimeout(() => { func.apply(this, args); }, timeout);
                };
            }

            async function fetchData(updateHistory = true) {
                tableLoadingOverlay.classList.add('active');
                if (currentState.search) searchingIndicator.style.display = 'block';

                const params = new URLSearchParams(currentState);
                const url = `/adminUser/offers?${params.toString()}`;

                try {
                    const res = await fetch(url, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
                    });
                    const data = await res.json();
                    if (data.success) {
                        currentOffers = data.offers;
                        renderTable(data.offers);
                        renderPagination(data);
                        if (updateHistory) window.history.pushState(currentState, '', url);

                        if (data.offers.length === 0) {
                            offersTableContainer.classList.add('d-none');
                            noOffersState.classList.remove('d-none');
                        } else {
                            offersTableContainer.classList.remove('d-none');
                            noOffersState.classList.add('d-none');
                        }
                    }
                } catch (err) {
                    console.error('Fetch error:', err);
                } finally {
                    tableLoadingOverlay.classList.remove('active');
                    searchingIndicator.style.display = 'none';
                }
            }

            function renderTable(offers) {
                offerTableBody.innerHTML = offers.map(offer => {
                    const typeLabel = offer.offerType.charAt(0).toUpperCase() + offer.offerType.slice(1);
                    const startDate = new Date(offer.startDate).toLocaleDateString('en-US', { month: 'short', day: '2-digit' });
                    const endDate = new Date(offer.endDate).toLocaleDateString('en-US', { month: 'short', day: '2-digit' });
                    const isExpired = new Date(offer.endDate) < new Date();
                    
                    let targetHtml = '';
                    if (offer.offerType === 'product') {
                        targetHtml = `<i class="bi bi-box-seam me-1"></i> ${offer.productId?.productName || 'Unknown Product'}`;
                    } else if (offer.offerType === 'category') {
                        targetHtml = `<i class="bi bi-tag me-1"></i> ${offer.categoryId?.categoryName || 'Unknown Category'}`;
                    } else if (offer.offerType === 'referral') {
                        targetHtml = `<i class="bi bi-people me-1"></i> Referral System`;
                    } else {
                        targetHtml = `<i class="bi bi-globe me-1"></i> Store-wide`;
                    }

                    return `
                        <tr>
                            <td><div class="offer-name">${offer.offerName}</div></td>
                            <td><span class="type-badge ${offer.offerType}">${typeLabel}</span></td>
                            <td><div class="target-info">${targetHtml}</div></td>
                            <td>
                                <div class="discount-val">${offer.discountType === 'percentage' ? offer.discountValue + '%' : '₹' + offer.discountValue}</div>
                                <div class="small text-muted">${offer.discountType.charAt(0).toUpperCase() + offer.discountType.slice(1)}</div>
                            </td>
                            <td><div class="base-price fw-600">${offer.offerType === 'product' ? (offer.basePrice ? '₹' + offer.basePrice : '—') : '<span style="color:#cbd5e1;text-decoration:line-through;font-size:13px;">N/A</span>'}</div></td>
                            <td><div class="discount-amt text-danger fw-600">${offer.offerType === 'product' ? (offer.discountAmount ? '- ₹' + Math.floor(offer.discountAmount) : '—') : '<span style="color:#cbd5e1;text-decoration:line-through;font-size:13px;">N/A</span>'}</div></td>
                            <td>
                                <div class="date-range">${startDate} - ${endDate}</div>
                                <div class="small ${isExpired ? 'text-danger' : 'text-success'}">${isExpired ? 'Expired' : 'Active'}</div>
                            </td>
                            <td><span class="status-pill ${offer.isActive ? 'active' : 'inactive'}">${offer.isActive ? 'Active' : 'Inactive'}</span></td>
                            <td>
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn-action edit" onclick="editOffer('${offer._id}')" title="Edit"><i class="bi bi-pencil-square"></i></button>
                                    <button class="btn-action toggle ${offer.isActive ? 'active' : 'inactive'}" onclick="toggleOfferStatus('${offer._id}')" title="${offer.isActive ? 'Deactivate' : 'Activate'}">
                                        <i class="bi ${offer.isActive ? 'bi-toggle-on' : 'bi-toggle-off'}"></i>
                                    </button>
                                    <button class="btn-action delete" onclick="deleteOffer('${offer._id}')" title="Delete"><i class="bi bi-trash3"></i></button>
                                </div>
                            </td>
                        </tr>`;
                }).join('');
            }

            function renderPagination(data) {
                const { currentPage, totalPages } = data;
                if (totalPages <= 1) {
                    paginationContainer.innerHTML = '';
                    return;
                }

                let html = `
                    <div class="pagination-container">
                        <nav aria-label="Offers Pagination">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                                    <a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage - 1})" aria-label="Previous">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>`;
                
                for (let i = 1; i <= totalPages; i++) {
                    html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                                <a class="page-link" href="javascript:void(0)" onclick="changePage(${i})">${i}</a>
                             </li>`;
                }

                html += `
                                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                                    <a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage + 1})" aria-label="Next">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>`;
                paginationContainer.innerHTML = html;
            }

            function changePage(p) {
                currentState.page = p;
                fetchData();
            }

            const debouncedSearch = debounce((val) => {
                currentState.search = val;
                currentState.page = 1;
                fetchData();
            });

            offerSearchInput.oninput = (e) => {
                debouncedSearch(e.target.value);
            };

            typeFilterSelect.onchange = (e) => {
                currentState.type = e.target.value;
                currentState.page = 1;
                fetchData();
            };

            statusFilterSelect.onchange = (e) => {
                currentState.status = e.target.value;
                currentState.page = 1;
                fetchData();
            };

            window.onpopstate = (e) => {
                if (e.state) {
                    currentState = e.state;
                    offerSearchInput.value = currentState.search;
                    typeFilterSelect.value = currentState.type;
                    statusFilterSelect.value = currentState.status;
                    fetchData(false);
                }
            };

            // Removed client-side applyFilters as we now use server-side pagination/filtering
            function clearOfferFilters() {
                currentState = { page: 1, search: '', type: 'all', status: 'all' };
                offerSearchInput.value = '';
                typeFilterSelect.value = 'all';
                statusFilterSelect.value = 'all';
                fetchData();
            }

            function toggleApplyFields() {
                const type = document.querySelector('input[name="offerType"]:checked').value;
                const select = document.getElementById('targetId');
                const targetLabel = document.getElementById('targetLabel');
                const percentRadio = document.querySelector('input[name="discountType"][value="percentage"]');
                const percentCard = percentRadio.closest('.option-card');
                const targetGroup = select.closest('.zyrax-input-group');

                if (type === 'all' || type === 'referral') {
                    targetGroup.style.display = 'none';
                    targetLabel.innerHTML = `Target <span>*</span>`;
                    select.innerHTML = '<option value="none" selected>Auto-target</option>';
                    
                    if (type === 'referral') {
                        // Force flat discount for referral
                        document.querySelector('input[name="discountType"][value="flat"]').checked = true;
                        percentRadio.disabled = true;
                        percentCard.style.opacity = '0.5';
                        percentCard.style.pointerEvents = 'none';
                        toggleValFields();
                    } else {
                        percentRadio.disabled = false;
                        percentCard.style.opacity = '1';
                        percentCard.style.pointerEvents = 'auto';
                    }
                } else {
                    percentRadio.disabled = false;
                    percentCard.style.opacity = '1';
                    percentCard.style.pointerEvents = 'auto';
                    
                    targetGroup.style.display = 'block';
                    targetLabel.innerHTML = `Select ${type.charAt(0).toUpperCase() + type.slice(1)} <span>*</span>`;
                    select.innerHTML = '<option value="" disabled selected>Choose target...</option>';

                    const list = type === 'product' ? products : categories;
                    list.forEach(item => {
                        const opt = document.createElement('option');
                        opt.value = item._id;
                        opt.textContent = type === 'product' ? item.productName : item.categoryName;
                        select.appendChild(opt);
                    });
                }
                updateOptionCards();
            }

            function toggleValFields() {
                const discType = document.querySelector('input[name="discountType"]:checked').value;
                const maxDiscInput = document.getElementById('maxDiscountAmount');
                const unitSymbol = document.getElementById('unitSymbol');
                const maxDiscWrapper = document.getElementById('maxDiscountWrapper');

                if (discType === 'flat') {
                    maxDiscInput.disabled = true;
                    maxDiscInput.value = '';
                    unitSymbol.textContent = '₹';
                    maxDiscWrapper.style.opacity = '0.5';
                } else {
                    maxDiscInput.disabled = false;
                    unitSymbol.textContent = '%';
                    maxDiscWrapper.style.opacity = '1';
                }
                updateOptionCards();
            }

            function openAddModal() {
                clearValidationErrors();
                document.getElementById('offerForm').reset();
                document.getElementById('offerId').value = '';
                document.getElementById('modalTitle').textContent = 'Add New Offer';
                document.getElementById('saveBtn').textContent = 'Save Offer';

                // Set default radios
                document.querySelector('input[name="discountType"][value="percentage"]').checked = true;
                document.querySelector('input[name="offerType"][value="product"]').checked = true;

                const today = new Date().toISOString().split('T')[0];
                document.getElementById('startDate').min = today;
                document.getElementById('endDate').min = today;
                
                document.getElementById('startDate').readOnly = false;
                document.getElementById('startDate').style.pointerEvents = 'auto';
                document.getElementById('startDate').style.background = '#fff';

                toggleApplyFields();
                toggleValFields();
                offerModal.show();
            }

            function editOffer(offerId) {
                const data = currentOffers.find(o => o._id === offerId);
                if (!data) return;

                // Expiration check
                if (new Date(data.endDate) < new Date()) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Locked',
                        text: "can't edit expired offer",
                        confirmButtonColor: '#1e293b'
                    });
                    return;
                }

                clearValidationErrors();
                document.getElementById('modalTitle').textContent = 'Edit Offer';
                document.getElementById('saveBtn').textContent = 'Update Offer';
                document.getElementById('offerId').value = data._id;
                document.getElementById('offerName').value = data.offerName;

                document.querySelector(`input[name="discountType"][value="${data.discountType}"]`).checked = true;
                document.querySelector(`input[name="offerType"][value="${data.offerType}"]`).checked = true;

                toggleApplyFields();

                const targetId = data.offerType === 'product'
                    ? (data.productId?._id || data.productId)
                    : (data.offerType === 'category' ? (data.categoryId?._id || data.categoryId) : 'none');

                document.getElementById('targetId').value = targetId;
                document.getElementById('discountValue').value = data.discountValue;
                document.getElementById('maxDiscountAmount').value = data.maxDiscountAmount || '';

                document.getElementById('startDate').value = new Date(data.startDate).toISOString().split('T')[0];
                document.getElementById('endDate').value = new Date(data.endDate).toISOString().split('T')[0];
                document.getElementById('isActive').checked = data.isActive;

                const today = new Date().toISOString().split('T')[0];
                const currentStart = new Date(data.startDate).toISOString().split('T')[0];
                
                document.getElementById('startDate').readOnly = true;
                document.getElementById('startDate').style.pointerEvents = 'none';
                document.getElementById('startDate').style.background = '#f8fafc';
                
                // Allow current start date even if it's in the past, but don't allow selecting dates before it or today
                document.getElementById('startDate').min = currentStart < today ? currentStart : today;
                document.getElementById('endDate').min = today;

                toggleValFields();
                offerModal.show();
            }

            function clearValidationErrors() {
                document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
                document.querySelectorAll('.error-message').forEach(el => el.style.display = 'none');
            }

            function showFieldError(fieldId, message) {
                const input = document.getElementById(fieldId);
                const errorDiv = document.getElementById(`error-${fieldId}`);
                if (input) {
                    input.classList.add('is-invalid');
                    if (errorDiv) {
                        errorDiv.textContent = message;
                        errorDiv.style.display = 'block';
                    }
                }
            }

            document.getElementById('offerForm').onsubmit = async (e) => {
                e.preventDefault();
                clearValidationErrors();

                let isValid = true;
                const offerName = document.getElementById('offerName').value.trim();
                const targetId = document.getElementById('targetId').value;
                const discountValue = parseFloat(document.getElementById('discountValue').value);
                const startDateVal = document.getElementById('startDate').value;
                const endDateVal = document.getElementById('endDate').value;
                const discountType = document.querySelector('input[name="discountType"]:checked').value;
                const offerType = document.querySelector('input[name="offerType"]:checked').value;

                if (!offerName) {
                    showFieldError('offerName', 'Offer name is required.');
                    isValid = false;
                } else if (offerName.length < 3) {
                    showFieldError('offerName', 'Offer name must be at least 3 characters.');
                    isValid = false;
                }

                if (!targetId && (offerType === 'product' || offerType === 'category')) {
                    showFieldError('targetId', 'Please select a product or category.');
                    isValid = false;
                }

                if (isNaN(discountValue) || discountValue <= 0) {
                    showFieldError('discountValue', 'Discount value must be greater than zero.');
                    isValid = false;
                } else if (discountType === 'percentage' && discountValue > 99) {
                    showFieldError('discountValue', 'Percentage cannot exceed 99%.');
                    isValid = false;
                }

                const isEdit = !!document.getElementById('offerId').value;
                const now = new Date();
                now.setHours(0, 0, 0, 0);
                const start = new Date(startDateVal);
                const end = new Date(endDateVal);

                if (!startDateVal) {
                    showFieldError('startDate', 'Start date is required.');
                    isValid = false;
                } else if (!isEdit && start < now) {
                    showFieldError('startDate', 'Start date cannot be in the past.');
                    isValid = false;
                }

                if (!endDateVal) {
                    showFieldError('endDate', 'End date is required.');
                    isValid = false;
                } else if (startDateVal && end <= start) {
                    showFieldError('endDate', 'End date must be strictly after the start date.');
                    isValid = false;
                }

                if (!isValid) return;

                const formData = new FormData(e.target);
                const body = Object.fromEntries(formData);
                body.isActive = document.getElementById('isActive').checked;

                if (body.offerType === 'product') {
                    body.productId = body.targetId;
                    body.categoryId = null;
                } else if (body.offerType === 'category') {
                    body.categoryId = body.targetId;
                    body.productId = null;
                } else {
                    body.productId = null;
                    body.categoryId = null;
                }
                
                // Remove targetId from body as it's not needed by the backend
                delete body.targetId;

                let url = isEdit ? `/adminUser/offers/edit/${body.offerId}` : '';
                if (!isEdit) {
                    if (body.offerType === 'product') url = '/adminUser/offers/add-product';
                    else if (body.offerType === 'category') url = '/adminUser/offers/add-category';
                    else if (body.offerType === 'referral') url = '/adminUser/offers/add-referral';
                    else if (body.offerType === 'all') url = '/adminUser/offers/add-all';
                }
                const method = isEdit ? 'PUT' : 'POST';

                try {
                    const res = await fetch(url, {
                        method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(body)
                    });

                    const result = await res.json();
                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: result.message,
                            confirmButtonColor: '#1a1a1a',
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => location.reload());
                    } else {
                        if (result.errors) {
                            Object.keys(result.errors).forEach(key => {
                                const fieldId = (key === 'productId' || key === 'categoryId') ? 'targetId' : key;
                                showFieldError(fieldId, result.errors[key]);
                            });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Oops...', text: result.message, confirmButtonColor: '#1a1a1a' });
                        }
                    }
                } catch (err) {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong. Please try again.' });
                }
            };

            async function toggleOfferStatus(id) {
                try {
                    const res = await fetch(`/adminUser/offers/toggle/${id}`, { method: 'PATCH' });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: data.message,
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => location.reload());
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                    }
                } catch (err) {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong' });
                }
            }

            async function deleteOffer(id) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "This action will permanently delete the offer.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#1a1a1a',
                    cancelButtonColor: '#f3f4f6',
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'Cancel'
                }).then(async (result) => {
                    if (result.isConfirmed) {
                        const res = await fetch(`/adminUser/offers/delete/${id}`, { method: 'DELETE' });
                        const resData = await res.json();
                        if (resData.success) {
                            Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Offer has been removed.', timer: 1000, showConfirmButton: false }).then(() => location.reload());
                        }
                    }
                });
            }

            // Sync End Date Min with Start Date
            document.getElementById('startDate').addEventListener('change', function() {
                const startVal = this.value;
                if (startVal) {
                    const nextDay = new Date(startVal);
                    nextDay.setDate(nextDay.getDate() + 1);
                    document.getElementById('endDate').min = nextDay.toISOString().split('T')[0];
                }
            });
        </script>
</body>

</html>