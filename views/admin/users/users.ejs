<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management — Zyrox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <link rel="stylesheet" href="/adminStyles/users/users.css">
</head>

<body class="admin-body">
    <%- include('../../partials/admin/sidebar', { currentPage: 'users' ,currentUser:admin }) %>

        <main class="admin-main">
            <div class="main-content">

                <!-- Page Header -->
                <div class="page-header d-flex justify-content-between align-items-center">
                    <div>
                        <p class="page-label">User Management</p>
                        <h1 class="page-title">User Management</h1>
                    </div>
                </div>

                <!-- Panel -->
                <div class="panel">

                    <!-- Panel topbar-->
                    <div class="panel-topbar d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                        <h2 class="panel-title">Users</h2>
                        <div class="topbar-controls d-flex align-items-center gap-2 flex-wrap">


                            <form method="GET" action="/admin/users" class="search-bar-group">
                                <div class="search-input-wrap" style="position: relative;">
                                    <i class="bi bi-search search-icon-inner"></i>
                                    <input type="search" name="search" id="searchInput"
                                        placeholder="Search by name or email…" class="search-field"
                                        value="<%= search || '' %>" autocomplete="off" style="padding-right: 30px;"
                                        oninput="document.getElementById('clearBtn').style.display = this.value.length > 0 ? 'block' : 'none'">
                                    <i class="bi bi-x" id="clearBtn" title="Clear Search"
                                        style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); font-size: 20px; color: #999; cursor: pointer; display: <%= search ? 'block' : 'none' %>;"
                                        onclick="document.getElementById('searchInput').value=''; this.style.display='none'; this.closest('form').submit();"></i>
                                </div>
                                <select name="status" class="filter-select" onchange="this.form.submit()">
                                    <option value="" <%=(!statusFilter || statusFilter==='' ) ? 'selected' : '' %>>All
                                        Status</option>
                                    <option value="active" <%=statusFilter==='active' ? 'selected' : '' %>>Active
                                    </option>
                                    <option value="blocked" <%=statusFilter==='blocked' ? 'selected' : '' %>>Blocked
                                    </option>
                                </select>
                                <select name="sortBy" class="filter-select" onchange="this.form.submit()">
                                    <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                                    <option value="oldest" <%= sortBy === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                                    <option value="name_asc" <%= sortBy === 'name_asc' ? 'selected' : '' %>>Name: A-Z</option>
                                    <option value="name_desc" <%= sortBy === 'name_desc' ? 'selected' : '' %>>Name: Z-A</option>
                                </select>
                                <button type="submit" class="search-submit-btn">
                                    <i class="bi bi-search"></i> Search
                                </button>
                            </form>

                        </div>
                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table class="table users-table">
                            <thead>
                                <tr>
                                    <th>Sl.No</th>
                                    <th>Users</th>
                                    <th>User ID</th>
                                    <th>Joined At</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>


                                <% users.forEach((user, index)=> { %>
                                    <tr class="<%= !user.isActive ? 'row-blocked' : '' %>">
                                        <td class="sl-no">
                                            <%= (currentPage - 1) * limit + index + 1 %>
                                        </td>
                                        <td>
                                            <div class="user-cell">
                                                <div class="user-avatar">
                                                    <%if(user.Profile_image){%>
                                                        <img src="<%= user.Profile_image %>" alt="Profile"
                                                            data-src="<%= user.Profile_image %>"
                                                            data-name="<%= user.Name %>"
                                                            onclick="previewImage(this.dataset.src, this.dataset.name)">
                                                        <%} else {%>
                                                            <%= user.Name.charAt(0).toUpperCase()%>
                                                                <%}%>

                                                </div>

                                                <div class="img-preview-overlay" id="imgPreviewOverlay"
                                                    onclick="closePreview()">
                                                    <div class="img-preview-box" onclick="event.stopPropagation()">
                                                        <button class="img-preview-close"
                                                            onclick="closePreview()">&times;</button>
                                                        <img id="imgPreviewSrc" src="" alt="Profile Preview">
                                                        <p id="imgPreviewName"></p>
                                                    </div>
                                                </div>

                                                <div>
                                                    <p class="u-name">
                                                        <%= user.Name %>
                                                    </p>
                                                    <p class="u-email">
                                                        <%= user.Email %>
                                                    </p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="uid-cell">
                                            <%= user._id.toString().slice(-8) %>
                                        </td>
                                        <td class="joined-cell">
                                            <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short' ,
                                                day: 'numeric' , year: 'numeric' }) %>
                                                <br>
                                                <span class="joined-time">
                                                    <%= new Date(user.createdAt).toLocaleTimeString('en-US', {
                                                        hour: '2-digit' , minute: '2-digit' }) %>
                                                </span>
                                        </td>
                                        <td>
                                            <span class="status-badge <%= user.isActive ? 'active' : 'blocked' %>">
                                                <%= user.isActive ? 'Active' : 'Blocked' %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="action-cell">
                                                <form
                                                    action="/admin/users/status?id=<%= user._id %>&status=<%= user.isActive ? 'block' : 'unblock' %>"
                                                    method="POST" style="display:inline;">
                                                    <button type="submit"
                                                        class="btn-action <%= user.isActive ? 'block' : 'unblock' %>"
                                                        title="<%= user.isActive ? 'Block' : 'Unblock' %>">
                                                        <i
                                                            class="bi <%= user.isActive ? 'bi-slash-circle' : 'bi-check-circle' %>"></i>
                                                    </button>
                                                </form>

                                                <a href="/admin/users/details?id=<%= user._id %>"
                                                    class="btn-view">view</a>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% if (users.length===0) { %>
                                            <tr>
                                                <td colspan="6">
                                                    <div class="empty-state">
                                                        <div class="empty-icon">
                                                            <i class="bi bi-person-slash"></i>
                                                        </div>
                                                        <h5 class="empty-title">No Users Found</h5>
                                                        <p class="empty-sub">We couldn't find any users matching your
                                                            search.</p>
                                                        <a href="/admin/users" class="btn-reset">
                                                            <i class="bi bi-arrow-counterclockwise"></i> Reset Search
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% } %>

                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="pagination-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <p class="showing-text">
                            Showing
                            <strong>
                                <%= typeof currentPage !=='undefined' && typeof totalUsers !=='undefined' && totalUsers>
                                    0 ?
                                    ((currentPage - 1) * limit + 1) + '-' + Math.min(currentPage * limit, totalUsers) :
                                    '0' %>
                            </strong>
                            of <strong>
                                <%= typeof totalUsers !=='undefined' ? totalUsers : 0 %>
                            </strong> users
                        </p>
                        <nav>
                            <ul class="pagination-list">
                                <% const tp=typeof totalPages !=='undefined' ? totalPages : 1; const cp=typeof
                                    currentPage !=='undefined' ? currentPage : 1; const src=typeof search !=='undefined'
                                    ? search : '' ; const stf=typeof statusFilter !=='undefined' ? statusFilter : '' ;
                                    let startPage=Math.max(1, cp - 1); let endPage=Math.min(tp, startPage + 2); if
                                    (endPage - startPage < 2) startPage=Math.max(1, endPage - 2); %>
                                    <!-- Previous -->
                                    <li>
                                        <a href="?page=<%= Math.max(1, cp - 1) %>&search=<%= src %>&status=<%= stf %>&sortBy=<%= typeof sortBy !=='undefined' ? sortBy : '' %>"
                                            class="page-btn <%= cp <= 1 ? 'disabled' : '' %>">
                                            <i class="bi bi-chevron-left"></i> Previous
                                        </a>
                                    </li>
                                    <!-- Page numbers -->
                                    <% for (let p=startPage; p <=endPage; p++) { %>
                                        <li>
                                            <a href="?page=<%= p %>&search=<%= src %>&status=<%= stf %>&sortBy=<%= typeof sortBy !=='undefined' ? sortBy : '' %>"
                                                class="page-btn <%= cp === p ? 'active' : '' %>">
                                                <%= p %>
                                            </a>
                                        </li>
                                        <% } %>
                                            <% if (endPage < tp) { %>
                                                <li><span class="page-btn dots">…</span></li>
                                                <% } %>
                                                    <!-- Next -->
                                                    <li>
                                                        <a href="?page=<%= cp + 1 %>&search=<%= src %>&status=<%= stf %>&sortBy=<%= typeof sortBy !=='undefined' ? sortBy : '' %>"
                                                            class="page-btn <%= cp >= tp ? 'disabled' : '' %>">
                                                            Next <i class="bi bi-chevron-right"></i>
                                                        </a>
                                                    </li>
                            </ul>
                        </nav>
                    </div>

                </div><!-- end panel -->
            </div><!-- end main-content -->
        </main><!-- end admin-main -->

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script>

            function previewImage(src, name) {
                document.getElementById('imgPreviewSrc').src = src;
                document.getElementById('imgPreviewName').textContent = name || '';
                document.getElementById('imgPreviewOverlay').classList.add('active');
            }

            function closePreview() {
                document.getElementById('imgPreviewOverlay').classList.remove('active');
                document.getElementById('imgPreviewSrc').src = '';
            }

            // Close on ESC key
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closePreview();
            });


        </script>
</body>

</html>