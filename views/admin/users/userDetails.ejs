<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Details — Zyrox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <link rel="stylesheet" href="/adminStyles/users/userDetails.css">
</head>

<body class="admin-body">
    <%- include('../../partials/admin/sidebar', { currentPage: 'users',currentUser:admin }) %>
    <main class="admin-main">
        <div class="main-content">

                <% if (user) { %>

                    <!-- Topbar -->
                    <div class="topbar d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="page-title">User Details</h1>
                            <p class="page-subtitle">Manage user information and view order history for <%= user.Name %>
                                    .</p>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/adminUserUser/users" class="btn-back">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <form
                                action="/adminUser/users/status?id=<%= user._id %>&status=<%= user.isActive ? 'block' : 'unblock' %>"
                                method="POST" style="display:inline;">
                                <%if(user.isActive){%>
                                    <button type="submit" class="btn-block" style="background-color:rgb(255, 0, 0);">
                                        <%} else {%>
                                            <button type="submit" class="btn-block" style="background-color:green;">

                                                <%}%>
                                                    <i
                                                        class="bi <%= user.isActive ? 'bi-slash-circle' : 'bi-check-circle' %>"></i>
                                                    <%= user.isActive ? 'Block User' : 'Unblock User' %>
                                            </button>
                            </form>
                        </div>
                    </div>

                    <div class="row g-3">

                        <!-- ===== PROFILE CARD ===== -->
                        <div class="col-12 col-lg-3">
                            <div class="panel text-center">

                                <div class="profile-avatar overflow-hidden">
                                    <% if (user.Profile_image) { %>
                                        <img src="<%= user.Profile_image %>" alt="<%= user.Name %>"
                                            style="width: 100%; height: 100%; object-fit: cover;">
                                        <% } else { %>
                                            <%= user.Name ? user.Name.charAt(0).toUpperCase() : 'U' %>
                                                <% } %>
                                </div>

                                <p class="profile-name">
                                    <%= user.Name %>
                                </p>

                                <span class="status-badge <%= user.isActive ? 'active' : 'blocked' %>">
                                    <%= user.isActive ? 'Active' : 'Blocked' %>
                                </span>

                                <div class="profile-divider"></div>

                                <div class="text-start">
                                    <div class="info-row">
                                        <p class="info-label">User ID</p>
                                        <p class="info-value">USR-88219</p>
                                    </div>
                                    <div class="info-row">
                                        <p class="info-label">Email Address</p>
                                        <p class="info-value">
                                            <i class="bi bi-envelope"></i>
                                            <%= user.Email %>
                                        </p>
                                    </div>
                                    <div class="info-row">
                                        <p class="info-label">Phone Number</p>
                                        <p class="info-value">
                                            <i class="bi bi-telephone"></i>
                                            <%= user.Phone_number || 'Not provided' %>
                                        </p>
                                    </div>
                                    <div class="info-row">
                                        <p class="info-label">Member Since</p>
                                        <p class="info-value">
                                            <i class="bi bi-calendar3"></i>
                                            <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short' ,
                                                day: 'numeric' , year: 'numeric' }) %>
                                        </p>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- ===== RIGHT COLUMN ===== -->
                        <div class="col-12 col-lg-9">

                            <!-- Stat cards -->
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="stat-card">
                                        <div class="stat-top">
                                            <span class="stat-label">Total Orders</span>
                                            <i class="bi bi-bag-check stat-icon"></i>
                                        </div>
                                        <p class="stat-value">24</p>
                                        <p class="stat-note">Lifetime orders</p>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="stat-card">
                                        <div class="stat-top">
                                            <span class="stat-label">Total Spent</span>
                                            <i class="bi bi-currency-rupee stat-icon"></i>
                                        </div>
                                        <p class="stat-value">₹3,450</p>
                                        <p class="stat-note">Avg ₹143.75 / order</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Recent Orders -->
                            <div class="panel">
                                <p class="panel-title">Recent Orders</p>
                                <p class="panel-subtitle">A list of recent orders placed by this user.</p>

                                <div class="table-responsive">
                                    <table class="table orders-table">
                                        <thead>
                                            <tr>
                                                <th>Order ID</th>
                                                <th>Date</th>
                                                <th>Status</th>
                                                <th class="text-end">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td><span class="order-id">#ORD-7721</span></td>
                                                <td>Oct 24, 2023</td>
                                                <td><span class="status-pill status-cancelled">Cancelled</span></td>
                                                <td class="text-end fw-600">₹120.50</td>
                                            </tr>
                                            <tr>
                                                <td><span class="order-id">#ORD-7650</span></td>
                                                <td>Oct 15, 2023</td>
                                                <td><span class="status-pill status-delivered">Delivered</span></td>
                                                <td class="text-end fw-600">₹59.00</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>

                    <% } %>

        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
</body>

</html>