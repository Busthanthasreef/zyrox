<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Details — Zyrox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        /* ===========================
           SAME THEME AS DASHBOARD
           =========================== */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --sidebar-w: 200px;
            --bg: #f5f4f0;
            --sidebar-bg: #1a1a1a;
            --white: #ffffff;
            --accent: #e8522a;
            --green: #22c55e;
            --text-dark: #111318;
            --text-mid: #555b6a;
            --text-light: #8b919e;
            --border: #e8e8e4;
            --radius: 12px;
            --radius-sm: 8px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text-dark);
        }

        .main-content {
            margin-left: 250px;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: var(--sidebar-w);
            min-width: var(--sidebar-w);
            background: var(--sidebar-bg);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding: 0 0 16px;
            position: fixed;
            top: 0;
            height: 100vh;
            overflow-y: auto;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--accent);
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 16px;
            padding: 14px 16px;
            margin-bottom: 10px;
        }

        .sidebar-section-label {
            font-size: 10.5px;
            color: rgba(255, 255, 255, 0.3);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 10px 16px 4px;
            font-weight: 500;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 2px;
            padding: 0 10px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 9px 12px;
            border-radius: var(--radius-sm);
            color: rgba(255, 255, 255, 0.55);
            text-decoration: none;
            font-size: 13.5px;
            transition: background 0.18s, color 0.18s;
        }

        .nav-item i {
            font-size: 14px;
        }

        .nav-item:hover {
            background: rgba(255, 255, 255, 0.07);
            color: rgba(255, 255, 255, 0.9);
        }

        .nav-item.active {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            font-weight: 500;
        }

        .sidebar-user {
            margin-top: auto;
            padding: 12px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            margin-top: 16px;
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .user-name {
            font-size: 12px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.85);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 1px;
        }

        .user-email {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.35);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ===== MAIN ===== */
        .main-content {
            padding: 24px 28px;
        }

        /* Topbar */
        .topbar {
            margin-bottom: 24px;
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .page-subtitle {
            font-size: 13px;
            color: var(--text-light);
            margin-top: 2px;
        }

        /* Back button */
        .btn-back {
            display: flex;
            align-items: center;
            gap: 7px;
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-dark);
            text-decoration: none;
            transition: background 0.18s;
        }

        .btn-back:hover {
            background: #f0eeea;
            color: var(--text-dark);
        }

        /* ===== PANELS ===== */
        .panel {
            background: var(--white);
            border-radius: var(--radius);
            padding: 20px;
            border: 1px solid var(--border);
            height: 100%;
        }

        .panel-title {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 2px;
        }

        .panel-subtitle {
            font-size: 12px;
            color: var(--text-light);
            margin-bottom: 16px;
        }

        /* ===== PROFILE CARD ===== */
        .profile-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
        }

        .profile-name {
            font-family: 'Syne', sans-serif;
            font-size: 17px;
            font-weight: 700;
            color: var(--text-dark);
            text-align: center;
            margin-bottom: 6px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 14px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.active {
            background: #dcfce7;
            color: #16a34a;
        }

        .status-badge.blocked {
            background: #fee2e2;
            color: #dc2626;
        }

        .profile-divider {
            border-top: 1px solid var(--border);
            margin: 14px 0;
        }

        .info-row {
            margin-bottom: 14px;
        }

        .info-label {
            font-size: 11px;
            color: var(--text-light);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 3px;
        }

        .info-value {
            font-size: 13px;
            color: var(--text-dark);
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .info-value i {
            color: var(--text-light);
            font-size: 13px;
        }

        /* ===== STAT CARDS ===== */
        .stat-card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 18px 18px 14px;
            border: 1px solid var(--border);
            height: 100%;
        }

        .stat-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .stat-label {
            font-size: 12.5px;
            color: var(--text-mid);
            font-weight: 500;
        }

        .stat-icon {
            color: var(--text-light);
            font-size: 15px;
        }

        .stat-value {
            font-family: 'Syne', sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: var(--text-dark);
            letter-spacing: -0.03em;
            margin-bottom: 4px;
            line-height: 1;
        }

        .stat-note {
            font-size: 11.5px;
            color: var(--text-light);
        }

        /* ===== BLOCK BUTTON ===== */
        .btn-block {
            display: flex;
            align-items: center;
            gap: 7px;
            background: #ef4444;
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 9px 16px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.18s;
            text-decoration: none;
        }

        .btn-block:hover {
            background: #dc2626;
            color: #fff;
        }

        /* ===== ORDERS TABLE ===== */
        .orders-table {
            font-size: 13px;
            margin-bottom: 0;
        }

        .orders-table thead th {
            font-size: 11.5px;
            font-weight: 600;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1.5px solid var(--border);
            padding: 8px 12px;
            background: transparent;
        }

        .orders-table tbody td {
            vertical-align: middle;
            border-color: var(--border);
            padding: 11px 12px;
            color: var(--text-dark);
        }

        .orders-table tbody tr:last-child td {
            border-bottom: none;
        }

        .order-id {
            font-weight: 600;
            color: var(--text-dark);
            font-family: monospace;
            font-size: 13px;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: 11.5px;
            font-weight: 600;
        }


        .status-delivered {
            background: #dcfce7;
            color: #16a34a;
        }

        .status-cancelled {
            background: #fee2e2;
            color: #dc2626;
        }

        .status-pending {
            background: #fef9c3;
            color: #a16207;
        }

        .status-processing {
            background: #dbeafe;
            color: #1d4ed8;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .sidebar {
                width: 160px;
                min-width: 160px;
            }

            .main-content {
                padding: 14px;
            }
        }

        @media (max-width: 576px) {
            .sidebar {
                display: none;
            }

            .main-content {
                padding: 12px;
            }
        }
    </style>
</head>

<body>

    <div class="d-flex" style="min-height:100vh;">

        <!-- ===================== SIDEBAR ===================== -->
        <%- include('../../partials/admin/sidebar', { currentPage: 'users' }) %>

            <!-- ===================== MAIN ===================== -->
            <main class="main-content flex-grow-1">

                <% if (user) { %>

                    <!-- Topbar -->
                    <div class="topbar d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="page-title">User Details</h1>
                            <p class="page-subtitle">Manage user information and view order history for <%= user.Name %>
                                    .</p>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/admin/users" class="btn-back">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <form
                                action="/admin/users/status?id=<%= user._id %>&status=<%= user.isActive ? 'block' : 'unblock' %>"
                                method="POST" style="display:inline;">
                                <%if(user.isActive){%>
                                    <button type="submit" class="btn-block" style="background-color:rgb(255, 0, 0);">
                                        <%} else {%>
                                            <button type="submit" class="btn-block" style="background-color:green;">

                                                <%}%>
                                                    <i
                                                        class="bi <%= user.isActive ? 'bi-slash-circle' : 'bi-check-circle' %>"></i>
                                                    <%= user.isActive ? 'Block User' : 'Unblock User' %>
                                            </button>
                            </form>
                        </div>
                    </div>

                    <div class="row g-3">

                        <!-- ===== PROFILE CARD ===== -->
                        <div class="col-12 col-lg-3">
                            <div class="panel text-center">

                                <div class="profile-avatar overflow-hidden">
                                    <% if (user.Profile_image) { %>
                                        <img src="<%= user.Profile_image %>" alt="<%= user.Name %>"
                                            style="width: 100%; height: 100%; object-fit: cover;">
                                        <% } else { %>
                                            <%= user.Name ? user.Name.charAt(0).toUpperCase() : 'U' %>
                                                <% } %>
                                </div>

                                <p class="profile-name">
                                    <%= user.Name %>
                                </p>

                                <span class="status-badge <%= user.isActive ? 'active' : 'blocked' %>">
                                    <%= user.isActive ? 'Active' : 'Blocked' %>
                                </span>

                                <div class="profile-divider"></div>

                                <div class="text-start">
                                    <div class="info-row">
                                        <p class="info-label">User ID</p>
                                        <p class="info-value">USR-88219</p>
                                    </div>
                                    <div class="info-row">
                                        <p class="info-label">Email Address</p>
                                        <p class="info-value">
                                            <i class="bi bi-envelope"></i>
                                            <%= user.Email %>
                                        </p>
                                    </div>
                                    <div class="info-row">
                                        <p class="info-label">Phone Number</p>
                                        <p class="info-value">
                                            <i class="bi bi-telephone"></i>
                                            <%= user.Phone_number || 'Not provided' %>
                                        </p>
                                    </div>
                                    <div class="info-row">
                                        <p class="info-label">Member Since</p>
                                        <p class="info-value">
                                            <i class="bi bi-calendar3"></i>
                                            <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short' ,
                                                day: 'numeric' , year: 'numeric' }) %>
                                        </p>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- ===== RIGHT COLUMN ===== -->
                        <div class="col-12 col-lg-9">

                            <!-- Stat cards -->
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="stat-card">
                                        <div class="stat-top">
                                            <span class="stat-label">Total Orders</span>
                                            <i class="bi bi-bag-check stat-icon"></i>
                                        </div>
                                        <p class="stat-value">24</p>
                                        <p class="stat-note">Lifetime orders</p>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="stat-card">
                                        <div class="stat-top">
                                            <span class="stat-label">Total Spent</span>
                                            <i class="bi bi-currency-rupee stat-icon"></i>
                                        </div>
                                        <p class="stat-value">₹3,450</p>
                                        <p class="stat-note">Avg ₹143.75 / order</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Recent Orders -->
                            <div class="panel">
                                <p class="panel-title">Recent Orders</p>
                                <p class="panel-subtitle">A list of recent orders placed by this user.</p>

                                <div class="table-responsive">
                                    <table class="table orders-table">
                                        <thead>
                                            <tr>
                                                <th>Order ID</th>
                                                <th>Date</th>
                                                <th>Status</th>
                                                <th class="text-end">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td><span class="order-id">#ORD-7721</span></td>
                                                <td>Oct 24, 2023</td>
                                                <td><span class="status-pill status-cancelled">Cancelled</span></td>
                                                <td class="text-end fw-600">₹120.50</td>
                                            </tr>
                                            <tr>
                                                <td><span class="order-id">#ORD-7650</span></td>
                                                <td>Oct 15, 2023</td>
                                                <td><span class="status-pill status-delivered">Delivered</span></td>
                                                <td class="text-end fw-600">₹59.00</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>

                    <% } %>

            </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>