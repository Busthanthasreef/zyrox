<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Report — Zyrox Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <style>
        :root {
            --bg: #0b0c0e;
            --bg-card: #141416;
            --border: rgba(255, 255, 255, .08);
            --accent: #6366f1;
            --text: #f1f5f9;
            --muted: #94a3b8;
            --green: #10b981;
            --radius: 12px;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
        }

        .page-wrapper {
            margin-left: var(--sidebar-width, 260px);
            padding: 30px;
        }

        .card {
            background: var(--bg-card);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            padding: 24px;
            margin-bottom: 24px;
        }

        .stat-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .stat-card {
            background: rgba(255, 255, 255, .02);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 5px;
            color: var(--green);
        }

        .stat-title {
            font-size: .85rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .table {
            color: var(--text);
            vertical-align: middle;
        }

        .table thead th {
            border-bottom: 1px solid var(--border);
            color: var(--muted);
            font-size: .8rem;
            text-transform: uppercase;
            border-top: none;
        }

        .table td {
            border-bottom: 1px solid var(--border);
            font-size: .9rem;
            background: transparent !important;
            color: var(--text) !important;
        }

        .table tbody tr:hover td {
            background: rgba(255, 255, 255, .01) !important;
        }

        .btn-xy {
            border-radius: 8px;
            font-weight: 600;
            padding: 10px 20px;
            font-size: .85rem;
            text-decoration: none;
        }

        .btn-dl-pdf {
            background: #e63946;
            border: none;
            color: white;
        }

        .btn-dl-excel {
            background: #10b981;
            border: none;
            color: white;
        }

        .filter-form {
            display: flex;
            gap: 15px;
            align-items: flex-end;
        }

        .form-control,
        .form-select {
            background: rgba(255, 255, 255, .05);
            border: 1px solid var(--border);
            color: white;
            border-radius: 6px;
        }

        .form-control:focus,
        .form-select:focus {
            background: rgba(255, 255, 255, .08);
            color: white;
            border-color: var(--accent);
            box-shadow: none;
        }
    </style>
</head>

<body>
    <%- include('../../partials/admin/sidebar', { currentPage: 'sales-report' , currentUser }) %>
        <div class="page-wrapper">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="m-0 fw-bold">Sales Report</h2>
                <div class="d-flex gap-2">
                    <a href="#" onclick="downloadFile('excel')" class="btn btn-xy btn-dl-excel"><i
                            class="bi bi-file-earmark-excel"></i> Excel</a>
                    <a href="#" onclick="downloadFile('pdf')" class="btn btn-xy btn-dl-pdf"><i
                            class="bi bi-file-earmark-pdf"></i> PDF</a>
                </div>
            </div>

            <div class="card">
                <form class="filter-form" method="GET" action="/admin/sales-report" id="salesFilterForm">
                    <div>
                        <label class="form-label" style="font-size: .8rem; color: var(--muted);">Filter Type</label>
                        <select name="filterType" id="filterType" class="form-select" onchange="toggleCustomDates()">
                            <option value="daily" <%=filterType==='daily' ? 'selected' : '' %>>Daily</option>
                            <option value="weekly" <%=filterType==='weekly' ? 'selected' : '' %>>Weekly</option>
                            <option value="monthly" <%=filterType==='monthly' ? 'selected' : '' %>>Monthly</option>
                            <option value="yearly" <%=filterType==='yearly' ? 'selected' : '' %>>Yearly</option>
                            <option value="custom" <%=filterType==='custom' ? 'selected' : '' %>>Custom Date Range
                            </option>
                        </select>
                    </div>
                    <div id="customDates" style="display: <%= filterType === 'custom' ? 'flex' : 'none' %>; gap: 15px;">
                        <div>
                            <label class="form-label" style="font-size: .8rem; color: var(--muted);">Start Date</label>
                            <input type="date" name="startDate" id="startDate" class="form-control"
                                value="<%= customStart || '' %>">
                        </div>
                        <div>
                            <label class="form-label" style="font-size: .8rem; color: var(--muted);">End Date</label>
                            <input type="date" name="endDate" id="endDate" class="form-control"
                                value="<%= customEnd || '' %>">
                        </div>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-primary btn-xy">Generate Report</button>
                    </div>
                </form>
            </div>

            <div class="stat-grid mb-4">
                <div class="stat-card">
                    <div class="stat-title">Total Sales Revenue</div>
                    <div class="stat-value">₹<%= data.totalSalesAmount.toLocaleString() %>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-title">Total Orders (Delivered)</div>
                    <div class="stat-value" style="color: var(--accent);">
                        <%= data.totalOrders %>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-title">Total Discounts Given</div>
                    <div class="stat-value" style="color: #f59e0b;">₹<%= data.totalDiscounts.toLocaleString() %>
                    </div>
                </div>
            </div>

            <div class="card" style="overflow-x: auto;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Discount</th>
                            <th>Final Price</th>
                            <th>Payment Method</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data.orders.length> 0) { %>
                            <% data.orders.forEach(order=> { %>
                                <tr>
                                    <td><span style="font-family: monospace;">
                                            <%= order.orderId %>
                                        </span></td>
                                    <td>
                                        <%= new Date(order.createdAt).toLocaleDateString() %>
                                    </td>
                                    <td>
                                        <%= order.userId ? order.userId.Name || order.userId.Email : 'User' %>
                                    </td>
                                    <td style="color: #f59e0b;">₹<%= (order.discount || 0) + (order.couponDiscount || 0)
                                            %>
                                    </td>
                                    <td style="color: var(--green); font-weight: 600;">₹<%= order.finalPrice %>
                                    </td>
                                    <td><span class="badge bg-secondary">
                                            <%= order.paymentMethod %>
                                        </span></td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center py-4" style="color: var(--muted);">No
                                                sales found for this period.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <script>
            function toggleCustomDates() {
                const filterType = document.getElementById('filterType').value;
                const customDates = document.getElementById('customDates');
                if (filterType === 'custom') {
                    customDates.style.display = 'flex';
                } else {
                    customDates.style.display = 'none';
                }
            }

            function downloadFile(type) {
                const form = document.getElementById('salesFilterForm');
                const url = new URL('/admin/sales-report/export/' + type, window.location.origin);
                const formData = new FormData(form);
                for (let [key, val] of formData.entries()) {
                    url.searchParams.append(key, val);
                }
                window.location.href = url.toString();
            }
        </script>
</body>

</html>