<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            background-color: #2b2b2b;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .reset-password-container {
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            max-width: 380px;
            width: 100%;
            padding: 40px 35px;
        }

        .logo-container {
            text-align: center;
            margin-bottom: 25px;
        }

        .logo {
            background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
            color: white;
            padding: 8px 20px;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 18px;
            font-weight: 600;
        }

        .logo i {
            font-size: 20px;
        }

        h1 {
            color: #1a1a1a;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 25px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .shield-icon {
            color: #7ed99b;
            font-size: 24px;
        }

        .form-label {
            color: #1a1a1a;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
        }

        .form-control {
            border: 2px solid #d0d0d0;
            border-radius: 6px;
            padding: 10px 15px;
            font-size: 14px;
            background-color: white;
            transition: border-color 0.3s;
            width: 100%;
        }

        .form-control:focus {
            border-color: #3b9eff;
            box-shadow: none;
            outline: none;
        }

        .error-message {
            background-color: #fff5f5;
            color: #d32f2f;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 12px;
            margin-top: 15px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .error-message i {
            font-size: 13px;
        }

        .btn-save {
            background-color: #7ed99b;
            color: #1a1a1a;
            border: none;
            border-radius: 6px;
            padding: 12px 30px;
            font-size: 14px;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.2s;
            margin-bottom: 12px;
        }

        .btn-save:hover {
            background-color: #6ec889;
            transform: translateY(-1px);
        }

        .btn-back {
            background-color: transparent;
            color: #666;
            border: none;
            padding: 10px 30px;
            font-size: 14px;
            font-weight: 500;
            width: 100%;
            cursor: pointer;
            transition: color 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-back:hover {
            color: #1a1a1a;
        }

        .btn-back i {
            font-size: 14px;
        }

        .mb-3 {
            margin-bottom: 18px;
        }

        @media (max-width: 576px) {
            .reset-password-container {
                padding: 35px 25px;
            }
        }

        @media (max-width: 575px) {
            .reset-password-container {
                padding: 28px 18px;
                border-radius: 10px;
            }

            h1 {
                font-size: 22px;
            }

            .btn-save,
            .btn-back {
                padding: 12px;
                font-size: 14px;
            }
        }

        @media (max-width: 360px) {
            .reset-password-container {
                padding: 22px 14px;
            }

            h1 {
                font-size: 19px;
            }
        }
    </style>
</head>

<body>
    <div class="reset-password-container">
        <div class="logo-container">
            <div class="logo">
                <i class="fas fa-lock"></i>
                Zyroxiz
            </div>
        </div>

        <h1>
            Reset Password
            <i class="fas fa-shield-alt shield-icon"></i>
        </h1>

        <form>
            <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" class="form-control" id="newPassword" placeholder="Enter New Password">
            </div>

            <div class="mb-3">
                <label for="confirmPassword" class="form-label">Confirm New Password</label>
                <input type="password" class="form-control" id="confirmPassword" placeholder="Confirm Password">
            </div>

            <button type="submit" class="btn-save">
                save changes
            </button>

            <button type="button" class="btn-back">
                <i class="fas fa-arrow-left"></i>
                Back to log in
            </button>
        </form>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>