<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            background-color: #fdfbf7 !important;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .page-title {
            color: #9e9e9e;
            font-size: 18px;
            font-weight: 400;
            position: absolute;
            top: 20px;
            left: 20px;
        }

        .forgot-password-container {
            background-color: white;
            border-radius: 16px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            max-width: 420px;
            width: 100%;
            padding: 45px 40px;
        }

        .logo-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .logo {
            background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
            color: white;
            padding: 8px 20px;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .logo i {
            font-size: 20px;
        }

        h1 {
            color: #1a1a1a;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 35px;
            text-align: center;
        }

        .form-label {
            color: #1a1a1a;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 10px;
            display: block;
        }

        .form-control {
            border: 2px solid #1a1a1a;
            border-radius: 25px;
            padding: 12px 20px;
            font-size: 14px;
            background-color: white;
            transition: border-color 0.3s;
            width: 100%;
        }

        .form-control:focus {
            border-color: #3b9eff;
            box-shadow: none;
            outline: none;
        }

        .form-control::placeholder {
            color: #999;
        }

        .error-message {
            background-color: #fff5f5;
            color: #d32f2f;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 13px;
            margin-top: 15px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .error-message i {
            font-size: 14px;
        }

        .btn-send-otp {
            background-color: #7ed99b;
            color: #1a1a1a;
            border: none;
            border-radius: 8px;
            padding: 13px 30px;
            font-size: 15px;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.2s;
            margin-bottom: 15px;
        }

        .btn-send-otp:hover {
            background-color: #6ec889;
            transform: translateY(-1px);
        }

        .resend-section {
            text-align: center;
            font-size: 14px;
            color: #1a1a1a;
        }

        .resend-section a {
            color: #7ed99b;
            text-decoration: none;
            font-weight: 600;
            margin-left: 5px;
        }

        .resend-section a:hover {
            text-decoration: underline;
        }

        .mb-3 {
            margin-bottom: 20px;
        }

        @media (max-width: 576px) {
            .forgot-password-container {
                padding: 35px 25px;
            }
        }

        @media (max-width: 575px) {
            .forgot-password-container {
                padding: 28px 18px;
                border-radius: 10px;
            }

            .logo {
                font-size: 22px;
            }

            .form-label {
                font-size: 13px;
            }

            .btn-send-otp {
                padding: 12px;
                font-size: 14px;
            }
        }

        @media (max-width: 360px) {
            .forgot-password-container {
                padding: 22px 14px;
            }
        }
    </style>
</head>

<body>

    <div class="forgot-password-container">
        <div class="logo-container">
            <div class="logo">
                <i class="fas fa-lock"></i>
                Zyroxiz
            </div>
        </div>

        <h1>Forgot Password ?</h1>

        <form>
            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <input type="email" class="form-control" id="email" placeholder="enter your email">
            </div>

            <div class="error-message">
                <i class="fas fa-exclamation-triangle"></i>
                Invalid email. Please try again.
            </div>

            <button type="submit" class="btn-send-otp">
                Send OTP
            </button>

            <div class="resend-section">
                Didn't receive the code? <a href="#">Resend</a>
            </div>
        </form>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>