<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard — Zyrox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <link rel="stylesheet" href="/adminStyles/home/dashboard.css">
</head>

<body>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <div class="d-flex" style="min-height:100vh;">

        <!-- ===================== SIDEBAR ===================== -->
        <%- include('../../partials/admin/sidebar', { currentPage: 'dashboard' ,currentUser:user }) %>

            <!-- ===================== MAIN ===================== -->
            <main class="main-content flex-grow-1">

                <!-- Top bar -->
                <div class="topbar d-flex justify-content-between align-items-center">
                    <h1 class="page-title">Dashboard</h1>
                    <a href="/admin/sales-report" class="btn-report">
                        <i class="bi bi-file-earmark-bar-graph"></i> view sales report
                    </a>
                </div>

                <!-- ===== STAT CARDS ===== -->
                <div class="row g-3 mb-4">

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Total Revenue</span>
                                <i class="bi bi-info-circle stat-icon"></i>
                            </div>
                            <p class="stat-value">
                                ₹<%= typeof stats !=='undefined' ? stats.totalRevenue : '45,231.89' %>
                            </p>
                            <p class="stat-change positive">
                                <i class="bi bi-arrow-up-short"></i>
                                +20.1% from last month
                            </p>
                        </div>
                    </div>

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Total Orders</span>
                                <i class="bi bi-cart stat-icon"></i>
                            </div>
                            <p class="stat-value">
                                +<%= typeof stats !=='undefined' ? stats.totalOrders : '2,350' %>
                            </p>
                            <p class="stat-change positive">
                                <i class="bi bi-arrow-up-short"></i>
                                +15% from last month
                            </p>
                        </div>
                    </div>

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Pending Orders</span>
                                <span class="stat-dot"></span>
                            </div>
                            <p class="stat-value">
                                <%= typeof stats !=='undefined' ? stats.pendingOrders : '48' %>
                            </p>
                            <p class="stat-change neutral">Requires attention</p>
                        </div>
                    </div>

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Active Users</span>
                                <i class="bi bi-person-lines-fill stat-icon"></i>
                            </div>
                            <p class="stat-value">
                                +<%= typeof stats !=='undefined' ? stats.activeUsers : '12,234' %>
                            </p>
                            <p class="stat-change positive">
                                <i class="bi bi-arrow-up-short"></i>
                                +7% from last month
                            </p>
                        </div>
                    </div>

                </div>

                <!-- ===== REVENUE CHART + RECENT SALES ===== -->
                <div class="row g-3 mb-4">

                    <!-- Chart -->
                    <div class="col-12 col-lg-7">
                        <div class="panel">
                            <p class="panel-title">Revenue Overview</p>
                            <p class="panel-subtitle">Monthly revenue performance for current year</p>
                            <canvas id="revenueChart" height="180"></canvas>
                        </div>
                    </div>

                    <!-- Recent Sales -->
                    <div class="col-12 col-lg-5">
                        <div class="panel">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div>
                                    <p class="panel-title mb-0">Recent Sales</p>
                                    <p class="panel-subtitle">
                                        You made
                                        <strong>
                                            <%= typeof stats !=='undefined' ? stats.monthlySales : '265' %>
                                        </strong>
                                        sales this month.
                                    </p>
                                </div>
                                <a href="/admin/orders" class="btn-view-more">view more</a>
                            </div>

                            <div class="sales-list">
                                <% if (typeof recentSales !=='undefined' && recentSales.length> 0) { %>
                                    <% recentSales.forEach(sale=> { %>
                                        <div class="sale-item">
                                            <div class="sale-avatar">
                                                <%= sale.name.charAt(0) %>
                                            </div>
                                            <div class="sale-info">
                                                <p class="sale-name">
                                                    <%= sale.name %>
                                                </p>
                                                <p class="sale-email">
                                                    <%= sale.email %>
                                                </p>
                                            </div>
                                            <p class="sale-amount">₹<%= sale.amount %>
                                            </p>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <!-- Default static data when no EJS data passed -->
                                                <div class="sale-item">
                                                    <div class="sale-avatar">O</div>
                                                    <div class="sale-info">
                                                        <p class="sale-name">Olivia Martin</p>
                                                        <p class="sale-email">olivia.martin@email.com</p>
                                                    </div>
                                                    <p class="sale-amount">₹1,999.00</p>
                                                </div>
                                                <div class="sale-item">
                                                    <div class="sale-avatar">J</div>
                                                    <div class="sale-info">
                                                        <p class="sale-name">Jackson Lee</p>
                                                        <p class="sale-email">jackson.lee@email.com</p>
                                                    </div>
                                                    <p class="sale-amount">₹39.00</p>
                                                </div>
                                                <div class="sale-item">
                                                    <div class="sale-avatar">I</div>
                                                    <div class="sale-info">
                                                        <p class="sale-name">Isabella Nguyen</p>
                                                        <p class="sale-email">isabella.nguyen@email.com</p>
                                                    </div>
                                                    <p class="sale-amount">₹299.00</p>
                                                </div>
                                                <div class="sale-item">
                                                    <div class="sale-avatar">O</div>
                                                    <div class="sale-info">
                                                        <p class="sale-name">Olivia Martin</p>
                                                        <p class="sale-email">olivia.martin@email.com</p>
                                                    </div>
                                                    <p class="sale-amount">₹1,999.00</p>
                                                </div>
                                                <% } %>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- ===== TRENDING PRODUCTS + TOP CATEGORIES ===== -->
                <div class="row g-3">

                    <!-- Trending Products -->
                    <div class="col-12 col-lg-7">
                        <div class="panel">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <p class="panel-title mb-0">Top Trending Products</p>
                                    <p class="panel-subtitle mb-0">Best performing items this week</p>
                                </div>
                                <a href="/admin/products" class="btn-view-all">View All Products <i
                                        class="bi bi-arrow-right"></i></a>
                            </div>

                            <div class="table-responsive">
                                <table class="table products-table">
                                    <thead>
                                        <tr>
                                            <th>Image</th>
                                            <th>Product Name</th>
                                            <th>Category</th>
                                            <th>Sales</th>
                                            <th>Revenue</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (typeof trendingProducts !=='undefined' && trendingProducts.length> 0) {
                                            %>
                                            <% trendingProducts.forEach(product=> { %>
                                                <tr>
                                                    <td>
                                                        <img src="<%= product.image %>" alt="<%= product.name %>"
                                                            class="product-img">
                                                    </td>
                                                    <td>
                                                        <p class="product-name">
                                                            <%= product.name %>
                                                        </p>
                                                        <p class="product-sku">
                                                            <%= product.sku %>
                                                        </p>
                                                    </td>
                                                    <td><span class="product-category">
                                                            <%= product.category %>
                                                        </span></td>
                                                    <td>
                                                        <%= product.sales %>
                                                    </td>
                                                    <td class="revenue-cell">₹<%= product.revenue %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <!-- Static fallback rows -->
                                                        <% const fallbackProducts=[ { img: '' , name: 'Galaxy S23 Ultra'
                                                            , sku: 'SAM-S23U-8-256-BLK' , category: 'Samsung' , sales:
                                                            342, revenue: '1,995,390' }, { img: '' ,
                                                            name: 'iPhone 17 Pro' , sku: 'APL-IP17P-8-256-TIT' ,
                                                            category: 'Apple' , sales: 288, revenue: '99,988.00' }, {
                                                            img: '' , name: 'Redmi Note 13 Pro' ,
                                                            sku: 'XMI-RN13P-8-128-BLK' , category: 'Xiaomi' , sales:
                                                            245, revenue: '12,90,999.00' }, { img: '' ,
                                                            name: 'Realme Narzo 60' , sku: 'RLM-N60-8-256-BLK' ,
                                                            category: 'Realme' , sales: 187, revenue: '99,9,610.00' }, {
                                                            img: '' , name: 'Moto Edge 40' , sku: 'MOTO-E40-12-256-GRN'
                                                            , category: 'Motorola' , sales: 156, revenue: '99,799.00' },
                                                            ] %>
                                                            <% fallbackProducts.forEach(p=> { %>
                                                                <tr>
                                                                    <td>
                                                                        <div class="product-img-placeholder"><i
                                                                                class="bi bi-phone"></i></div>
                                                                    </td>
                                                                    <td>
                                                                        <p class="product-name">
                                                                            <%= p.name %>
                                                                        </p>
                                                                        <p class="product-sku">
                                                                            <%= p.sku %>
                                                                        </p>
                                                                    </td>
                                                                    <td><span class="product-category">
                                                                            <%= p.category %>
                                                                        </span></td>
                                                                    <td>
                                                                        <%= p.sales %>
                                                                    </td>
                                                                    <td class="revenue-cell">₹<%= p.revenue %>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                                    <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>


                    <!-- Top Categories -->
                    <div class="col-12 col-lg-5">
                        <div class="panel">
                            <p class="panel-title">Top Categories</p>
                            <p class="panel-subtitle">Revenue share by category</p>

                            <div class="categories-list">
                                <% if (typeof topCategories !=='undefined' && topCategories.length> 0) { %>
                                    <% topCategories.forEach(cat=> { %>
                                        <div class="category-item">
                                            <div class="d-flex justify-content-between mb-1">
                                                <span class="cat-name">
                                                    <%= cat.name %>
                                                </span>
                                                <span class="cat-percent">
                                                    <%= cat.percent %>%
                                                </span>
                                            </div>
                                            <div class="progress-bar-wrap">
                                                <div class="progress-bar-fill" style="width: <%= cat.percent %>%">
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <!-- Static fallback -->
                                                <% const fallbackCats=[ { name: 'Samsung' , percent: 45 }, {
                                                    name: 'Xiaomi' , percent: 28 }, { name: 'Apple' , percent: 15 }, {
                                                    name: 'Sports' , percent: 8 }, { name: 'Others' , percent: 4 }, ] %>
                                                    <% fallbackCats.forEach(cat=> { %>
                                                        <div class="category-item">
                                                            <div class="d-flex justify-content-between mb-1">
                                                                <span class="cat-name">
                                                                    <%= cat.name %>
                                                                </span>
                                                                <span class="cat-percent">
                                                                    <%= cat.percent %>%
                                                                </span>
                                                            </div>
                                                            <div class="progress-bar-wrap">
                                                                <div class="progress-bar-fill"
                                                                    style="width: '<%= cat.percent %>%'"></div>
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                                            <% } %>
                            </div>

                            <a href="/admin/categories" class="btn-view-categories">View Categories</a>
                        </div>
                    </div>

                </div><!-- end row -->
                <% if(successSwal){%>
                    <script>
                        Swal.fire({
                            toast: true,
                            position: 'top',
                            icon: 'success',
                            title: 'Welcome back,',
                            text: 'You have successfully logged in.',
                            showConfirmButton: false,
                            timer: 1900,
                            timerProgressBar: true,
                            background: '#1e293b',        // dark admin style
                            color: '#f1f5f9',
                            iconColor: '#22c55e',
                            customClass: {
                                popup: 'admin-toast'
                            },
                            didOpen: (toast) => {
                                toast.style.borderLeft = '5px solid #22c55e';
                            }
                        });
                    </script>
                    <%}%>




            </main><!-- end main -->

    </div><!-- end flex wrapper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>





        // Revenue chart
        const ctx = document.getElementById('revenueChart').getContext('2d');

        const revenueData = <% - typeof dashboardChartData !== 'undefined' ? JSON.stringify(dashboardChartData) : JSON.stringify([0, 1200, 2000, 1500, 3000, 4500, 3800, 5000, 6000, 7500, 9000, 9800]) %>;

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    data: revenueData,
                    borderColor: '#22c55e',
                    borderWidth: 2.5,
                    pointRadius: 3,
                    pointBackgroundColor: '#22c55e',
                    fill: false,
                    tension: 0.3,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: {
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: { font: { family: 'Inter', size: 11 }, color: '#888' }
                    },
                    y: {
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: { font: { family: 'Inter', size: 11 }, color: '#888' }
                    }
                }
            }
        });
    </script>

</body>

</html>