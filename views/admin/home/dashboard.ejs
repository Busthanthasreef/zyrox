<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard — Zyrox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <link rel="stylesheet" href="/adminStyles/home/dashboard.css">
</head>

<body class="admin-body">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <%- include('../../partials/admin/sidebar', { currentPage: 'dashboard' ,currentUser:user }) %>

        <main class="admin-main">
            <div class="main-content">

                <!-- Top bar -->
                <div class="topbar d-flex justify-content-between align-items-center">
                    <h1 class="page-title">Dashboard</h1>
                    <a href="/adminUser/sales-report" class="btn-report">
                        <i class="bi bi-file-earmark-bar-graph"></i> view sales report
                    </a>
                </div>

                <!-- ===== STAT CARDS ===== -->
                <div class="row g-3 mb-4">

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Total Revenue</span>
                                <i class="bi bi-info-circle stat-icon"></i>
                            </div>
                            <p class="stat-value">
                                ₹<%= typeof stats !=='undefined' ? stats.totalRevenue : '45,231.89' %>
                            </p>

                        </div>
                    </div>

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Total Orders</span>
                                <i class="bi bi-cart stat-icon"></i>
                            </div>
                            <p class="stat-value">
                                <%= typeof stats !=='undefined' ? stats.totalOrders : '2,350' %>
                            </p>

                        </div>
                    </div>

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Pending Orders</span>
                                <span class="stat-dot"></span>
                            </div>
                            <p class="stat-value">
                                <%= typeof stats !=='undefined' ? stats.pendingOrders : '0' %>
                            </p>

                        </div>
                    </div>

                    <div class="col-6 col-xl-3">
                        <div class="stat-card">
                            <div class="stat-top">
                                <span class="stat-label">Active Users</span>
                                <i class="bi bi-person-lines-fill stat-icon"></i>
                            </div>
                            <p class="stat-value">
                                <%= typeof stats !=='undefined' ? stats.activeUsers : '12,234' %>
                            </p>

                        </div>
                    </div>

                </div>

                <!-- ===== REVENUE CHART + RECENT SALES ===== -->
                <div class="row g-3 mb-4">

                    <!-- Chart -->
                    <div class="col-12 col-lg-7">
                        <div class="panel">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <div>
                                    <p class="panel-title mb-0">
                                        <%= chartTitle %>
                                    </p>
                                    <p class="panel-subtitle">Revenue trend analysis</p>
                                </div>
                                <div class="dropdown">
                                    <button class="btn-filter dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-calendar3 me-1"></i>
                                        <%= filter.charAt(0).toUpperCase() + filter.slice(1) %>
                                    </button>
                                    <ul class="dropdown-menu shadow border-0">
                                        <li><a class="dropdown-item" href="/adminUser/dashboard?filter=weekly">Weekly</a>
                                        </li>
                                        <li><a class="dropdown-item" href="/adminUser/dashboard?filter=monthly">Monthly</a>
                                        </li>
                                        <li><a class="dropdown-item" href="/adminUser/dashboard?filter=yearly">Yearly</a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <div class="chart-container" style="position: relative; height:300px;">
                                <canvas id="revenueChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Sales -->
                    <div class="col-12 col-lg-5">
                        <div class="panel">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div>
                                    <p class="panel-title mb-0">Recent Sales</p>
                                    <p class="panel-subtitle">
                                        You made
                                        <strong>
                                            <%= typeof stats !=='undefined' ? stats.monthlySales : '265' %>
                                        </strong>
                                        sales this month.
                                    </p>
                                </div>
                                <a href="/adminUser/orders" class="btn-view-more">view more</a>
                            </div>

                            <div class="sales-list">
                                <% if (typeof recentSales !=='undefined' && recentSales.length> 0) { %>
                                    <% recentSales.forEach(sale=> { %>
                                        <div class="sale-item">
                                            <div class="sale-avatar">
                                                <%= sale.name.charAt(0) %>
                                            </div>
                                            <div class="sale-info">
                                                <p class="sale-name">
                                                    <%= sale.name %>
                                                </p>
                                                <p class="sale-email">
                                                    <%= sale.email %>
                                                </p>
                                            </div>
                                            <p class="sale-amount">₹<%= sale.amount %>
                                            </p>
                                        </div>
                                        <% }) %>
                                            <% } %>

                            </div>
                        </div>
                    </div>

                </div>

                <!-- ===== TRENDING PRODUCTS + TOP CATEGORIES ===== -->
                <div class="row g-3">

                    <!-- Trending Products -->
                    <div class="col-12 col-lg-7">
                        <div class="panel">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <p class="panel-title mb-0">Best Selling Products (Top 10)</p>
                                    <p class="panel-subtitle mb-0">Top performing units by sales volume</p>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="/adminUser/sales-report" class="btn-view-all" title="View Detailed Report"><i
                                            class="bi bi-journal-text me-1"></i> Ledger Book</a>
                                    <a href="/adminUser/products" class="btn-view-all">View All <i
                                            class="bi bi-arrow-right"></i></a>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table products-table">
                                    <thead>
                                        <tr>
                                            <th>Image</th>
                                            <th>Product Name</th>
                                            <th>Category</th>
                                            <th>Sales</th>
                                            <th>Revenue</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (typeof topProducts !=='undefined' && topProducts.length> 0) {
                                            %>
                                            <% topProducts.forEach(product=> { %>
                                                <tr>
                                                    <td>
                                                        <img src="<%= product.image %>" alt="<%= product.name %>"
                                                            class="product-img">
                                                    </td>
                                                    <td>
                                                        <p class="product-name">
                                                            <%= product.name %>
                                                        </p>
                                                        <p class="product-sku">
                                                            <%= product.sku %>
                                                        </p>
                                                    </td>
                                                    <td><span class="product-category">
                                                            <%= product.category %>
                                                        </span></td>
                                                    <td style="font-weight: 700;">
                                                        <%= product.sales %>
                                                    </td>
                                                    <td class="revenue-cell">₹<%= product.revenue %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>


                    <!-- Top Categories -->
                    <div class="col-12 col-lg-5">
                        <div class="panel">
                            <p class="panel-title">Best Selling Categories (Top 10)</p>
                            <p class="panel-subtitle">Sales contribution by category</p>

                            <div class="categories-list">
                                <% if (typeof topCategories !=='undefined' && topCategories.length> 0) { %>
                                    <% topCategories.forEach(cat=> { %>
                                        <div class="category-item">
                                            <div class="d-flex justify-content-between mb-1">
                                                <span class="cat-name">
                                                    <%= cat.name %>
                                                </span>
                                                <span class="cat-percent">
                                                    <%= cat.percent %>%
                                                </span>
                                            </div>
                                            <div class="progress-bar-wrap">
                                                <div class="progress-bar-fill" style="width: <%= cat.percent %>%">
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <%}%>

                            </div>

                            <a href="/adminUser/categories" class="btn-view-categories">View Categories</a>
                        </div>
                    </div>

                </div><!-- end row -->

                <div class="row g-3 mt-1">
                    <div class="col-12 col-xl-6">
                        <div class="panel">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <p class="panel-title mb-0">Order Status Distribution</p>
                                    <p class="panel-subtitle mb-0">Current status breakdown for all orders</p>
                                </div>
                            </div>
                            <div class="chart-container" style="position: relative; height:300px;">
                                <canvas id="statusChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xl-6">
                        <div class="panel">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <p class="panel-title mb-0">Payment Methods</p>
                                    <p class="panel-subtitle mb-0">Transactional platform distribution</p>
                                </div>
                            </div>
                            <div class="chart-container" style="position: relative; height:300px;">
                                <canvas id="paymentChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <% if(successSwal){%>
                    <script>
                        Swal.fire({
                            toast: true,
                            position: 'top',
                            icon: 'success',
                            title: 'Welcome back,',
                            text: 'You have successfully logged in.',
                            showConfirmButton: false,
                            timer: 1900,
                            timerProgressBar: true,
                            background: '#1e293b',        // dark admin style
                            color: '#f1f5f9',
                            iconColor: '#22c55e',
                            customClass: {
                                popup: 'admin-toast'
                            },
                            didOpen: (toast) => {
                                toast.style.borderLeft = '5px solid #22c55e';
                            }
                        });
                    </script>
                    <%}%>




            </div><!-- end main-content -->
        </main><!-- end admin-main -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            // Helper to safely parse EJS data
            const revenueLabels = <%- JSON.stringify(chartLabels) %>;
            const revenueData = <%- JSON.stringify(chartData) %>;
            const statusLabels = <%- typeof orderStatusData !== 'undefined' ? JSON.stringify(orderStatusData.labels) : '[]' %>;
            const statusCounts = <%- typeof orderStatusData !== 'undefined' ? JSON.stringify(orderStatusData.counts) : '[]' %>;
            const paymentLabels = <%- typeof paymentData !== 'undefined' ? JSON.stringify(paymentData.labels) : '[]' %>;
            const paymentCounts = <%- typeof paymentData !== 'undefined' ? JSON.stringify(paymentData.counts) : '[]' %>;

            // 1. Revenue Overview Chart
            const ctx = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: revenueLabels,
                    datasets: [{
                        data: revenueData,
                        borderColor: '#22c55e',
                        backgroundColor: (context) => {
                            const canvas = context.chart.canvas;
                            const ctx = canvas.getContext('2d');
                            const gradient = ctx.createLinearGradient(0, 0, 0, 300);
                            gradient.addColorStop(0, 'rgba(34, 197, 94, 0.2)');
                            gradient.addColorStop(1, 'rgba(34, 197, 94, 0)');
                            return gradient;
                        },
                        borderWidth: 3.5,
                        pointRadius: 4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#22c55e',
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { font: { family: 'Inter', size: 11, weight: '500' }, color: '#64748b' }
                        },
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false },
                            ticks: { font: { family: 'Inter', size: 11 }, color: '#64748b' }
                        }
                    }
                }
            });

            // 2. Status Distribution Chart
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: statusLabels,
                    datasets: [{
                        data: statusCounts,
                        backgroundColor: ['#ef4444', '#22c55e', '#f59e0b', '#3b82f6', '#64748b', '#8b5cf6'],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: { usePointStyle: true, padding: 20, font: { family: 'Inter', size: 12 } }
                        }
                    },
                    cutout: '70%'
                }
            });

            // 3. Payment Method Chart
            const paymentCtx = document.getElementById('paymentChart').getContext('2d');
            new Chart(paymentCtx, {
                type: 'pie',
                data: {
                    labels: paymentLabels,
                    datasets: [{
                        data: paymentCounts,
                        backgroundColor: ['#3b82f6', '#22c55e', '#f59e0b', '#8b5cf6', '#ec4899'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: { usePointStyle: true, padding: 20, font: { family: 'Inter', size: 12 } }
                        }
                    }
                }
            });

            // 4. Weekly Sales Chart
            const weeklyCtx = document.getElementById('weeklyChart').getContext('2d');
            new Chart(weeklyCtx, {
                type: 'bar',
                data: {
                    labels: weeklyLabels,
                    datasets: [{
                        label: 'Revenue',
                        data: weeklyTotals,
                        backgroundColor: '#4361ee',
                        borderRadius: 6,
                        barThickness: 30
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { family: 'Inter', size: 11 } } },
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false }, ticks: { font: { family: 'Inter', size: 11 } } }
                    }
                }
            });
        </script>
</body>

</html>