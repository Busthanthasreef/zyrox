<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories — Zyrox Admin</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=3">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Sora:wght@300;400;500;600;700&family=DM+Sans:wght@400;500;600&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/adminStyles/category/categories.css">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
</head>

<body class="admin-body">
    <%- include('../../partials/admin/sidebar', { currentPage: 'categories' , currentUser: admin }) %>

        <main class="admin-main">
            <div class="main-content">

                <!-- ── Page Header ── -->
                <div class="page-header">
                    <h2>
                        <i class="bi bi-grid-3x3-gap-fill" style="color:var(--accent);font-size:20px;"></i>
                        Categories
                    </h2>
                    <button class="btn-primary-custom" onclick="openAddModal()">
                        <i class="bi bi-plus-lg"></i> Add Category
                    </button>
                </div>

                <!-- ── Stat Cards ── -->
                <div class="stats-container">
                    <div class="stat-card">
                        <h4>Total Categories</h4>
                        <h2>
                            <%= totalCategories %>
                        </h2>
                        <i class="bi bi-collection stat-icon"></i>
                    </div>
                    <div class="stat-card">
                        <h4>Active</h4>
                        <h2>
                            <%= activeCategories %>
                        </h2>
                        <i class="bi bi-check-circle stat-icon"></i>
                    </div>
                    <div class="stat-card">
                        <h4>Inactive</h4>
                        <h2 id="inActiveCategoriesCount">
                            <%= inActiveCategories %>
                        </h2>
                        <i class="bi bi-x-circle stat-icon"></i>
                    </div>
                </div>

                <div id="searchingIndicator" style="display: none; align-items: center; gap: 8px; margin-bottom: 12px; font-size: 13px; font-weight: 600; color: var(--accent);">
                    <div class="spinner-sm" style="width: 14px; height: 14px; border: 2px solid #e2e8f0; border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
                    <span>Searching categories...</span>
                </div>

                <!-- ── Table Container ── -->

                <div class="table-container ">

                    <!-- Toolbar -->
                    <div class="table-toolbar">
                        <h3 class="table-toolbar-title">
                            <i class="bi bi-list-ul"></i>
                            All Categories
                        </h3>

                        <div class="filter-form">
                            <div class="search-wrap" style="position: relative;">
                                <i class="bi bi-search search-icon"></i>
                                <input type="search" id="categorySearchInput"
                                    placeholder="Search by Name or ID…" value="<%= search || '' %>" autocomplete="off"
                                    style="padding-right: 30px;">
                                <i class="bi bi-x" id="categoryClearBtn" title="Clear Search"
                                    style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); font-size: 20px; color: #999; cursor: pointer; display: <%= search ? 'block' : 'none' %>;"></i>
                            </div>

                            <select id="statusFilter" class="filter-select">
                                <option value="" <%=(!statusFilter || statusFilter==='' ) ? 'selected' : '' %>>All Status</option>
                                <option value="active" <%=statusFilter==='active' ? 'selected' : '' %>>Active</option>
                                <option value="blocked" <%=statusFilter==='blocked' ? 'selected' : '' %>>Blocked</option>
                            </select>

                            <select id="countFilter" class="filter-select">
                                <option value="" <%=(!countFilter || countFilter==='' ) ? 'selected' : '' %>>All Products</option>
                                <option value="has_products" <%=countFilter==='has_products' ? 'selected' : '' %>>With Products</option>
                                <option value="no_products" <%=countFilter==='no_products' ? 'selected' : '' %>>No Products</option>
                            </select>

                            <select id="sortBy" class="filter-select">
                                <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                                <option value="oldest" <%= sortBy === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                                <option value="name_asc" <%= sortBy === 'name_asc' ? 'selected' : '' %>>Name: A-Z</option>
                                <option value="name_desc" <%= sortBy === 'name_desc' ? 'selected' : '' %>>Name: Z-A</option>
                            </select>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="table-scroll" style="position: relative;">
                        <div id="tableLoadingOverlay" style="position: absolute; inset: 0; background: rgba(255,255,255,0.4); display: none; align-items: center; justify-content: center; z-index: 100; backdrop-filter: blur(1px);">
                            <div class="spinner-sm" style="width: 32px; height: 32px; border: 3px solid #e2e8f0; border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
                        </div>
                        <table class="category-table" id="categoryTable">
                            <thead>
                                <tr>
                                    <th>SI.No</th>
                                    <th>Category ID</th>
                                    <th>Category Name</th>
                                    <th><i class="bi bi-box-seam"></i> Products</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                <% if (categories && categories.length> 0) { %>

                                    <% categories.forEach((cat, ind)=> { %>
                                        <tr>
                                            <!-- Pagination based serial number -->
                                            <td>
                                                <%= ((currentPage - 1) * limit) + ind + 1 %>
                                            </td>

                                            <td>
                                                <span class="cat-id" title="<%= cat._id %>">
                                                    <%= cat._id.toString().substring(0, 8).toUpperCase() %>...
                                                </span>
                                            </td>

                                            <td>
                                                <span class="cat-name" style="text-transform: capitalize;">
                                                    <i class="bi bi-tag"></i>
                                                    <%= cat.categoryName %>
                                                </span>
                                            </td>

                                            <td>
                                                <span
                                                    class="product-count <%= cat.productCount > 0 ? 'has-products' : 'no-products' %>">
                                                    <i class="bi bi-box"></i>
                                                    <%= cat.productCount ?? 0 %>
                                                </span>
                                            </td>

                                            <td>
                                                <span class="badge <%= cat.IsActive ? 'active' : 'inactive' %>">
                                                    <i
                                                        class="bi bi-<%= cat.IsActive ? 'check-circle-fill' : 'x-circle-fill' %>"></i>
                                                    <%= cat.IsActive ? 'Active' : 'Inactive' %>
                                                </span>
                                            </td>

                                            <td>
                                                <div class="action-cell">
                                                    <button class="edit-btn"
                                                        onclick="openEditModal('<%= cat._id %>', '<%= cat.categoryName %>', '<%= cat.IsActive %>')">
                                                        <i class="bi bi-pencil-fill"></i>
                                                    </button>

                                                    <button class="status-btn <%= cat.IsActive ? 'active' : '' %>"
                                                        onclick="toggleStatus('<%= cat._id %>')" 
                                                        title="<%= cat.IsActive ? 'Deactivate' : 'Activate' %>">
                                                        <i class="bi <%= cat.IsActive ? 'bi-toggle-on' : 'bi-toggle-off' %>"></i>
                                                    </button>

                                                    <button class="delete-btn"
                                                        onclick="deleteConfirmation('<%= cat._id %>')">
                                                        <i class="bi bi-trash-fill"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>

                                            <% } else { %>
                                                <tr>
                                                    <td colspan="6" style="text-align:center; padding:80px 20px;">
                                                        <div class="empty-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                                            <i class="bi bi-search" style="font-size: 48px; color: #cbd5e1; margin-bottom: 16px;"></i>
                                                            <h4 style="font-weight: 700; color: #1e293b; margin-bottom: 8px;">No Categories Found</h4>
                                                            <p style="color: #64748b; font-size: 14px; max-width: 350px; margin: 0 auto;">We couldn't find any categories matching your current search or status filter.</p>
                                                            <% if ((typeof search !== 'undefined' && search) || (typeof statusFilter !== 'undefined' && statusFilter)) { %>
                                                                <a href="/adminUser/categories" class="btn btn-dark px-4 py-2 mt-3" style="border-radius: 8px; font-weight: 600; font-size: 13px;">
                                                                    <i class="bi bi-arrow-counterclockwise me-1"></i> Clear All Filters
                                                                </a>
                                                            <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% } %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div id="paginationContainer">
                        <% if (totalPages> 1) { %>
                            <div class="pagination-footer">
                                <p class="showing-text" id="showingText">
                                    Showing
                                    <strong><%= totalCategories> 0 ? ((currentPage - 1) * limit + 1) + '–' + Math.min(currentPage * limit, totalCategories) : 0 %></strong>
                                    of <strong><%= totalCategories %></strong> Categories
                                </p>

                                <nav>
                                    <ul class="pagination-list" id="paginationList">
                                        <li>
                                            <a href="javascript:void(0)" onclick="changePage(<%= Math.max(1, currentPage - 1) %>)"
                                                class="page-btn <%= currentPage <= 1 ? 'disabled' : '' %>">
                                                <i class="bi bi-chevron-left"></i> Previous
                                            </a>
                                        </li>
                                        <% for (let p=1; p <=totalPages; p++) { %>
                                            <li>
                                                <a href="javascript:void(0)" onclick="changePage(<%= p %>)"
                                                    class="page-btn <%= currentPage === p ? 'active' : '' %>">
                                                    <%= p %>
                                                </a>
                                            </li>
                                        <% } %>
                                        <li>
                                            <a href="javascript:void(0)" onclick="changePage(<%= currentPage + 1 %>)"
                                                class="page-btn <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                                Next <i class="bi bi-chevron-right"></i>
                                            </a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        <% } %>
                    </div>

                </div>

            </div><!-- /main-content -->
        </main><!-- /adminUser-main -->


        <!-- ═══════════════════════════════════════════
     ADD CATEGORY MODAL
════════════════════════════════════════════ -->
        <div class="modal-overlay" id="addCategoryModal">
            <div class="modal-box">
                <div class="modal-header">
                    <h3><i class="bi bi-plus-circle-fill"></i> Add Category</h3>
                    <button class="modal-close" onclick="closeAddModal()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <form action="/adminUser/categories-add" method="POST" id="addCategory">
                    <div class="modal-body">
                        <div>
                            <label>Category Name</label>
                            <input type="text" name="categoryName" id="categoryName"
                                placeholder="e.g. Xiaomi, Apple, Samsung">
                        </div>

                        <div class="toggle-box">
                            <div>
                                <strong>Status</strong>
                                <span class="status-label is-inactive" id="addStatusLabel">Inactive</span>
                                <p>Enable this category immediately</p>
                            </div>
                            <label class="switch">
                                <input type="checkbox" name="status" id="addStatusToggle" value="true">
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secondary" onclick="closeAddModal()">
                            <i class="bi bi-x"></i> Cancel
                        </button>
                        <button type="submit" class="btn-dark">
                            <i class="bi bi-check2"></i> Save Category
                        </button>
                    </div>
                </form>
            </div>
        </div>


        <!-- ═══════════════════════════════════════════
     EDIT CATEGORY MODAL
════════════════════════════════════════════ -->
        <div class="modal-overlay" id="editCategoryModal">
            <div class="modal-box">
                <div class="modal-header">
                    <h3><i class="bi bi-pencil-fill"></i> Edit Category</h3>
                    <button class="modal-close" onclick="closeEditModal()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <form id="editCategoryForm" method="POST">
                    <input type="hidden" name="_method" value="PUT">
                    <input type="hidden" name="categoryId" id="editCategoryId">

                    <div class="modal-body">
                        <div>
                            <label>Category Name</label>
                            <input type="text" name="categoryName" id="editCategoryName" placeholder="Category name">
                        </div>

                        <div class="toggle-box">
                            <div>
                                <strong>
                                    <i class="bi bi-toggle-on" style="color:var(--accent);margin-right:5px;"></i>
                                    Status
                                </strong>
                                <span class="status-label is-inactive" id="editStatusLabel">Inactive</span>
                                <p>Category is visible in store</p>
                            </div>
                            <label class="switch">
                                <input type="checkbox" name="status" id="editCategoryStatus" value="true">
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secondary" onclick="closeEditModal()">
                            <i class="bi bi-x"></i> Cancel
                        </button>
                        <button type="submit" class="btn-dark">
                            <i class="bi bi-check2"></i> Update Category
                        </button>
                    </div>
                </form>
            </div>
        </div>


        <!-- Scripts -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

        <script>
            // State Management
            let currentState = {
                page: <%= currentPage %>,
                search: '<%= search || "" %>',
                status: '<%= statusFilter || "" %>',
                countFilter: '<%= countFilter || "" %>',
                sortBy: '<%= sortBy || "newest" %>'
            };

            const categoryTableBody = document.querySelector('#categoryTable tbody');
            const categorySearchInput = document.getElementById('categorySearchInput');
            const statusFilterSelect = document.getElementById('statusFilter');
            const countFilterSelect = document.getElementById('countFilter');
            const sortBySelect = document.getElementById('sortBy');
            const tableLoadingOverlay = document.getElementById('tableLoadingOverlay');
            const searchingIndicator = document.getElementById('searchingIndicator');
            const categoryClearBtn = document.getElementById('categoryClearBtn');
            const showingText = document.getElementById('showingText');
            const paginationList = document.getElementById('paginationList');
            const totalCategoriesCount = document.querySelector('.stats-container .stat-card:nth-child(1) h2');
            const activeCategoriesCount = document.querySelector('.stats-container .stat-card:nth-child(2) h2');
            const inActiveCategoriesCount = document.getElementById('inActiveCategoriesCount');

            function debounce(func, timeout = 500) {
                let timer;
                return (...args) => {
                    clearTimeout(timer);
                    timer = setTimeout(() => { func.apply(this, args); }, timeout);
                };
            }

            async function fetchData(updateHistory = true) {
                tableLoadingOverlay.style.display = 'flex';
                if (currentState.search) searchingIndicator.style.display = 'flex';

                const params = new URLSearchParams(currentState);
                const url = `/adminUser/categories?${params.toString()}`;

                try {
                    const res = await fetch(url, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
                    });
                    const data = await res.json();
                    if (data.success) {
                        renderTable(data.categories, data.currentPage, data.limit);
                        renderPagination(data);
                        updateStats(data);
                        if (updateHistory) window.history.pushState(currentState, '', url);
                    }
                } catch (err) {
                    console.error('Fetch error:', err);
                } finally {
                    tableLoadingOverlay.style.display = 'none';
                    searchingIndicator.style.display = 'none';
                }
            }

            function renderTable(categories, cp, limit) {
                if (!categories || categories.length === 0) {
                    categoryTableBody.innerHTML = `
                        <tr>
                            <td colspan="6" style="text-align:center; padding:80px 20px;">
                                <div class="empty-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                    <i class="bi bi-search" style="font-size: 48px; color: #cbd5e1; margin-bottom: 16px;"></i>
                                    <h4 style="font-weight: 700; color: #1e293b; margin-bottom: 8px;">No Categories Found</h4>
                                    <p style="color: #64748b; font-size: 14px; max-width: 350px; margin: 0 auto;">We couldn't find any categories matching your criteria.</p>
                                    <button onclick="clearAllFilters()" class="btn btn-dark px-4 py-2 mt-3" style="border-radius: 8px; font-weight: 600; font-size: 13px;">Clear Filters</button>
                                </div>
                            </td>
                        </tr>`;
                    return;
                }

                categoryTableBody.innerHTML = categories.map((cat, ind) => {
                    const serialNum = ((cp - 1) * limit) + ind + 1;
                    const catShortId = cat._id.toString().substring(0, 8).toUpperCase();
                    return `
                        <tr>
                            <td>${serialNum}</td>
                            <td><span class="cat-id" title="${cat._id}">${catShortId}...</span></td>
                            <td><span class="cat-name" style="text-transform: capitalize;"><i class="bi bi-tag"></i> ${cat.categoryName}</span></td>
                            <td>
                                <span class="product-count ${cat.productCount > 0 ? 'has-products' : 'no-products'}">
                                    <i class="bi bi-box"></i> ${cat.productCount ?? 0}
                                </span>
                            </td>
                            <td>
                                <span class="badge ${cat.IsActive ? 'active' : 'inactive'}">
                                    <i class="bi bi-${cat.IsActive ? 'check-circle-fill' : 'x-circle-fill'}"></i>
                                    ${cat.IsActive ? 'Active' : 'Inactive'}
                                </span>
                            </td>
                            <td>
                                <div class="action-cell">
                                    <button class="edit-btn" onclick="openEditModal('${cat._id}', '${cat.categoryName}', ${cat.IsActive})">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="status-btn ${cat.IsActive ? 'active' : ''}" onclick="toggleStatus('${cat._id}')" title="${cat.IsActive ? 'Deactivate' : 'Activate'}">
                                        <i class="bi ${cat.IsActive ? 'bi-toggle-on' : 'bi-toggle-off'}"></i>
                                    </button>
                                    <button class="delete-btn" onclick="deleteConfirmation('${cat._id}')">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>`;
                }).join('');
            }

            function renderPagination(data) {
                const { currentPage, totalPages, totalCategories, limit } = data;
                const paginationContainer = document.getElementById('paginationContainer');
                
                if (totalPages <= 1) {
                    paginationContainer.innerHTML = '';
                    return;
                }

                let html = `
                    <div class="pagination-footer">
                        <p class="showing-text">
                            Showing <strong>${totalCategories > 0 ? ((currentPage - 1) * limit + 1) + '–' + Math.min(currentPage * limit, totalCategories) : 0}</strong> of <strong>${totalCategories}</strong> Categories
                        </p>
                        <nav>
                            <ul class="pagination-list">
                                <li>
                                    <a href="javascript:void(0)" onclick="changePage(${Math.max(1, currentPage - 1)})" class="page-btn ${currentPage <= 1 ? 'disabled' : ''}">
                                        <i class="bi bi-chevron-left"></i> Previous
                                    </a>
                                </li>`;
                
                for (let p = 1; p <= totalPages; p++) {
                    html += `
                                <li>
                                    <a href="javascript:void(0)" onclick="changePage(${p})" class="page-btn ${currentPage === p ? 'active' : ''}">${p}</a>
                                </li>`;
                }

                html += `
                                <li>
                                    <a href="javascript:void(0)" onclick="changePage(${currentPage + 1})" class="page-btn ${currentPage >= totalPages ? 'disabled' : ''}">
                                        Next <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>`;
                paginationContainer.innerHTML = html;
            }

            function updateStats(data) {
                if (totalCategoriesCount) totalCategoriesCount.innerText = data.totalCategories;
                if (activeCategoriesCount) activeCategoriesCount.innerText = data.activeCategories;
                if (inActiveCategoriesCount) inActiveCategoriesCount.innerText = data.inActiveCategories;
            }

            function changePage(p) {
                if (p < 1) return;
                currentState.page = p;
                fetchData();
            }

            const debouncedSearch = debounce((val) => {
                currentState.search = val;
                currentState.page = 1;
                fetchData();
            });

            categorySearchInput.oninput = (e) => {
                const val = e.target.value;
                categoryClearBtn.style.display = val.length > 0 ? 'block' : 'none';
                debouncedSearch(val);
            };

            categoryClearBtn.onclick = () => {
                categorySearchInput.value = '';
                categoryClearBtn.style.display = 'none';
                currentState.search = '';
                currentState.page = 1;
                fetchData();
            };

            statusFilterSelect.onchange = (e) => {
                currentState.status = e.target.value;
                currentState.page = 1;
                fetchData();
            };

            countFilterSelect.onchange = (e) => {
                currentState.countFilter = e.target.value;
                currentState.page = 1;
                fetchData();
            };

            sortBySelect.onchange = (e) => {
                currentState.sortBy = e.target.value;
                currentState.page = 1;
                fetchData();
            };

            function clearAllFilters() {
                currentState = { page: 1, search: '', status: '', countFilter: '', sortBy: 'newest' };
                categorySearchInput.value = '';
                categoryClearBtn.style.display = 'none';
                statusFilterSelect.value = '';
                countFilterSelect.value = '';
                sortBySelect.value = 'newest';
                fetchData();
            }

            window.onpopstate = (e) => {
                if (e.state) {
                    currentState = e.state;
                    categorySearchInput.value = currentState.search;
                    statusFilterSelect.value = currentState.status;
                    countFilterSelect.value = currentState.countFilter;
                    sortBySelect.value = currentState.sortBy;
                    fetchData(false);
                }
            };

            /* ── Status Toggle ── */
            async function toggleStatus(id) {
                console.log('Toggling status for:', id);
                try {
                    const res = await axios.patch(`/adminUser/categories/toggle/${id}`);
                    if (res.data.success) {
                        Swal.fire({
                            title: 'Updated!',
                            text: res.data.message,
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false,
                            background: '#fff',
                            color: '#111827'
                        }).then(() => location.reload());
                    } else {
                        Swal.fire({ title: 'Error', text: res.data.message, icon: 'error' });
                    }
                } catch (error) {
                    console.error('Toggle error:', error);
                    Swal.fire({ title: 'Error', text: 'Something went wrong', icon: 'error' });
                }
            }

    async function deleteConfirmation(id) {
                const result = await Swal.fire({
                    title: 'Are you sure?',
                    text: 'This category will be deleted.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc2626',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'Yes, sure',
                    cancelButtonText: 'Cancel'
                });

                if (result.isConfirmed) {
                    try {
                        const response = await axios.patch(`/adminUser/categories/delete/${id}`);
                        Swal.fire({
                            icon: 'success',
                            title: response.data.message,
                            position: 'center',
                            showConfirmButton: false,
                            timer: 1000
                        });
                        setTimeout(() => window.location.reload(), 1000);
                    } catch (error) {
                        Swal.fire({
                            icon: 'error',
                            title: error.message || 'Delete failed',
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 1500
                        });
                    }
                }
            }

            /* ── Add Category ── */
            document.getElementById('addCategory').addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const originalBtnHtml = btn.innerHTML;
                const categoryName = document.getElementById('categoryName').value.trim();
                const status = document.getElementById('addStatusToggle').checked;

                // Validation
                if (!categoryName) {
                    return Swal.fire({ icon: 'warning', title: 'Required', text: 'Category name is required', toast: true, position: 'top' });
                }
                if (categoryName.length < 3) {
                    return Swal.fire({ icon: 'warning', title: 'Too Short', text: 'Category name must be at least 3 characters', toast: true, position: 'top' });
                }
                if (!/^[a-zA-Z0-9\s]+$/.test(categoryName)) {
                    return Swal.fire({ icon: 'warning', title: 'Invalid Characters', text: 'Only alphanumeric characters are allowed', toast: true, position: 'top' });
                }

                try {
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
                    
                    const response = await axios.post('/adminUser/categories-add', { categoryName, status });
                    Swal.fire({
                        icon: 'success',
                        title: response.data.message,
                        position: 'center',
                        showConfirmButton: false,
                        timer: 1000
                    });
                    setTimeout(() => window.location.reload(), 1000);
                } catch (error) {
                    btn.disabled = false;
                    btn.innerHTML = originalBtnHtml;
                    Swal.fire({
                        icon: 'error',
                        title: error.response?.data?.message || 'Something went wrong',
                        toast: true,
                        position: 'top',
                        showConfirmButton: false,
                        timer: 2000
                    });
                }
            });

            /* ── Edit Category ── */
            document.getElementById('editCategoryForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const originalBtnHtml = btn.innerHTML;
                const id = document.getElementById('editCategoryId').value;
                const categoryName = document.getElementById('editCategoryName').value.trim();
                const status = document.getElementById('editCategoryStatus').checked;

                // Validation
                if (!categoryName) {
                    return Swal.fire({ icon: 'warning', title: 'Required', text: 'Category name is required', toast: true, position: 'top' });
                }
                if (categoryName.length < 3) {
                    return Swal.fire({ icon: 'warning', title: 'Too Short', text: 'Category name must be at least 3 characters', toast: true, position: 'top' });
                }
                if (!/^[a-zA-Z0-9\s]+$/.test(categoryName)) {
                    return Swal.fire({ icon: 'warning', title: 'Invalid Characters', text: 'Only alphanumeric characters are allowed', toast: true, position: 'top' });
                }

                try {
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Updating...';

                    const response = await axios.put(`/adminUser/categories/${id}`, { categoryName, status });
                    Swal.fire({
                        icon: 'success',
                        title: response.data.message,
                        position: 'center',
                        showConfirmButton: false,
                        timer: 900
                    });
                    setTimeout(() => window.location.reload(), 900);
                } catch (error) {
                    btn.disabled = false;
                    btn.innerHTML = originalBtnHtml;
                    Swal.fire({
                        icon: 'error',
                        title: error.response?.data?.message || 'Update failed',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 2000
                    });
                }
            });

            /* ── Status Label Sync ── */
            function syncStatusLabel(checkbox, labelEl) {
                if (checkbox.checked) {
                    labelEl.textContent = 'Active';
                    labelEl.className = 'status-label is-active';
                } else {
                    labelEl.textContent = 'Inactive';
                    labelEl.className = 'status-label is-inactive';
                }
            }

            const addToggle = document.getElementById('addStatusToggle');
            const addStatusLabel = document.getElementById('addStatusLabel');
            addToggle.addEventListener('change', () => syncStatusLabel(addToggle, addStatusLabel));

            const editToggle = document.getElementById('editCategoryStatus');
            const editStatusLabel = document.getElementById('editStatusLabel');
            editToggle.addEventListener('change', () => syncStatusLabel(editToggle, editStatusLabel));

            /* ── Modal Controls ── */
            const openModalClass = 'show';
            const scrollLockClass = 'modal-open';
            function updateScrollLock() {
                const hasOpenModal = document.querySelector(`.modal-overlay.${openModalClass}`);
                document.body.classList.toggle(scrollLockClass, !!hasOpenModal);
            }
            function openAddModal() {
                document.getElementById('addCategoryModal').classList.add(openModalClass);
                updateScrollLock();
            }
            function closeAddModal() {
                document.getElementById('addCategoryModal').classList.remove(openModalClass);
                updateScrollLock();
            }

            function openEditModal(id, name, status) {
                const modal = document.getElementById('editCategoryModal');
                modal.classList.add(openModalClass);
                document.getElementById('editCategoryId').value = id;
                document.getElementById('editCategoryName').value = name;
                editToggle.checked = (status === 'true' || status === true);
                syncStatusLabel(editToggle, editStatusLabel);
                document.getElementById('editCategoryForm').action = `/adminUser/categories/${id}`;
                updateScrollLock();
            }

            function closeEditModal() {
                document.getElementById('editCategoryModal').classList.remove(openModalClass);
                updateScrollLock();
            }

            /* ── Close on backdrop click or Escape ── */
            document.querySelectorAll('.modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function (e) {
                    if (e.target === this) {
                        this.classList.remove(openModalClass);
                        updateScrollLock();
                    }
                });
            });

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    document.querySelectorAll(`.modal-overlay.${openModalClass}`)
                        .forEach(m => m.classList.remove(openModalClass));
                    updateScrollLock();
                }
            });

        </script>

</body>

</html>