<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders Management | Zyrox Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <link rel="stylesheet" href="/adminStyles/orders/orders.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* ════════════════════════════════════════════
   Zyrox Admin — Orders Page Styles
   Color system & typography matched to
   categories.css — layout/structure unchanged
════════════════════════════════════════════ */

        /* ── CSS Variables (identical to category page) ── */
        :root {
            --bg: #f5f6fa;
            --surface: #ffffff;
            --surface2: #f0f0f0;
            --border: #e8eaf0;
            --accent: #eb8525;
            --accent-soft: rgba(124, 110, 245, 0.12);
            --accent-glow: rgba(124, 110, 245, 0.3);
            --text-primary: #000000;
            --text-secondary: #000000;
            --text-muted: #000000;
            --white: #ffffff;
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
            --info: #0ea5e9;
            --orange: #f97316;
            --radius: 14px;
            --radius-sm: 8px;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            min-height: 100vh;
        }

        /* ── Layout ── */
        .d-flex {
            display: flex;
        }

        .main-content {
            flex: 1;
            padding: 28px 32px;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* ── Page Header ── */
        .top-section {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            flex-shrink: 0;
        }

        .page-title {
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 22px;
            color: var(--text-primary);
        }

        /* ── Bell ── */
        .bell-container {
            position: relative;
        }

        .bell-icon {
            width: 38px;
            height: 38px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 16px;
            color: var(--text-secondary);
            transition: border-color 0.2s, color 0.2s;
            position: relative;
        }

        .bell-icon:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .bell-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            background: var(--danger);
            color: #fff;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            font-size: 9px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--bg);
        }

        /* ── Requests Dropdown ── */
        .requests-dropdown {
            position: absolute;
            top: 46px;
            right: 0;
            width: 340px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            z-index: 1000;
            display: none;
            overflow: hidden;
        }

        .requests-dropdown.show {
            display: block;
        }

        .dropdown-header {
            padding: 13px 16px;
            border-bottom: 1px solid var(--border);
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 12px;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .request-list {
            max-height: 380px;
            overflow-y: auto;
        }

        .request-item {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
        }

        .request-type-badge {
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 3px 7px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 6px;
        }

        .badge-return {
            background: rgba(245, 158, 11, 0.15);
            color: #f59e0b;
        }

        .badge-cancel {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        .request-item>div[style*="font-weight: 800"] {
            color: var(--text-primary) !important;
            font-size: 13px !important;
        }

        .request-item>div[style*="color: #999"] {
            color: var(--text-muted) !important;
            font-size: 11px !important;
        }

        .request-reason {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 6px;
            line-height: 1.5;
            font-style: italic;
        }

        /* Review & Action button */
        .request-btns .btn.btn-sm.btn-dark {
            background: var(--accent-soft) !important;
            border: 1px solid var(--accent) !important;
            color: var(--accent) !important;
            font-size: 10px !important;
            font-weight: 800 !important;
            border-radius: var(--radius-sm) !important;
            letter-spacing: 0.5px;
            transition: background 0.2s, color 0.2s;
        }

        .request-btns .btn.btn-sm.btn-dark:hover {
            background: var(--accent) !important;
            color: #fff !important;
        }

        /* Empty state (dropdown) */
        .empty-state {
            padding: 40px 20px;
            text-align: center;
        }

        .empty-icon {
            font-size: 32px;
            display: block;
            margin-bottom: 10px;
            opacity: 0.25;
        }

        .empty-title {
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .empty-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* ── Stat Grid ── */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 24px;
            flex-shrink: 0;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            position: relative;
            overflow: hidden;
            transition: transform 0.2s, border-color 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            border-color: var(--accent);
        }

        .stat-card-title {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .stat-card-val {
            font-family: 'Inter', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.1;
            margin-bottom: 6px;
        }

        .stat-card-growth {
            font-size: 11px;
            font-weight: 600;
        }

        .stat-card-growth.pos {
            color: var(--success);
        }

        .stat-card-growth.neg {
            color: var(--danger);
        }

        .stat-card-growth.neu {
            color: var(--text-muted);
        }

        .stat-card-icon {
            position: absolute;
            right: 16px;
            bottom: 14px;
            font-size: 36px;
            opacity: 0.06;
            color: var(--accent);
        }

        /* ── Orders Card (Table Container) ── */
        .orders-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        /* ── Card Header / Toolbar ── */
        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
            background: transparent;
            flex-wrap: wrap;
            gap: 12px;
            flex-shrink: 0;
        }

        .table-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            border-top: 1px solid var(--border);
            background: transparent;
            flex-wrap: wrap;
            gap: 14px;
            flex-shrink: 0;
        }

        /* ── Search Area ── */
        .search-area-wrapper {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .search-pill {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-pill>.bi-search {
            position: absolute;
            left: 11px;
            font-size: 13px;
            color: black;
            pointer-events: none;
        }

        .search-pill-input {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--text-primary);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            padding: 8px 32px 8px 32px;
            width: 240px;
            outline: none;
            transition: border-color 0.2s;
        }

        .search-pill-input:focus {
            border-color: var(--accent);
        }

        .search-pill-input::placeholder {
            color: var(--text-muted);
        }

        .search-clear-btn {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 16px;
            color: var(--text-muted);
            cursor: pointer;
            display: none;
            transition: color 0.15s;
        }

        .search-clear-btn:hover {
            color: var(--text-primary);
        }

        .search-btn {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 8px 18px;
            font-size: 12px;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            white-space: nowrap;
            height: 38px;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: opacity 0.2s;
        }

        .search-btn:hover {
            opacity: 0.85;
        }

        /* ── Table Area ── */
        .table-area {
            flex: 1;
            overflow-x: auto;
            overflow-y: auto;
            min-height: 0;
        }

        .orders-table {
            width: 100%;
            border-collapse: collapse;
        }

        .orders-table thead tr {
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
        }

        .orders-table th {
            padding: 13px 16px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-muted);
            white-space: nowrap;
            text-align: left;
        }

        .orders-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s;
        }

        .orders-table tbody tr:last-child {
            border-bottom: none;
        }

        .orders-table tbody tr:hover {
            background: var(--surface2);
        }

        .orders-table td {
            padding: 14px 16px;
            font-size: 13px;
            color: var(--text-secondary);
            vertical-align: middle;
        }

        /* SI.No */
        .orders-table td:first-child {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
        }

        /* Order ID column */
        .orders-table td:nth-child(2) {
            font-family: 'Inter', sans-serif;
            font-weight: 700 !important;
            color: var(--accent) !important;
        }

        /* Customer name */
        .name {
            font-weight: 600;
            font-size: 13px;
            color: var(--text-primary);
        }

        .email {
            font-size: 11px;
            color: var(--text-muted);
        }

        /* Date column */
        .orders-table td:nth-child(4) {
            font-weight: 600 !important;
            color: var(--text-secondary) !important;
            font-size: 12px !important;
        }

        /* Payment method column */
        .orders-table td:nth-child(5) {
            color: var(--text-muted) !important;
            font-size: 11px !important;
            font-weight: 700 !important;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Final price column */
        .orders-table td:nth-child(7) {
            font-family: 'Inter', sans-serif;
            font-weight: 700 !important;
            font-size: 14px !important;
            color: var(--text-primary) !important;
        }

        /* User cell */
        .user-td {
            min-width: 200px;
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--border);
        }

        .user-avatar-init {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--accent-soft);
            border: 2px solid var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: var(--accent);
            font-family: 'Inter', sans-serif;
            flex-shrink: 0;
        }

        .user-meta {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        /* ── Status Tags ── */
        .status-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            white-space: nowrap;
        }

        /* Dynamic color injection via inline style from EJS is kept,
   but we override with sensible defaults per keyword */
        .status-tag[style*="#fd7e14"],
        /* Pending */
        .status-tag[style*="fd7e14"] {
            background: rgba(249, 115, 22, 0.12) !important;
            color: #f97316 !important;
            border: 1px solid rgba(249, 115, 22, 0.25) !important;
        }

        .status-tag[style*="#ffc107"],
        /* Processing */
        .status-tag[style*="ffc107"] {
            background: rgba(234, 179, 8, 0.12) !important;
            color: #eab308 !important;
            border: 1px solid rgba(234, 179, 8, 0.25) !important;
        }

        .status-tag[style*="#0ea5e9"],
        /* Shipped */
        .status-tag[style*="0ea5e9"] {
            background: rgba(14, 165, 233, 0.12) !important;
            color: #0ea5e9 !important;
            border: 1px solid rgba(14, 165, 233, 0.25) !important;
        }

        .status-tag[style*="#22c55e"],
        /* Delivered */
        .status-tag[style*="22c55e"] {
            background: rgba(34, 197, 94, 0.12) !important;
            color: #22c55e !important;
            border: 1px solid rgba(34, 197, 94, 0.25) !important;
        }

        .status-tag[style*="#FF0000"],
        /* Cancelled */
        .status-tag[style*="FF0000"],
        .status-tag[style*="#ef4444"],
        .status-tag[style*="ef4444"] {
            background: rgba(239, 68, 68, 0.12) !important;
            color: #ef4444 !important;
            border: 1px solid rgba(239, 68, 68, 0.25) !important;
        }

        .status-tag[style*="#f59e0b"],
        /* Returned */
        .status-tag[style*="f59e0b"] {
            background: rgba(245, 158, 11, 0.12) !important;
            color: #f59e0b !important;
            border: 1px solid rgba(245, 158, 11, 0.25) !important;
        }

        /* Return/Cancel Requested — purple accent */
        .status-tag[style*="#7c6ef5"],
        .status-tag[style*="7c6ef5"] {
            background: var(--accent-soft) !important;
            color: var(--accent) !important;
            border: 1px solid var(--accent-glow) !important;
        }

        /* ── View Button ── */
        .view-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--text-secondary);
            font-size: 11px;
            font-weight: 600;
            padding: 6px 12px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .view-btn:hover {
            background: var(--accent-soft);
            border-color: var(--accent);
            color: var(--accent);
        }

        /* ── Table Footer / Pagination ── */
        .table-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 20px;
            border-top: 1px solid var(--border);
            flex-wrap: wrap;
            gap: 12px;
        }

        .showing-info {
            font-size: 12px;
            color: black;
        }

        .pag-nav-group {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .p-nav-link,
        .p-num {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 12px;
            border-radius: var(--radius-sm);
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            background: var(--surface2);
            border: 1px solid var(--border);
            text-decoration: none;
            transition: all 0.2s;
        }

        .p-nav-link:hover:not(.disabled),
        .p-num:hover:not(.active) {
            border-color: var(--accent);
            color: var(--accent);
        }

        .p-num.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        .p-nav-link.disabled {
            opacity: 0.35;
            pointer-events: none;
        }

        /* ── Empty Table Row ── */
        .table-empty-row td {
            text-align: center;
            padding: 60px 0;
        }

        .table-empty-row .empty-state {
            display: inline-block;
        }

        .table-empty-row .empty-icon {
            font-size: 36px;
            opacity: 0.25;
            margin-bottom: 12px;
        }

        .table-empty-row .empty-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 4px;
            font-family: 'Inter', sans-serif;
        }

        .table-empty-row .empty-subtitle {
            font-size: 13px;
            color: var(--text-muted);
        }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 10px;
        }
    </style>
</head>

<body class="admin-body">
    <%- include('../../partials/admin/sidebar', { currentPage: 'orders' ,currentUser:user }) %>

        <main class="admin-main">
            <div class="main-content">

                <!-- Page Header -->
                <div class="top-section">
                    <h1 class="page-title">Orders</h1>
                    <div class="bell-container">
                        <div class="bell-icon" id="bellToggle">
                            <i class="bi bi-bell"></i>
                            <% if (returnRequests.length> 0) { %>
                                <span class="bell-badge">
                                    <%= returnRequests.length %>
                                </span>
                                <% } %>
                        </div>

                        <div class="requests-dropdown" id="requestsDropdown">
                            <div class="dropdown-header">Inbox & Requests</div>
                            <div class="request-list">
                                <% if (returnRequests && returnRequests.length> 0) { %>
                                    <% returnRequests.forEach(req=> {
                                        const isR = req.orderStatus === 'Return Requested';
                                        const isC = req.orderStatus === 'Cancellation Requested';
                                        const itemReqs = req.items.filter(i => ['Return Requested', 'Cancellation Requested'].includes(i.status));


                                        let displayType = 'Request';
                                        if (isR || isC) {
                                        displayType = isR ? 'Return' : 'Cancellation';
                                        } else if (itemReqs.length > 0) {
                                        displayType = itemReqs[0].status.includes('Return') ? 'Item Return' : 'Item Cancellation';
                                        }
                                        %>
                                        <div class="request-item">
                                            <span
                                                class="request-type-badge <%= (displayType.includes('Return')) ? 'badge-return' : 'badge-cancel' %>">
                                                <%= displayType %> Request
                                            </span>
                                            <div style="font-weight: 800; font-size: 12px; color:#111;">
                                                <%= req.userId?.Name || 'User' %>
                                            </div>
                                            <div style="font-size: 10px; color: #000000;">Order #<%= req.orderId %>
                                            </div>

                                            <% if (itemReqs.length> 0 && !(isR || isC)) { %>
                                                <div style="font-size: 9px; color: #000000; font-weight: 700;">
                                                    Items: <%= itemReqs.map(i=> i.name).join(', ') %>
                                                </div>
                                                <% } %>

                                                    <div class="request-reason">
                                                        "<%= req.returnReason || req.cancellationReason || itemReqs[0]?.returnReason || itemReqs[0]?.cancellationReason || 'No reason' %>"
                                                    </div>

                                                    <div class="request-btns text-center mt-2">
                                                        <a href="/admin/orders/details?id=<%= req._id %>"
                                                            class="btn btn-sm btn-dark w-100 py-1"
                                                            style="font-size: 10px; font-weight: 800;">
                                                           View
                                                        </a>
                                                    </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <div class="empty-state">
                                                    <i class="bi bi-check2-circle empty-icon" style="color:#10b981"></i>
                                                    <div class="empty-title">All caught up!</div>
                                                    <div class="empty-subtitle">No incoming return or cancellation
                                                        requests</div>
                                                </div>
                                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats Row -->
                <div class="stat-grid">
                    <div class="stat-card">
                        <span class="stat-card-title">Total Revenue</span>
                        <div class="stat-card-val">₹<%= stats.totalRevenue %>
                        </div>
                    </div>
                    <div class="stat-card">
                        <span class="stat-card-title">Total Orders</span>
                        <div class="stat-card-val">+<%= stats.totalOrders %>
                        </div>
                       
                       
                    </div>
                    <div class="stat-card">
                        <span class="stat-card-title">Pending Fulfillment</span>
                        <div class="stat-card-val">
                            <%= stats.pendingOrders %>
                        </div>
                        
                    </div>
                    <div class="stat-card">
                        <span class="stat-card-title">Return/Cancel Rate</span>
                        <div class="stat-card-val">
                            <%= stats.returns %>
                    </div>
                    </div>
                </div>

                <!-- Orders Table Card -->
                <div class="orders-card">
                    <div class="card-header">
                        <form action="/admin/orders" method="GET" class="search-area-wrapper">
                            <div class="search-pill">
                                <i class="bi bi-search"></i>
                                <input type="text" name="search" id="searchInput" class="search-pill-input"
                                    placeholder="Search by ID or name..." value="<%= search %>" style="height:38px;">
                                <i class="bi bi-x search-clear-btn" id="clearBtn" title="Clear Search"></i>
                            </div>
                            <button type="submit" class="search-btn">Search Orders</button>
                        </form>
                    </div>

                    <div class="table-area">
                        <table class="orders-table">
                            <thead>
                                <tr>

                                    <th width="8%">SI.NO</th>
                                    <th width="16%">Order ID</th>
                                    <th width="28%">Customer Info</th>
                                    <th width="12%">Order Date</th>
                                    <th width="10%">Method</th>
                                    <th width="18%">Current Status</th>
                                    <th width="12%">Final Price</th>
                                    <th width="4%">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (orders && orders.length> 0) { %>
                                    <% orders.forEach((order, ind)=> { %>

                                        <tr>

                                            <td>
                                                <%= (page - 1) * limit + (ind + 1) %>
                                            </td>
                                            <td style="font-weight: 800; color:#111;">#<%= order.orderId %>
                                            </td>
                                            <td class="user-td">
                                                <div class="user-cell">
                                                    <% if (order.userId && order.userId.Profile_image) { %>
                                                        <img src="<%= order.userId.Profile_image %>" class="user-avatar"
                                                            alt="">
                                                        <% } else { %>
                                                            <div class="user-avatar-init">
                                                                <%= order.userId ? order.userId.Name.charAt(0).toUpperCase() : 'U' %>
                                                            </div>
                                                            <% } %>
                                                                <div class="user-meta">
                                                                    <span class="name">
                                                                        <%= order.userId ? order.userId.Name.split(' ')[0] : ' Guest' %>
                                                                    </span>
                                                                    <span class="email">
                                                                        <%= order.userId ? order.userId.Email : '—' %>
                                                                    </span>
                                                                </div>
                                                </div>
                                            </td>
                                            <td style="font-weight: 800; color: #111;">
                                                <%= new Date(order.createdAt).toLocaleDateString('en-US', { month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                            </td>
                                            <td
                                                style="color:var(--text-secondary); font-size:11px; font-weight:800; text-transform:uppercase;">
                                                <%= order.paymentMethod %>
                                            </td>
                                            <td>
                                                <% 
                                                const sRaw = order.orderStatus.toLowerCase();
                                                    let tCol = '#ffc107'; 
                                                                                                
                                                    if (sRaw.includes('pending')) { 
                                                        tCol = '#f97316'; 
                                                    } 
                                                    else if (sRaw.includes('processing')) { 
                                                        tCol = '#ffc107';
                                                    } 
                                                    else if (sRaw.includes('shipped')) { 
                                                        tCol = '#0ea5e9'; 
                                                    } 
                                                    else if (sRaw.includes('delivered')) { 
                                                        tCol = '#22c55e'; 
                                                    }
                                                    else if (sRaw.includes('cancelled')) { 
                                                        tCol = '#ef4444'; 
                                                    } 
                                                    else if (sRaw.includes('returned')) { 
                                                        tCol = '#f59e0b'; 
                                                    } 
                                                    %>
                                                    <span class="status-tag"
                                                        style="background-color: <%= tCol %>20; color: <%= tCol %>; border: 1px solid <%= tCol %>40;">
                                                        <%= order.orderStatus %>
                                                    </span>
                                            </td>
                                            <td style="font-weight: 800; font-size: 14px; color:#111;">
                                                ₹<%= (order.finalPrice || 0).toLocaleString('en-IN') %>
                                            </td>
                                            <td>
                                                <a href="/admin/orders/details?id=<%= order._id %>" class="view-btn">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr class="table-empty-row">
                                                    <td colspan="7">
                                                        <div class="empty-state">
                                                            <i class="bi bi-box-seam empty-icon"></i>
                                                            <div class="empty-title">No orders found yet</div>
                                                            <div class="empty-subtitle">Your store hasn't received any
                                                                orders matching your criteria</div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <div class="table-footer">
                        <div class="showing-info">
                            Showing <%= totalOrdersCount===0 ? 0 : ((page - 1) * limit) + 1 %>-<%= Math.min(page * limit, totalOrdersCount) %> of <%= totalOrdersCount %>
                        </div>

                        <% if (totalPages> 1) { %>
                            <div class="pag-nav-group">
                                <a href="/admin/orders?page=<%= page - 1 %>&search=<%= search %>"
                                    class="p-nav-link <%= page === 1 ? 'disabled' : '' %>">
                                    <i class="bi bi-chevron-left"></i> Previous
                                </a>
                                <% for(let i=Math.max(1, page-2); i <=Math.min(totalPages, page+2); i++) { %>
                                    <a href="/admin/orders?page=<%= i %>&search=<%= search %>"
                                        class="p-num <%= page === i ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>
                                        <a href="/admin/orders?page=<%= page + 1 %>&search=<%= search %>"
                                            class="p-nav-link <%= page >= totalPages ? 'disabled' : '' %>">
                                            Next <i class="bi bi-chevron-right"></i>
                                        </a>
                            </div>
                            <% } %>
                    </div>
                </div><!-- end main-content -->
        </main><!-- end admin-main -->


        <script>
            const bell = document.getElementById('bellToggle');
            const dropdown = document.getElementById('requestsDropdown');
            if (bell) {
                bell.onclick = (e) => { e.stopPropagation(); dropdown.classList.toggle('show'); };
            }
            window.onclick = () => dropdown.classList.remove('show');

            // Search Input Functionality
            const searchInput = document.getElementById('searchInput');
            const clearBtn = document.getElementById('clearBtn');

            if (clearBtn) {
                clearBtn.onclick = () => {
                    window.location.href = '/admin/orders';
                };
            }

            if (searchInput) {
                // Ensure clear button visibility on load if search exists
                if (searchInput.value.length > 0) {
                    clearBtn.style.display = 'block';
                }
                searchInput.oninput = () => {
                    clearBtn.style.display = searchInput.value.length > 0 ? 'block' : 'none';
                };
            }

            function handleRequest(orderId, action) {
                const url = action === 'accept' ? '/admin/orders/accept-return' : '/admin/orders/decline-return';
                Swal.fire({
                    title: 'Confirm Operation',
                    text: `${action.charAt(0).toUpperCase() + action.slice(1)} this request permanently?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: action === 'accept' ? '#10b981' : '#ef4444',
                    confirmButtonText: 'Yes, proceed'
                }).then((res) => {
                    if (res.isConfirmed) {
                        fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ orderId }) })
                            .then(r => r.json()).then(d => {
                                if (d.success) location.reload();
                                else Swal.fire('Error', d.message, 'error');
                            });
                    }
                });
            }
        </script>
</body>

</html>