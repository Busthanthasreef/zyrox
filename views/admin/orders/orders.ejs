<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders Management | Zyrox Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <link rel="stylesheet" href="/adminStyles/orders/orders.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --bg: #f5f6fa;
            --surface: #ffffff;
            --surface2: #f0f0f0;
            --border: #e8eaf0;
            --accent: #4f6ef7;
            --accent-soft: rgba(79, 110, 247, 0.12);
            --accent-glow: rgba(79, 110, 247, 0.3);
            --text-primary: #1e293b;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --white: #ffffff;
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
            --info: #0ea5e9;
            --orange: #f97316;
            --radius: 14px;
            --radius-sm: 8px;
            --skeleton: #e2e8f0;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            min-height: 100vh;
        }

        .d-flex {
            display: flex;
        }

        .main-content {
            flex: 1;
            padding: 20px 28px;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        .top-section {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
            flex-shrink: 0;
        }

        .page-title {
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 22px;
            color: var(--text-primary);
        }

        /* ── Bell ── */
        .bell-container {
            position: relative;
        }

        .bell-icon {
            width: 38px;
            height: 38px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 16px;
            color: var(--text-secondary);
            transition: border-color 0.2s, color 0.2s;
            position: relative;
        }

        .bell-icon:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .bell-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            background: var(--danger);
            color: #fff;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            font-size: 10px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--surface);
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.3);
        }

        /* ── Requests Dropdown ── */
        .requests-dropdown {
            position: absolute;
            top: 46px;
            right: 0;
            width: 340px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
            z-index: 1000;
            display: none;
            overflow: hidden;
            backdrop-filter: blur(10px);
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .requests-dropdown.show {
            display: block;
        }

        .dropdown-header {
            padding: 13px 16px;
            border-bottom: 1px solid var(--border);
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 12px;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .request-list {
            max-height: 380px;
            overflow-y: auto;
        }

        .request-item {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
        }

        .request-type-badge {
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 3px 7px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 6px;
        }

        .badge-return {
            background: rgba(245, 158, 11, 0.15);
            color: #f59e0b;
        }

        .badge-cancel {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        .request-reason {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 6px;
            line-height: 1.5;
            font-style: italic;
        }

        .request-btns .btn.btn-sm.btn-dark {
            background: var(--accent-soft) !important;
            border: 1px solid var(--accent) !important;
            color: var(--accent) !important;
            font-size: 10px !important;
            font-weight: 800 !important;
            border-radius: var(--radius-sm) !important;
            letter-spacing: 0.5px;
            transition: background 0.2s, color 0.2s;
        }

        .request-btns .btn.btn-sm.btn-dark:hover {
            background: var(--accent) !important;
            color: #fff !important;
        }

        .empty-state {
            padding: 40px 20px;
            text-align: center;
        }

        .empty-icon {
            font-size: 32px;
            display: block;
            margin-bottom: 10px;
            opacity: 0.25;
        }

        .empty-title {
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .empty-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* ── Stat Grid ── */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin-bottom: 16px;
            flex-shrink: 0;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 12px 16px;
            position: relative;
            overflow: hidden;
            transition: transform 0.2s, border-color 0.2s;
            cursor: pointer;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            border-color: var(--accent);
        }

        .stat-card-title {
            display: block;
            font-size: 10px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 6px;
        }

        .stat-card-val {
            font-family: 'Inter', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.1;
            margin-bottom: 4px;
        }

        .stat-card-growth {
            font-size: 10px;
            font-weight: 600;
        }

        .stat-card-growth.pos {
            color: var(--success);
        }

        .stat-card-growth.neg {
            color: var(--danger);
        }

        .stat-card-growth.neu {
            color: var(--text-muted);
        }

        /* FIX #6: Added missing .warning class */
        .stat-card-growth.warning {
            color: var(--warning);
        }

        .stat-card-icon {
            position: absolute;
            right: 12px;
            bottom: 10px;
            font-size: 28px;
            opacity: 0.06;
            color: var(--accent);
        }

        /* ── Orders Card ── */
        .orders-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        .card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
            background: transparent;
            flex-wrap: wrap;
            gap: 10px;
            flex-shrink: 0;
        }

        .table-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 18px;
            border-top: 1px solid var(--border);
            background: transparent;
            flex-wrap: wrap;
            gap: 12px;
            flex-shrink: 0;
        }

        /* ── Search Area ── */
        .search-area-wrapper {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
            flex: 1;
            justify-content: flex-end;
            min-width: 0;
        }

        .search-pill {
            position: relative;
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }

        .search-pill>.bi-search {
            position: absolute;
            left: 10px;
            font-size: 12px;
            color: var(--text-muted);
            pointer-events: none;
        }

        .search-pill-input {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--text-primary);
            font-size: 12px;
            font-family: 'Inter', sans-serif;
            padding: 6px 28px 6px 28px;
            width: 200px;
            min-width: 180px;
            height: 32px;
            outline: none;
            transition: border-color 0.2s;
        }

        .search-pill-input:focus {
            border-color: var(--accent);
        }

        .search-pill-input::placeholder {
            color: var(--text-muted);
        }

        .search-clear-btn {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            display: none;
            transition: color 0.15s;
        }

        .search-clear-btn:hover {
            color: var(--text-primary);
        }

        .status-filter-select {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--text-primary);
            font-size: 12px;
            font-family: 'Inter', sans-serif;
            padding: 6px 10px;
            height: 32px;
            outline: none;
            cursor: pointer;
            transition: border-color 0.2s;
            min-width: 120px;
            max-width: 160px;
            flex-shrink: 0;
        }

        .status-filter-select:focus {
            border-color: var(--accent);
        }

        /* ── Table Area ── */
        .table-area {
            flex: 1;
            overflow-x: auto;
            overflow-y: auto;
            min-height: 0;
            position: relative;
        }

        .orders-table {
            width: 100%;
            border-collapse: collapse;
        }

        .orders-table thead tr {
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
        }

        .orders-table th {
            padding: 13px 16px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-muted);
            white-space: nowrap;
            text-align: left;
        }

        /* FIX #2: Sticky header needs proper thead context */
        .orders-table thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background: var(--surface2);
            box-shadow: 0 1px 0 var(--border);
        }

        .orders-table tbody tr {
            border-bottom: 2px solid #000000;
            transition: background 0.15s;
            cursor: pointer;
        }

        .orders-table tbody tr:last-child {
            border-bottom: 2px solid #000000;
        }

        .orders-table tbody tr:hover {
            background: var(--bg) !important;
        }

        .orders-table td {
            padding: 14px 16px;
            font-size: 13px;
            color: var(--text-secondary);
            vertical-align: middle;
        }

        .orders-table td:first-child {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
        }

        .orders-table td:nth-child(2) {
            font-family: 'Inter', sans-serif;
            font-weight: 700 !important;
            color: var(--accent) !important;
        }

        .orders-table td:nth-child(4) {
            font-weight: 600 !important;
            color: var(--text-secondary) !important;
            font-size: 12px !important;
        }

        .orders-table td:nth-child(5) {
            color: var(--text-muted) !important;
            font-size: 11px !important;
            font-weight: 700 !important;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .orders-table td:nth-child(8) {
            font-family: 'Inter', sans-serif;
            font-weight: 700 !important;
            font-size: 14px !important;
            color: var(--text-primary) !important;
        }

        .name {
            font-weight: 600;
            font-size: 13px;
            color: var(--text-primary);
        }

        .email {
            font-size: 11px;
            color: var(--text-muted);
        }

        .user-td {
            min-width: 200px;
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--border);
        }

        .user-avatar-init {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--accent-soft);
            border: 2px solid var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: var(--accent);
            font-family: 'Inter', sans-serif;
            flex-shrink: 0;
        }

        .user-meta {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        /* ── Status Tags ── */
        .status-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            white-space: nowrap;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .status-tag:hover {
            transform: scale(1.05);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .status-tag-no-border {
            border: none !important;
        }

        /* ── View Button ── */
        .view-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--text-secondary);
            font-size: 11px;
            font-weight: 600;
            padding: 6px 12px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .view-btn:hover {
            background: var(--accent-soft);
            border-color: var(--accent);
            color: var(--accent);
        }

        /* ── Pagination ── */
        .showing-info {
            font-size: 12px;
            color: black;
        }

        .pag-nav-group {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .p-nav-link,
        .p-num {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 12px;
            border-radius: var(--radius-sm);
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            background: var(--surface2);
            border: 1px solid var(--border);
            text-decoration: none;
            transition: all 0.2s;
        }

        .p-nav-link:hover:not(.disabled),
        .p-num:hover:not(.active) {
            border-color: var(--accent);
            color: var(--accent);
        }

        .p-num.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        .p-nav-link.disabled {
            opacity: 0.35;
            pointer-events: none;
        }

        /* ── Empty Table Row ── */
        .table-empty-row td {
            text-align: center;
            padding: 60px 0;
        }

        .table-empty-row .empty-state {
            display: inline-block;
        }

        .table-empty-row .empty-icon {
            font-size: 36px;
            opacity: 0.25;
            margin-bottom: 12px;
        }

        .table-empty-row .empty-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 4px;
            font-family: 'Inter', sans-serif;
        }

        .table-empty-row .empty-subtitle {
            font-size: 13px;
            color: var(--text-muted);
        }

        /* ── Breadcrumbs ── */
        .breadcrumb-nav {
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .breadcrumb-nav a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.2s;
        }

        .breadcrumb-nav a:hover {
            color: var(--accent);
        }

        .breadcrumb-nav .separator {
            opacity: 0.5;
        }

        .breadcrumb-nav .current {
            color: var(--text-primary);
            font-weight: 600;
        }

        /* ── Column Sorting ── */
        .sortable-th {
            cursor: pointer;
            user-select: none;
            transition: color 0.2s;
        }

        .sortable-th:hover {
            color: var(--accent) !important;
        }

        .sort-indicator {
            margin-left: 4px;
            opacity: 0.3;
            font-size: 10px;
        }

        .sortable-th.active-sort {
            color: var(--accent) !important;
        }

        .sortable-th.active-sort .sort-indicator {
            opacity: 1;
        }

        /* ── Filter Chips ── */
        .filter-chips-wrapper {
            display: none;
            align-items: center;
            gap: 8px;
            padding: 12px 20px;
            flex-wrap: wrap;
            border-bottom: 1px solid var(--border);
            background: var(--bg);
            min-height: 0;
        }

        .filter-chips-wrapper:not(:empty) {
            display: flex;
        }

        .filter-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--accent-soft);
            color: var(--accent);
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 600;
            border: 1px solid var(--accent-glow);
        }

        .filter-chip .remove-chip {
            cursor: pointer;
            opacity: 0.6;
            transition: opacity 0.2s;
            font-size: 14px;
            line-height: 1;
        }

        .filter-chip .remove-chip:hover {
            opacity: 1;
        }

        .clear-all-filters {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            cursor: pointer;
            margin-left: 4px;
            transition: color 0.2s;
            text-decoration: underline;
            text-underline-offset: 2px;
        }

        .clear-all-filters:hover {
            color: var(--danger);
        }

        /* ── Loading Overlay ── */
        .table-loading-overlay {
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100;
            backdrop-filter: blur(1px);
        }

        .table-loading-overlay.active {
            display: flex;
        }

        /* ── Skeleton ── */
        .skeleton {
            background-color: var(--skeleton);
            background-image: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0));
            background-size: 200px 100%;
            background-repeat: no-repeat;
            display: inline-block;
            border-radius: 4px;
            animation: skeleton-loading 1.5s infinite linear;
        }

        @keyframes skeleton-loading {
            0% {
                background-position: -200px 0;
            }

            100% {
                background-position: calc(200px + 100%) 0;
            }
        }

        /* ── Tooltips ── */
        [data-tooltip] {
            position: relative;
        }

        [data-tooltip]::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%) translateY(-5px);
            background: #334155;
            color: #fff;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 10px;
            white-space: nowrap;
            opacity: 0;
            visibility: hidden;
            transition: all 0.2s;
            z-index: 1000;
        }

        [data-tooltip]:hover::after {
            opacity: 1;
            visibility: visible;
        }

        /* ── Pagination Controls ── */
        .pagination-controls {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .go-to-page {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 600;
        }

        .go-to-page input {
            width: 40px;
            height: 28px;
            text-align: center;
            border: 1px solid var(--border);
            border-radius: 4px;
            background: var(--surface2);
            outline: none;
        }

        /* ── Micro-animations ── */
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out backwards;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .searching-indicator {
            display: none;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: var(--accent);
            font-weight: 600;
            margin-left: 10px;
        }

        .searching-indicator.active {
            display: flex;
        }

        .spinner-sm {
            width: 12px;
            height: 12px;
            border: 2px solid var(--accent-soft);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── Responsive ── */
        @media (max-width: 1400px) {
            .search-area-wrapper {
                width: 100%;
                justify-content: flex-start;
            }
            
            .status-filter-select {
                min-width: 120px;
                max-width: 150px;
            }
            
            .search-pill-input {
                width: 200px;
                min-width: 180px;
            }
        }

        @media (max-width: 768px) {
            .orders-table thead {
                display: none;
            }

            .orders-table tbody tr {
                display: block;
                padding: 16px;
                border: 1px solid var(--border);
                border-radius: var(--radius);
                margin-bottom: 16px;
                background: var(--surface);
            }

            .orders-table td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 8px 0;
                text-align: right;
                border-bottom: 1px solid var(--bg);
            }

            .orders-table td:last-child {
                border-bottom: none;
                justify-content: center;
                padding-top: 12px;
            }

            .orders-table td::before {
                content: attr(data-label);
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                color: var(--text-muted);
                text-align: left;
            }

            .orders-card {
                background: transparent;
                border: none;
                overflow: visible;
            }

            .stat-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .main-content {
                padding: 16px;
                height: auto;
                overflow: visible;
            }

            .table-area {
                overflow: visible;
            }
        }
    </style>
</head>

<body class="admin-body">
    <%- include('../../partials/admin/sidebar', { currentPage: 'orders' , currentUser: user }) %>

        <main class="admin-main">
            <div class="main-content">

                <!-- Breadcrumbs -->
                <nav class="breadcrumb-nav">
                    <a href="/adminUser/dashboard">Dashboard</a>
                    <span class="separator"><i class="bi bi-chevron-right"></i></span>
                    <span class="current">Orders</span>
                </nav>

                <!-- Page Header -->
                <div class="top-section">
                    <h1 class="page-title">Orders</h1>
                    <div class="bell-container">
                        <div class="bell-icon" id="bellToggle">
                            <i class="bi bi-bell"></i>
                            <% if (returnRequests.length> 0) { %>
                                <span class="bell-badge">
                                    <%= returnRequests.length %>
                                </span>
                                <% } %>
                        </div>

                        <div class="requests-dropdown" id="requestsDropdown">
                            <div class="dropdown-header">Inbox &amp; Requests</div>
                            <div class="request-list">
                                <% if (returnRequests && returnRequests.length> 0) { %>
                                    <% returnRequests.forEach(req=> {
                                        const isR = req.orderStatus === 'Return Requested';
                                        const isC = req.orderStatus === 'Cancellation Requested';
                                        const itemReqs = req.items.filter(i => ['Return Requested', 'Cancellation Requested'].includes(i.status));
                                        let displayType = 'Request';
                                        if (isR || isC) {
                                        displayType = isR ? 'Return' : 'Cancellation';
                                        } else if (itemReqs.length > 0) {
                                        displayType = itemReqs[0].status.includes('Return') ? 'Item Return' : 'Item Cancellation';
                                        }
                                        %>
                                        <div class="request-item">
                                            <span
                                                class="request-type-badge <%= (displayType.includes('Return')) ? 'badge-return' : 'badge-cancel' %>">
                                                <%= displayType %> Request
                                            </span>
                                            <div style="font-weight: 800; font-size: 12px; color:#111;">
                                                <%= req.userId?.Name || 'User' %>
                                            </div>
                                            <div style="font-size: 10px; color: #000000;">Order #<%= req.orderId %>
                                            </div>

                                            <% if (itemReqs.length> 0 && !(isR || isC)) { %>
                                                <div style="font-size: 9px; color: #000000; font-weight: 700;">
                                                    Items: <%= itemReqs.map(i=> i.name).join(', ') %>
                                                </div>
                                                <% } %>

                                                    <div class="request-reason">
                                                        "<%= req.returnReason || req.cancellationReason ||itemReqs[0]?.returnReason || itemReqs[0]?.cancellationReason || 'No reason' %>"
                                                    </div>

                                                    <div class="request-btns text-center mt-2">
                                                        <a href="/adminUser/orders/details?id=<%= req._id %>"
                                                            class="btn btn-sm btn-dark w-100 py-1"
                                                            style="font-size: 10px; font-weight: 800;">
                                                            View
                                                        </a>
                                                    </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <div class="empty-state">
                                                    <i class="bi bi-check2-circle empty-icon" style="color:#10b981"></i>
                                                    <div class="empty-title">All caught up!</div>
                                                    <div class="empty-subtitle">No incoming return or cancellation
                                                        requests</div>
                                                </div>
                                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats Row -->
                <div class="stat-grid">
                    <div class="stat-card animate-fade-in" style="animation-delay: 0.1s"
                        onclick="applyQuickFilter('status', 'Delivered')" data-tooltip="Click to see delivered orders">
                        <span class="stat-card-title">Total Revenue</span>
                        <div class="stat-card-val">₹<%= stats.totalRevenue %>
                        </div>
                        <span class="stat-card-growth pos"><i class="bi bi-arrow-up"></i> Collected</span>
                        <i class="bi bi-currency-rupee stat-card-icon"></i>
                    </div>
                    <div class="stat-card animate-fade-in" style="animation-delay: 0.2s"
                        onclick="applyQuickFilter('status', '')" data-tooltip="Click to see all orders">
                        <span class="stat-card-title">Total Orders</span>
                        <div class="stat-card-val">
                            <%= stats.totalOrders %>
                        </div>
                        <span class="stat-card-growth neu">Lifetime</span>
                        <i class="bi bi-bag-check stat-card-icon"></i>
                    </div>
                    <div class="stat-card animate-fade-in" style="animation-delay: 0.3s"
                        onclick="applyQuickFilter('status', 'Pending')" data-tooltip="Click to see pending orders">
                        <span class="stat-card-title">Pending Fulfillment</span>
                        <div class="stat-card-val">
                            <%= stats.pendingOrders %>
                        </div>
                        <span class="stat-card-growth neg">Requires Action</span>
                        <i class="bi bi-clock-history stat-card-icon"></i>
                    </div>
                    <div class="stat-card animate-fade-in" style="animation-delay: 0.4s"
                        onclick="applyQuickFilter('status', 'Return Requested')"
                        data-tooltip="Click to see return requests">
                        <span class="stat-card-title">Return/Cancel Requests</span>
                        <div class="stat-card-val">
                            <%= stats.returns %>
                        </div>
                        <!-- FIX #6: was 'warning' class — now defined in CSS -->
                        <span class="stat-card-growth warning">In Progress</span>
                        <i class="bi bi-arrow-left-right stat-card-icon"></i>
                    </div>
                </div>

                <!-- Orders Table Card -->
                <div class="orders-card animate-fade-in" style="animation-delay: 0.5s">
                    <div class="card-header">
                        <h3 style="font-size: 16px; font-weight: 700; color: var(--text-primary); margin: 0; flex-shrink: 0; align-self: center;">Recent
                            Orders</h3>
                        <div class="search-area-wrapper">
                            <select id="sortFilter" class="status-filter-select" onchange="applySort(this.value)">
                                <option value="newest" <%=sort==='newest' ? 'selected' : '' %>>Newest First</option>
                                <option value="oldest" <%=sort==='oldest' ? 'selected' : '' %>>Oldest First</option>
                                <option value="priceHigh" <%=sort==='priceHigh' ? 'selected' : '' %>>Price: High to Low
                                </option>
                                <option value="priceLow" <%=sort==='priceLow' ? 'selected' : '' %>>Price: Low to High
                                </option>
                            </select>

                            <select id="statusFilter" class="status-filter-select">
                                <option value="">All Order Status</option>
                                <option value="Pending" <%=status==='Pending' ? 'selected' : '' %>>Pending</option>
                                <option value="Processing" <%=status==='Processing' ? 'selected' : '' %>>Processing
                                </option>
                                <option value="Shipped" <%=status==='Shipped' ? 'selected' : '' %>>Shipped</option>
                                <option value="Delivered" <%=status==='Delivered' ? 'selected' : '' %>>Delivered
                                </option>
                                <option value="Cancelled" <%=status==='Cancelled' ? 'selected' : '' %>>Cancelled
                                </option>
                                <option value="Returned" <%=status==='Returned' ? 'selected' : '' %>>Returned</option>
                                <option value="Return Requested" <%=status==='Return Requested' ? 'selected' : '' %>>Return Requested</option>
                                <option value="Failed" <%=status==='Failed' ? 'selected' : '' %>>Failed</option>
                            </select>

                            <select id="methodFilter" class="status-filter-select">
                                <option value="">All Methods</option>
                                <option value="COD" <%=paymentMethod==='COD' ? 'selected' : '' %>>COD</option>
                                <option value="Online" <%=paymentMethod==='Online' ? 'selected' : '' %>>Online</option>
                                <option value="Wallet" <%=paymentMethod==='Wallet' ? 'selected' : '' %>>Wallet</option>
                            </select>

                            <select id="paymentStatusFilter" class="status-filter-select">
                                <option value="">All Payment Status</option>
                                <option value="Pending" <%=paymentStatus==='Pending' ? 'selected' : '' %>>Pending
                                </option>
                                <option value="Paid" <%=paymentStatus==='Paid' ? 'selected' : '' %>>Paid</option>
                                <option value="Failed" <%=paymentStatus==='Failed' ? 'selected' : '' %>>Failed</option>
                                <option value="Refunded" <%=paymentStatus==='Refunded' ? 'selected' : '' %>>Refunded
                                </option>
                            </select>

                            <div class="search-pill">
                                <i class="bi bi-search"></i>
                                <input type="text" id="searchInput" class="search-pill-input"
                                    placeholder="Search by ID, name, or email..." value="<%= search %>"
                                    style="height:38px;">
                                <i class="bi bi-x search-clear-btn" id="clearBtn" title="Clear Search"></i>
                            </div>

                            <div class="searching-indicator" id="searchingIndicator">
                                <div class="spinner-sm"></div>
                                <span>Searching...</span>
                            </div>
                        </div>
                    </div>

                    <!-- Active Filter Chips -->
                    <div class="filter-chips-wrapper" id="filterChips"></div>

                    <div class="table-area" style="position: relative;">
                        <div class="table-loading-overlay" id="tableLoadingOverlay">
                            <div class="spinner-sm" style="width: 32px; height: 32px; border-width: 3px;"></div>
                        </div>

                        <table class="orders-table" id="ordersTable">
                            <!-- FIX #2: Proper thead opening/closing tags + tbody outside thead -->
                            <thead>
                                <tr>
                                    <th width="5%">SI.NO</th>
                                    <th width="15%" class="sortable-th" onclick="applySort('orderId')">
                                        Order ID <i class="bi bi-arrow-down-up sort-indicator"></i>
                                    </th>
                                    <th width="25%">Customer Info</th>
                                    <th width="15%" class="sortable-th" onclick="applySort('newest')">
                                        Order Date <i class="bi bi-arrow-down-up sort-indicator"></i>
                                    </th>
                                    <th width="10%">Method</th>
                                    <th width="10%">Payment</th>
                                    <th width="15%" class="sortable-th" onclick="applySort('status')">
                                        Current Status <i class="bi bi-arrow-down-up sort-indicator"></i>
                                    </th>
                                    <th>Total Amount</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <!-- FIX #2: tbody is now correctly outside thead -->
                            <tbody id="ordersTableBody">
                                <% if (orders && orders.length> 0) { %>
                                    <% orders.forEach((order, ind)=> { %>
                                        <tr onclick="navigateToOrder('<%= order._id %>')">
                                            <td data-label="SI.NO">
                                                <%= (page - 1) * limit + (ind + 1) %>
                                            </td>
                                            <td data-label="Order ID" style="font-weight: 800; color:var(--accent);">#
                                                <%= order.orderId %>
                                            </td>
                                            <td data-label="Customer Info" class="user-td">
                                                <div class="user-cell">
                                                    <% if (order.userId && order.userId.Profile_image) { %>
                                                        <img src="<%= order.userId.Profile_image %>" class="user-avatar"
                                                            alt="">
                                                        <% } else { %>
                                                            <div class="user-avatar-init">
                                                                <%= order.userId ? order.userId.Name.charAt(0).toUpperCase() : 'U' %>
                                                            </div>
                                                            <% } %>
                                                                <div class="user-meta">
                                                                    <span class="name">
                                                                        <%= order.userId ?
                                                                            order.userId.Name.split(' ')[0] : 'Guest'
                                                                            %>
                                                                    </span>
                                                                    <span class="email">
                                                                        <%= order.userId ? order.userId.Email : '—' %>
                                                                    </span>
                                                                </div>
                                                </div>
                                            </td>
                                            <td data-label="Order Date" style="font-weight: 600;">
                                                <%= new Date(order.createdAt).toLocaleDateString('en-US', {
                                                    month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                            </td>
                                            <td data-label="Method"
                                                style="font-size:11px; font-weight:800; text-transform:uppercase; color: var(--text-muted);">
                                                <%= order.paymentMethod %>
                                            </td>
                                            <td data-label="Payment">
                                                <% const pRaw=(order.paymentStatus || 'Pending' ).toLowerCase();
                                                 let pCol='#94a3b8' ; 
                                                    if (pRaw.includes('paid')) pCol='#22c55e' ;  
                                                    else if (pRaw.includes('pending')) pCol='#f97316' ;  
                                                    else if (pRaw.includes('failed')) pCol='#ef4444' ;  
                                                    else if (pRaw.includes('refunded')) pCol='#0ea5e9' ; %>
                                                    <span class="status-tag"
                                                        style="background-color: <%= pCol %>15; color: <%= pCol %>; border: 1px solid <%= pCol %>30;">
                                                        <%= order.paymentStatus === 'Refunded' ? 'FULLY REFUNDED' : order.paymentStatus %>
                                                    </span>
                                            </td>
                                            <td data-label="Current Status">
                                                <% const statusCounts={}; order.items.forEach(item=> {
                                                    statusCounts[item.status] = (statusCounts[item.status] || 0) + 1;
                                                    });
                                                    const sortedEntries = Object.entries(statusCounts).sort();
                                                    const isAllCancelled = sortedEntries.length === 1 &&
                                                    sortedEntries[0][0] === 'Cancelled';
                                                    %>
                                                    <div style="display: flex; flex-direction: column; gap: 6px; align-items: flex-start;">
                                                        <% if (isAllCancelled) { %>
                                                            <span class="status-tag status-tag-no-border"
                                                                style="color: #ef4444; background: rgba(239, 68, 68, 0.12); justify-content: center;">
                                                                Order Cancelled
                                                            </span>
                                                            <% } else { %>
                                                                <% sortedEntries.forEach(([status, count])=> {
                                                                    const sRaw = status.toLowerCase();
                                                                    let tCol = '#94a3b8';
                                                                    if (sRaw.includes('pending')) tCol = '#f97316';
                                                                    else if (sRaw.includes('processing')) tCol = '#eab308';
                                                                    else if (sRaw.includes('shipped')) tCol = '#0ea5e9';
                                                                    else if (sRaw.includes('delivered')) tCol = '#22c55e';
                                                                    else if (sRaw.includes('cancelled')) tCol = '#ef4444';
                                                                    else if (sRaw.includes('returned')) tCol = '#f59e0b';
                                                                    else if (sRaw.includes('failed')) tCol = '#ef4444';
                                                                    else if (sRaw.includes('request')) tCol = '#7c6ef5';
                                                                    else if (sRaw.includes('retry')) tCol = '#f97316';
                                                                    %>
                                                                    <span class="status-tag"
                                                                        style="background-color: <%= tCol %>15; color: <%= tCol %>; border: 1px solid <%= tCol %>30; font-size: 10px; padding: 4px 8px; border-radius: 20px;"
                                                                        onclick="event.stopPropagation(); applyQuickFilter('status', '<%= status %>')"
                                                                        data-tooltip="Filter by <%= status %>">
                                                                        <%= count %>x <%= status %>
                                                                    </span>
                                                                    <% }) %>
                                                                        <% } %>
                                                    </div>
                                            </td>
                                            <td data-label="Final Price" style="font-weight: 800; font-size: 14px;">
                                                ₹<%= (order.finalPrice || 0).toLocaleString('en-IN') %>
                                            </td>
                                            <td data-label="Action">
                                                <a href="/adminUser/orders/details?id=<%= order._id %>" class="view-btn"
                                                    onclick="event.stopPropagation()" data-tooltip="View Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr class="table-empty-row">
                                                    <td colspan="9">
                                                        <div class="empty-state">
                                                            <i class="bi bi-search empty-icon"
                                                                style="opacity: 0.5;"></i>
                                                            <div class="empty-title">No orders matching your criteria
                                                            </div>
                                                            <div class="empty-subtitle">We couldn't find any orders that
                                                                match your current search or filters.</div>
                                                            <% if (search || status) { %>
                                                                <a href="javascript:void(0)" onclick="clearAllFilters()"
                                                                    class="btn btn-sm btn-dark mt-3 px-4 py-2"
                                                                    style="border-radius: 8px; font-weight: 700; font-size: 13px;">
                                                                    <i class="bi bi-x-circle me-1"></i> Clear All
                                                                    Filters
                                                                </a>
                                                                <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <div class="table-footer">
                        <div class="pagination-controls">
                            <div class="showing-info" id="showingInfo">
                                Showing <%= totalOrdersCount===0 ? 0 : ((page - 1) * limit) + 1 %>–<%= Math.min(page *
                                        limit, totalOrdersCount) %> of <%= totalOrdersCount %>
                            </div>
                        </div>

                        <div class="pag-nav-group" id="paginationGroup">
                            <% if (totalPages> 1) { %>
                                <a href="javascript:void(0)" onclick="changePage(<%= page - 1 %>)"
                                    class="p-nav-link <%= page === 1 ? 'disabled' : '' %>">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                                <% for (let i=Math.max(1, page - 2); i <=Math.min(totalPages, page + 2); i++) { %>
                                    <a href="javascript:void(0)" onclick="changePage(<%= i %>)"
                                        class="p-num <%= page === i ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>
                                        <a href="javascript:void(0)" onclick="changePage(<%= page + 1 %>)"
                                            class="p-nav-link <%= page >= totalPages ? 'disabled' : '' %>">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                        <% } %>
                                            <div class="go-to-page">
                                                <span>Go to</span>
                                                <input type="number" id="goToPageInput" min="1" max="<%= totalPages %>"
                                                    value="<%= page %>">
                                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- end main-content -->
        </main><!-- end admin-main -->

        <script>
            // ── State Management ──────────────────────────────────────────────────
            let currentState = {
                page:' <%= page %>',
                search: '<%= search %>',
                status: '<%= status %>',
                paymentMethod: '<%= paymentMethod %>',
                paymentStatus: '<%= paymentStatus %>',
                sort: '<%= sort %>',
                limit: '<%= limit %>'
        };

            // ── Elements ──────────────────────────────────────────────────────────
            const tableBody = document.getElementById('ordersTableBody');
            const searchInput = document.getElementById('searchInput');
            const statusFilter = document.getElementById('statusFilter');
            const methodFilter = document.getElementById('methodFilter');
            const paymentStatusFilter = document.getElementById('paymentStatusFilter');
            const sortFilter = document.getElementById('sortFilter');
            const clearBtn = document.getElementById('clearBtn');
            const tableOverlay = document.getElementById('tableLoadingOverlay');
            const searchingIndicator = document.getElementById('searchingIndicator');
            const filterChips = document.getElementById('filterChips');
            const showingInfo = document.getElementById('showingInfo');
            const paginationGroup = document.getElementById('paginationGroup');

            // FIX #1: limitSelect removed — no such element in HTML.
            // FIX #3: Wire up goToPageInput on initial load
            const goToPageInput = document.getElementById('goToPageInput');
            if (goToPageInput) {
                goToPageInput.onchange = () => changePage(goToPageInput.value);
            }

            // ── Helpers ───────────────────────────────────────────────────────────
            function debounce(func, timeout = 800) {
                let timer;
                return (...args) => {
                    clearTimeout(timer);
                    timer = setTimeout(() => { func.apply(this, args); }, timeout);
                };
            }

            // ── Fetch Data via AJAX ───────────────────────────────────────────────
            async function fetchData(updateHistory = true) {
                tableOverlay.classList.add('active');
                if (currentState.search) searchingIndicator.classList.add('active');

                const params = new URLSearchParams(currentState);
                const url = `/adminUser/orders?${params.toString()}`;

                try {
                    const response = await fetch(url, {
                        headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const data = await response.json();

                    if (data.success) {
                        renderTable(data.orders, data.page, data.limit);
                        renderPagination(data);
                        updateChips();
                        if (updateHistory) {
                            window.history.pushState(currentState, '', url);
                        }
                    } else {
                        showError();
                    }
                } catch (err) {
                    console.error('Fetch error:', err);
                    showError();
                } finally {
                    tableOverlay.classList.remove('active');
                    searchingIndicator.classList.remove('active');
                }
            }

            // ── Render Table ──────────────────────────────────────────────────────
            function renderTable(orders, page, limit) {
                if (!orders || orders.length === 0) {
                    tableBody.innerHTML = `
                    <tr class="table-empty-row">
                        <td colspan="9">
                            <div class="empty-state">
                                <i class="bi bi-search empty-icon" style="opacity: 0.5;"></i>
                                <div class="empty-title">No orders found</div>
                                <div class="empty-subtitle">Try adjusting your filters or search terms</div>
                                <a href="javascript:void(0)" onclick="clearAllFilters()" class="btn btn-sm btn-dark mt-3 px-4 py-2" style="border-radius: 8px; font-weight: 700; font-size: 13px;">
                                    <i class="bi bi-x-circle me-1"></i> Clear All Filters
                                </a>
                            </div>
                        </td>
                    </tr>`;
                    return;
                }

                tableBody.innerHTML = orders.map((order, ind) => {
                    const pRaw = (order.paymentStatus || 'Pending').toLowerCase();
                    let pCol = '#94a3b8';
                    if (pRaw.includes('paid')) pCol = '#22c55e';
                    else if (pRaw.includes('pending')) pCol = '#f97316';
                    else if (pRaw.includes('failed')) pCol = '#ef4444';
                    else if (pRaw.includes('refunded')) pCol = '#0ea5e9';

                    // Build item status tags
                    const statusCounts = {};
                    (order.items || []).forEach(item => {
                        statusCounts[item.status] = (statusCounts[item.status] || 0) + 1;
                    });
                    const sortedEntries = Object.entries(statusCounts).sort();
                    const isAllCancelled = sortedEntries.length === 1 && sortedEntries[0][0] === 'Cancelled';

                    let statusTagsHtml = '';
                    if (isAllCancelled) {
                        statusTagsHtml = `<span class="status-tag status-tag-no-border" style="color:#ef4444; background:rgba(239,68,68,0.12);">Order Cancelled</span>`;
                    } else {
                        statusTagsHtml = sortedEntries.map(([status, count]) => {
                            const sRaw = status.toLowerCase();
                            let tCol = '#94a3b8';
                            if (sRaw.includes('pending')) tCol = '#f97316';
                            else if (sRaw.includes('processing')) tCol = '#eab308';
                            else if (sRaw.includes('shipped')) tCol = '#0ea5e9';
                            else if (sRaw.includes('delivered')) tCol = '#22c55e';
                            else if (sRaw.includes('cancelled')) tCol = '#ef4444';
                            else if (sRaw.includes('returned')) tCol = '#f59e0b';
                            else if (sRaw.includes('failed')) tCol = '#ef4444';
                            else if (sRaw.includes('request')) tCol = '#7c6ef5';
                            else if (sRaw.includes('retry')) tCol = '#f97316';
                            return `<span class="status-tag"
                            style="background-color:${tCol}15; color:${tCol}; border:1px solid ${tCol}30; font-size:10px; padding:3px 8px; border-radius:20px;"
                            onclick="event.stopPropagation(); applyQuickFilter('status','${status}')"
                            data-tooltip="Filter by ${status}">
                            ${count}x ${status}
                        </span>`;
                        }).join('');
                    }

                    return `
                    <tr onclick="navigateToOrder('${order._id}')" class="animate-fade-in">
                        <td data-label="SI.NO">${(page - 1) * limit + (ind + 1)}</td>
                        <td data-label="Order ID" style="font-weight:800; color:var(--accent);">#${order.orderId}</td>
                        <td data-label="Customer Info" class="user-td">
                            <div class="user-cell">
                                ${order.userId?.Profile_image
                            ? `<img src="${order.userId.Profile_image}" class="user-avatar" alt="">`
                            : `<div class="user-avatar-init">${(order.userId?.Name || 'U').charAt(0).toUpperCase()}</div>`
                        }
                                <div class="user-meta">
                                    <span class="name">${order.userId ? order.userId.Name.split(' ')[0] : 'Guest'}</span>
                                    <span class="email">${order.userId?.Email || '—'}</span>
                                </div>
                            </div>
                        </td>
                        <td data-label="Order Date" style="font-weight:600;">
                            ${new Date(order.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                        </td>
                        <td data-label="Method" style="font-size:11px; font-weight:800; text-transform:uppercase; color:var(--text-muted);">
                            ${order.paymentMethod}
                        </td>
                        <td data-label="Payment">
                            <span class="status-tag" style="background-color:${pCol}15; color:${pCol}; border:1px solid ${pCol}30;">
                                ${order.paymentStatus === 'Refunded' ? 'FULLY REFUNDED' : order.paymentStatus}
                            </span>
                        </td>
                        <td data-label="Current Status">
                            <div style="display: flex; flex-direction: column; gap: 6px; align-items: flex-start;">
                                ${statusTagsHtml}
                            </div>
                        </td>
                        <td data-label="Final Price" style="font-weight:800; font-size:14px;">
                            ₹${(order.finalPrice || 0).toLocaleString('en-IN')}
                        </td>
                        <td data-label="Action">
                            <a href="/adminUser/orders/details?id=${order._id}" class="view-btn" onclick="event.stopPropagation()" data-tooltip="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>`;
                }).join('');
            }

            // ── Render Pagination ─────────────────────────────────────────────────
            function renderPagination(data) {
                const { page, totalPages, totalOrdersCount, limit } = data;
                showingInfo.innerHTML = `Showing ${totalOrdersCount === 0 ? 0 : ((page - 1) * limit) + 1}–${Math.min(page * limit, totalOrdersCount)} of ${totalOrdersCount}`;

                if (totalPages <= 1) {
                    paginationGroup.style.display = 'none';
                    return;
                }
                paginationGroup.style.display = 'flex';

                let html = `<a href="javascript:void(0)" onclick="changePage(${page - 1})" class="p-nav-link ${page === 1 ? 'disabled' : ''}"><i class="bi bi-chevron-left"></i></a>`;

                for (let i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) {
                    html += `<a href="javascript:void(0)" onclick="changePage(${i})" class="p-num ${page === i ? 'active' : ''}">${i}</a>`;
                }

                // FIX #3: goToPageInput wired inline here for dynamically rendered pagination
                html += `
                <a href="javascript:void(0)" onclick="changePage(${page + 1})" class="p-nav-link ${page >= totalPages ? 'disabled' : ''}"><i class="bi bi-chevron-right"></i></a>
                <div class="go-to-page">
                    <span>Go to</span>
                    <input type="number" id="goToPageInput" min="1" max="${totalPages}" value="${page}" onchange="changePage(this.value)">
                </div>`;

                paginationGroup.innerHTML = html;
            }

            // ── Update Filter Chips ───────────────────────────────────────────────
            function updateChips() {
                let chipsHtml = '';
                if (currentState.status) {
                    chipsHtml += `<div class="filter-chip">Status: ${currentState.status}<i class="bi bi-x remove-chip" onclick="applyQuickFilter('status', '')"></i></div>`;
                }
                if (currentState.search) {
                    chipsHtml += `<div class="filter-chip">Search: "${currentState.search}"<i class="bi bi-x remove-chip" onclick="applyQuickFilter('search', '')"></i></div>`;
                }
                if (currentState.paymentMethod) {
                    chipsHtml += `<div class="filter-chip">Method: ${currentState.paymentMethod}<i class="bi bi-x remove-chip" onclick="applyQuickFilter('paymentMethod', '')"></i></div>`;
                }
                if (currentState.paymentStatus) {
                    chipsHtml += `<div class="filter-chip">Payment: ${currentState.paymentStatus}<i class="bi bi-x remove-chip" onclick="applyQuickFilter('paymentStatus', '')"></i></div>`;
                }
                if (currentState.sort !== 'newest') {
                    chipsHtml += `<div class="filter-chip">Sort: ${currentState.sort}<i class="bi bi-x remove-chip" onclick="applySort('newest')"></i></div>`;
                }
                if (chipsHtml) {
                    chipsHtml += `<span class="clear-all-filters" onclick="clearAllFilters()">Clear All</span>`;
                }
                filterChips.innerHTML = chipsHtml;
            }

            // ── Event Handlers ────────────────────────────────────────────────────
            const debouncedSearch = debounce((val) => {
                currentState.search = val;
                currentState.page = 1;
                const params = new URLSearchParams(currentState);
                window.location.href = `/adminUser/orders?${params.toString()}`;
            });

            searchInput.oninput = (e) => {
                const val = e.target.value;
                clearBtn.style.display = val.length > 0 ? 'block' : 'none';
                debouncedSearch(val);
            };

            clearBtn.onclick = () => {
                searchInput.value = '';
                clearBtn.style.display = 'none';
                currentState.search = '';
                currentState.page = 1;
                window.location.href = '/adminUser/orders';
            };

            statusFilter.onchange = (e) => {
                currentState.status = e.target.value;
                currentState.page = 1;
                const params = new URLSearchParams(currentState);
                window.location.href = `/adminUser/orders?${params.toString()}`;
            };

            methodFilter.onchange = (e) => {
                currentState.paymentMethod = e.target.value;
                currentState.page = 1;
                const params = new URLSearchParams(currentState);
                window.location.href = `/adminUser/orders?${params.toString()}`;
            };

            paymentStatusFilter.onchange = (e) => {
                currentState.paymentStatus = e.target.value;
                currentState.page = 1;
                const params = new URLSearchParams(currentState);
                window.location.href = `/adminUser/orders?${params.toString()}`;
            };

            // FIX #1: limitSelect.onchange removed — element doesn't exist in HTML

            function applyQuickFilter(key, val) {
                currentState[key] = val;
                currentState.page = 1;
                if (key === 'status') statusFilter.value = val;
                if (key === 'paymentMethod') methodFilter.value = val;
                if (key === 'paymentStatus') paymentStatusFilter.value = val;
                if (key === 'search') {
                    searchInput.value = val;
                    clearBtn.style.display = val ? 'block' : 'none';
                }
                const params = new URLSearchParams(currentState);
                window.location.href = `/adminUser/orders?${params.toString()}`;
            }

            function applySort(sortType) {
                currentState.sort = sortType;
                currentState.page = 1;
                sortFilter.value = sortType;
                const params = new URLSearchParams(currentState);
                window.location.href = `/adminUser/orders?${params.toString()}`;
            }

            function changePage(p) {
                if (!p || p < 1) return;
                currentState.page = parseInt(p);
                const params = new URLSearchParams(currentState);
                window.location.href = `/adminUser/orders?${params.toString()}`;
            }

            function clearAllFilters() {
                currentState = {
                    page: 1,
                    search: '',
                    status: '',
                    paymentMethod: '',
                    paymentStatus: '',
                    sort: 'newest',
                    limit: currentState.limit
                };
                searchInput.value = '';
                clearBtn.style.display = 'none';
                statusFilter.value = '';
                methodFilter.value = '';
                paymentStatusFilter.value = '';
                sortFilter.value = 'newest';
                window.location.href = '/adminUser/orders';
            }

            function navigateToOrder(id) {
                window.location.href = `/adminUser/orders/details?id=${id}`;
            }

            function showError() {
                Swal.fire({
                    icon: 'error',
                    title: 'Fetch Failed',
                    text: 'Something went wrong while loading orders. Please try again.',
                    confirmButtonText: 'Retry'
                }).then(() => fetchData());
            }

            // ── Keyboard Shortcuts ────────────────────────────────────────────────
            document.addEventListener('keydown', (e) => {
                if (e.key === '/' && document.activeElement !== searchInput) {
                    e.preventDefault();
                    searchInput.focus();
                }
            });

            // ── Bell Dropdown ─────────────────────────────────────────────────────
            const bell = document.getElementById('bellToggle');
            const dropdown = document.getElementById('requestsDropdown');
            if (bell) {
                bell.onclick = (e) => { e.stopPropagation(); dropdown.classList.toggle('show'); };
            }
            window.onclick = () => dropdown.classList.remove('show');

            // ── Init ──────────────────────────────────────────────────────────────
            updateChips();

            // Show clear button if search has value on load
            if (searchInput.value) clearBtn.style.display = 'block';
        </script>
</body>

</html>