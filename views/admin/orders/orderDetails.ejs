<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details | Zyrox Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/adminStyles/partials/sidebar.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            background-color: #080e1a;
            color: #e2e8f0;
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
        }

        /* Subtle grid background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(99, 102, 241, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(99, 102, 241, 0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: 0;
        }

        .page-wrap {
            position: relative;
            z-index: 1;
        }

        /* Cards */
        .card {
            background: rgba(15, 23, 42, 0.85);
            border: 1px solid rgba(99, 102, 241, 0.12);
            border-radius: 16px;
            backdrop-filter: blur(10px);
        }

        /* Status tracker */
        .tracker-line {
            position: absolute;
            top: 7px;
            left: 8px;
            right: 8px;
            height: 1px;
            background: #1e293b;
            z-index: 0;
        }

        .tracker-line-fill {
            height: 100%;
            background: linear-gradient(90deg, #6366f1, #06b6d4);
            transition: width 0.6s ease;
        }

        /* Buttons */
        .btn-ghost {
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 10px 20px;
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            background: transparent;
            color: #94a3b8;
        }

        .btn-ghost:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #e2e8f0;
        }

        .btn-danger {
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 10px;
            padding: 12px 20px;
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            background: transparent;
            color: #f87171;
            width: 100%;
        }

        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.08);
            border-color: rgba(239, 68, 68, 0.5);
        }

        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            border: none;
            border-radius: 10px;
            padding: 12px 24px;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            color: white;
            transition: all 0.2s;
            letter-spacing: 0.01em;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        /* Tag / Badge */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            padding: 4px 12px;
            border-radius: 999px;
        }

        .badge-delivered {
            background: rgba(34, 197, 94, 0.1);
            color: #4ade80;
            border: 1px solid rgba(34, 197, 94, 0.25);
        }

        .badge-pending {
            background: rgba(234, 179, 8, 0.1);
            color: #facc15;
            border: 1px solid rgba(234, 179, 8, 0.25);
        }

        .badge-processing {
            background: rgba(99, 102, 241, 0.12);
            color: #a5b4fc;
            border: 1px solid rgba(99, 102, 241, 0.3);
        }

        .badge-shipped {
            background: rgba(6, 182, 212, 0.1);
            color: #22d3ee;
            border: 1px solid rgba(6, 182, 212, 0.25);
        }

        .badge-cancelled {
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.25);
        }

        .badge-returned {
            background: rgba(251, 146, 60, 0.1);
            color: #fb923c;
            border: 1px solid rgba(251, 146, 60, 0.25);
        }

        .badge-return-requested {
            background: rgba(251, 146, 60, 0.1);
            color: #fb923c;
            border: 1px solid rgba(251, 146, 60, 0.25);
        }

        .badge-cancellation-requested {
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.25);
        }

        /* Spec pill */
        .spec-pill {
            background: rgba(30, 41, 59, 0.8);
            border: 1px solid rgba(99, 102, 241, 0.1);
            border-radius: 8px;
            padding: 5px 12px;
            font-size: 0.72rem;
            color: #64748b;
            font-family: 'DM Mono', monospace;
        }

        .spec-pill b {
            color: #e2e8f0;
        }

        /* Divider */
        .divider {
            border: none;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            margin: 12px 0;
        }
    </style>
</head>

<body class="">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <div class="fixed h-screen w-72 flex-shrink-0 group">
            <%- include('../../partials/admin/sidebar', { currentPage: 'orders' , currentUser: admin }) %>
        </div>

        <!-- Main Content -->
        <main class="flex-grow ml-72 p-6 md:p-10 overflow-y-auto w-full">
            <div class="page-wrap max-w-5xl">

                <!-- Back button -->
                <button class="btn-ghost mb-8 flex items-center gap-2" onclick="window.location.href='/admin/orders'">
                    <i class="fas fa-arrow-left text-xs"></i> Back to Orders
                </button>

                <!-- Page Header -->
                <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
                    <div>
                        <p class="text-xs text-slate-500 uppercase tracking-widest mb-1">Order Reference</p>
                        <h1 class="text-2xl font-bold tracking-tight text-white font-['DM_Mono']">
                            #<%= order.orderId %>
                        </h1>
                    </div>
                    <% const statusLower=order.orderStatus.toLowerCase(); let badgeClass='badge-pending' ; if
                        (statusLower==='delivered' ) badgeClass='badge-delivered' ; else if (statusLower==='processing'
                        ) badgeClass='badge-processing' ; else if (statusLower==='shipped' ) badgeClass='badge-shipped'
                        ; else if (statusLower==='cancelled' ) badgeClass='badge-cancelled' ; else if
                        (statusLower==='returned' ) badgeClass='badge-returned' ; else if
                        (statusLower==='return requested' ) badgeClass='badge-return-requested' ; else if
                        (statusLower==='cancellation requested' ) badgeClass='badge-cancellation-requested' ; %>
                        <span class="badge <%= badgeClass %>">
                            <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                            <%= order.orderStatus %>
                        </span>
                </div>

                <!-- Main Grid -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

                    <!-- LEFT: Items -->
                    <div class="lg:col-span-2 space-y-4">
                        <% if(order.items) { order.items.forEach((item, index)=> { %>
                            <div class="card overflow-hidden">
                                <div class="p-5">
                                    <div class="flex gap-5">
                                        <!-- Product Image -->
                                        <div
                                            class="w-28 h-28 rounded-xl overflow-hidden flex-shrink-0 bg-slate-900 border border-slate-800">
                                            <img src="<%= item.image %>" alt="<%= item.name %>"
                                                class="w-full h-full object-cover">
                                        </div>

                                        <!-- Product Info -->
                                        <div class="flex-1 min-w-0">
                                            <div class="flex justify-between items-start gap-2">
                                                <h2 class="text-base font-semibold text-white leading-tight">
                                                    <%= item.name %>
                                                </h2>
                                                <span class="text-base font-bold text-white whitespace-nowrap">₹<%=
                                                        item.price.toLocaleString('en-IN') %></span>
                                            </div>

                                            <div class="flex flex-wrap gap-2 mt-3">
                                                <span class="spec-pill">RAM <b>
                                                        <%= item.RAM %>
                                                    </b></span>
                                                <span class="spec-pill">Storage <b>
                                                        <%= item.storage %>
                                                    </b></span>
                                                <span class="spec-pill">Color <b>
                                                        <%= item.color %>
                                                    </b></span>
                                            </div>

                                            <!-- Admin Action: Accept/Decline Request -->
                                            <% if (['return requested', 'cancellation requested'
                                                ].includes(statusLower)) { %>
                                                <div class="mt-4 flex gap-2">
                                                    <button class="btn-primary text-xs py-2 px-4"
                                                        style="background:linear-gradient(135deg,#22c55e,#16a34a)"
                                                        onclick="handleRequest('<%= order._id %>', 'accept')">
                                                        <i class="fas fa-check mr-1"></i> Accept Request
                                                    </button>
                                                    <button class="btn-danger text-xs py-2 px-4"
                                                        onclick="handleRequest('<%= order._id %>', 'decline')">
                                                        <i class="fas fa-times mr-1"></i> Decline Request
                                                    </button>
                                                </div>
                                                <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) } %>

                                <% if (order.returnReason || order.cancellationReason) { %>
                                    <div class="card p-5 border-l-4 border-amber-500">
                                        <p class="text-xs text-amber-400 uppercase tracking-widest font-semibold mb-2">
                                            Request Information</p>
                                        <p class="text-sm text-slate-300">
                                            <span class="text-slate-500">Reason:</span>
                                            <%= order.returnReason || order.cancellationReason %>
                                        </p>
                                    </div>
                                    <% } %>
                    </div>

                    <!-- RIGHT: Sidebar -->
                    <div class="space-y-4">
                        <!-- Customer Details -->
                        <div class="card p-5">
                            <p class="text-xs text-indigo-400 uppercase tracking-widest font-semibold mb-4">Customer
                                Info</p>
                            <div class="flex items-center gap-3 mb-4">
                                <div
                                    class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-indigo-400 font-bold">
                                    <%= order.userId?.Name?.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-white">
                                        <%= order.userId?.Name %>
                                    </p>
                                    <p class="text-xs text-slate-500">
                                        <%= order.userId?.Email %>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Shipping Address -->
                        <div class="card p-5">
                            <p class="text-xs text-indigo-400 uppercase tracking-widest font-semibold mb-4">Shipping
                                Address</p>
                            <div class="space-y-2.5 text-sm">
                                <div class="flex items-center gap-2.5">
                                    <i class="far fa-user w-4 text-center text-slate-500 text-xs"></i>
                                    <span class="font-semibold text-white">
                                        <%= order.shippingAddress.fullName %>
                                    </span>
                                </div>
                                <div class="flex items-center gap-2.5">
                                    <i class="fas fa-phone-alt w-4 text-center text-slate-500 text-xs"></i>
                                    <span class="text-slate-400">
                                        <%= order.shippingAddress.phone %>
                                    </span>
                                </div>
                                <div class="flex items-center gap-2.5">
                                    <i class="fas fa-map-marker-alt w-4 text-center text-slate-500 text-xs"></i>
                                    <span class="text-white">
                                        <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %>
                                    </span>
                                </div>
                                <div class="flex items-start gap-2.5 pt-1 border-t border-slate-800 mt-2">
                                    <i class="fas fa-home w-4 text-center text-slate-600 text-xs mt-0.5"></i>
                                    <span class="text-slate-400 text-xs leading-relaxed">
                                        <%= order.shippingAddress.houseName %>, <%= order.shippingAddress.locality %>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Price Details -->
                        <div class="card p-5">
                            <p class="text-xs text-indigo-400 uppercase tracking-widest font-semibold mb-4">Price
                                Breakdown</p>
                            <div class="space-y-2.5 text-sm">
                                <div class="flex justify-between text-slate-400">
                                    <span>Subtotal</span>
                                    <span class="text-white font-medium">₹<%= order.subtotal?.toLocaleString('en-IN') %>
                                            </span>
                                </div>
                                <% if (order.discount> 0) { %>
                                    <div class="flex justify-between text-slate-400">
                                        <span>Discount</span>
                                        <span class="text-green-400">-₹<%= order.discount?.toLocaleString('en-IN') %>
                                                </span>
                                    </div>
                                    <% } %>
                                        <% if (order.couponDiscount> 0) { %>
                                            <div class="flex justify-between text-slate-400">
                                                <span>Coupon</span>
                                                <span class="text-green-400">-₹<%=
                                                        order.couponDiscount?.toLocaleString('en-IN') %></span>
                                            </div>
                                            <% } %>
                                                <hr class="divider">
                                                <div class="flex justify-between font-bold text-base">
                                                    <span class="text-white">Amount</span>
                                                    <span class="text-indigo-400">₹<%=
                                                            order.finalPrice?.toLocaleString('en-IN') %></span>
                                                </div>
                                                <p class="text-[10px] text-slate-500 mt-2">Payment Method: <b>
                                                        <%= order.paymentMethod %>
                                                    </b></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Success Toast -->
    <div id="toast"
        class="fixed bottom-6 right-6 z-[200] transition-all duration-500 translate-y-20 opacity-0 pointer-events-none">
        <div
            class="flex items-center gap-3 bg-slate-900 border border-indigo-500/30 rounded-2xl px-5 py-3.5 shadow-2xl">
            <div class="w-8 h-8 rounded-full bg-indigo-500/15 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-check text-indigo-400 text-xs" id="toast-icon"></i>
            </div>
            <div>
                <p class="text-white text-sm font-semibold" id="toast-title">Done</p>
                <p class="text-slate-400 text-xs" id="toast-msg"></p>
            </div>
        </div>
    </div>

    <script>
        // ── Admin Request Management ──
        function handleRequest(orderId, action) {
            const url = action === 'accept' ? '/admin/orders/accept-return' : '/admin/orders/decline-return';
            const title = action === 'accept' ? 'Approve Request?' : 'Decline Request?';

            if (!confirm(title + " Are you sure?")) return;

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId })
            })
                .then(r => r.json())
                .then(d => {
                    if (d.success) {
                        showToast('Success', d.message, 'fa-check-circle');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showToast('Error', d.message, 'fa-exclamation-circle');
                    }
                })
                .catch(() => showToast('Error', 'Server connection failed.', 'fa-exclamation-circle'));
        }

        // ── Toast ──
        function showToast(title, msg, icon = 'fa-check') {
            const t = document.getElementById('toast');
            document.getElementById('toast-title').textContent = title;
            document.getElementById('toast-msg').textContent = msg;
            document.getElementById('toast-icon').className = `fas ${icon} text-indigo-400 text-xs`;
            t.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
            setTimeout(() => {
                t.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
            }, 3000);
        }
    </script>
</body>

</html>