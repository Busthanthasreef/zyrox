                </div>
            </form>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>



        function updateColorValue(color) {

            document.getElementById("colorValue").value = color
        }

        const productId = '<%= typeof product !== "undefined" ? product._id : "" %>';

        function goToPage(page) {
            const url = new URL(window.location.href);
            url.searchParams.set('page', page);
            window.location.href = url.toString();
        }

        function toggleVariant(variantId, isActive) {
            fetch(`/admin/variants/${variantId}/toggle`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ isActive })
            })
                .then(res => res.json())
                .then(data => { if (!data.success) { alert('Failed to update status.'); window.location.reload(); } })
                .catch(() => window.location.reload());
        }

        function setDefault(variantId) {
            fetch(`/admin/variants/${variantId}/set-default`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(res => res.json())
                .then(data => { if (data.success) window.location.reload(); else alert('Failed to set default.'); })
                .catch(() => window.location.reload());
        }

        // ── Modal helpers
        function openAddModal() {
            document.getElementById('addModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        // Called from the data-attr button — avoids all inline quote issues
        function openEditModalFromBtn(btn) {
            const variant = JSON.parse(decodeURIComponent(btn.dataset.variant));
            openEditModal(variant);
        }

        function openEditModal(variant) {
            const form = document.getElementById('editVariantForm');
            form.action = `/admin/products/${productId}/variants/${variant.id}/edit`;

            document.getElementById('editColor').value = variant.color || '';
            document.getElementById('editStorage').value = variant.storage || '';
            document.getElementById('editRAM').value = variant.RAM || '';
            document.getElementById('editPrice').value = variant.price || 0;
            document.getElementById('editStock').value = variant.stock || 0;
            document.getElementById('editSKU').value = variant.SKU || '';

            const toggle = document.getElementById('editStatusToggle');
            toggle.checked = !!variant.isActive;
            syncStatusDot('editStatusDot', toggle);

            ['editSlot0', 'editSlot1', 'editSlot2'].forEach((slotId, i) => {
                const slot = document.getElementById(slotId);
                const img = slot.querySelector('.preview-img');
                if (variant.images && variant.images[i]) {
                    img.src = variant.images[i];
                    slot.classList.add('has-image');
                } else {
                    img.src = '';
                    slot.classList.remove('has-image');
                }
            });

            document.getElementById('editModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('open');
            document.body.style.overflow = '';
        }

        function handleOverlayClick(e, id) {
            if (e.target === document.getElementById(id)) closeModal(id);
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { closeModal('addModal'); closeModal('editModal'); }
        });

        function previewImg(input, slotId) {
            const slot = document.getElementById(slotId);
            const img = slot.querySelector('.preview-img');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { img.src = e.target.result; slot.classList.add('has-image'); };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function removeImg(slotId, e) {
            e.stopPropagation();
            const slot = document.getElementById(slotId);
            const img = slot.querySelector('.preview-img');
            const input = slot.querySelector('input[type="file"]');
            img.src = ''; input.value = '';
            slot.classList.remove('has-image');
        }

        function syncStatusDot(dotId, toggle) {
            document.getElementById(dotId).style.background = toggle.checked ? 'var(--green)' : '#9ca3af';
        }

        // Called when color picker changes → update text input with color name
        function updateColorValue(hex) {
            document.getElementById('colorValue').value = getColorName(hex);
            document.getElementById('colorPicker').value = hex;
        }

        // Called when user types in the text input → update color picker
        function handleColorInput(value) {
            const ctx = document.createElement('canvas').getContext('2d');
            ctx.fillStyle = value; // browser parses color names like "red", "navy", etc.
            const parsed = ctx.fillStyle;  // returns hex if valid, "#000000" if not recognized
            if (parsed) {
                document.getElementById('colorPicker').value = parsed;
            }
        }

        // Maps hex → nearest named color
        function getColorName(hex) {
            const colors = {
                "#ff0000": "Red", "#00ff00": "Green", "#0000ff": "Blue",
                "#ffff00": "Yellow", "#ff00ff": "Magenta", "#00ffff": "Cyan",
                "#000000": "Black", "#ffffff": "White", "#808080": "Gray",
                "#ffa500": "Orange", "#800080": "Purple", "#a52a2a": "Brown",
                "#ffc0cb": "Pink", "#40e0d0": "Turquoise", "#000080": "Navy",
                "#808000": "Olive", "#008000": "Dark Green", "#800000": "Maroon",
                "#ff6347": "Tomato", "#4682b4": "Steel Blue", "#d2691e": "Chocolate",
                "#f5f5dc": "Beige", "#ffe4c4": "Bisque", "#dc143c": "Crimson",
                "#b8860b": "Dark Goldenrod", "#006400": "Dark Green",
                "#8b008b": "Dark Magenta", "#ff8c00": "Dark Orange",
                "#e9967a": "Dark Salmon", "#9400d3": "Dark Violet",
                "#1e90ff": "Dodger Blue", "#b22222": "Firebrick",
                "#228b22": "Forest Green", "#daa520": "Goldenrod",
                "#adff2f": "Green Yellow", "#ff69b4": "Hot Pink",
                "#cd5c5c": "Indian Red", "#f0e68c": "Khaki",
                "#7cfc00": "Lawn Green", "#add8e6": "Light Blue",
                "#f08080": "Light Coral", "#90ee90": "Light Green",
                "#ffb6c1": "Light Pink", "#20b2aa": "Light Sea Green",
                "#87cefa": "Light Sky Blue", "#778899": "Light Slate Gray",
                "#32cd32": "Lime Green", "#ff00ff": "Fuchsia",
                "#66cdaa": "Medium Aquamarine", "#ba55d3": "Medium Orchid",
                "#9370db": "Medium Purple", "#3cb371": "Medium Sea Green",
                "#7b68ee": "Medium Slate Blue", "#00fa9a": "Medium Spring Green",
                "#48d1cc": "Medium Turquoise", "#c71585": "Medium Violet Red",
                "#191970": "Midnight Blue", "#ffe4e1": "Misty Rose",
                "#ffe4b5": "Moccasin", "#000080": "Navy Blue",
                "#fdf5e6": "Old Lace", "#6b8e23": "Olive Drab",
                "#ff4500": "Orange Red", "#da70d6": "Orchid",
                "#eee8aa": "Pale Goldenrod", "#98fb98": "Pale Green",
                "#afeeee": "Pale Turquoise", "#db7093": "Pale Violet Red",
                "#ffefd5": "Papaya Whip", "#ffdab9": "Peach Puff",
                "#cd853f": "Peru", "#dda0dd": "Plum", "#b0e0e6": "Powder Blue",
                "#bc8f8f": "Rosy Brown", "#4169e1": "Royal Blue",
                "#8b4513": "Saddle Brown", "#fa8072": "Salmon",
                "#f4a460": "Sandy Brown", "#2e8b57": "Sea Green",
                "#fff5ee": "Seashell", "#a0522d": "Sienna",
                "#87ceeb": "Sky Blue", "#6a5acd": "Slate Blue",
                "#708090": "Slate Gray", "#00ff7f": "Spring Green",
                "#4169e1": "Steel Blue", "#d2b48c": "Tan",
                "#008080": "Teal", "#d8bfd8": "Thistle", "#ff6347": "Tomato",
                "#40e0d0": "Turquoise", "#ee82ee": "Violet",
                "#f5deb3": "Wheat", "#ffff00": "Yellow",
                "#9acd32": "Yellow Green"
            };

            // Find closest color by comparing RGB distance
            const r1 = parseInt(hex.slice(1, 3), 16);
            const g1 = parseInt(hex.slice(3, 5), 16);
            const b1 = parseInt(hex.slice(5, 7), 16);

            let closest = hex;
            let minDist = Infinity;

            for (const [colorHex, colorName] of Object.entries(colors)) {
                const r2 = parseInt(colorHex.slice(1, 3), 16);
                const g2 = parseInt(colorHex.slice(3, 5), 16);
                const b2 = parseInt(colorHex.slice(5, 7), 16);
                const dist = Math.sqrt((r1 - r2) ** 2 + (g1 - g2) ** 2 + (b1 - b2) ** 2);
                if (dist < minDist) {
                    minDist = dist;
                    closest = colorName;
                }
            }

            return closest;
        }
    </script>
</body>

</html>