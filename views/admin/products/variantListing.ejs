                        </div>

                    </div>
                    <div class="form-group">
                        <label class="form-label">Storage</label>
                        <input type="number" placeholder="eg. 8GB" class="form-input">

                    </div>
                    <div class="form-group">
                        <label class="form-label">RAM</label>
                        <input type="number" class="form-input" placeholder="eg.128GB">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock</label>
                        <input type="number" name="stock" class="form-input" placeholder="0" min="0" value="0">
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Price</label>
                        <div class="input-prefix">
                            <span>₹</span>
                            <input type="number" name="price" placeholder="0.00" min="0" step="0.01" value="0.00">
                        </div>
                    </div>
                    <div class="form-group full">
                        <label class="form-label">SKU</label>
                        <input type="text" name="SKU" class="form-input" placeholder="Enter the SKU of this Product">
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Status</label>
                        <div class="status-row">
                            <div class="status-label"><span class="status-dot" id="addStatusDot"></span> Active</div>
                            <label class="toggle-switch">
