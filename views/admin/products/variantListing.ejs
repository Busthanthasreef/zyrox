                            onchange="previewImg(this, 'addSlot0')">
                        <i class="bi bi-camera upload-icon"></i>
                        <span class="upload-label">Upload Image</span>
                        <img class="preview-img" src="" alt="">
                        <button type="button" class="remove-img" onclick="removeImg('addSlot0', event)"><i
                                class="bi bi-x"></i></button>
                    </div>
                    <div class="img-upload-slot" id="addSlot1">
                        <input type="file" name="variantImages" accept="image/*"
                            onchange="previewImg(this, 'addSlot1')">
                        <i class="bi bi-camera upload-icon"></i>
                        <span class="upload-label">Upload Image</span>
                        <img class="preview-img" src="" alt="">
                        <button type="button" class="remove-img" onclick="removeImg('addSlot1', event)"><i
                                class="bi bi-x"></i></button>
                    </div>
                    <div class="img-upload-slot" id="addSlot2">
                        <input type="file" name="variantImages" accept="image/*"
                            onchange="previewImg(this, 'addSlot2')">
                        <i class="bi bi-camera upload-icon"></i>
                        <span class="upload-label">Upload Image</span>
                        <img class="preview-img" src="" alt="">
                        <button type="button" class="remove-img" onclick="removeImg('addSlot2', event)"><i
                                class="bi bi-x"></i></button>
                    </div>
