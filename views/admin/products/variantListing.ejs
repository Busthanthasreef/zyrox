            </div>
            <form id="editVariantForm" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_method" value="PUT">

                <div class="img-upload-row">
                    <div class="img-upload-slot" id="editSlot0">
                        <input type="file" name="variantImages" accept="image/*"
                            onchange="previewImg(this, 'editSlot0')">
                        <i class="bi bi-camera upload-icon"></i>
                        <span class="upload-label">Upload Image</span>
                        <img class="preview-img" src="" alt="">
                        <button type="button" class="remove-img" onclick="removeImg('editSlot0', event)"><i
                                class="bi bi-x"></i></button>
                    </div>
                    <div class="img-upload-slot" id="editSlot1">
                        <input type="file" name="variantImages" accept="image/*"
                            onchange="previewImg(this, 'editSlot1')">
                        <i class="bi bi-camera upload-icon"></i>
                        <span class="upload-label">Upload Image</span>
                        <img class="preview-img" src="" alt="">
                        <button type="button" class="remove-img" onclick="removeImg('editSlot1', event)"><i
                                class="bi bi-x"></i></button>
                    </div>
                    <div class="img-upload-slot" id="editSlot2">
                        <input type="file" name="variantImages" accept="image/*"
                            onchange="previewImg(this, 'editSlot2')">
                        <i class="bi bi-camera upload-icon"></i>
                        <span class="upload-label">Upload Image</span>
                        <img class="preview-img" src="" alt="">
                        <button type="button" class="remove-img" onclick="removeImg('editSlot2', event)"><i
                                class="bi bi-x"></i></button>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Color</label>
                        <select name="color" id="editColor" class="form-select-custom" required>
                            <option value="">Select One</option>
                            <option value="Black Titanium">Black Titanium</option>
                            <option value="White Titanium">White Titanium</option>
                            <option value="Blue">Blue</option>
                            <option value="Natural Titanium">Natural Titanium</option>
                            <option value="Desert Titanium">Desert Titanium</option>
                        </select>
                    </div>
                    <div style="display:flex; gap:10px; align-items:center;">
                            <!-- Color Picker -->
                            <input type="color"  id="colorPicker"
                                style="width:50px; height:40px; border:none; cursor:pointer;"
                                onchange="updateColorValue(this.value)">

                            <!-- Color Name Input (remove readonly, add oninput handler) -->
                            <input type="text" name="color" id="colorValue" class="form-input"
                                placeholder="e.g. Red, Navy, #ff0000" oninput="handleColorInput(this.value)">

                        </div>
                    <div class="form-group">
                        <label class="form-label">Storage</label>
                        <select name="storage" id="editStorage" class="form-select-custom">
                            <option value="">Select</option>
                            <option value="128">128 GB</option>
                            <option value="256">256 GB</option>
                            <option value="512">512 GB</option>
                            <option value="1024">1 TB</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">RAM</label>
                        <select name="RAM" id="editRAM" class="form-select-custom">
                            <option value="">Select</option>
                            <option value="4">4 GB</option>
                            <option value="6">6 GB</option>
                            <option value="8">8 GB</option>
                            <option value="12">12 GB</option>
                            <option value="16">16 GB</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock</label>
                        <input type="number" name="stock" id="editStock" class="form-input" min="0">
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Price</label>
                        <div class="input-prefix">
                            <span>₹</span>
                            <input type="number" name="price" id="editPrice" placeholder="0.00" min="0" step="0.01">
                        </div>
                    </div>
                    <div class="form-group full">
                        <label class="form-label">SKU</label>
                        <input type="text" name="SKU" id="editSKU" class="form-input"
                            placeholder="Enter the SKU of this Product">
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Status</label>
                        <div class="status-row">
                            <div class="status-label"><span class="status-dot" id="editStatusDot"></span> Active</div>
                            <label class="toggle-switch">
                                <input type="checkbox" name="isActive" id="editStatusToggle"
                                    onchange="syncStatusDot('editStatusDot', this)">
                                <div class="toggle-track"></div>
                            </label>
                        </div>
