<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<!-- Inter Font -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
<style>
    /* ========== NAVIGATION BAR ========== */
    .navbar {
        width: 100%;
        padding: 15px 1%;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: fixed;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid #ffffff71;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--accent, #00ff04);
        font-size: 20px;
        transition: transform 0.3s ease;
    }

    .nav-left.mobile-active {
        transform: translateX(130px);
    }

    .logo {
        font-weight: 700;
        color: #fff;
        font-family: 'Inter', sans-serif;
        letter-spacing: -0.5px;
    }

    .nav-links {
        list-style: none;
        display: flex;
        gap: 35px;
        align-items: center;
    }

    .nav-links a {
        text-decoration: none;
        color: #fff;
        font-size: 14px;
        font-weight: 500;
        transition: .3s;
        opacity: 0.8;
    }

    .nav-links a:hover {
        color: var(--accent, #00ff04);
        opacity: 1;
    }

    /* ===== ACTIVE PAGE LINK ===== */
    .nav-links a.active {
        color: var(--accent, #00ff04);
        opacity: 1;
        font-weight: 700;
    }

    /* ===== CATEGORIES DROPDOWN ===== */
    .dropdown {
        position: relative;
    }

    .dropdown-toggle {
        cursor: pointer;
    }

    .dropdown-toggle::after {
        content: "▾";
        font-size: 0.75em;
    }

    .dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 14px);
        left: 0;
        background-color: #1a1a1a;
        min-width: 190px;
        border-radius: 8px;
        border: 1px solid #2a2a2a;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        z-index: 999;
        padding: 6px 0;
    }

    .dropdown::after .dropdown-menu {
        display: inline;
    }

    .dropdown-menu a {
        display: block;
        padding: 10px 18px;
        color: #fff !important;
        text-decoration: none !important;
        font-size: 14px;
        white-space: nowrap;
        transition: background 0.2s, color 0.2s, padding 0.2s;
        border-bottom: 1px solid #2a2a2a;
    }

    .dropdown-menu a:last-child {
        border-bottom: none;
    }

    .dropdown-menu a:hover {
        background-color: #2a2a2a;
        color: #00ff04 !important;
        padding-left: 24px;
    }

    /* ===== SEARCH BOX ===== */
    .search-box {
        background: #1c1c1c;
        padding: 5px 20px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        width: 300px;
        gap: 10px;
        margin-right: 20px;
    }

    .search-box input {
        background: transparent;
        border: none;
        outline: none;
        color: #0fff7b;
        width: 100%;
    }

    .search-box input::placeholder {
        color: #666;
        font-size: small;
    }

    .nav-icons {
        display: flex;
        gap: 20px;
        align-items: center;
        margin-right: 20px;
    }

    .icon {
        position: relative;
        color: #fff;
        font-size: 18px;
        cursor: pointer;
        transition: color 0.3s;
    }

    .icon:hover {
        color: #00ff04;
    }

    .badge {
        position: absolute;
        height: 20px;
        width: 20px;
        top: -11px;
        right: -10px;
        background: #f03232;
        color: #ffffff;
        font-size: 9px;
        font-weight: 500;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 47%;
    }

    /* Wishlist heart badge – match cart count STYLE */
    .icon .badge {
        background: #f03232;
    }

    /* ===== PROFILE BUTTON ===== */
    .profile-btn {
        background: #1c1c1c;
        border: 1px solid #2a2a2a;
        color: #fff;
        padding: 10px 20px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s;
        position: relative;
    }

    .profile-btn:hover {
        background: #2a2a2a;
        border-color: #00ff04;
    }

    .profile-btn i.fa-chevron-down {
        font-size: 12px;
        transition: transform 0.3s;
    }

    .profile-btn.active i.fa-chevron-down {
        transform: rotate(180deg);
    }

    .prof {
        cursor: pointer;
        align-self: center;
        padding-left: 21px;
        padding-top: 6px;
        color: #fff;
    }

    /* ===== PROFILE DROPDOWN ===== */
    .profile-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 10px;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        min-width: 200px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        z-index: 1001;
    }

    .profile-dropdown.show {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .profile-dropdown a {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        color: #fff;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s;
        border-bottom: 1px solid #2a2a2a;
    }

    .profile-dropdown a:last-child {
        border-bottom: none;
    }

    .profile-dropdown a:hover {
        background: #2a2a2a;
        color: #00ff04;
    }

    .profile-dropdown a i {
        font-size: 16px;
        width: 20px;
    }

    /* ===== HAMBURGER ===== */
    .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        position: absolute;
        right: 15px;
    }

    .hamburger span {
        width: 25px;
        height: 3px;
        background: #fff;
        transition: 0.4s;
    }

    .hamburger.active span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
    }

    .hamburger.active span:nth-child(2) {
        opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
        transform: rotate(-45deg) translate(6px, -6px);
    }

    /* ========== SIDEBAR ========== */
    .sidebar {
        position: fixed;
        right: -100%;
        top: 0;
        width: 100%;
        height: auto;
        max-height: 100vh;
        background: #000;
        padding: 30px;
        transition: .4s ease;
        z-index: 2000;
        border-left: 1px solid #1c1c1c;
        overflow-y: auto;
    }

    .sidebar.active {
        right: 0;
    }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #00ff04;
        font-size: 22px;
    }

    .sidebar-logo i {
        font-size: 24px;
    }

    .sidebar-logo .logo {
        font-weight: 600;
        color: #fff;
    }

    .close-btn {
        background: none;
        border: none;
        color: #fff;
        font-size: 24px;
        cursor: pointer;
        transition: color 0.3s;
    }

    .close-btn:hover {
        color: #00ff04;
    }

    .sidebar-links {
        list-style: none;
        padding: 0;
    }

    .sidebar-links li {
        margin-bottom: 0;
    }

    .sidebar-links a {
        display: block;
        color: #fff;
        text-decoration: none;
        font-size: 16px;
        padding: 15px 0;
        transition: .3s;
        border-bottom: 1px solid #1c1c1c;
    }

    .sidebar-links a:hover {
        color: #00ff04;
        padding-left: 10px;
    }

    .sidebar-links a.active {
        color: #00ff04;
        text-decoration: underline;
        text-underline-offset: 5px;
    }

    /* ===== SIDEBAR CATEGORIES ACCORDION ===== */
    .sidebar-dropdown {
        border-bottom: 1px solid #1c1c1c;
    }

    .sidebar-dropdown summary {
        display: block;
        color: #fff;
        font-size: 16px;
        padding: 15px 0;
        cursor: pointer;
        list-style: none;
        transition: .3s;
    }

    .sidebar-dropdown summary::-webkit-details-marker {
        display: none;
    }

    .sidebar-dropdown summary:hover {
        color: #00ff04;
        padding-left: 10px;
    }

    .sidebar-dropdown summary.active {
        color: #00ff04;
    }

    .sidebar-dropdown summary::after {
        content: " ▾";
        font-size: 0.75em;
    }

    .sidebar-dropdown[open] summary::after {
        content: " ▴";
    }

    .sidebar-cat-links a {
        display: block;
        padding: 12px 0 12px 20px;
        font-size: 14px;
        color: #aaa;
        text-decoration: none;
        border-bottom: 1px solid #1c1c1c;
        transition: .3s;
    }

    .sidebar-cat-links a:last-child {
        border-bottom: none;
    }

    .sidebar-cat-links a:hover {
        color: #00ff04;
        padding-left: 28px;
    }

    /* ===== OVERLAY ===== */
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        opacity: 0;
        visibility: hidden;
        transition: .3s;
        z-index: 1500;
    }

    .overlay.active {
        opacity: 1;
        visibility: visible;
    }
</style>

