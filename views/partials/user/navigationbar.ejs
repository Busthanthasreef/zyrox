                <script>
                    document.addEventListener('DOMContentLoaded', () => {
                        const success = <%- JSON.stringify(successMessage || '') %>;
                        const error = <%- JSON.stringify(errorMessage || '') %>;
                        const info = <%- JSON.stringify(infoMessage || '') %>;

                        if (success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: success,
                                timer: 3000,
                                timerProgressBar: true,
                                background: '#0a0c14',
                                color: '#f0f2ff'
                            });
                        } else if (error) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: error,
                                background: '#0a0c14',
                                color: '#f0f2ff'
                            });
                        } else if (info) {
                            Swal.fire({
                                icon: 'info',
                                title: 'Notice',
                                text: info,
                                background: '#0a0c14',
                                color: '#f0f2ff'
                            });
                        }
                    });
                </script>