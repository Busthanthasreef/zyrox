<!-- SweetAlert2 (load once) -->
<script>
    if (!window.Swal) {
        const swalScript = document.createElement('script');
        swalScript.src = 'https://cdn.jsdelivr.net/npm/sweetalert2@11';
        document.head.appendChild(swalScript);
    }
</script>
<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<!-- Inter Font -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
<style>
    /* ========== GLOBAL RESPONSIVE FIXES ========== */
    img {
        max-width: 100%;
        height: auto;
    }

    .table-responsive,
    .table-area {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    input,
    select,
    textarea,
    button {
        font-family: 'Inter', sans-serif;
    }

    button,
    a.btn {
        min-height: 44px;
        min-width: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    @media (max-width: 575px) {

        .d-flex,
        .row,
        .grid,
        .products-grid,
        .categories-grid,
        .footer-content {
            flex-direction: column !important;
        }
    }

    /* ========== GLOBAL ANIMATIONS ========== */
    * {
        transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
    }

    button, .btn, a, .category-item, .product-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        position: relative;
        overflow: hidden;
    }

    button:hover::after, .btn:hover::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
        transform: rotate(45deg);
        animation: shine 1.5s infinite;
    }

    @keyframes shine {
        0% { transform: translateX(-100%) rotate(45deg); }
        100% { transform: translateX(100%) rotate(45deg); }
    }

    button:active, .btn:active {
        transform: scale(0.95) !important;
    }

    input, select, textarea {
        transition: all 0.3s ease !important;
    }

    input:focus, select:focus, textarea:focus {
        transform: translateY(-1px);
        box-shadow: 0 5px 15px rgba(255, 255, 255, 0.1) !important;
    }

    @keyframes ripple {
        0% { transform: scale(0); opacity: 1; }
        100% { transform: scale(4); opacity: 0; }
    }

    .hover-ripple {
        position: relative;
        overflow: hidden;
    }

    /* Page Transition Effect */
    body {
        animation: pageFadeIn 0.5s ease-out;
    }

    @keyframes pageFadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ========== NAVIGATION BAR ========== */
    .navbar {
        width: 100%;
        padding: 15px 1%;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: fixed;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid #ffffff71;
        flex-wrap: nowrap;
    }



    .nav-left {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--accent, #4f6ef7);
        font-size: 20px;
        transition: transform 0.3s ease;
    }

    .nav-left.mobile-active {
        transform: translateX(130px);
    }

    .logo {
        font-weight: 700;
        color: #fff;
        font-family: 'Inter', sans-serif;
        letter-spacing: -0.5px;
    }

    .nav-links {
        list-style: none;
        display: flex;
        gap: 20px;
        align-items: center;
    }


    .nav-links a {
        text-decoration: none;
        color: #fff;
        font-size: 14px;
        font-weight: 500;
        transition: .3s;
        opacity: 0.8;
    }

    .nav-links a:hover {
        color: var(--accent, #4f6ef7);
        opacity: 1;
    }

    /* ===== ACTIVE PAGE LINK ===== */
    .nav-links a.active {
        color: var(--accent, #4f6ef7);
        opacity: 1;
        font-weight: 700;
    }

    /* ===== CATEGORIES DROPDOWN ===== */
    .dropdown {
        position: relative;
    }

    .dropdown-toggle {
        cursor: pointer;
    }

    .dropdown-toggle::after {
        content: "▾";
        font-size: 0.75em;
    }

    .dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 14px);
        left: 0;
        background-color: #1a1a1a;
        border-radius: 12px;
        border: 1px solid #2a2a2a;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
        z-index: 999;
        padding: 10px;
        flex-direction: column;
        flex-wrap: wrap;
        max-height: 260px;
        /* Approx 6 rows of 40px */
        min-width: 200px;
        width: max-content;
        gap: 2px;
    }

    .dropdown:hover .dropdown-menu {
        display: flex;
    }

    .dropdown-item-wrap {
        display: flex;
        align-items: center;
        padding: 10px 15px;
        color: #fff;
        text-decoration: none;
        font-size: 13.5px;
        transition: all 0.2s;
        cursor: pointer;
        width: 190px;
        gap: 12px;
        border-radius: 6px;
    }

    .dropdown-item-wrap:hover {
        background: rgba(0, 255, 4, 0.05);
        color: #4f6ef7;
    }

    .dropdown-item-wrap input[type="checkbox"] {
        accent-color: #4f6ef7;
        width: 15px;
        height: 15px;
        cursor: pointer;
    }

    .dropdown-item-wrap span {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .nav-icons {
        display: flex;
        gap: 15px;
        align-items: center;
        margin-right: 10px;
    }


    .icon {
        position: relative;
        color: #fff;
        font-size: 18px;
        cursor: pointer;
        transition: color 0.3s;
    }

    .icon:hover {
        color: #4f6ef7;
        transform: scale(1.15);
    }

    .badge {
        position: absolute;
        height: 20px;
        width: 20px;
        top: -11px;
        right: -10px;
        background: #f03232;
        color: #ffffff;
        font-size: 9px;
        font-weight: 500;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 47%;
    }

    /* Wishlist heart badge – match cart count STYLE */
    .icon .badge {
        background: #f03232;
    }

    /* ===== PROFILE BUTTON ===== */
    .profile-btn {
        background: #1c1c1c;
        border: 1px solid #2a2a2a;
        color: #fff;
        padding: 10px 20px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s;
        position: relative;
    }

    .profile-btn:hover {
        background: #2a2a2a;
        border-color: #4f6ef7;
    }

    .profile-btn i.fa-chevron-down {
        font-size: 12px;
        transition: transform 0.3s;
    }

    .profile-btn.active i.fa-chevron-down {
        transform: rotate(180deg);
    }

    .prof {
        cursor: pointer;
        align-self: center;
        padding-left: 21px;
        padding-top: 6px;
        color: #fff;
    }

    /* ===== PROFILE DROPDOWN ===== */
    .profile-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 10px;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        min-width: 200px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        z-index: 1001;
    }

    .profile-dropdown.show {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .profile-dropdown a {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        color: #fff;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s;
        border-bottom: 1px solid #2a2a2a;
    }

    .profile-dropdown a:last-child {
        border-bottom: none;
    }

    .profile-dropdown a:hover {
        background: #2a2a2a;
        color: #4f6ef7;
    }

    .profile-dropdown a i {
        font-size: 16px;
        width: 20px;
    }

    /* ===== HAMBURGER ===== */
    .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        position: absolute;
        right: 15px;
        z-index: 21;
    }

    .hamburger span {
        width: 25px;
        height: 3px;
        background: #fff;
        transition: 0.4s;
    }

    .hamburger.active span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
    }

    .hamburger.active span:nth-child(2) {
        opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
        transform: rotate(-45deg) translate(6px, -6px);
    }

    /* ========== MOBILE SIDEBAR ========== */
    .mobile-sidebar {
        position: fixed;
        right: -100%;
        top: 0;
        width: 100%;
        height: auto;
        max-height: 100vh;
        background: #000;
        padding: 30px;
        transition: .4s ease;
        z-index: 2000;
        border-left: 1px solid #1c1c1c;
        overflow-y: auto;
    }

    .mobile-sidebar.active {
        right: 0;
    }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #4f6ef7;
        font-size: 22px;
    }

    .sidebar-logo i {
        font-size: 24px;
    }

    .sidebar-logo .logo {
        font-weight: 600;
        color: #fff;
    }

    .close-btn {
        background: none;
        border: none;
        color: #fff;
        font-size: 24px;
        cursor: pointer;
        transition: color 0.3s;
    }

    .close-btn:hover {
        color: #4f6ef7;
    }

    /* Sidebar Search */
    .sidebar-search-box {
        display: flex;
        background: #111;
        border: 1px solid #222;
        border-radius: 12px;
        overflow: hidden;
        margin: 0 10px;
    }
    .sidebar-search-input {
        flex: 1;
        background: transparent;
        border: none;
        color: #fff;
        padding: 12px 15px;
        font-size: 14px;
        outline: none;
    }
    .sidebar-search-btn {
        background: var(--accent);
        border: none;
        color: #000;
        padding: 0 18px;
        cursor: pointer;
        transition: .3s;
    }
    .sidebar-search-btn:hover {
        background: #fff;
    }

    .sidebar-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.05);
        margin: 20px 0;
        list-style: none;
    }

    .sidebar-links {
        list-style: none;
        padding: 0;
    }

    .sidebar-links li {
        margin-bottom: 0;
    }

    .sidebar-links a {
        display: block;
        color: #fff;
        text-decoration: none;
        font-size: 16px;
        padding: 15px 0;
        transition: .3s;
        border-bottom: 1px solid #1c1c1c;
    }

    .sidebar-links a:hover {
        color: #4f6ef7;
        padding-left: 10px;
    }

    .sidebar-links a.active {
        color: #4f6ef7;
        text-decoration: underline;
        text-underline-offset: 5px;
    }

    /* ===== SIDEBAR CATEGORIES ACCORDION ===== */
    .sidebar-dropdown {
        border-bottom: 1px solid #1c1c1c;
    }

    .sidebar-dropdown summary {
        display: block;
        color: #fff;
        font-size: 16px;
        padding: 15px 0;
        cursor: pointer;
        list-style: none;
        transition: .3s;
    }

    .sidebar-dropdown summary::-webkit-details-marker {
        display: none;
    }

    .sidebar-dropdown summary:hover {
        color: #4f6ef7;
        padding-left: 10px;
    }

    .sidebar-dropdown summary.active {
        color: #4f6ef7;
    }

    .sidebar-dropdown summary::after {
        content: " ▾";
        font-size: 0.75em;
    }

    .sidebar-dropdown[open] summary::after {
        content: " ▴";
    }

    .sidebar-cat-links a {
        display: block;
        padding: 12px 0 12px 20px;
        font-size: 14px;
        color: #aaa;
        text-decoration: none;
        border-bottom: 1px solid #1c1c1c;
        transition: .3s;
    }

    .sidebar-cat-links a:last-child {
        border-bottom: none;
    }

    .sidebar-cat-links a:hover {
        color: #4f6ef7;
        padding-left: 28px;
    }

    /* ===== OVERLAY ===== */
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        opacity: 0;
        visibility: hidden;
        transition: .3s;
        z-index: 1500;
    }

    .overlay.active {
        opacity: 1;
        visibility: visible;
    }

    /* ========== RESPONSIVE NAVBAR ========== */
    @media (max-width: 1024px) {


        .navbar {
            padding: 10px 3%;
        }

        .nav-links,
        .search-box {
            display: none;
        }

        .hamburger {
            display: flex;
        }

        .nav-icons {
            margin-right: 50px;
            gap: 15px;
        }

        .profile-btn {
            padding: 8px 12px;
        }

        .nav-left {
            font-size: 18px;
        }
    }

    @media (max-width: 575px) {
        .nav-icons {
            gap: 10px;
            margin-right: 40px;
        }

        .profile-btn {
            padding: 6px 10px;
        }

        .logo {
            font-size: 16px;
        }
    }
</style>

<!-- ========== NAVBAR ========== -->
<nav class="navbar">

    <!-- Left: Logo -->
    <div class="nav-left" id="navLogo">
        <i class="fas fa-store"></i>
        <div class="logo">Zyrox</div>
    </div>

    <!-- Center: Nav Links -->
    <ul class="nav-links">
        <li>
            <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">
                Home
            </a>
        </li>

        <li>
            <a href="/products" class="<%= currentPage === 'products' ? 'active' : '' %>">
                Products
            </a>
        </li>

        <!-- Categories Dropdown -->
        <li class="dropdown">
            <a href="/products" class="dropdown-toggle <%= currentPage === 'categories' ? 'active' : '' %>">
                Categories
            </a>
            <div class="dropdown-menu">
                <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                    <% categories.forEach(category=> { %>
                        <div class="dropdown-item-wrap"
                            onclick="handleCategorySelect(event, '<%= category.categoryName %>')">
                            <input type="checkbox" value="<%= category.categoryName %>" <%=typeof curBrands
                                !=='undefined' && curBrands.includes(category.categoryName) ? 'checked' : '' %>
                            onclick="event.stopPropagation(); handleCategorySelect(event, '<%= category.categoryName %>
                                ')">
                                <span>
                                    <%= category.categoryName %>
                                </span>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="dropdown-item-wrap">No categories found</div>
                                <% } %>
            </div>
        </li>

        <li>
            <a href="/aboutUs" class="<%= currentPage === 'aboutUs' ? 'active' : '' %>">
                About Us
            </a>
        </li>
    </ul>



    <!-- Right Icons -->
    <div class="nav-icons">
        <div class="icon">
            <a href="/wishlist"><i class="far fa-heart"></i></a>
            <% if (typeof wishlistCount !=='undefined' && wishlistCount> 0) { %>
                <span class="badge">
                    <%= wishlistCount %>
                </span>
                <% } %>
        </div>

        <div class="icon">
            <a href="/cart"><i class="fas fa-shopping-cart"></i></a>
            <% if (typeof cartItemCount !=='undefined' && cartItemCount> 0) { %>
                <span class="badge">
                    <%= cartItemCount %>
                </span>
                <% } %>
        </div>

        <!-- Profile Button -->
        <div style="position: relative;">
            <button class="profile-btn" id="profileBtn" onclick="toggleProfileDropdown()">
                <% if (user) { %>
                    <i class="far fa-user-circle"></i>
                    <span>
                        <%= user.Name.split(" ")[0] %></span>
                <% } else { %>
                    <span>ACCOUNT</span>
                <% } %>
                <i class=" fas fa-chevron-down"></i>
            </button>

            <div class="profile-dropdown" id="profileDropdown">
                <% if (user) { %>
                    <p class="prof">
                        <i class="fas fa-user"></i>
                        <%= user.Name.split(" ").slice(0, 2).join(" ") %>
                    </p>
                    <hr>
                    <a href=" /profile" onclick="closeProfileDropdown()">
                            <i class="fas fa-user-circle"></i> My Profile
                            </a>
                            <a href="/address" onclick="closeProfileDropdown()">
                                <i class="fas fa-map-marker-alt"></i> My Addresses
                            </a>

                            <a href="/myOrders" onclick="closeProfileDropdown()">
                                <i class="fas fa-box"></i> My Orders
                            </a>
                            <a href="/wallet" onclick="closeProfileDropdown()">
                                <i class="fas fa-wallet"></i> My Wallet
                            </a>
                            <hr>
                            <a onclick="confirmLogout()" style="cursor:pointer;">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                            <% } else { %>
                                <a href="/signIn" onclick="closeProfileDropdown()">
                                    <i class="fas fa-sign-in-alt"></i> Sign In
                                </a>
                                <a href="/signUp" onclick="closeProfileDropdown()">
                                    <i class="fas fa-user-plus"></i> Sign Up
                                </a>
                                <% } %>
            </div>
        </div>
    </div>

    <!-- Hamburger -->
    <div class="hamburger" onclick="toggleSidebar()">
        <span></span>
        <span></span>
        <span></span>
    </div>
</nav>

<!-- ========== MOBILE SIDEBAR ========== -->
<div class="mobile-sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <i class="fas fa-store"></i>
            <span class="logo">Zyrox</span>
        </div>
        <button class="close-btn" onclick="toggleSidebar()">
            <i class="fas fa-times"></i>
        </button>
    </div>

    <ul class="sidebar-links">
        <!-- Sidebar Search -->
        <li class="sidebar-search-item px-3 mb-4">
            <form action="/products" method="GET" class="sidebar-search-box">
                <input type="text" name="search" placeholder="Search products..." class="sidebar-search-input">
                <button type="submit" class="sidebar-search-btn"><i class="fas fa-search"></i></button>
            </form>
        </li>
        <li>
            <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>" onclick="toggleSidebar()">
                Home
            </a>
        </li>
        <li>
            <a href="/products" class="<%= currentPage === 'products' ? 'active' : '' %>" onclick="toggleSidebar()">
                Products
            </a>
        </li>

        <!-- Sidebar Categories Accordion -->
        <li>
            <details class="sidebar-dropdown">
                <summary class="<%= currentPage === 'categories' ? 'active' : '' %>">
                    Categories
                </summary>
                <div class="sidebar-cat-links">
                    <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                        <% categories.forEach(category=> { %>
                            <a href="/products?brand=<%= category.categoryName %>" onclick="toggleSidebar()">
                                <i class="fas fa-tag" style="font-size:11px; margin-right:8px; color:#4f6ef7;"></i>
                                <%= category.categoryName %>
                            </a>
                            <% }) %>
                                <% } else { %>
                                    <a href="#">No categories found</a>
                                    <% } %>
                </div>
            </details>
        </li>

        <li>
            <a href="/aboutUs" class="<%= currentPage === 'aboutUs' ? 'active' : '' %>" onclick="toggleSidebar()">
                About Us
            </a>
        </li>

        <!-- Sidebar Account Section -->
        <li class="sidebar-divider"></li>
        <li>
            <details class="sidebar-dropdown">
                <summary class="<%= (['profile', 'orders', 'wallet', 'address'].includes(currentPage)) ? 'active' : '' %>">
                    <i class="fas fa-user-circle" style="margin-right: 8px;"></i>
                    <%= user ? user.Name.split(' ')[0].toUpperCase() : 'ACCOUNT' %>
                </summary>
                <div class="sidebar-cat-links">
                    <% if (user) { %>
                        <a href="/profile" onclick="toggleSidebar()">
                            <i class="fas fa-user-circle" style="font-size:11px; margin-right:8px; color:#4f6ef7;"></i>
                            My Profile
                        </a>
                        <a href="/myOrders" onclick="toggleSidebar()">
                            <i class="fas fa-box" style="font-size:11px; margin-right:8px; color:#4f6ef7;"></i>
                            My Orders
                        </a>
                        <a href="/wallet" onclick="toggleSidebar()">
                            <i class="fas fa-wallet" style="font-size:11px; margin-right:8px; color:#4f6ef7;"></i>
                            My Wallet
                        </a>
                        <a href="/address" onclick="toggleSidebar()">
                            <i class="fas fa-map-marker-alt" style="font-size:11px; margin-right:8px; color:#4f6ef7;"></i>
                            My Addresses
                        </a>
                        <a onclick="confirmLogout()" style="cursor:pointer; color: #ff4d4d !important;">
                            <i class="fas fa-sign-out-alt" style="font-size:11px; margin-right:8px;"></i>
                            Logout
                        </a>
                    <% } else { %>
                        <a href="/signIn" onclick="toggleSidebar()">
                            <i class="fas fa-sign-in-alt" style="font-size:11px; margin-right:8px; color:#4f6ef7;"></i>
                            Sign In
                        </a>
                        <a href="/signUp" onclick="toggleSidebar()">
                            <i class="fas fa-user-plus" style="font-size:11px; margin-right:8px; color:#4f6ef7;"></i>
                            Sign Up
                        </a>
                    <% } %>
                </div>
            </details>
        </li>
    </ul>
</div>

<!-- ========== OVERLAY ========== -->
<div class="overlay" id="overlay" onclick="toggleSidebar()"></div>
<!-- JavaScript -->
<script>

    function confirmLogout() {

        Swal.fire({
            icon: 'warning',
            text: "are you sure you want to logout?",
            showCancelButton: true,
            confirmButtonText: "yes,iam sure",
            cancelButtonText: "NO"
        }).then((isconfirm) => {
            if (isconfirm.isConfirmed) {
                window.location.href = "/logout"
            }
        })

    }






    // Toggle Sidebar
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');
        const hamburger = document.querySelector('.hamburger');
        const navLogo = document.getElementById('navLogo');

        sidebar.classList.toggle('active');
        overlay.classList.toggle('active');
        hamburger.classList.toggle('active');

        // Animate logo in mobile
        if (window.innerWidth < 768) {
            navLogo.classList.toggle('mobile-active');
        }
    }

    // Toggle Profile Dropdown
    function toggleProfileDropdown() {
        const dropdown = document.getElementById('profileDropdown');
        const btn = document.getElementById('profileBtn');

        dropdown.classList.toggle('show');
        btn.classList.toggle('active');
    }

    // Close Profile Dropdown
    function closeProfileDropdown() {
        const dropdown = document.getElementById('profileDropdown');
        const btn = document.getElementById('profileBtn');

        dropdown.classList.remove('show');
        btn.classList.remove('active');
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function (event) {
        const dropdown = document.getElementById('profileDropdown');
        const btn = document.getElementById('profileBtn');

        if (!btn.contains(event.target) && !dropdown.contains(event.target)) {
            closeProfileDropdown();
        }
    });

    // Prevent body scroll when sidebar is open
    const sidebar = document.getElementById('sidebar');
    const observer = new MutationObserver(function (mutations) {
        mutations.forEach(function (mutation) {
            if (sidebar.classList.contains('active')) {
                document.body.style.overflow = 'hidden';
            } else {
                document.body.style.overflow = 'auto';
            }
        });
    });

    observer.observe(sidebar, {
        attributes: true,
        attributeFilter: ['class']
    });

    // Category Filter from Navbar
    function handleCategorySelect(event, categoryName) {
        // Find the checkbox within the current context (either event target or currentTarget)
        const checkbox = event.currentTarget.tagName === 'DIV'
            ? event.currentTarget.querySelector('input[type="checkbox"]')
            : event.target;

        // If clicked on the div, manually toggle checkbox (if event wasn't from the checkbox itself)
        if (event.currentTarget.tagName === 'DIV' && event.target !== checkbox) {
            checkbox.checked = !checkbox.checked;
        }

        updateCategoryFilters();
    }

    function updateCategoryFilters() {
        const checkboxes = document.querySelectorAll('.dropdown-item-wrap input[type="checkbox"]:checked');
        const selected = Array.from(checkboxes).map(cb => cb.value);

        const currentUrl = new URL(window.location.href);
        const productsUrl = new URL(window.location.origin + '/products');

        // If we're already on the products page, keep other filters but update brand
        if (window.location.pathname === '/products') {
            currentUrl.searchParams.delete('brand');
            currentUrl.searchParams.delete('page'); // Reset to first page
            selected.forEach(val => currentUrl.searchParams.append('brand', val));
            window.location.href = currentUrl.toString();
        } else {
            // If on another page, just go to products with the brand filter
            selected.forEach(val => productsUrl.searchParams.append('brand', val));
            window.location.href = productsUrl.toString();
        }
    }
</script>

