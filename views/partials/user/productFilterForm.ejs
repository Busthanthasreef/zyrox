<%
  const fSuffix = (typeof suffix !== 'undefined') ? suffix : '';
  const fMobile = (typeof isMobile !== 'undefined') && isMobile;
%>
<form id="filterForm<%= fSuffix %>" method="GET" action="/products" onsubmit="showLoading()">

    <!-- Hidden: always carry sort & search so submitting the filter doesn't lose them -->
    <input type="hidden" name="sort"   id="hiddenSort<%= fSuffix %>"   value="<%= curSort   %>">
    <input type="hidden" name="search" id="hiddenSearch<%= fSuffix %>" value="<%= curSearch %>">

    <div class="sidebar-header">
        <span class="sidebar-title">Filter by</span>
        <a href="/products<% if (curSort) { %>?sort=<%= curSort %><% } %>"
            class="clear-all text-decoration-none" onclick="showLoading()">Clear All</a>
    </div>

    <!-- BRANDS (CATEGORIES) -->
    <div class="sidebar-section">
        <div class="sidebar-section-title" style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
            <span style="flex-shrink: 0;">Brands</span>
            <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(212, 175, 55, 0.3), transparent);"></div>
            <% if (safeBrands.length > 5) { %>
                <button type="button" class="toggle-more-btn" onclick="toggleMoreItems('brands<%= fSuffix %>', this)" style="background: none; border: none; color: var(--accent); font-size: 0.7rem; font-weight: 700; cursor: pointer; padding: 2px 6px; display: flex; align-items: center; gap: 4px; flex-shrink: 0;">
                    <span class="toggle-text">More</span>
                    <i class="fas fa-chevron-down toggle-icon" style="font-size: 0.6rem; transition: transform 0.3s;"></i>
                </button>
            <% } %>
        </div>
        <% if (safeBrands.length > 0) { %>
            <div id="brands<%= fSuffix %>">
                <% safeBrands.forEach((brand, index) => { %>
                    <div class="cb-row <%= index >= 5 ? 'hidden-item' : '' %>" style="<%= index >= 5 ? 'display: none;' : '' %>">
                        <label>
                            <input type="checkbox" name="brand" value="<%= brand.name %>"
                                <%= curBrands.includes(brand.name) ? 'checked' : '' %>
                                <% if (!fMobile) { %>onchange="handlePriceSubmit('<%= fSuffix %>')"<% } %>>
                            <span><%= brand.name %></span>
                        </label>
                        <span class="cb-count"><%= brand.count %></span>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <span class="no-data">No categories available</span>
        <% } %>
    </div>

    <!-- PRICE RANGE -->
    <div class="sidebar-section">
        <div class="sidebar-section-title">Price Range</div>
        <div class="price-inputs-row">
            <div class="p-input-group">
                <label for="minPriceInput<%= fSuffix %>">Min</label>
                <div class="p-input-wrap">
                    <span>₹</span>
                    <input type="number" name="minPrice"
                        id="minPriceInput<%= fSuffix %>"
                        value="<%= curMin %>"
                        min="<%= PRICE_MIN_VAL %>" max="<%= PRICE_MAX_VAL %>" step="1">
                </div>
            </div>
            <div class="p-input-group">
                <label for="maxPriceInput<%= fSuffix %>">Max</label>
                <div class="p-input-wrap">
                    <span>₹</span>
                    <input type="number" name="maxPrice"
                        id="maxPriceInput<%= fSuffix %>"
                        value="<%= curMax %>"
                        min="<%= PRICE_MIN_VAL %>" max="<%= PRICE_MAX_VAL %>" step="1">
                </div>
            </div>
        </div>
        <% if (!fMobile) { %>
            <div class="mt-3">
                <button type="submit" class="btn-apply-desktop" onclick="showLoading()">
                    Apply Range
                </button>
            </div>
        <% } %>
    </div>

    <!-- COLOR -->
    <div class="sidebar-section">
        <div class="sidebar-section-title" style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
            <span style="flex-shrink: 0;">Color</span>
            <div style="flex: 1; height: 1px; background: linear-gradient(to right, rgba(212, 175, 55, 0.3), transparent);"></div>
            <% if (safeColors.length > 5) { %>
                <button type="button" class="toggle-more-btn" onclick="toggleMoreItems('colors<%= fSuffix %>', this)" style="background: none; border: none; color: var(--accent); font-size: 0.7rem; font-weight: 700; cursor: pointer; padding: 2px 6px; display: flex; align-items: center; gap: 4px; flex-shrink: 0;">
                    <span class="toggle-text">More</span>
                    <i class="fas fa-chevron-down toggle-icon" style="font-size: 0.6rem; transition: transform 0.3s;"></i>
                </button>
            <% } %>
        </div>
        <% if (safeColors.length > 0) { %>
            <div id="colors<%= fSuffix %>">
                <% safeColors.forEach((color, index) => { %>
                    <div class="cb-row <%= index >= 5 ? 'hidden-item' : '' %>" style="<%= index >= 5 ? 'display: none;' : '' %>">
                        <label>
                            <input type="checkbox" name="color" value="<%= color %>"
                                <%= curColors.includes(color) ? 'checked' : '' %>
                                <% if (!fMobile) { %>onchange="handlePriceSubmit('<%= fSuffix %>')"<% } %>>
                            <span><%= color %></span>
                        </label>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <span class="no-data">No colors</span>
        <% } %>
    </div>

    <!-- Apply (Mobile only) -->
    <% if (fMobile) { %>
    <div class="mt-4 pb-3">
        <button type="submit" class="btn w-100 py-3 fw-bold"
            style="border-radius:12px;background:var(--accent);border:none;color:#000;"
            onclick="showLoading()">
            APPLY FILTERS
        </button>
    </div>
    <% } %>

</form>