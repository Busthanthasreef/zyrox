<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/userStyles/error/error404.css">
</head>

<body>
    <div class="error-container">
        <div class="search-icon">
            <div class="search-circle-outer">
                <div class="search-circle-inner">
                    <div class="search-glass"></div>
                </div>
            </div>
        </div>

        <h1>404 - Page not found</h1>
        <p class="error-message">
            Sorry, we couldn't find the page you're looking for. Perhaps you've mistyped the URL?
        </p>
        <% if (user) { %>
            <a href="/" class="btn-dashboard text-decoration-none">
                <svg class="home-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                </svg>
                Go To Home
            </a>
            <% } %>
            <%if(admin){%>
                <a href="/admin/dashboard" class="btn-dashboard text-decoration-none">
                    <svg class="home-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                    </svg>
                    Go To Dashboard
                </a>
                <% } %>

                    <p class="footer-text">Page not found</p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>