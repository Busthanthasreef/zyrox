<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zyrox – My Wallet</title>


    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
    <style>
        :root {
            --bg-deep: #0c0f1a;
            --bg-card: #141824;
            --bg-card-h: #1a1f2e;
            --accent: #4f6ef7;
            --accent-rgb: 0, 255, 4;
            --primary-blue: #4f6ef7;
            --text: #e8eaf6;
            --sub: #7b8fb5;
            --border: rgba(255, 255, 255, 0.05);
            --border2: rgba(255, 255, 255, 0.1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-deep);
            color: var(--text);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* ── CONTENT ── */
        .page-wrapper {
            display: flex;
            min-height: 100vh;
            align-items: flex-start;
            padding-top: 80px;
        }

        .main-wrapper {
            flex: 1;
            padding-bottom: 80px; /* Space for bottom nav */
        }

        .content-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 24px 20px;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .page-subtitle {
            font-size: 0.85rem;
            color: var(--sub);
            margin-bottom: 24px;
        }

        /* ── BALANCE CARD ── */
        .balance-card {
            background: var(--bg-card);
            border: 1px solid var(--border2);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 30px;
            position: relative;
        }

        .balance-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--sub);
            letter-spacing: 1px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .balance-label i {
            color: var(--accent);
            font-size: 0.9rem;
        }

        .balance-amount-wrap {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .balance-amount {
            font-size: 2.2rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .currency-symbol {
            color: var(--accent);
            font-weight: 700;
        }

        .btn-add-money-mini {
            background: var(--accent);
            color: #000;
            border: none;
            border-radius: 10px;
            padding: 8px 16px;
            font-size: 0.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 4px 15px rgba(var(--accent-rgb), 0.3);
            transition: all 0.2s;
        }

        .balance-footer-note {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 50px;
            padding: 8px 16px;
            font-size: 0.75rem;
            color: var(--sub);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .balance-footer-note i {
            color: var(--accent);
        }

        /* ── SECTION HEADING ── */
        .section-heading {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-heading i {
            color: #4a90e2;
        }

        /* ── TRANSACTION CARDS (MOBILE) ── */
        .txn-card {
            background: var(--bg-card);
            border: 1px solid var(--border2);
            border-radius: 16px;
            padding: 18px;
            margin-bottom: 15px;
        }

        .txn-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .txn-card-date {
            font-size: 0.75rem;
            color: var(--sub);
        }

        .txn-card-amount {
            font-size: 1rem;
            font-weight: 800;
        }

        .txn-card-desc-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }

        .txn-card-title {
            font-size: 1rem;
            font-weight: 700;
        }

        .txn-badge {
            font-size: 0.6rem;
            font-weight: 800;
            padding: 3px 10px;
            border-radius: 6px;
            text-transform: uppercase;
        }

        .badge-credit {
            background: rgba(var(--accent-rgb), 0.1);
            color: var(--accent);
            border: 1px solid rgba(var(--accent-rgb), 0.2);
        }

        .badge-debit {
            background: rgba(255, 77, 109, 0.1);
            color: #ff4d6d;
            border: 1px solid rgba(255, 77, 109, 0.2);
        }

        .txn-card-order {
            font-size: 0.8rem;
            color: var(--sub);
            margin-bottom: 12px;
        }

        .txn-card-footer {
            font-size: 0.7rem;
            color: rgba(255, 255, 255, 0.3);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .txn-card-footer .divider {
            color: rgba(255, 255, 255, 0.1);
        }

        .amount-credit { color: var(--accent); }
        .amount-debit { color: #ff4d6d; }

        /* ── TABLE (DESKTOP) ── */
        .txn-table { width: 100%; border-collapse: collapse; }
        .txn-table th { padding: 12px; font-size: 0.75rem; color: var(--sub); text-align: left; border-bottom: 1px solid var(--border2); }
        .txn-table td { padding: 15px 12px; font-size: 0.85rem; border-bottom: 1px solid var(--border); }

        /* ── SECURE BANNER ── */
        .secure-banner {
            background: rgba(var(--accent-rgb), 0.05);
            border: 1px solid rgba(var(--accent-rgb), 0.1);
            border-radius: 12px;
            padding: 15px;
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .secure-banner i { color: var(--accent); font-size: 1.2rem; }
        .secure-banner-title { font-weight: 700; font-size: 0.85rem; margin-bottom: 4px; }
        .secure-banner-text { font-size: 0.75rem; color: var(--sub); line-height: 1.4; }

        /* ── FOOTER STYLES ── */
        .footer-zyrox {
            background: #080a12;
            border-top: 1px solid var(--border);
            padding: 60px 20px 30px;
            margin-top: 50px;
        }
        .footer-brand { font-size: 1.5rem; font-weight: 800; margin-bottom: 20px; color: #fff; }
        .footer-brand span { color: var(--accent); }
        .footer-tagline { color: var(--sub); font-size: 0.85rem; line-height: 1.6; margin-bottom: 25px; }
        .footer-social { display: flex; gap: 12px; }
        .social-btn {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--sub);
            transition: all 0.3s;
            text-decoration: none;
        }
        .social-btn:hover { background: var(--accent); color: #000; transform: translateY(-3px); }
        .footer-col-title { font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px; }
        .footer-link { display: block; color: var(--sub); font-size: 0.85rem; margin-bottom: 12px; text-decoration: none; transition: 0.2s; }
        .footer-link:hover { color: var(--accent); padding-left: 5px; }
        .footer-divider { border-color: var(--border); margin: 40px 0 20px; }
        .footer-copy { font-size: 0.75rem; color: var(--sub); }

        @media (max-width: 992px) {
            .desktop-sidebar { display: none !important; }
            .content-container { padding: 15px 16px 40px; }
            .footer-zyrox { display: none !important; } /* Hide big footer on mobile */
        }

        /* ── MODAL STYLES ── */
        .modal-zyrox .modal-content {
            background: #111627;
            border: 1px solid var(--border2);
            border-radius: 20px;
            color: var(--text);
        }
        .modal-zyrox .modal-header { border-bottom: 1px solid var(--border); padding: 20px 24px; }
        .modal-zyrox .modal-title { font-weight: 800; font-size: 1.1rem; }
        .modal-zyrox .btn-close { filter: invert(1); opacity: 0.5; }
        .modal-zyrox .modal-body { padding: 24px; }

        .modal-balance-row {
            background: rgba(255,255,255,0.03);
            border-radius: 12px;
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .modal-balance-label { font-size: 0.75rem; color: var(--sub); }
        .modal-balance-value { font-weight: 700; color: var(--accent); }

        .preset-label { font-size: 0.7rem; font-weight: 700; color: var(--sub); margin-bottom: 10px; text-transform: uppercase; }
        
        .amount-input-wrap { position: relative; margin-bottom: 20px; }
        .rupee-sign { position: absolute; left: 16px; top: 12px; color: var(--accent); font-weight: 700; font-size: 1.2rem; }
        .amount-input {
            width: 100%;
            background: #1a1f2e;
            border: 1px solid var(--border2);
            border-radius: 12px;
            padding: 12px 16px 12px 40px;
            color: #fff;
            font-size: 1.2rem;
            font-weight: 700;
        }
        .amount-hint { font-size: 0.65rem; color: var(--sub); margin-top: 6px; }

        .preset-chips { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 25px; }
        .preset-chip {
            background: #1a1f2e;
            border: 1px solid var(--border2);
            border-radius: 10px;
            padding: 8px;
            text-align: center;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .preset-chip:hover { border-color: var(--accent); background: rgba(var(--accent-rgb), 0.05); }
        .preset-chip.selected { background: var(--accent); color: #000; border-color: var(--accent); }

        .btn-confirm-add {
            width: 100%;
            background: var(--accent);
            color: #000;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 800;
            font-size: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.2s;
        }
        .btn-confirm-add:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn-confirm-add:not(:disabled):hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(var(--accent-rgb), 0.4); }

        /* ── PAGINATION ── */
        .pagination-zyrox {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-top: 28px;
            margin-bottom: 8px;
        }

        .pag-item {
            width: 38px;
            height: 38px;
            border-radius: 9px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--sub);
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 700;
            transition: all 0.2s;
        }

        .pag-item.active {
            background: var(--accent);
            color: #000;
            border-color: var(--accent);
            box-shadow: 0 0 15px rgba(79, 110, 247, 0.4);
        }

        .pag-item:hover:not(.active) {
            background: rgba(255, 255, 255, 0.06);
            color: #fff;
            border-color: var(--border2);
        }
    </style>
</head>

<body>
    <%- include('../../partials/user/navigationbar') %>
    <!-- ═══════════ PAGE WRAPPER ═══════════ -->
    <div class="page-wrapper">

        <!-- ── SIDEBAR ── -->
        <%- include('../../partials/user/profileSidebar', { activePage: 'wallet' }) %>


            <!-- ── MAIN ── -->
            <main class="main-wrapper">

                <div class="content-container">

                    <header class="page-header">
                        <h1 class="page-title">My Wallet</h1>
                        <p class="page-subtitle">Your secure digital wallet for faster checkouts and easy refunds.</p>
                    </header>

                    <!-- Premium Balance Card -->
                    <div class="balance-card">
                        <div class="balance-main">
                            <div class="balance-label">
                                <i class="fas fa-shield-alt"></i> AVAILABLE BALANCE
                            </div>
                            <div class="balance-amount-wrap">
                                <div class="balance-amount">
                                    <span class="currency-symbol">₹</span>
                                    <%= (wallet && wallet.balance ? wallet.balance : 0).toLocaleString('en-IN', {
                                        minimumFractionDigits: 2 }) %>
                                </div>
                                <button class="btn-add-money-mini">
                                    <i class="fas fa-plus-circle"></i> Add Money
                                </button>
                            </div>
                            <div class="balance-footer-note">
                                <i class="fas fa-check-circle"></i>
                                <span>Ready for instant transactions & easy refunds</span>
                            </div>
                        </div>
                    </div>

                    <!-- Transaction History -->
                    <div class="section-heading">
                        <i class="far fa-clock"></i> Transaction History
                    </div>

                    <div class="txn-list-mobile d-lg-none">
                        <% if (transactions && transactions.length> 0) { %>
                            <% transactions.forEach(txn=> { %>
                                <div class="txn-card">
                                    <div class="txn-card-header">
                                        <div class="txn-card-date">
                                            <%= new Date(txn.Payment_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>, 
                                            <%= new Date(txn.Payment_time).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                                        </div>
                                        <div class="txn-card-amount <%= txn.Amount > 0 ? 'amount-credit' : 'amount-debit' %>">
                                            <%= txn.Amount > 0 ? '+' : '' %>₹<%= Math.abs(txn.Amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                                        </div>
                                    </div>
                                    <div class="txn-card-body">
                                        <div class="txn-card-desc-row">
                                            <div class="txn-card-title"><%= txn.Description %></div>
                                            <span class="txn-badge <%= txn.Amount > 0 ? 'badge-credit' : 'badge-debit' %>">
                                                <%= txn.Amount > 0 ? 'Credit' : 'Debit' %>
                                            </span>
                                        </div>
                                        <div class="txn-card-order">
                                            <% if (txn.Order_id) { %>
                                                for Cancelled Order #ORD-<%= txn.Order_id.toString().substring(0, 12).toUpperCase() %>
                                            <% } %>
                                        </div>
                                        <div class="txn-card-footer">
                                            <span>Txn ID: <%= txn._id.toString().substring(0, 12).toUpperCase() %></span>
                                            <% if (txn.Order_id) { %>
                                                <span class="divider">|</span>
                                                <span>Order ID: #ORD-<%= txn.Order_id.toString().substring(0, 12).toUpperCase() %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-txns">No transactions found</div>
                        <% } %>
                    </div>

                    <div class="txn-table-wrap d-none d-lg-block">
                        <div class="txn-table-container">
                            <table class="txn-table">
                                <thead>
                                    <tr>
                                        <th>Date &amp; Time</th>
                                        <th>Transaction ID</th>
                                        <th>Order ID</th>
                                        <th>Description</th>
                                        <th>Status</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    <% if (transactions && transactions.length> 0) { %>
                                        <% transactions.forEach(txn=> { %>
                                            <tr>
                                                <td>
                                                    <div class="fw-500">
                                                        <%= new Date(txn.Payment_date).toLocaleDateString('en-US', {
                                                            month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                                    </div>
                                                    <div class="txn-date">
                                                        <%= new Date(txn.Payment_time).toLocaleTimeString('en-US', {
                                                            hour: '2-digit' , minute: '2-digit' }) %>
                                                    </div>
                                                </td>
                                                <td class="txn-id">
                                                    <%= txn._id.toString().substring(0, 12).toUpperCase() %>
                                                </td>
                                                <td>
                                                    <% if (txn.Order_id) { %>
                                                        <a href="/myOrders/details?id=<%= txn.Order_id %>"
                                                            class="order-link">#ORD-<%=
                                                                txn.Order_id.toString().substring(0, 8).toUpperCase() %>
                                                        </a>
                                                        <% } else { %>
                                                            <span class="text">N/A</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <%= txn.Description %>
                                                </td>
                                                <td>
                                                    <% if (txn.Amount> 0) { %>
                                                        <span class="badge-status badge-success"><i
                                                                class="bi bi-arrow-down-circle"></i> Credit</span>
                                                        <% } else { %>
                                                            <span class="badge-status badge-danger"><i
                                                                    class="bi bi-arrow-up-circle"></i> Debit</span>
                                                            <% } %>
                                                </td>
                                                <td
                                                    class="text-end <%= txn.Amount > 0 ? 'amount-credit' : 'amount-debit' %>">
                                                    <%= txn.Amount> 0 ? '+' : '' %>₹<%=
                                                            Math.abs(txn.Amount).toLocaleString('en-IN', {
                                                            minimumFractionDigits: 2 }) %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6" class="text-center py-5">
                                                            <div class="text-muted mb-2"><i
                                                                    class="bi bi-wallet2 fs-2"></i>
                                                            </div>
                                                            <div class="text-muted">No transactions found.</div>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <% if (totalPages> 1) { %>
                            <div class="pagination-zyrox">
                                <% if (currentPage > 1) { %>
                                    <a href="/wallet?page=<%= currentPage - 1 %>" class="pag-item">
                                        <i class="fas fa-chevron-left" style="font-size: 11px;"></i>
                                    </a>
                                <% } %>

                                <% for(let i = 1; i <= totalPages; i++) { %>
                                    <a href="/wallet?page=<%= i %>" class="pag-item <%= currentPage === i ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                <% } %>

                                <% if (currentPage < totalPages) { %>
                                    <a href="/wallet?page=<%= currentPage + 1 %>" class="pag-item">
                                        <i class="fas fa-chevron-right" style="font-size: 11px;"></i>
                                    </a>
                                <% } %>
                            </div>
                            <% } %>
                    </div>

                    <!-- Secure Wallet Banner -->
                    <div class="secure-banner">
                        <i class="bi bi-shield-lock-fill"></i>
                        <div>
                            <div class="secure-banner-title">Secure Wallet</div>
                            <div class="secure-banner-text">
                                Your wallet is securely stored using bank-grade encryption and can be used seamlessly
                                during
                                checkout.
                                We never store your card details in plain text.
                            </div>
                        </div>
                    </div>

                </div> <!-- End content-container -->
            </main>
    </div>

    <%- include('../../partials/user/bottomNav', { activePage: 'wallet' }) %>

    <!-- ═══════════ ADD MONEY MODAL ═══════════ -->
    <div class="modal fade modal-zyrox" id="addMoneyModal" tabindex="-1" aria-labelledby="addMoneyModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title" id="addMoneyModalLabel">
                        <i class="bi bi-wallet2 me-2" style="color:var(--accent)"></i>Add Money
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">

                    <!-- Current Balance -->
                    <div class="modal-balance-row">
                        <span class="modal-balance-label">Current Balance</span>
                        <span class="modal-balance-value">
                            ₹<%= (wallet && wallet.balance ? wallet.balance : 0).toLocaleString('en-IN', {
                                minimumFractionDigits: 2 }) %>
                        </span>
                    </div>
                    <!-- Custom Amount Input -->
                    <div class="preset-label">Enter Amount</div>
                    <div class="amount-input-wrap">
                        <span class="rupee-sign">₹</span>
                        <input type="number" class="amount-input" id="addMoneyInput" placeholder="0.00" min="1"
                            max="100000" />
                        <div class="amount-hint">Min ₹1 &nbsp;·&nbsp; Max ₹1,00,000 per transaction</div>
                    </div>

                    <!-- Preset Chips -->
                    <div class="preset-label">Quick Select</div>
                    <div class="preset-chips">
                        <div class="preset-chip" data-amount="500">₹500</div>
                        <div class="preset-chip" data-amount="1000">₹1,000</div>
                        <div class="preset-chip" data-amount="2000">₹2,000</div>
                        <div class="preset-chip" data-amount="5000">₹5,000</div>
                        <div class="preset-chip" data-amount="10000">₹10,000</div>
                        <div class="preset-chip" data-amount="50000">₹50,000</div>
                    </div>


                    <!-- Confirm Button -->
                    <button class="btn-confirm-add" id="confirmAddBtn" disabled>
                        <i class="bi bi-plus-circle-fill"></i>
                        <span id="confirmBtnText">Add Money</span>
                    </button>

                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════ FOOTER ═══════════ -->
    <footer class="footer-zyrox">
        <div class="row g-4">

            <!-- Brand col -->
            <div class="col-12 col-md-3">
                <div class="footer-brand"><i class="bi bi-hexagon-fill me-1"></i>Zy<span>rox</span></div>
                <p class="footer-tagline">
                    Your trusted destination for genuine smartphones from top brands.
                    Secure payments and exceptional customer service.
                </p>
                <div class="footer-social">
                    <a href="#" class="social-btn"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-youtube"></i></a>
                </div>
