    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Use the key passed from the controller
        const RAZORPAY_KEY = '<%= razorpayKeyId %>';

        // ── Pagination ──
        // (Existing pagination logic can be simplified as it's now handled by the server)

        // ── Add Money Modal ──
        const addMoneyModalEl = document.getElementById('addMoneyModal');
        const addMoneyModal = new bootstrap.Modal(addMoneyModalEl);

        // Open modal on button click
        document.querySelector('.btn-add-money-mini').addEventListener('click', () => {
            addMoneyModal.show();
        });

        const amountInput = document.getElementById('addMoneyInput');
        const confirmBtn = document.getElementById('confirmAddBtn');
        const confirmTxt = document.getElementById('confirmBtnText');
        const presetChips = document.querySelectorAll('.preset-chip');

        // Preset chip selection
        presetChips.forEach(chip => {
            chip.addEventListener('click', function () {
                presetChips.forEach(c => c.classList.remove('selected'));
                this.classList.add('selected');
                amountInput.value = this.dataset.amount;
                updateConfirmBtn(this.dataset.amount);
            });
        });

        // Manual input clears chip selection
        amountInput.addEventListener('input', function () {
            presetChips.forEach(c => c.classList.remove('selected'));
            updateConfirmBtn(this.value);
        });

        function updateConfirmBtn(val) {
            const amount = parseFloat(val);
            if (amount >= 1 && amount <= 100000) {
                confirmBtn.disabled = false;
                confirmTxt.textContent = `Add ₹${Number(amount).toLocaleString('en-IN')}`;
            } else {
                confirmBtn.disabled = true;
                confirmTxt.textContent = 'Add Money';
            }
        }

        // Confirm action with Razorpay
        confirmBtn.addEventListener('click', async function () {
            const amount = parseFloat(amountInput.value);
            if (isNaN(amount) || amount < 1) return;

            confirmBtn.disabled = true;
            confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';

            try {
                // 1. Create order on server
                const response = await fetch('/wallet/add-money', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount })
                });

                const data = await response.json();
                if (!data.success) throw new Error(data.message);

                // 2. Open Razorpay Modal
                const options = {
                    key: RAZORPAY_KEY,
                    amount: data.order.amount,
                    currency: data.order.currency,
                    name: "Zyrox",
                    description: "Wallet Top-up",
                    order_id: data.order.id,
                    handler: async function (response) {
                        try {
                            // 3. Verify payment on server
                            const verifyRes = await fetch('/wallet/verify-payment', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature,
                                    amount: amount
                                })
                            });

                            const verifyData = await verifyRes.json();
                            if (verifyData.success) {
                                addMoneyModal.hide();
                                await Swal.fire({
                                    icon: 'success',
                                    title: 'Payment Successful',
                                    text: '₹' + amount + ' has been added to your wallet.',
                                    background: '#111627',
                                    color: '#fff',
                                    confirmButtonColor: '#00e676'
                                });
                                window.location.reload();
                            } else {
                                throw new Error(verifyData.message);
                            }
                        } catch (err) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Verification Failed',
                                text: err.message,
                                background: '#111627',
                                color: '#fff'
                            });
                        }
                    },
                    prefill: {
                        name: "<%= user && user.Name ? user.Name : '' %>",
                        email: "<%= user && user.Email ? user.Email : '' %>",
                        contact: "<%= user && user.Phone_number ? user.Phone_number : '' %>"
                    },
                    theme: { color: "#00e676" },
                    modal: {
                        ondismiss: function () {
                            confirmBtn.disabled = false;
                            confirmBtn.innerHTML = '<i class="bi bi-plus-circle-fill"></i> Add Money';
                        }
                    }
                };

                const rzp = new Razorpay(options);
                rzp.open();

            } catch (error) {
                console.error(error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: error.message || 'Something went wrong!',
                    background: '#111627',
                    color: '#fff'
                });
                confirmBtn.disabled = false;
                confirmBtn.innerHTML = '<i class="bi bi-plus-circle-fill"></i> Add Money';
            }
        });
    </script>

</body>

