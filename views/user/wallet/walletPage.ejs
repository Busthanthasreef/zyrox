<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zyrax – My Wallet</title>


    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">

    <style>
        :root {
            --bg-deep: #0c0f1a;
            --bg-card: #111627;

            --bg-row: #161c30;
            --accent-green: #00e676;
            --accent-teal: #00bcd4;
            --accent-red: #ff4d6d;
            --accent-gold: #ffd600;
            --text-primary: #e8eaf6;
            --text-muted: #7b8fb5;
            --border: #1e2a45;
            --nav-bg: #0a0d18;
            --card-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
            --green-glow: 0 0 18px rgba(0, 230, 118, 0.35);
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-deep);
            color: var(--text-primary);
            /* min-height: 100vh; */
        }

        /* ── NAVBAR ── */
        .navbar-zyrax {
            background: var(--nav-bg);
            border-bottom: 1px solid var(--border);
            padding: 0 1.5rem;
            height: 58px;
        }

        .brand-logo {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.45rem;
            color: var(--accent-green) !important;
            letter-spacing: -0.5px;
            text-decoration: none;
        }

        .brand-logo span {
            color: var(--text-primary);
        }

        .nav-link-top {
            color: var(--text-muted) !important;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0 .9rem !important;
            transition: color .2s;
        }

        .nav-link-top:hover {
            color: var(--accent-green) !important;
        }

        .search-bar {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-primary);
            font-size: 0.82rem;
            padding: .38rem 1rem;
            width: 230px;
            outline: none;
            transition: border-color .2s;
        }

        .search-bar::placeholder {
            color: var(--text-muted);
        }

        .search-bar:focus {
            border-color: var(--accent-green);
        }

        .nav-icon-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.2rem;
            padding: .25rem .5rem;
            transition: color .2s;
            cursor: pointer;
        }

        .nav-icon-btn:hover {
            color: var(--accent-green);
        }

        /* ── LAYOUT ── */
        .page-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ── MAIN CONTENT ── */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg-deep);
            height: 100vh;
            overflow-y: auto;
            position: relative;
        }

        .content-container {
            max-width: 1200px;
            width: 100%;
            margin: 0 auto;
            padding: 2.5rem 2rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .page-header {
            margin-bottom: 1.25rem;
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 0.25rem;
            letter-spacing: -0.5px;
        }

        .page-subtitle {
            font-size: 0.85rem;
            color: var(--text-muted);
            max-width: 600px;
        }

        /* ── BALANCE CARD ── */
        .balance-card {
            background: linear-gradient(135deg, rgba(21, 27, 49, 0.9) 0%, rgba(13, 18, 33, 0.95) 100%);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 22px;
            padding: 2.5rem;
            box-shadow: var(--card-shadow), 0 0 20px rgba(0, 230, 118, 0.05);
            position: relative;
            overflow: hidden;
            display: grid;
            grid-template-columns: 1fr auto;
            align-items: center;
            gap: 2rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .balance-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7);
            border-color: rgba(0, 230, 118, 0.2);
        }

        .balance-card::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(0, 230, 118, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .balance-main {
            flex: 1;
            min-width: 280px;
        }

        .balance-label {
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .balance-label i {
            color: var(--accent-green);
        }

        .balance-amount {
            font-family: 'Syne', sans-serif;
            font-size: 2.4rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -1px;
            line-height: 1;
            margin-bottom: 1rem;
            display: flex;
            align-items: baseline;
            gap: 0.4rem;
        }

        .balance-amount .currency-symbol {
            font-size: 1.4rem;
            color: var(--accent-green);
            font-weight: 700;
        }

        .balance-note-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.75rem;
            color: var(--text-primary);
            background: rgba(255, 255, 255, 0.05);
            padding: 0.4rem 1rem;
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .balance-note-pill i {
            color: var(--accent-green);
            font-size: 0.8rem;
        }

        .btn-add-money {
            background: var(--accent-green);
            color: #000;
            font-family: 'Inter', sans-serif;
            font-weight: 800;
            font-size: 0.9rem;
            border: none;
            border-radius: 12px;
            padding: 0.85rem 1.75rem;
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            box-shadow: var(--green-glow);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            white-space: nowrap;
        }

        .btn-add-money:hover {
            background: #fff;
            color: #000;
            transform: scale(1.05);
            box-shadow: 0 0 35px rgba(255, 255, 255, 0.3);
        }

        .btn-add-money i {
            font-size: 1.2rem;
        }

        /* ── TRANSACTION SECTION ── */
        .section-heading {
            font-family: 'Syne', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0.5rem 0 1rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .section-heading i {
            color: var(--accent-teal);
            font-size: 1.1rem;
        }

        /* ── TABLE (REFINED) ── */
        .txn-table-wrap {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: var(--card-shadow);
            display: flex;
            flex-direction: column;
            min-height: 350px;
        }

        .txn-table-container {
            flex-grow: 1;
            overflow-x: auto;
        }

        .txn-table {
            width: 100%;
            border-collapse: collapse;
        }

        .txn-table thead tr {
            background: rgba(255, 255, 255, 0.02);
            border-bottom: 1px solid var(--border);
        }

        .txn-table thead th {
            padding: 1rem 1.25rem;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--text-muted);
            text-align: left;
            white-space: nowrap;
        }

        .txn-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.2s;
        }

        .txn-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.03);
        }

        .txn-table tbody td {
            padding: 0.85rem 1.25rem;
            color: var(--text-primary);
            font-size: 0.85rem;
            vertical-align: middle;
        }

        .txn-date {
            color: var(--text-muted);
            font-size: .78rem;
        }

        .txn-id {
            font-family: 'DM Mono', monospace;
            font-size: .78rem;
            color: var(--text-muted);
            letter-spacing: .3px;
        }

        .order-link {
            color: var(--accent-teal);
            font-weight: 500;
            text-decoration: none;
            font-size: .82rem;
        }

        .order-link:hover {
            color: var(--accent-green);
            text-decoration: underline;
        }

        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .28rem .7rem;
            border-radius: 6px;
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: .4px;
        }

        .badge-success {
            background: rgba(0, 230, 118, 0.12);
            color: var(--accent-green);
            border: 1px solid rgba(0, 230, 118, 0.2);
        }

        .badge-danger {
            background: rgba(255, 77, 109, 0.12);
            color: var(--accent-red);
            border: 1px solid rgba(255, 77, 109, 0.2);
        }

        .badge-info {
            background: rgba(0, 188, 212, 0.12);
            color: var(--accent-teal);
            border: 1px solid rgba(0, 188, 212, 0.2);
        }

        .amount-credit {
            color: var(--accent-green);
            font-weight: 700;
        }

        .amount-debit {
            color: var(--accent-red);
            font-weight: 700;
        }

        /* ── PAGINATION ── */
        .txn-pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: .4rem;
            padding: 1rem;
            border-top: 1px solid var(--border);
        }

        .page-btn {
            background: var(--bg-row);
            border: 1px solid var(--border);
            color: var(--text-muted);
            border-radius: 7px;
            padding: .32rem .8rem;
            font-size: .78rem;
            cursor: pointer;
            transition: all .18s;
        }

        .page-btn:hover {
            border-color: var(--accent-green);
            color: var(--accent-green);
        }

        .page-btn.active {
            background: var(--accent-green);
            border-color: var(--accent-green);
            color: #000;
            font-weight: 700;
        }

        /* ── ADD MONEY MODAL ── */
        .modal-zyrax .modal-content {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
        }

        .modal-zyrax .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 1.25rem 1.5rem;
        }

        .modal-zyrax .modal-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--text-primary);
        }

        .modal-zyrax .btn-close {
            filter: invert(1) opacity(0.5);
        }

        .modal-zyrax .btn-close:hover {
            filter: invert(1) opacity(1);
        }

        .modal-zyrax .modal-body {
            padding: 1.5rem;
        }

        .modal-zyrax .modal-footer {
            border-top: 1px solid var(--border);
            padding: 1rem 1.5rem;
        }

        /* Current Balance display inside modal */
        .modal-balance-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--bg-row);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: .85rem 1.1rem;
            margin-bottom: 1.25rem;
        }

        .modal-balance-label {
            font-size: .78rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .modal-balance-value {
            font-family: 'Syne', sans-serif;
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--accent-green);
        }

        /* Preset amount chips */
        .preset-label {
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: .65rem;
        }

        .preset-chips {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            margin-bottom: 1.25rem;
        }

        .preset-chip {
            background: var(--bg-row);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-muted);
            font-size: .82rem;
            font-weight: 600;
            padding: .42rem .9rem;
            cursor: pointer;
            transition: all .18s;
            user-select: none;
        }

        .preset-chip:hover {
            border-color: var(--accent-green);
            color: var(--accent-green);
            background: rgba(0, 230, 118, 0.06);
        }

        .preset-chip.selected {
            border-color: var(--accent-green);
            background: rgba(0, 230, 118, 0.12);
            color: var(--accent-green);
            box-shadow: 0 0 10px rgba(0, 230, 118, 0.2);
        }

        /* Custom amount input */
        .amount-input-wrap {
            position: relative;
            margin-bottom: .35rem;
        }

        .amount-input-wrap .rupee-sign {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1rem;
            font-weight: 700;
            color: var(--accent-green);
            pointer-events: none;
        }

        .amount-input {
            width: 100%;
            background: var(--bg-row);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text-primary);
            font-family: 'Syne', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            padding: .75rem 1rem .75rem 2.2rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }

        .amount-input::placeholder {
            color: var(--text-muted);
            font-weight: 400;
            font-size: .9rem;
        }

        .amount-input:focus {
            border-color: var(--accent-green);
            box-shadow: 0 0 0 3px rgba(0, 230, 118, 0.12);
        }

        .amount-hint {
            font-size: .73rem;
            color: var(--text-muted);
            margin-top: .4rem;
        }

        /* Confirm button */
        .btn-confirm-add {
            width: 100%;
            background: var(--accent-green);
            color: #000;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            font-size: .9rem;
            border: none;
            border-radius: 10px;
            padding: .75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            box-shadow: var(--green-glow);
            transition: all .2s;
            cursor: pointer;
            margin-top: 1.25rem;
        }

        .btn-confirm-add:hover {
            background: #00ff85;
            transform: translateY(-1px);
            box-shadow: 0 0 28px rgba(0, 230, 118, 0.5);
        }

        .btn-confirm-add:disabled {
            background: #1a3a2a;
            color: #3a5a4a;
            box-shadow: none;
            transform: none;
            cursor: not-allowed;
        }

        /* ── SECURE WALLET BANNER ── */
        .secure-banner {
            background: linear-gradient(90deg, rgba(0, 188, 212, 0.07) 0%, rgba(0, 230, 118, 0.04) 100%);
            border: 1px solid rgba(0, 188, 212, 0.18);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            margin-top: 1.75rem;
            display: flex;
            align-items: flex-start;
            gap: .85rem;
        }

        .secure-banner i {
            color: var(--accent-teal);
            font-size: 1.35rem;
            margin-top: .1rem;
            flex-shrink: 0;
        }

        .secure-banner-title {
            font-weight: 700;
            font-size: .85rem;
            color: var(--accent-teal);
            margin-bottom: .2rem;
        }

        .secure-banner-text {
            font-size: .78rem;
            color: var(--text-muted);
            line-height: 1.55;
        }

        /* ── FOOTER ── */
        .footer-zyrax {
            background: var(--nav-bg);
            border-top: 1px solid var(--border);
            padding: 3rem 2.5rem 1.5rem;
        }

        .footer-brand {
            font-family: 'Syne', sans-serif;
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--accent-green);
        }

        .footer-brand span {
            color: var(--text-primary);
        }

        .footer-tagline {
            font-size: .8rem;
            color: var(--text-muted);
            margin-top: .5rem;
            line-height: 1.6;
            max-width: 220px;
        }

        .footer-social {
            display: flex;
            gap: .6rem;
            margin-top: 1.2rem;
        }

        .social-btn {
            width: 34px;
            height: 34px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: .95rem;
            transition: all .2s;
            cursor: pointer;
            text-decoration: none;
        }

        .social-btn:hover {
            border-color: var(--accent-green);
            color: var(--accent-green);
        }

        .footer-col-title {
            font-family: 'Syne', sans-serif;
            font-size: .82rem;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: var(--text-primary);
            margin-bottom: 1rem;
        }

        .footer-link {
            display: block;
            font-size: .8rem;
            color: var(--text-muted);
            text-decoration: none;
            margin-bottom: .5rem;
            transition: color .18s;
        }

        .footer-link:hover {
            color: var(--accent-green);
        }

        .footer-divider {
            border-color: var(--border);
            margin: 2rem 0 1rem;
        }

        .footer-copy {
            font-size: .75rem;
            color: var(--text-muted);
        }



        /* Subtle fade-in animation */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .balance-card {
            animation: fadeUp .5s ease both;
        }

        .txn-table-wrap {
            animation: fadeUp .55s ease .1s both;
        }

        .secure-banner {
            animation: fadeUp .55s ease .2s both;
        }

        @media (max-width: 768px) {
            .balance-card {
                grid-template-columns: 1fr;
                text-align: center;
                padding: 2rem 1.5rem;
            }

            .balance-main {
                min-width: unset;
            }

            .balance-amount {
                justify-content: center;
            }

            .btn-add-money {
                width: 100%;
                justify-content: center;
            }

            .content-container {
                padding: 1.5rem 1rem;
            }
        }
    </style>
</head>

<body>

    <!-- ═══════════ PAGE WRAPPER ═══════════ -->
    <div class="page-wrapper">

        <!-- ── SIDEBAR ── -->
        <%- include('../../partials/user/profileSidebar', { activePage: 'wallet' }) %>


            <!-- ── MAIN ── -->
            <main class="main-content">
                <div class="content-container">

                    <header class="page-header">
                        <h1 class="page-title">My Wallet</h1>
                        <p class="page-subtitle">Your secure digital wallet for faster checkouts and easy refunds.</p>
                    </header>

                    <!-- Premium Balance Card -->
                    <div class="balance-card">
                        <div class="balance-main">
                            <div class="balance-label">
                                <i class="bi bi-shield-lock-fill"></i> Available Balance
                            </div>
                            <div class="balance-amount">
                                <span class="currency-symbol">₹</span>
                                <%= (wallet && wallet.balance ? wallet.balance : 0).toLocaleString('en-IN', {
                                    minimumFractionDigits: 2 }) %>
                            </div>
                            <div class="balance-note-pill">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Ready for instant transactions & easy refunds</span>
                            </div>
                        </div>
                        <button class="btn-add-money">
                            <i class="bi bi-plus-circle-fill"></i> Add Money
                        </button>
                    </div>

                    <!-- Transaction History -->
                    <div class="section-heading">
                        <i class="bi bi-clock-history"></i> Transaction History
                    </div>

                    <div class="txn-table-wrap">
                        <div class="txn-table-container">
                            <table class="txn-table">
                                <thead>
                                    <tr>
                                        <th>Date &amp; Time</th>
                                        <th>Transaction ID</th>
                                        <th>Order ID</th>
                                        <th>Description</th>
                                        <th>Status</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    <% if (transactions && transactions.length> 0) { %>
                                        <% transactions.forEach(txn=> { %>
                                            <tr>
                                                <td>
                                                    <div class="fw-500">
                                                        <%= new Date(txn.Payment_date).toLocaleDateString('en-US', {
                                                            month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                                    </div>
                                                    <div class="txn-date">
                                                        <%= new Date(txn.Payment_time).toLocaleTimeString('en-US', {
                                                            hour: '2-digit' , minute: '2-digit' }) %>
                                                    </div>
                                                </td>
                                                <td class="txn-id">
                                                    <%= txn._id.toString().substring(0, 12).toUpperCase() %>
                                                </td>
                                                <td>
                                                    <% if (txn.Order_id) { %>
                                                        <a href="/myOrders/details?id=<%= txn.Order_id %>"
                                                            class="order-link">#ORD-<%=
                                                                txn.Order_id.toString().substring(0, 8).toUpperCase() %>
                                                        </a>
                                                        <% } else { %>
                                                            <span class="text">N/A</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <%= txn.Description %>
                                                </td>
                                                <td>
                                                    <% if (txn.Amount> 0) { %>
                                                        <span class="badge-status badge-success"><i
                                                                class="bi bi-arrow-down-circle"></i> Credit</span>
                                                        <% } else { %>
                                                            <span class="badge-status badge-danger"><i
                                                                    class="bi bi-arrow-up-circle"></i> Debit</span>
                                                            <% } %>
                                                </td>
                                                <td
                                                    class="text-end <%= txn.Amount > 0 ? 'amount-credit' : 'amount-debit' %>">
                                                    <%= txn.Amount> 0 ? '+' : '' %>₹<%=
                                                            Math.abs(txn.Amount).toLocaleString('en-IN', {
                                                            minimumFractionDigits: 2 }) %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6" class="text-center py-5">
                                                            <div class="text-muted mb-2"><i
                                                                    class="bi bi-wallet2 fs-2"></i>
                                                            </div>
                                                            <div class="text-muted">No transactions found.</div>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <% if (totalPages> 1) { %>
                            <div class="txn-pagination">
                                <% if (currentPage> 1) { %>
                                    <a href="/wallet?page=<%= currentPage - 1 %>"
                                        class="page-btn text-decoration-none">&#8249; Previous</a>
                                    <% } %>

                                        <% for(let i=1; i <=totalPages; i++) { %>
                                            <a href="/wallet?page=<%= i %>"
                                                class="page-btn text-decoration-none <%= currentPage === i ? 'active' : '' %>">
                                                <%= i %>
                                            </a>
                                            <% } %>

                                                <% if (currentPage < totalPages) { %>
                                                    <a href="/wallet?page=<%= currentPage + 1 %>"
                                                        class="page-btn text-decoration-none">Next &#8250;</a>
                                                    <% } %>
                            </div>
                            <% } %>
                    </div>

                    <!-- Secure Wallet Banner -->
                    <div class="secure-banner">
                        <i class="bi bi-shield-lock-fill"></i>
                        <div>
                            <div class="secure-banner-title">Secure Wallet</div>
                            <div class="secure-banner-text">
                                Your wallet is securely stored using bank-grade encryption and can be used seamlessly
                                during
                                checkout.
                                We never store your card details in plain text.
                            </div>
                        </div>
                    </div>

                </div> <!-- End content-container -->
            </main>
    </div>

    <!-- ═══════════ ADD MONEY MODAL ═══════════ -->
