<!DOCTYPE html>
<html>

<head>
    <title>Shopping Cart</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/userStyles/cart/cart.css">


     <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="userStyles/home/landingPage.css">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="cart-bg">

    <%-include('../../partials/user/navigationbar',{user, cartItemCount ,categories})%>

    <div class="container py-5">

        <div class="row">

            <!-- LEFT SIDE -->
            <div class="col-lg-8">

                <h2 class="text-white mb-2">Shopping Cart</h2>
                <p class="text-light">
                    <%= cartItems.length %> items in your cart
                </p>

                <% cartItems.forEach(item=> { %>

                    <div class="cart-card d-flex align-items-center justify-content-between mb-3">

                        <div class="d-flex align-items-center gap-3">

                            <img src="<%= item.product.image %>" class="cart-img">

                            <div>
                                <h6 class="text-white mb-1">
                                    <%= item.product.name %>
                                </h6>
                                <small class="text-muted">
                                    Color: <%= item.product.color %> <br>
                                        RAM: <%= item.product.ram %> <br>
                                            Storage: <%= item.product.storage %>
                                </small>
                            </div>
                        </div>

                        <!-- Quantity -->
                        <div class="qty-box">
                            <button>-</button>
                            <span>
                                <%= item.quantity %>
                            </span>
                            <button>+</button>
                        </div>

                        <!-- Price -->
                        <div class="text-end">
                            <h6 class="text-white">₹<%= item.product.price.toLocaleString() %>
                            </h6>
                        </div>

                        <div>
                            <button class="btn btn-sm btn-outline-danger">🗑</button>
                        </div>

                    </div>

                    <% }) %>

                        <!-- Pagination -->
                        <nav class="mt-4">
                            <ul class="pagination">

                                <% for(let i=1; i <=totalPages; i++) { %>

                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>">
                                            <%= i %>
                                        </a>
                                    </li>

                                    <% } %>

                            </ul>
                        </nav>

            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-4">

                <div class="summary-box">

                    <h5>Order Summary</h5>

                    <div class="d-flex justify-content-between mt-3">
                        <span>Subtotal</span>
                        <span>₹<%= subtotal.toLocaleString() %></span>
                    </div>

                    <div class="d-flex justify-content-between text-success">
                        <span>Discount</span>
                        <span>-₹<%= discount.toLocaleString() %></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Shipping</span>
                        <span>₹<%= shipping %></span>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span>₹<%= total.toLocaleString() %></span>
                    </div>

                    <button class="btn btn-warning w-100 mt-4">
                        Proceed to Checkout
                    </button>

                </div>

            </div>

        </div>

    </div>

</body>

</html>