<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shopping Cart — Zyrox</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --bg: #0b0c10;
            --bg-card: #12131a;
            --bg-mid: #1a1b26;
            --bg-row: #0f1018;
            --accent: #00ff04;
            --accent-lt: rgba(200, 136, 58, .13);
            --accent-b: rgba(200, 136, 58, .4);
            --green: #00d4a0;
            --red: #e63946;
            --text: #e8e8f0;
            --muted: #55566a;
            --border: rgba(255, 255, 255, .07);
            --border-mid: rgba(255, 255, 255, .12);
            --radius: 12px;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--bg);
            background-image:
                radial-gradient(ellipse 80% 40% at 50% -10%, rgba(200, 136, 58, .08) 0%, transparent 65%),
                radial-gradient(ellipse 40% 30% at 90% 90%, rgba(0, 212, 160, .05) 0%, transparent 60%);
            font-family: 'Inter', sans-serif;
            color: var(--text);
            min-height: 100vh;
            padding-top: 70px;
        }

        /* ── PAGE SHELL ── */
        .cart-shell {
            max-width: 1160px;
            margin: 0 auto;
            padding: 36px 20px 60px;
        }

        /* ── HEADER ── */
        .cart-header {
            margin-bottom: 28px;
        }

        .cart-title {
            font-family: 'Inter', sans-serif;
            font-size: 1.65rem;
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .cart-title::after {
            content: '';
            flex: 1;
            max-width: 120px;
            height: 2px;
            background: linear-gradient(90deg, var(--accent), transparent);
        }

        .cart-count {
            font-family: 'Inter', sans-serif;
            font-size: .82rem;
            font-weight: 500;
            color: var(--muted);
            margin-top: 6px;
        }

        /* ── MAIN GRID ── */
        .cart-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 24px;
            align-items: start;
        }

        /* ── CART TABLE ── */
        .cart-table-wrap {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .cart-thead {
            display: grid;
            grid-template-columns: 2.4fr 1.1fr 1.2fr 36px;
            gap: 12px;
            padding: 12px 20px;
            background: rgba(255, 255, 255, .025);
            border-bottom: 1px solid var(--border);
        }

        .thead-cell {
            font-family: 'Inter', sans-serif;
            font-size: .58rem;
            font-weight: 700;
            letter-spacing: 1.4px;
            color: var(--muted);
            text-transform: uppercase;
        }

        .thead-cell.center {
            text-align: center;
        }

        .thead-cell.right {
            text-align: right;
        }

        /* ── CART ROW ── */
        .cart-row {
            display: grid;
            grid-template-columns: 2.4fr 1.1fr 1.2fr 36px;
            gap: 12px;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            align-items: center;
            transition: background .2s;
            animation: rowIn .35s ease both;
        }

        .cart-row:last-child {
            border-bottom: none;
        }

        .cart-row:hover {
            background: rgba(255, 255, 255, .022);
        }

        .cart-row.out-of-stock-row {
            opacity: .55;
        }

        @keyframes rowIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Product cell */
        .product-cell {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .product-img-wrap {
            width: 66px;
            height: 66px;
            flex-shrink: 0;
            background: var(--bg-mid);
            border: 1px solid var(--border-mid);
            border-radius: 9px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .product-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 6px;
        }

        .product-meta {
            min-width: 0;
        }

        .product-name {
            font-family: 'Inter', sans-serif;
            font-size: .74rem;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }

        .product-specs {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            margin-top: 5px;
        }

        .spec-chip {
            font-size: .6rem;
            font-weight: 500;
            background: rgba(124, 58, 237, .1);
            border: 1px solid rgba(124, 58, 237, .2);
            border-radius: 4px;
            color: var(--muted);
            padding: 1px 6px;
        }

        .oos-label {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: .62rem;
            font-weight: 700;
            color: var(--red);
            margin-top: 4px;
        }

        /* Admin-inactive product banner */
        .unavailable-banner {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 6px;
            padding: 4px 10px;
            background: rgba(230, 57, 70, .10);
            border: 1px solid rgba(230, 57, 70, .28);
            border-radius: 5px;
            font-size: .62rem;
            font-weight: 700;
            color: var(--red);
            letter-spacing: .3px;
        }

        .unavailable-banner i {
            font-size: .65rem;
        }

        /* Muted price for unavailable items */
        .price-unavailable {
            font-family: 'Inter', sans-serif;
            font-size: .82rem;
            color: var(--muted);
            font-style: italic;
        }

        /* Quantity cell */
        .qty-cell {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }

        /* Below-qty unavailable message */
        .qty-unavail-msg {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: .58rem;
            font-weight: 700;
            color: var(--red);
            background: rgba(230, 57, 70, .09);
            border: 1px solid rgba(230, 57, 70, .22);
            border-radius: 4px;
            padding: 3px 8px;
            letter-spacing: .2px;
            white-space: nowrap;
        }

        .qty-ctrl {
            display: inline-flex;
            align-items: center;
            border: 1px solid var(--border-mid);
            border-radius: 7px;
            overflow: hidden;
            background: var(--bg-row);
        }

        .qty-btn {
            width: 30px;
            height: 30px;
            background: transparent;
            border: none;
            color: var(--text);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .7rem;
            transition: background .15s, color .15s;
        }

        .qty-btn:hover:not(:disabled) {
            background: rgba(200, 136, 58, .12);
            color: var(--accent);
        }

        .qty-btn:disabled {
            opacity: .3;
            cursor: not-allowed;
        }

        .qty-num {
            width: 34px;
            text-align: center;
            font-size: .84rem;
            font-weight: 700;
            color: var(--text);
            background: transparent;
            border: none;
            user-select: none;
        }

        /* Price cell */
        .price-cell {
            text-align: right;
        }

        .price-new {
            font-family: 'Inter', sans-serif;
            font-size: .9rem;
            font-weight: 700;
            color: var(--green);
        }

        .price-unit {
            font-size: .64rem;
            color: var(--muted);
            margin-top: 2px;
        }

        /* Remove cell */
        .remove-btn {
            width: 30px;
            height: 30px;
            background: transparent;
            border: 1px solid rgba(230, 57, 70, .22);
            border-radius: 6px;
            color: rgba(230, 57, 70, .5);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .72rem;
            transition: all .2s;
        }

        .remove-btn:hover {
            background: rgba(230, 57, 70, .12);
            color: var(--red);
            border-color: rgba(230, 57, 70, .5);
        }

        /* Empty cart */
        .empty-cart {
            padding: 60px 20px;
            text-align: center;
        }

        .empty-cart i {
            font-size: 3rem;
            color: rgba(200, 136, 58, .2);
            margin-bottom: 16px;
            display: block;
        }

        .empty-cart p {
            font-family: 'Inter', sans-serif;
            font-size: .84rem;
            letter-spacing: 1px;
            color: var(--muted);
        }

        /* ── PAGINATION ── */
        .cart-pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            padding: 14px 20px;
            border-top: 1px solid var(--border);
        }

        .pg-btn {
            width: 32px;
            height: 32px;
            background: var(--bg-row);
            border: 1px solid var(--border-mid);
            border-radius: 6px;
            color: var(--muted);
            cursor: pointer;
            font-size: .78rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
            text-decoration: none;
        }

        .pg-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--accent-lt);
        }

        .pg-btn.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        .pg-btn.disabled {
            opacity: .3;
            pointer-events: none;
        }

        /* ── ORDER SUMMARY ── */
        .order-summary {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 22px;
            position: sticky;
            top: 86px;
        }

        .summary-title {
            font-family: 'Inter', sans-serif;
            font-size: .84rem;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--text);
            margin-bottom: 18px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 7px 0;
            font-size: .82rem;
        }

        .summary-row .label {
            color: var(--muted);
        }

        .summary-row .value {
            font-weight: 600;
            color: var(--text);
        }

        .summary-row .value.green {
            color: var(--green);
        }

        .summary-row .value.red {
            color: var(--red);
        }

        .summary-divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 10px 0;
        }

        .summary-total {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
        }

        .total-label {
            font-family: 'Inter', sans-serif;
            font-size: .8rem;
            font-weight: 700;
            color: var(--text);
            letter-spacing: .5px;
        }

        .total-value {
            font-family: 'Inter', sans-serif;
            font-size: 1.22rem;
            font-weight: 800;
            color: var(--green);
        }

        /* Checkout btn */
        .btn-checkout {
            width: 100%;
            margin-top: 16px;
            padding: 13px;
            background: linear-gradient(135deg, #e09a45, #d97706);
            border: none;
            border-radius: 9px;
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: 1px;
            cursor: pointer;
            transition: opacity .2s, transform .15s, box-shadow .2s;
            box-shadow: 0 4px 18px rgba(200, 136, 58, .3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-checkout:hover:not(:disabled) {
            opacity: .88;
            transform: translateY(-1px);
            box-shadow: 0 7px 24px rgba(200, 136, 58, .45);
        }

        .btn-checkout:disabled {
            background: var(--bg-mid);
            color: var(--muted);
            box-shadow: none;
            cursor: not-allowed;
        }

        .oos-warning {
            font-size: .68rem;
            color: var(--red);
            text-align: center;
            margin-top: 8px;
            display: none;
        }

        .oos-warning.show {
            display: block;
        }

        /* Continue shopping */
        .btn-continue {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 28px;
            padding: 9px 22px;
            background: transparent;
            border: 1px solid var(--border-mid);
            border-radius: 8px;
            color: var(--muted);
            font-family: 'Inter', sans-serif;
            font-size: .8rem;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s;
            cursor: pointer;
        }

        .btn-continue:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        /* scrollbar */
        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(200, 136, 58, .3);
            border-radius: 10px;
        }

        @media (max-width: 992px) {
            .cart-grid {
                grid-template-columns: 1fr;
            }

            .order-summary {
                position: static;
            }
        }

        @media (max-width: 575px) {
            .cart-thead {
                display: none;
            }

            .cart-row {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .qty-cell,
            .price-cell {
                justify-content: flex-start;
                text-align: left;
            }
        }
    </style>
</head>

<body>
    <%- include('../../partials/user/navigationbar', { user, cartItemCount, currentPage: 'cart' , categories }) %>

        <div class="cart-shell">

            <!-- Header -->
            <div class="cart-header">
                <div class="cart-title">
                    <i class="fas fa-shopping-cart" style="color:var(--accent);font-size:1.2rem;"></i>
                    Shopping Cart
                </div>
                <div class="cart-count">
                    <% if (cartItems && cartItems.length> 0) { %>
                        <%= cartItemCount %> item<%= cartItemCount !==1 ? 's' : '' %> in your cart
                                <% } else { %>
                                    Your cart is empty
                                    <% } %>
                </div>
            </div>

            <div class="cart-grid">

                <!-- ══ LEFT: CART ITEMS ══ -->
                <div>
                    <div class="cart-table-wrap">

                        <% if (cartItems && cartItems.length> 0) { %>

                            <!-- Table head -->
                            <div class="cart-thead">
                                <div class="thead-cell">Product</div>
                                <div class="thead-cell center">Quantity</div>
                                <div class="thead-cell right">Price</div>
                                <div class="thead-cell"></div>
                            </div>

                            <!-- Rows -->
                            <% cartItems.forEach(function(item, idx) { %>
                                <% const isUnavailable=!item.isAvailable; %>
                                    <% const isAdminInactive=!!item.isAdminInactive; %>
                                        <div class="cart-row <%= isUnavailable ? 'out-of-stock-row' : '' %>"
                                            id="row-<%= item.variantId %>" data-variant="<%= item.variantId %>"
                                            data-product="<%= item.productId %>" data-price="<%= item.product.price %>"
                                            data-original-price="<%= item.product.originalPrice %>"
                                            data-stock="<%= item.product.stock || 0 %>"
                                            data-admin-inactive="<%= isAdminInactive %>"
                                            style="animation-delay: <%= idx * 0.06 %>s">

                                            <!-- Product info -->
                                            <div class="product-cell">
                                                <div class="product-img-wrap">
                                                    <img src="<%= item.product.image %>" alt="<%= item.product.name %>"
                                                        loading="lazy">
                                                </div>
                                                <div class="product-meta">
                                                    <div class="product-name" title="<%= item.product.name %>">
                                                        <%= item.product.name %>
                                                    </div>
                                                    <div class="product-specs">
                                                        <% if (item.product.color) { %><span class="spec-chip">
                                                                <%= item.product.color %>
                                                            </span>
                                                            <% } %>
                                                                <% if (item.product.ram) { %><span
                                                                        class="spec-chip">RAM:
                                                                        <%= item.product.ram %>
                                                                    </span>
                                                                    <% } %>
                                                                        <% if (item.product.storage) { %><span
                                                                                class="spec-chip">Storage: <%=
                                                                                    item.product.storage %></span>
                                                                            <% } %>
                                                    </div>
                                                    <% if (isUnavailable && !isAdminInactive) { %>
                                                        <div class="oos-label">
                                                            <i class="fas fa-times-circle"></i>
                                                            Out of Stock
                                                        </div>
                                                        <% } %>
                                                </div>
                                            </div>

                                            <!-- Quantity -->
                                            <!-- ↓ buttons disabled when unavailable -->
                                            <div class="qty-cell">
                                                <div class="qty-ctrl">
                                                    <button class="qty-btn" <%=isUnavailable ? 'disabled' : '' %>
                                                        onclick="changeQty('<%= item.variantId %>', '<%= item.productId
                                                                %>',
                                                                -1, <%= item.product.stock || 0 %>)"
                                                                    id="minus-<%= item.variantId %>">
                                                                        <i class="fas fa-minus"></i>
                                                    </button>
                                                    <span class="qty-num" id="qty-<%= item.variantId %>">
                                                        <%= item.quantity %>
                                                    </span>
                                                    <button class="qty-btn" <%=(isUnavailable || item.quantity>=
                                                        Math.min(3,
                                                        item.product.stock)) ?
                                                        'disabled' : '' %>
                                                        onclick="changeQty('<%= item.variantId %>', '<%= item.productId
                                                                %>',
                                                                1, <%= item.product.stock || 0 %>)" id="plus-<%=
                                                                        item.variantId %>">
                                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                </div>
                                                <% if (isAdminInactive) { %>
                                                    <div class="qty-unavail-msg">
                                                        <i class="fas fa-ban"></i>
                                                        Product is currently unavailable
                                                    </div>
                                                    <% } else if (isUnavailable) { %>
                                                        <div class="qty-unavail-msg">
                                                            <i class="fas fa-times-circle"></i>
                                                            Out of Stock
                                                        </div>
                                                        <% } %>
                                            </div>

                                            <!-- Price -->
                                            <div class="price-cell">
                                                <% if (isUnavailable) { %>
                                                    <div class="price-unavailable" id="price-<%= item.variantId %>">—
                                                    </div>
                                                    <div class="price-unit">not available</div>
                                                    <% } else { %>
                                                        <div class="price-new" id="price-<%= item.variantId %>">
                                                            ₹<%= (item.product.price *
                                                                item.quantity).toLocaleString('en-IN') %>
                                                        </div>

                                                        <% if (item.product.price < item.product.originalPrice) { %>
                                                            <div class="price-unit"
                                                                style="text-decoration: line-through; color: var(--muted); font-size: 0.6rem;">
                                                                ₹<%= item.product.originalPrice.toLocaleString('en-IN')
                                                                    %>
                                                            </div>
                                                            <% } %>

                                                                <div class="price-unit">₹<%=
                                                                        item.product.price.toLocaleString('en-IN') %>
                                                                        each</div>
                                                                <% } %>
                                            </div>

                                            <!-- Remove -->
                                            <button type="button" class="remove-btn"
                                                onclick="removeItem('<%= item.variantId %>', '<%= item.productId %>')"
                                                title="Remove">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>

                                        </div>
                                        <% }) %>

                                            <% } else { %>
                                                <div class="empty-cart">
                                                    <i class="fas fa-box-open"></i>
                                                    <p>Your cart is empty</p>
                                                    <a href="/products"
                                                        style="display:inline-block;margin-top:14px;color:var(--accent);font-size:.78rem;text-decoration:none;">
                                                        Browse Products →
                                                    </a>
                                                </div>
                                                <% } %>

                    </div>

                    <!-- Pagination -->
                    <% if (totalPages> 1) { %>
                        <div class="cart-pagination">
                            <a href="?page=<%= currentPage - 1 %>"
                                class="pg-btn <%= currentPage <= 1 ? 'disabled' : '' %>">
                                <i class="fas fa-chevron-left" style="font-size:.6rem;"></i>
                            </a>
                            <% for (let p=1; p <=totalPages; p++) { %>
                                <a href="?page=<%= p %>" class="pg-btn <%= p === currentPage ? 'active' : '' %>">
                                    <%= p %>
                                </a>
                                <% } %>
                                    <a href="?page=<%= currentPage + 1 %>"
                                        class="pg-btn <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                        <i class="fas fa-chevron-right" style="font-size:.6rem;"></i>
                                    </a>
                        </div>
                        <% } %>

                            <!-- Continue shopping -->
                            <a href="/products" class="btn-continue">
                                <i class="fas fa-arrow-left" style="font-size:.72rem;"></i> Continue Shopping
                            </a>
                </div>

                <!-- ══ RIGHT: ORDER SUMMARY ══ -->
                <div class="order-summary">
                    <div class="summary-title">Order Summary</div>

                    <div class="summary-row">
                        <span class="label">Subtotal</span>
                        <span class="value" id="summary-subtotal">₹<%= subtotal.toLocaleString('en-IN') %></span>
                    </div>
                    <div class="summary-row">
                        <span class="label">Discount</span>
                        <span class="value red" id="summary-discount">
                            <%= discount> 0 ? '−₹' + discount.toLocaleString('en-IN') : '₹0.00' %>
                        </span>
                    </div>
                    <div class="summary-row">
                        <span class="label">Shipping</span>
                        <span class="value green" id="summary-shipping">
                            <%= shipping===0 ? 'Free' : '₹' + shipping.toLocaleString('en-IN') %>
                        </span>
                    </div>

                    <hr class="summary-divider">

                    <div class="summary-total">
                        <span class="total-label">Total</span>
                        <span class="total-value" id="summary-total">₹<%= total.toLocaleString('en-IN') %></span>
                    </div>

                    <button type="button" class="btn-checkout" id="checkoutBtn" onclick="proceedCheckout()" <%=cartItems
                        && cartItems.length> 0 ? '' : 'disabled' %>>
                        <i class="fas fa-lock" style="font-size:.68rem;"></i>
                        Proceed to Checkout
                    </button>
                    <div class="oos-warning" id="oosWarning">
                        <i class="fas fa-exclamation-triangle"></i>
                        Remove unavailable items before checkout
                    </div>

                    <!-- Mini trust badges -->
                    <div
                        style="display:flex;justify-content:center;gap:16px;margin-top:18px;padding-top:14px;border-top:1px solid var(--border);">
                        <div style="text-align:center;">
                            <i class="fas fa-shield-alt" style="color:var(--accent);font-size:.9rem;"></i>
                            <div style="font-size:.58rem;color:var(--muted);margin-top:3px;">Secure</div>
                        </div>
                        <div style="text-align:center;">
                            <i class="fas fa-undo" style="color:var(--accent);font-size:.9rem;"></i>
                            <div style="font-size:.58rem;color:var(--muted);margin-top:3px;">Returns</div>
                        </div>
                        <div style="text-align:center;">
                            <i class="fas fa-truck" style="color:var(--accent);font-size:.9rem;"></i>
                            <div style="font-size:.58rem;color:var(--muted);margin-top:3px;">Fast Ship</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
        <script>

            /* ─── GLOBAL CART LIMIT ─────────────────────── */
            const MAX_QTY = 3;

            /* ═══════════════════════════════════════════
               LOCAL STATE — mirrors server data
            ═══════════════════════════════════════════ */
            const cartState = {};

            // Hydrate from server-rendered rows
            document.querySelectorAll('.cart-row').forEach(row => {
                const vid = row.dataset.variant;
                const price = parseFloat(row.dataset.price);
                const originalPrice = parseFloat(row.dataset.originalPrice);
                const stock = parseInt(row.dataset.stock, 10);
                const qty = parseInt(document.getElementById('qty-' + vid)?.textContent || '1', 10);
                const isAdminInactive = row.dataset.adminInactive === 'true';
                cartState[vid] = { price, originalPrice, stock, qty, isAdminInactive };
            });

            /* ═══════════════════════════════════════════
               QUANTITY CHANGE
            ═══════════════════════════════════════════ */
            async function changeQty(variantId, productId, delta, stock) {
                const state = cartState[variantId];
                if (!state) return;

                const btnId = delta > 0 ? `plus-${variantId}` : `minus-${variantId}`;
                const btn = document.getElementById(btnId);
                const originalHtml = btn.innerHTML;

                const newQty = state.qty + delta;

                // Lower bound
                if (newQty < 1) return;

                // ── MAX QUANTITY LIMIT (3 per product) ──
                if (newQty > MAX_QTY) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Quantity Limit Reached',
                        html: `You can only add up to <strong>${MAX_QTY}</strong> units of the same product to your cart.`,
                        confirmButtonText: 'Got it',
                        confirmButtonColor: '#00ff04',
                        background: '#12131a',
                        color: '#e8e8f0',
                        iconColor: '#00ff04',
                        customClass: {
                            popup: 'swal-zyrox'
                        }
                    });
                    return;
                }

                // ── Stock exceeded ──
                const stockLimit = stock;
                if (newQty > stockLimit) {
                    Swal.fire({
                        toast: true, position: 'top-end', icon: 'warning',
                        title: stockLimit === 0
                            ? 'Out of stock'
                            : `Only ${stockLimit} unit${stockLimit > 1 ? 's' : ''} available`,
                        showConfirmButton: false, timer: 2500,
                        background: '#12131a', color: '#e8e8f0', iconColor: '#00ff04'
                    });
                    return;
                }

                try {
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:10px;height:10px;border-width:2px"></span>';

                    const res = await fetch('/cart/update-quantity', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ variantId, productId, quantity: newQty })
                    });

                    const data = await res.json();

                    if (!data.success) {
                        Swal.fire({
                            toast: true, position: 'top-end', icon: 'warning',
                            title: data.message || 'Could not update quantity',
                            showConfirmButton: false, timer: 2200,
                            background: '#12131a', color: '#e8e8f0'
                        });
                        return;
                    }

                    // Update local state
                    state.qty = newQty;
                    document.getElementById('qty-' + variantId).textContent = newQty;

                    // Update row price
                    const rowPrice = state.price * newQty;
                    document.getElementById('price-' + variantId).textContent =
                        '₹' + rowPrice.toLocaleString('en-IN');

                    const stockLimitLocal = state.stock;
                    document.getElementById('minus-' + variantId).disabled = newQty <= 1;
                    document.getElementById('plus-' + variantId).disabled = newQty >= MAX_QTY || newQty >= stockLimitLocal;

                    // Update summary from server data
                    recalcSummary(data.subtotal, data.discount, data.total);

                } catch (err) {
                    Swal.fire({
                        toast: true, position: 'top-end', icon: 'error',
                        title: 'Network error', showConfirmButton: false, timer: 2000,
                        background: '#12131a', color: '#e8e8f0'
                    });
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            }

            /* ═══════════════════════════════════════════
               REMOVE ITEM
            ═══════════════════════════════════════════ */
            async function removeItem(variantId, productId) {

                const confirmed = await Swal.fire({
                    title: 'Remove item?',
                    text: 'This item will be removed from your cart.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Remove',
                    cancelButtonText: 'Keep it',
                    confirmButtonColor: '#e63946',
                    cancelButtonColor: '#1a1b26',
                    background: '#12131a',
                    color: '#e8e8f0'
                });

                // ❌ Cancel → no reload
                if (!confirmed.isConfirmed) return;

                const btn = document.querySelector(`#row-${variantId} .remove-btn`);
                const originalHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;border-width:2px"></span>';

                try {
                    const res = await fetch('/cart/remove', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ variantId, productId })
                    });

                    const data = await res.json();

                    if (!data.success) {
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: 'error',
                            title: data.message || 'Could not remove item',
                            showConfirmButton: false,
                            timer: 2000,
                            background: '#12131a',
                            color: '#e8e8f0'
                        });
                        return;
                    }

                    // ✅ Optional: show success before reload
                    await Swal.fire({
                        icon: 'success',
                        title: 'Item removed',
                        showConfirmButton: false,
                        timer: 800,
                        background: '#12131a',
                        color: '#e8e8f0'
                    });

                    // ✅ NOW reload safely
                    window.location.reload();

                } catch (err) {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'error',
                        title: 'Network error',
                        showConfirmButton: false,
                        timer: 2000,
                        background: '#12131a',
                        color: '#e8e8f0'
                    });
                }
            }

            /* ═══════════════════════════════════════════
               RECALCULATE SUMMARY (client-side)
            ═══════════════════════════════════════════ */
            function recalcSummary(srvSubtotal, srvDiscount, srvTotal) {
                let subtotal = srvSubtotal;
                let discount = srvDiscount;
                let total = srvTotal;

                if (srvSubtotal === undefined) {
                    subtotal = 0;
                    discount = 0;
                    Object.values(cartState).forEach(s => {
                        if (!s.isAdminInactive && s.price > 0) {
                            subtotal += s.originalPrice * s.qty;
                            discount += (s.originalPrice - s.price) * s.qty;
                        }
                    });
                    total = subtotal - discount;
                }

                document.getElementById('summary-subtotal').textContent = '₹' + subtotal.toLocaleString('en-IN');
                document.getElementById('summary-discount').textContent = discount > 0 ? '−₹' + discount.toLocaleString('en-IN') : '₹0.00';
                document.getElementById('summary-total').textContent = '₹' + total.toLocaleString('en-IN');

                checkOOS();
            }

            function checkOOS() {
                const rows = document.querySelectorAll('.cart-row');
                const hasUnavailableOnCurrentPage = [...rows].some(r => {
                    const adminInactive = r.dataset.adminInactive === 'true';
                    const stock = parseInt(r.dataset.stock, 10);
                    const qty = parseInt(document.getElementById('qty-' + r.dataset.variant)?.textContent || '0', 10);
                    return adminInactive || stock <= 0 || qty > stock;
                });

                // hasUnavailableItems comes from server-side loadCart
                const hasGlobalUnavailable = <%= typeof hasUnavailableItems !== 'undefined' ? (hasUnavailableItems ? 'true' : 'false') : 'false' %>;
                const isEmpty = <%= typeof cartItemCount !== 'undefined' ? (cartItemCount === 0 ? 'true' : 'false') : 'true' %>;

                const btn = document.getElementById('checkoutBtn');
                const warn = document.getElementById('oosWarning');

                btn.disabled = hasUnavailableOnCurrentPage || hasGlobalUnavailable || isEmpty;
                warn.classList.toggle('show', hasUnavailableOnCurrentPage || hasGlobalUnavailable);
            }

            /* ═══════════════════════════════════════════
               SHOW EMPTY STATE
            ═══════════════════════════════════════════ */
            function checkEmptyCart() {
                const rows = document.querySelectorAll('.cart-row');
                if (rows.length === 0) {
                    const wrap = document.querySelector('.cart-table-wrap');
                    wrap.innerHTML = `
                <div class="empty-cart">
                    <i class="fas fa-box-open"></i>
                    <p>Your cart is empty</p>
                    <a href="/products" style="display:inline-block;margin-top:14px;color:var(--accent);font-size:.78rem;text-decoration:none;">
                        Browse Products →
                    </a>
                </div>`;
                    document.querySelector('.cart-count').textContent = 'Your cart is empty';
                }
            }

            /* ═══════════════════════════════════════════
               UPDATE CART BADGE IN NAVBAR
            ═══════════════════════════════════════════ */
            function updateCartCountBadge(count) {
                const badge = document.querySelector('.cart-badge');
                if (badge) badge.textContent = count ?? '';
            }

            function proceedCheckout() {
                const btn = document.getElementById('checkoutBtn');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
                window.location.href = '/checkout';
            }

            /* Run on load */
            checkOOS();
        </script>
</body>

</html>