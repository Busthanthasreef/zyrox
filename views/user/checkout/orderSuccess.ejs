<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Success – ShopX</title>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <style>
        :root {
            --bg-deep: #0a0c14;
            --bg-card: #111422;
            --bg-surface: #181c2e;
            --border: #252a42;
            --accent: #4f6ef7;
            --accent-glow: rgba(79, 110, 247, .35);
            --accent-2: #00d4aa;
            --text-1: #f0f2ff;
            --text-2: #8b92b8;
            --text-3: #4f566b;
            --radius-md: 14px;
            --radius-lg: 20px;
            --transition: .22s cubic-bezier(.4, 0, .2, 1);
        }

        body {
            background: var(--bg-deep);
            color: var(--text-1);
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-image:
                radial-gradient(ellipse 60% 40% at 75% -10%, rgba(79, 110, 247, .12) 0%, transparent 60%),
                radial-gradient(ellipse 40% 30% at 10% 90%, rgba(0, 212, 170, .08) 0%, transparent 60%);
        }

        .success-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .success-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 3rem 2rem;
            max-width: 600px;
            width: 100%;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            animation: fadeIn 0.6s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .illustration {
            width: 120px;
            height: 120px;
            margin: 0 auto 2rem;
            background: rgba(0, 212, 170, 0.1);
            border: 2px solid var(--accent-2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: var(--accent-2);
            box-shadow: 0 0 30px rgba(0, 212, 170, 0.2);
            animation: bounce 2s infinite ease-in-out;
        }

        @keyframes bounce {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        .success-title {
            font-family: 'Inter', sans-serif;
            font-weight: 800;
            font-size: 2.5rem;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, #8b92b8 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .success-msg {
            color: var(--text-2);
            font-size: 1.1rem;
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .order-info {
            background: var(--bg-surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 1.5rem;
            margin-bottom: 2.5rem;
            text-align: left;
        }

        .order-info .row-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.8rem;
            font-size: 0.95rem;
        }

        .order-info .row-item:last-child {
            margin-bottom: 0;
            padding-top: 0.8rem;
            border-top: 1px solid var(--border);
            font-weight: 700;
            color: var(--accent);
        }

        .actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, var(--accent) 0%, #6c8aff 100%);
            color: #fff;
            border: none;
            border-radius: var(--radius-md);
            padding: 1rem 2rem;
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            text-decoration: none;
            transition: all var(--transition);
            box-shadow: 0 4px 15px rgba(79, 110, 247, 0.3);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(79, 110, 247, 0.45);
            color: #fff;
        }

        .btn-outline-custom {
            background: transparent;
            color: var(--text-1);
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            padding: 1rem 2rem;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            text-decoration: none;
            transition: all var(--transition);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-outline-custom:hover {
            border-color: var(--accent);
            background: rgba(79, 110, 247, 0.05);
            color: #fff;
        }

        @media (max-width: 576px) {
            .success-title {
                font-size: 1.8rem;
            }

            .btn-primary-custom,
            .btn-outline-custom {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>

<body>
    <%- include('../../partials/user/navigationbar', {user, categories, cartItemCount: 0, currentPage: 'checkout' }) %>

        <div class="success-container">
            <div class="success-card">
                <div class="illustration">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <h1 class="success-title">Thank You!</h1>
                <p class="success-msg">
                    Your order <strong>#<%= order.orderId %></strong> has been placed successfully.<br>
                </p>

                <div class="order-info">
                    <div class="row-item">
                        <span>Payment Method</span>
                        <span>
                            <%= order.paymentMethod %>
                        </span>
                    </div>
                    <div class="row-item">
                        <span>Shipping To</span>
                        <span>
                            <%= order.shippingAddress.fullName %>
                        </span>
                    </div>
                    <div class="row-item">
                        <span>Order Total</span>
                        <span>₹<%= order.finalPrice.toLocaleString('en-IN') %></span>
                    </div>
                </div>

                <div class="actions">
                    <a href="/orders" class="btn-primary-custom">
                        <i class="bi bi-bag-check-fill"></i> View My Orders
                    </a>
                    <a href="/products" class="btn-outline-custom">
                        <i class="bi bi-arrow-left"></i> Continue Shopping
                    </a>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>