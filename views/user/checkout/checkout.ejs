<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ZYROX - Checkout</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <style>
        :root {
            --bg-deep: #0a0c14;
            --bg-card: #111422;
            --bg-surface: #181c2e;
            --bg-hover: #1e2338;
            --border: #252a42;
            --accent: #4f6ef7;
            --accent-glow: rgba(79, 110, 247, .35);
            --accent-2: #00d4aa;
            --danger: #ff4d6d;
            --text-1: #f0f2ff;
            --text-2: #8b92b8;
            --text-3: #4f566b;
            --success: #00d4aa;
            --gold: #f4b942;
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 20px;
            --shadow-card: 0 4px 24px rgba(0, 0, 0, .45);
            --transition: .22s cubic-bezier(.4, 0, .2, 1);
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--bg-deep);
            font-family: 'Inter', sans-serif;
            color: var(--text-1);
            min-height: 100vh;
            background-image:
                radial-gradient(ellipse 60% 40% at 75% -10%, rgba(79, 110, 247, .12) 0%, transparent 60%),
                radial-gradient(ellipse 40% 30% at 10% 90%, rgba(0, 212, 170, .08) 0%, transparent 60%);
        }

        /* ─── TOPBAR ─────────────────────────────── */
        .topbar {
            background: rgba(17, 20, 34, .85);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            padding: .9rem 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar .brand {
            font-family: 'Inter', sans-serif;
            font-weight: 800;
            font-size: 1.35rem;
            letter-spacing: -.5px;
            color: var(--text-1);
            text-decoration: none;
        }

        .topbar .brand span {
            color: var(--accent);
        }

        .page-title {
            font-family: 'Inter', sans-serif;
            font-weight: 800;
            font-size: 1.9rem;
            letter-spacing: -.5px;
        }

        .page-title span {
            color: var(--accent);
        }

        /* ─── CARDS ──────────────────────────────── */
        .card-dark {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-card);
        }

        .card-dark .card-header-custom {
            padding: 1.1rem 1.4rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-dark .card-header-custom .title {
            font-weight: 700;
            font-size: 1rem;
            color: var(--text-1);
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        .card-dark .card-header-custom .title .icon-circle {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(79, 110, 247, .15);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            font-size: .8rem;
        }

        /* ─── ADDRESS ────────────────────────────── */
        .address-grid {
            display: flex;
            flex-direction: column;
            gap: .8rem;
            padding: 1.2rem 1.4rem;
        }

        .address-card {
            border: 1.5px solid var(--border);
            border-radius: var(--radius-md);
            padding: 1rem 1.1rem;
            cursor: pointer;
            transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
            position: relative;
        }

        .address-card:hover {
            background: var(--bg-hover);
            border-color: rgba(79, 110, 247, .4);
        }

        .address-card.selected {
            border-color: var(--accent);
            background: rgba(79, 110, 247, .06);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

        .address-card .radio-dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: border-color var(--transition);
        }

        .address-card.selected .radio-dot {
            border-color: var(--accent);
        }

        .address-card.selected .radio-dot::after {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
        }

        .address-card .addr-name {
            font-weight: 600;
            font-size: .92rem;
            color: var(--text-1);
        }

        .address-card .addr-text {
            font-size: .82rem;
            color: var(--text-2);
            line-height: 1.55;
        }

        .addr-badge {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .04em;
            text-transform: uppercase;
            padding: .15rem .5rem;
            border-radius: 99px;
        }

        .addr-badge.home {
            background: rgba(79, 110, 247, .15);
            color: var(--accent);
        }

        .addr-badge.work {
            background: rgba(0, 212, 170, .12);
            color: var(--accent-2);
        }

        .addr-badge.default {
            background: rgba(244, 185, 66, .12);
            color: var(--gold);
        }

        /* FIX: edit icon button — accessible, keyboard-friendly */
        .btn-edit-addr-icon {
            background: transparent;
            border: none;
            color: var(--text-3);
            cursor: pointer;
            padding: 4px 6px;
            border-radius: var(--radius-sm);
            transition: color var(--transition), background var(--transition);
            font-size: 1rem;
            line-height: 1;
        }

        .btn-edit-addr-icon:hover {
            color: var(--accent);
            background: rgba(79, 110, 247, .08);
        }

        .btn-add-addr {
            margin: 0 1.4rem 1.2rem;
            border: 1.5px dashed var(--border);
            background: transparent;
            color: var(--text-3);
            border-radius: var(--radius-md);
            padding: .75rem;
            width: calc(100% - 2.8rem);
            font-size: .86rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            cursor: pointer;
            transition: border-color var(--transition), color var(--transition), background var(--transition);
        }

        .btn-add-addr:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: rgba(79, 110, 247, .05);
        }

        /* ─── ORDER ITEMS ────────────────────────── */
        .order-items-list {
            padding: 1rem 1.4rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .order-item-row {
            display: flex;
            gap: 1rem;
            align-items: center;
            padding: .9rem;
            background: var(--bg-surface);
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            transition: background var(--transition);
        }

        .order-item-row:hover {
            background: var(--bg-hover);
        }

        .order-item-img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: var(--radius-sm);
            background: var(--bg-hover);
            flex-shrink: 0;
        }

        .item-meta .item-name {
            font-weight: 600;
            font-size: .88rem;
            color: var(--text-1);
            line-height: 1.35;
        }

        .item-meta .item-attr {
            font-size: .76rem;
            color: var(--text-3);
            margin-top: .25rem;
        }

        .item-meta .item-qty-badge {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            margin-top: .35rem;
            font-size: .75rem;
            color: var(--text-2);
        }

        .item-price-col {
            text-align: right;
            flex-shrink: 0;
        }

        .item-price-col .price-main {
            font-weight: 700;
            font-size: .95rem;
            color: var(--text-1);
        }

        .item-price-col .price-orig {
            font-size: .75rem;
            color: var(--text-3);
            text-decoration: line-through;
        }

        .item-price-col .price-save {
            font-size: .72rem;
            color: var(--success);
        }

        /* ─── PRICE SUMMARY ──────────────────────── */
        .price-summary {
            padding: 1.2rem 1.4rem;
        }

        .price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .45rem 0;
            font-size: .88rem;
        }

        .price-row .label {
            color: var(--text-2);
        }

        .price-row .val {
            color: var(--text-1);
            font-weight: 500;
        }

        .price-row.discount .val {
            color: var(--success);
        }

        .price-row.shipping .val {
            color: var(--accent-2);
        }

        .price-divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: .5rem 0;
        }

        .price-row.total .label {
            font-weight: 700;
            font-size: 1rem;
            color: var(--text-1);
        }

        .price-row.total .val {
            font-weight: 800;
            font-size: 1.15rem;
            color: var(--accent);
        }

        .savings-pill {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: rgba(0, 212, 170, .1);
            color: var(--accent-2);
            border: 1px solid rgba(0, 212, 170, .2);
            border-radius: 99px;
            font-size: .78rem;
            font-weight: 600;
            padding: .35rem .8rem;
            margin-top: .5rem;
        }

        /* ─── COUPON ─────────────────────────────── */
        .coupon-section {
            padding: 0 1.4rem 1.2rem;
        }

        /* FIX: Applied coupon state */
        .coupon-applied-state {
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: .6rem;
            background: rgba(0, 212, 170, .07);
            border: 1.5px solid rgba(0, 212, 170, .3);
            border-radius: var(--radius-md);
            padding: .7rem 1rem;
        }

        .coupon-applied-state.visible {
            display: flex;
        }

        .coupon-applied-info {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .86rem;
            color: var(--accent-2);
            font-weight: 600;
        }

        .btn-remove-coupon {
            background: transparent;
            border: 1px solid rgba(255, 77, 109, .4);
            color: var(--danger);
            font-size: .75rem;
            font-weight: 600;
            padding: .3rem .65rem;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: background var(--transition), border-color var(--transition);
        }

        .btn-remove-coupon:hover {
            background: rgba(255, 77, 109, .1);
            border-color: var(--danger);
        }

        .coupon-input-wrap {
            display: flex;
            gap: .6rem;
            background: var(--bg-surface);
            border: 1.5px solid var(--border);
            border-radius: var(--radius-md);
            overflow: hidden;
            padding: .35rem .35rem .35rem .9rem;
            transition: border-color var(--transition);
        }

        .coupon-input-wrap:focus-within {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

        .coupon-input-wrap input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: var(--text-1);
            font-size: .86rem;
            font-family: 'Inter', sans-serif;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .coupon-input-wrap input::placeholder {
            color: var(--text-3);
            text-transform: none;
            letter-spacing: 0;
        }

        /* FIX: Apply button loading state */
        .btn-apply {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: .45rem 1rem;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity var(--transition), transform var(--transition);
            min-width: 72px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .35rem;
        }

        .btn-apply:hover:not(:disabled) {
            opacity: .88;
            transform: scale(.97);
        }

        .btn-apply:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
        }

        .coupon-hint {
            font-size: .76rem;
            color: var(--accent);
            cursor: pointer;
            margin-top: .5rem;
            display: inline-block;
            text-decoration: none;
        }

        .coupon-hint:hover {
            text-decoration: underline;
        }

        /* ─── PAYMENT METHOD ─────────────────────── */
        .payment-list {
            padding: 1rem 1.4rem;
            display: flex;
            flex-direction: column;
            gap: .7rem;
        }

        .payment-option {
            display: flex;
            align-items: center;
            gap: .9rem;
            padding: .9rem 1rem;
            border-radius: var(--radius-md);
            border: 1.5px solid var(--border);
            cursor: pointer;
            transition: border-color var(--transition), background var(--transition), opacity var(--transition);
        }

        .payment-option:hover:not(.disabled) {
            background: var(--bg-hover);
            border-color: rgba(79, 110, 247, .3);
        }

        .payment-option.selected {
            border-color: var(--accent);
            background: rgba(79, 110, 247, .06);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

        .payment-option.disabled {
            opacity: .38;
            cursor: not-allowed;
            filter: grayscale(.6);
        }

        .payment-option .pay-icon {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            background: var(--bg-hover);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .payment-option .pay-name {
            font-weight: 600;
            font-size: .88rem;
            color: var(--text-1);
        }

        .payment-option .pay-desc {
            font-size: .76rem;
            color: var(--text-3);
        }

        .payment-option .radio-dot {
            margin-left: auto;
        }

        /* FIX: Wallet balance indicator */
        .wallet-balance-badge {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            font-size: .72rem;
            font-weight: 700;
            color: var(--gold);
            background: rgba(244, 185, 66, .1);
            border: 1px solid rgba(244, 185, 66, .2);
            border-radius: 99px;
            padding: .15rem .5rem;
            margin-top: .2rem;
        }

        .wallet-insufficient {
            font-size: .72rem;
            color: var(--danger);
            font-weight: 600;
            margin-top: .2rem;
        }

        /* ─── PLACE ORDER BTN ────────────────────── */
        .btn-place-order {
            width: 100%;
            padding: 1rem;
            background: #6c8aff;
            border: none;
            border-radius: var(--radius-md);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: .02em;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(79, 110, 247, .4);
            transition: transform var(--transition), box-shadow var(--transition);
        }

        .btn-place-order::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 255, 255, .12), transparent);
        }

        .btn-place-order:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(79, 110, 247, .55);
        }

        .btn-place-order:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn-place-order:disabled {
            opacity: .7;
            cursor: not-allowed;
        }

        .btn-place-order .arrow {
            transition: transform .25s ease;
            display: inline-block;
        }

        .btn-place-order:hover:not(:disabled) .arrow {
            transform: translateX(4px);
        }

        .secure-note {
            text-align: center;
            font-size: .76rem;
            color: var(--text-3);
            margin-top: .6rem;
        }

        .secure-note i {
            color: var(--success);
        }

        .items-count-badge {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            font-size: .78rem;
            color: var(--text-3);
            font-weight: 500;
        }

        /* ─── BACK BUTTON ────────────────────────── */
        /* FIX: replaced margin-left:80% with margin-left:auto */
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: 10px 20px;
            margin-bottom: 20px;
            margin-left: auto;
            font-size: 14px;
            font-weight: 500;
            color: #fff;
            background: linear-gradient(135deg, #4f6ef7, #7b8cff);
            border-radius: 30px;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 6px 18px rgba(79, 110, 247, 0.3);
        }

        .back-btn-wrap {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 12px;
        }

        .back-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(79, 110, 247, 0.4);
            background: linear-gradient(135deg, #3c5df0, #6a7cff);
            color: #fff;
        }

        .back-btn:active {
            transform: scale(0.96);
        }

        ::-webkit-scrollbar {
            width: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 99px;
        }

        /* ─── ADDRESS MODAL ──────────────────────── */
        .modal-dark .modal-content {
            background: #1c2333;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
        }

        .modal-dark .modal-header {
            border-bottom: 1px solid var(--border);
        }

        .modal-dark .modal-footer {
            border-top: 1px solid var(--border);
        }

        .modal-dark .modal-title {
            font-weight: 700;
        }

        .form-section-label {
            display: block;
            font-size: .85rem;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 1rem;
        }

        .address-type-group {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 1.2rem;
            margin-bottom: 1.5rem;
        }

        .address-type-radios {
            display: flex;
            gap: 2rem;
        }

        .type-radio-wrap {
            display: flex;
            align-items: center;
            gap: .6rem;
            cursor: pointer;
            color: #fff;
            font-size: .9rem;
            font-weight: 500;
        }

        .type-radio-wrap input {
            accent-color: #00ff88;
            width: 18px;
            height: 18px;
        }

        .input-group-dark {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
        }

        .input-group-dark:focus-within {
            border-color: #00ff88;
            background: rgba(255, 255, 255, 0.08);
        }

        .input-group-dark .prefix {
            padding: .7rem 1rem;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.5);
            font-size: .9rem;
            font-weight: 600;
        }

        .input-group-dark input {
            background: transparent;
            border: none;
            padding: .7rem 1rem;
            color: #fff;
            width: 100%;
            outline: none;
        }

        .form-label-top {
            font-size: .82rem;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: .6rem;
        }

        .input-field-dark {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: .7rem 1.2rem;
            color: #fff;
            width: 100%;
            transition: all 0.3s ease;
            outline: none;
        }

        .input-field-dark:focus {
            border-color: #00ff88;
            background: rgba(255, 255, 255, 0.08);
        }

        .input-field-dark::placeholder {
            color: rgba(255, 255, 255, 0.2);
        }

        .p-48 {
            padding: 2.5rem;
        }

        .btn-save-address {
            background: #00ff88;
            color: #111422;
            padding: .75rem 1.8rem;
            border-radius: 20px;
            font-weight: 700;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-save-address:hover {
            background: #00d472;
            transform: scale(1.03);
        }

        /* ─── COUPON MODAL ──────────────────────────── */
        .coupon-modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .65);
            backdrop-filter: blur(6px);
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .coupon-modal-overlay.show {
            display: flex;
        }

        .coupon-modal {
            background: #fff;
            border-radius: 16px;
            width: 94%;
            max-width: 460px;
            max-height: 80vh;
            box-shadow: 0 24px 64px rgba(0, 0, 0, .4);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: slideUp .3s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px) scale(.97);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .coupon-modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 1.4rem;
            border-bottom: 1px solid #eee;
        }

        .coupon-modal-header .cm-title {
            display: flex;
            align-items: center;
            gap: .6rem;
        }

        .coupon-modal-header .cm-title .cm-icon {
            width: 32px;
            height: 32px;
            background: #e8f5e9;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: #2e7d32;
        }

        .coupon-modal-header .cm-title h4 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            color: #1a1a2e;
        }

        .coupon-modal-header .cm-title p {
            margin: 0;
            font-size: .75rem;
            color: #888;
        }

        .coupon-modal-close {
            width: 32px;
            height: 32px;
            border: none;
            background: #f5f5f5;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: #555;
            cursor: pointer;
            transition: all .2s;
        }

        .coupon-modal-close:hover {
            background: #e0e0e0;
            color: #222;
        }

        .coupon-modal-body {
            padding: 1rem 1.4rem 1.4rem;
            overflow-y: auto;
            flex: 1;
        }

        .coupon-modal-body::-webkit-scrollbar {
            width: 4px;
        }

        .coupon-modal-body::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }

        .cm-empty {
            text-align: center;
            padding: 2rem 1rem;
            color: #888;
            font-size: .88rem;
        }

        .cm-empty i {
            font-size: 2rem;
            color: #ccc;
            display: block;
            margin-bottom: .6rem;
        }

        .cm-coupon-card {
            background: #f0faf0;
            border: 1.5px solid #c8e6c9;
            border-radius: 12px;
            padding: 1rem 1.1rem;
            margin-bottom: .75rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .8rem;
            transition: transform .15s, box-shadow .15s;
            position: relative;
            overflow: hidden;
        }

        .cm-coupon-card:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(46, 125, 50, .1);
        }

        .cm-coupon-left {
            flex: 1;
            min-width: 0;
        }

        .cm-coupon-code-row {
            display: flex;
            align-items: center;
            gap: .5rem;
            margin-bottom: .4rem;
            flex-wrap: wrap;
        }

        .cm-code-badge {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: .82rem;
            font-weight: 800;
            letter-spacing: 1.2px;
            color: #2e7d32;
            background: #fff;
            border: 1.5px dashed #66bb6a;
            border-radius: 6px;
            padding: .3rem .7rem;
        }

        .cm-save-tag {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            font-size: .62rem;
            font-weight: 700;
            color: #fff;
            background: #2e7d32;
            border-radius: 4px;
            padding: .2rem .5rem;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .cm-coupon-desc {
            font-size: .8rem;
            color: #444;
            margin-bottom: .35rem;
            line-height: 1.3;
        }

        .cm-coupon-meta {
            display: flex;
            gap: .8rem;
            flex-wrap: wrap;
        }

        .cm-coupon-meta span {
            font-size: .68rem;
            color: #777;
            display: flex;
            align-items: center;
            gap: .25rem;
        }

        .cm-coupon-meta span i {
            font-size: .7rem;
            color: #2e7d32;
        }

        .cm-apply-btn {
            flex-shrink: 0;
            padding: .5rem 1rem;
            background: #fff;
            border: 1.5px solid #2e7d32;
            border-radius: 8px;
            color: #2e7d32;
            font-family: 'Inter', sans-serif;
            font-size: .76rem;
            font-weight: 700;
            letter-spacing: .5px;
            cursor: pointer;
            transition: all .2s;
        }

        .cm-apply-btn:hover {
            background: #2e7d32;
            color: #fff;
        }

        .cm-apply-btn:active {
            transform: scale(0.95);
        }

        /* ─── RESPONSIVE ─────────────────────────── */
        @media (max-width: 992px) {
            .page-title {
                font-size: 1.4rem;
            }

            .order-item-img {
                width: 48px;
                height: 48px;
            }
        }

        .contentDiv {
            margin-top: 50px;
        }
    </style>
</head>

<body>

    <%- include('../../partials/user/navigationbar', { user, cartItemCount, currentPage: 'cart' , categories }) %>

        <div id="checkoutPage" class="contentDiv">
            <div class="container-xl py-4 py-md-5">

                <div class="d-flex align-items-center gap-2 mb-3">
                    <h1 class="page-title">Check<span>out</span></h1>
                    <span class="items-count-badge ms-2">
                        <i class="bi bi-bag"></i>
                        <%- cartItems.length %> item<%= cartItems.length !==1 ? 's' : '' %>
                    </span>
                </div>

                <!-- FIX: Back button wrapped for flex alignment — no more margin-left:80% -->
                <div class="back-btn-wrap">
                    <a href="/cart" class="back-btn">
                        <i class="bi bi-arrow-left"></i> Back to Cart
                    </a>
                </div>

                <div class="row g-4">

                    <!-- ── LEFT COLUMN ────────────────────── -->
                    <div class="col-lg-7 d-flex flex-column">

                        <!-- ── DELIVERY ADDRESS ────────────── -->
                        <div class="card-dark mb-4">
                            <div class="card-header-custom">
                                <div class="title">
                                    <div class="icon-circle"><i class="bi bi-geo-alt-fill"></i></div>
                                    Delivery Address
                                </div>
                            </div>

                            <div class="address-grid" id="addressGrid">
                                <% userAddresses.forEach(function(addr) { %>
                                    <div class="address-card <%= addr.isDefault ? 'selected' : '' %>"
                                        onclick="selectAddress(this, '<%= addr._id %>')"
                                        data-address-id="<%= addr._id %>">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="radio-dot mt-1"></div>
                                            <div class="flex-grow-1">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <span class="addr-name">
                                                        <%= addr.name %>
                                                    </span>
                                                    <span
                                                        class="addr-badge <%= addr.addressType.toLowerCase() === 'work' ? 'work' : 'home' %>">
                                                        <i
                                                            class="bi bi-<%= addr.addressType.toLowerCase() === 'work' ? 'building' : 'house-fill' %>"></i>
                                                        <%= addr.addressType %>
                                                    </span>
                                                    <% if (addr.isDefault) { %>
                                                        <span class="addr-badge default"><i class="bi bi-star-fill"></i>
                                                            Default</span>
                                                        <% } %>
                                                </div>
                                                <p class="addr-text">
                                                    <%= addr.houseName %>
                                                        <% if (addr.locality) { %>, <%= addr.locality %>
                                                                <% } %><br />
                                                                    <%= addr.city %>, <%= addr.state %> – <%=
                                                                                addr.pincode %><br />
                                                                                <i class="bi bi-telephone-fill"
                                                                                    style="font-size:.72rem"></i> +91
                                                                                <%= addr.phone %>
                                                </p>
                                            </div>
                                            <% /* FIX: Single accessible button — no more hidden duplicate button */
                                                const addrSafe=JSON.stringify(addr).replace(/'/g, '&#39;'
                                                ).replace(/</g, '&lt;' ).replace( />/g, '&gt;');
                                            %>
                                            <!-- FIX: accessible role, aria-label, keyboard-friendly -->
                                            <button class="btn-edit-addr-icon"
                                                aria-label="Edit address for <%= addr.name %>"
                                                onclick="event.stopPropagation(); openEditModal(this)"
                                                data-addr='<%- addrSafe %>'>
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>

                            <button class="btn-add-addr" onclick="openAddModal()">
                                <i class="bi bi-plus-circle"></i> Add a new address
                            </button>
                        </div>

                        <!-- ── ORDER ITEMS ──────────────────── -->
                        <div class="card-dark">
                            <div class="card-header-custom">
                                <div class="title">
                                    <div class="icon-circle"><i class="bi bi-bag-fill"></i></div>
                                    Order Items
                                </div>
                                <span class="items-count-badge">
                                    <%- cartItems.length %> item<%= cartItems.length !==1 ? 's' : '' %>
                                </span>
                            </div>

                            <div class="order-items-list">
                                <% cartItems.forEach(function(item) { %>
                                    <div class="order-item-row">
                                        <img src="<%= item.product.images[0] || '/images/placeholder.png' %>"
                                            alt="<%= item.product.name %>" class="order-item-img"
                                            onerror="this.src='/images/placeholder.png'" />
                                        <div class="item-meta flex-grow-1">
                                            <div class="item-name">
                                                <%= item.product.name %>
                                            </div>
                                            <div class="item-attr">
                                                <% if (item.selectedColor) { %>Color: <strong>
                                                        <%= item.selectedColor %>
                                                    </strong> &nbsp;•&nbsp; <% } %>
                                                        <% if (item.selectedStorage) { %>Storage: <strong>
                                                                <%= item.selectedStorage %>
                                                            </strong> &nbsp;•&nbsp; <% } %>
                                                                <% if (item.selectedRam) { %>RAM: <strong>
                                                                        <%= item.selectedRam %>
                                                                    </strong>
                                                                    <% } %>
                                            </div>
                                            <div class="item-qty-badge">
                                                <i class="bi bi-stack"></i> Qty: <strong>
                                                    <%= item.quantity %>
                                                </strong>
                                            </div>
                                        </div>
                                        <div class="item-price-col">
                                            <div class="price-main">₹<%= (item.product.discountedPrice *
                                                    item.quantity).toLocaleString('en-IN') %>
                                            </div>
                                            <% if (item.product.originalPrice> item.product.discountedPrice) { %>
                                                <div class="price-orig">₹<%= (item.product.originalPrice *
                                                        item.quantity).toLocaleString('en-IN') %>
                                                </div>
                                                <div class="price-save">Save ₹<%= ((item.product.originalPrice -
                                                        item.product.discountedPrice) *
                                                        item.quantity).toLocaleString('en-IN') %>
                                                </div>
                                                <% } %>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>

                    </div><!-- end left col -->

                    <!-- ── RIGHT COLUMN ───────────────────── -->
                    <div class="col-lg-5 d-flex flex-column">

                        <!-- ── PAYMENT METHOD ───────────────── -->
                        <div class="card-dark mb-4">
                            <div class="card-header-custom">
                                <div class="title">
                                    <div class="icon-circle"><i class="bi bi-credit-card-2-front-fill"></i></div>
                                    Payment Method
                                </div>
                            </div>
                            <div class="payment-list">

                                <!-- Cash on Delivery -->
                                <div class="payment-option " id="pay-cod" onclick="selectPayment('COD')">
                                    <div class="pay-icon">
                                        <i class="bi bi-cash-stack"></i>
                                    </div>
                                    <div>
                                        <div class="pay-name">Cash on Delivery</div>
                                        <% if (totalAmount>= 30000) { %>
                                            <div class="pay-desc"
                                                style="color:rgba(255, 74, 29, 0.1);color:var(--danger);">
                                                COD not available for orders above ₹30,000
                                            </div>
                                            <% } else { %>
                                                <div class="pay-desc" style="color:var(--accent);">
                                                    Pay when you receive your order
                                                </div>
                                                <% } %>
                                    </div>
                                    <div class="radio-dot ms-auto" id="radio-cod"></div>
                                </div>

                                <!-- Razorpay -->
                                <div class="payment-option" id="pay-razorpay" onclick="selectPayment('Razorpay')">
                                    <div class="pay-icon" style="background:rgba(100,100,200,.1);color:#7c8ce4;">
                                        <i class="bi bi-lightning-charge-fill"></i>
                                    </div>
                                    <div>
                                        <div class="pay-name">Razorpay</div>
                                        <div class="pay-desc">UPI, Cards, Net Banking</div>
                                    </div>
                                    <div class="radio-dot ms-auto"></div>
                                </div>

                                <!-- Wallet Payment -->
                                <% if (typeof walletBalance !=='undefined' ) { %>
                                    <div class="payment-option" id="pay-wallet" onclick="selectPayment('Wallet')">
                                        <div class="pay-icon"
                                            style="background:rgba(66, 244, 122, 0.1);color:var(--danger);">
                                            <i class="bi bi-wallet2"></i>
                                        </div>
                                        <div>
                                            <div class="pay-name">Wallet</div>
                                            <div class="pay-desc">Pay from your Zyrox Wallet</div>
                                            <div class="wallet-balance-badge">
                                                Balance: ₹<%= walletBalance.toLocaleString('en-IN') %>
                                            </div>
                                            <% if (walletBalance < totalAmount) { %>
                                                <div class="wallet-insufficient">No Enough Balance to pay total amount
                                                </div>
                                                <% } %>
                                        </div>
                                        <div class="radio-dot ms-auto"></div>
                                    </div>
                                    <% } %>



                            </div>
                        </div>

                        <!-- COUPON -->
                        <div class="card-dark mb-4">
                            <div class="card-header-custom">
                                <div class="title">
                                    <div class="icon-circle"><i class="bi bi-tag-fill"></i></div>
                                    Promo Code
                                </div>
                            </div>

                            <div class="coupon-section mt-3">

                                <% /* Determine if a coupon is already applied server-side */ const
                                    isCouponApplied=couponDiscount> 0 && appliedCoupon;
                                    %>

                                    <!-- FIX: Applied coupon state — shown when coupon is active -->
                                    <div class="coupon-applied-state <%= isCouponApplied ? 'visible' : '' %>"
                                        id="couponAppliedState">
                                        <div class="coupon-applied-info">
                                            <i class="bi bi-check-circle-fill"></i>
                                            <span id="appliedCouponLabel">
                                                <% if (isCouponApplied) { %>
                                                    "<%= appliedCoupon %>" applied — ₹<%=
                                                            couponDiscount.toLocaleString('en-IN') %> off
                                                            <% } %>
                                            </span>
                                        </div>
                                        <!-- FIX: Remove coupon button -->
                                        <button class="btn-remove-coupon" onclick="removeCoupon()">
                                            <i class="bi bi-x-lg"></i> Remove
                                        </button>
                                    </div>

                                    <!-- Input row — hidden if coupon already applied -->
                                    <div id="couponInputRow" style="<%= isCouponApplied ? 'display:none' : '' %>">
                                        <div class="coupon-input-wrap">
                                            <!-- FIX: uppercase transform applied via CSS, value trimmed in JS -->
                                            <input type="text" id="couponInput" placeholder="Enter coupon code…"
                                                autocomplete="off" />
                                            <!-- FIX: loading state on button -->
                                            <button class="btn-apply" id="applyBtn"
                                                onclick="applyCoupon()">Apply</button>
                                        </div>
                                        <a href="#" class="coupon-hint" onclick="toggleCoupons(event)">
                                            <i class="bi bi-ticket-perforated"></i> View all available coupons
                                        </a>
                                    </div>

                                    <div id="couponError" class="mt-2"
                                        style="font-size:.8rem;color:var(--danger);display:none;"></div>
                                    <div id="couponSuccess" class="mt-2"
                                        style="font-size:.8rem;color:var(--success);display:none;"></div>
                            </div>
                        </div>

                        <!-- PRICE SUMMARY -->
                        <div class="card-dark mb-4">
                            <div class="card-header-custom">
                                <div class="title">
                                    <div class="icon-circle"><i class="bi bi-receipt"></i></div>
                                    Price Summary
                                </div>
                            </div>

                            <div class="price-summary">
                                <div class="price-row">
                                    <span class="label">Subtotal (<%= cartItems.length %> items)</span>
                                    <span class="val">₹<%= subtotal.toLocaleString('en-IN') %></span>
                                </div>
                                <% if (discount> 0) { %>
                                    <div class="price-row discount">
                                        <span class="label">Product Discount</span>
                                        <span class="val">– ₹<%= discount.toLocaleString('en-IN') %></span>
                                    </div>
                                    <% } %>
                                        <% if (couponDiscount> 0) { %>
                                            <div class="price-row discount">
                                                <span class="label">Coupon (<%= appliedCoupon %>)</span>
                                                <span class="val">– ₹<%= couponDiscount.toLocaleString('en-IN') %>
                                                </span>
                                            </div>
                                            <% } %>
                                                <div class="price-row shipping">
                                                    <span class="label">Shipping</span>
                                                    <span class="val">
                                                        <%= shippingCharge===0 ? 'FREE' : '₹' +
                                                            shippingCharge.toLocaleString('en-IN') %>
                                                    </span>
                                                </div>
                                                <% if (tax> 0) { %>
                                                    <div class="price-row">
                                                        <span class="label">GST & Taxes</span>
                                                        <span class="val">₹<%= tax.toLocaleString('en-IN') %></span>
                                                    </div>
                                                    <% } %>
                                                        <hr class="price-divider" />
                                                        <div class="price-row total">
                                                            <span class="label">Total Payable</span>
                                                            <span class="val">₹<%= totalAmount.toLocaleString('en-IN')
                                                                    %></span>
                                                        </div>
                                                        <% if ((discount + couponDiscount)> 0) { %>
                                                            <div class="savings-pill">
                                                                <i class="bi bi-check-circle-fill"></i>
                                                                You save ₹<%= (discount +
                                                                    couponDiscount).toLocaleString('en-IN') %> on this
                                                                    order!
                                                            </div>
                                                            <% } %>
                            </div>
                        </div>

                        <!-- PLACE ORDER -->
                        <button class="btn-place-order" id="placeOrderBtn" onclick="placeOrder()">
                            Place Order &nbsp;·&nbsp; ₹<%= totalAmount.toLocaleString('en-IN') %>
                                <span class="arrow">→</span>
                        </button>
                        <p class="secure-note">
                            <i class="bi bi-shield-lock-fill"></i>
                            100% Secure &amp; Encrypted. Your data is safe.
                        </p>

                    </div><!-- end right col -->
                </div><!-- end row -->
            </div><!-- end container -->
        </div><!-- end checkoutPage -->

        <!-- ─── AVAILABLE COUPONS MODAL ─────────────────────────── -->
        <div class="coupon-modal-overlay" id="couponModalOverlay" onclick="closeCouponModal(event)">
            <div class="coupon-modal" onclick="event.stopPropagation()">
                <div class="coupon-modal-header">
                    <div class="cm-title">
                        <div class="cm-icon"><i class="bi bi-ticket-perforated-fill"></i></div>
                        <div>
                            <h4>Available Coupons</h4>
                            <p>Best offers for you</p>
                        </div>
                    </div>
                    <button class="coupon-modal-close" aria-label="Close coupons" onclick="closeCouponModal()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="coupon-modal-body" id="couponModalBody">
                    <% if (coupons.length===0) { %>
                        <div class="cm-empty">
                            <i class="bi bi-ticket-perforated"></i>
                            No coupons available right now
                        </div>
                        <% } %>

                            <% coupons.forEach(coupon=> {
                                /* FIX: format validTill date for display */
                                let validTillDisplay = 'N/A';
                                if (coupon.validTill) {
                                try {
                                validTillDisplay = new Date(coupon.validTill).toLocaleDateString('en-IN', {
                                day: '2-digit', month: 'short', year: 'numeric'
                                });
                                } catch(e) {
                                validTillDisplay = coupon.validTill;
                                }
                                }
                                /* FIX: format discount label to show ₹ or % using schema fields */
                                const discountLabel = coupon.discountType === 'percentage'
                                ? coupon.discountValue + '% off'
                                : '₹' + Number(coupon.discountValue).toLocaleString('en-IN') + ' off';
                                %>
                                <div class="cm-coupon-card">
                                    <div class="cm-coupon-left">
                                        <div class="cm-coupon-code-row">
                                            <span class="cm-code-badge">
                                                <%= coupon.code %>
                                            </span>
                                            <span class="cm-save-tag">SAVE <%= discountLabel %></span>
                                        </div>
                                        <div class="cm-coupon-desc">
                                            <%= coupon.description %>
                                        </div>
                                        <div class="cm-coupon-meta">
                                            <span><i class="bi bi-cash"></i> Min ₹<%= coupon.minCartValue || 0 %></span>
                                            <span><i class="bi bi-clock"></i> Valid till <%= validTillDisplay %></span>
                                        </div>
                                    </div>
                                    <button class="cm-apply-btn" onclick="applyCouponFromModal('<%= coupon.code %>')">
                                        APPLY
                                    </button>
                                </div>
                                <% }) %>
                </div>
            </div>
        </div>

        <!-- ─── ADD / EDIT ADDRESS MODAL ─────────────────────────── -->
        <div class="modal fade" id="addAddressModal" tabindex="-1" data-bs-backdrop="static">
            <div class="modal-dialog modal-dialog-centered modal-lg modal-dark">
                <div class="modal-content">
                    <div class="modal-body p-48">
                        <h4 id="modalTitle" class="text-white mb-4">Add New Address</h4>
                        <input type="hidden" id="addr_id">

                        <div class="address-type-group">
                            <span class="form-section-label">Address Type</span>
                            <div class="address-type-radios">
                                <label class="type-radio-wrap">
                                    <input type="radio" name="addressType" value="home" checked> Home
                                </label>
                                <label class="type-radio-wrap">
                                    <input type="radio" name="addressType" value="work"> Work
                                </label>
                                <label class="type-radio-wrap">
                                    <input type="radio" name="addressType" value="other"> Other
                                </label>
                            </div>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-label-top">Full Name</div>
                                <input type="text" class="input-field-dark" id="addr_fullName"
                                    placeholder="Recipient Name" autocomplete="name">
                            </div>
                            <div class="col-md-6">
                                <div class="form-label-top">Phone Number</div>
                                <div class="input-group-dark">
                                    <div class="prefix">+91</div>
                                    <input type="text" id="addr_phone" placeholder="10 Digit Number" maxlength="10"
                                        autocomplete="tel">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-label-top">House Name / No.</div>
                                <input type="text" class="input-field-dark" id="addr_line1"
                                    placeholder="Building Name / No." autocomplete="address-line1">
                            </div>
                            <div class="col-md-6">
                                <div class="form-label-top">Locality / Street</div>
                                <input type="text" class="input-field-dark" id="addr_line2" placeholder="Area / Street"
                                    autocomplete="address-line2">
                            </div>
                            <div class="col-md-4">
                                <div class="form-label-top">City</div>
                                <input type="text" class="input-field-dark" id="addr_city" placeholder="City"
                                    autocomplete="address-level2">
                            </div>
                            <div class="col-md-4">
                                <div class="form-label-top">State</div>
                                <input type="text" class="input-field-dark" id="addr_state" placeholder="State"
                                    autocomplete="address-level1">
                            </div>
                            <div class="col-md-4">
                                <div class="form-label-top">Pincode</div>
                                <input type="text" class="input-field-dark" id="addr_pin" placeholder="6 Digit Code"
                                    maxlength="6" autocomplete="postal-code">
                            </div>
                            <div class="col-12">
                                <div class="form-label-top">Country</div>
                                <input type="text" class="input-field-dark" id="addr_country" value="India" readonly>
                            </div>
                            <div class="col-12 mt-3">
                                <label class="type-radio-wrap" style="color:rgba(255,255,255,0.6);font-size:.84rem;">
                                    <input type="checkbox" id="addr_default" style="width:16px;height:16px;">
                                    Set as default address
                                </label>
                            </div>
                            <div id="addrError" class="col-12"
                                style="font-size:.8rem;color:#ff5555;display:none;margin-top:1rem;"></div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5">
                            <button class="btn" style="color:#aab0c4;font-weight:600;"
                                data-bs-dismiss="modal">Cancel</button>
                            <button class="btn btn-save-address" id="saveBtn" onclick="saveAddress()">Save
                                Address</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ─── SCRIPTS ───────────────────────────────────────── -->
        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            /* ── Server-side data injected safely ─── */
            const PAGE_DATA = {
                totalAmount: <%= totalAmount || 0 %>,
                itemCount: <%= cartItems ?cartItems.length : 0 %>,
                    csrfToken: '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>',
                        razorpayKey: '<%= typeof razorpayKey !== "undefined" ? razorpayKey : "" %>',
                            walletBalance: <%= typeof walletBalance !== "undefined" ? walletBalance : 0 %>
            };

            /* FIX: consistent casing — always store as sent to server */
            let selectedAddressId = '<%- userAddresses.find(a => a.isDefault)?._id || (userAddresses[0]?._id) || "" %>';
            /* FIX: default logic — COD if allowed, otherwise Razorpay */
            let selectedPayment = PAGE_DATA.totalAmount > 1000 ? 'Razorpay' : 'COD';

            /* Auto-select Razorpay if COD is disabled */
            window.addEventListener('DOMContentLoaded', () => {
                if (PAGE_DATA.totalAmount > 1000) {
                    const codOpt = document.getElementById('pay-cod');
                    if (codOpt) codOpt.classList.remove('selected');
                    const razorOpt = document.getElementById('pay-razorpay');
                    if (razorOpt) razorOpt.classList.add('selected');
                }
            });

            /* ── Address Selection ─────────────────── */
            function selectAddress(el, id) {
                document.querySelectorAll('.address-card').forEach(c => c.classList.remove('selected'));
                el.classList.add('selected');
                selectedAddressId = id;
            }

            /* ── Payment Selection ─────────────────── */
            /* FIX: unified casing — method stored exactly as passed, radio uses lowercase id */
            function selectPayment(method) {
                if (method === 'Wallet' && PAGE_DATA.walletBalance < PAGE_DATA.totalAmount) {
                    Swal.fire({
                        icon: 'info',
                        title: 'wallet Not Available',
                        text: 'no enough balance to pay total amount .',
                        background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7'
                    });
                    return;
                }
                if (method === 'COD' && PAGE_DATA.totalAmount > 30000) {
                    Swal.fire({
                        icon: 'info',
                        title: 'COD Not Available',
                        text: 'Cash on Delivery is only available for orders below ₹30,000.',
                        background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7'
                    });
                    return;
                }
                selectedPayment = method;
                document.querySelectorAll('.payment-option:not(.disabled)').forEach(o => o.classList.remove('selected'));
                document.getElementById('pay-' + method.toLowerCase())?.classList.add('selected');
            }

            /* ── Coupon helpers ─────────────────────── */
            function setCouponLoading(loading) {
                const btn = document.getElementById('applyBtn');
                if (!btn) return;
                btn.disabled = loading;
                btn.innerHTML = loading
                    ? '<span class="spinner-border spinner-border-sm" style="width:14px;height:14px;border-width:2px"></span>'
                    : 'Apply';
            }

            /* FIX: trim + uppercase before sending; loading state; no blind setTimeout */
            function applyCoupon() {
                const rawCode = document.getElementById('couponInput').value;
                const code = rawCode.trim().toUpperCase();
                const errEl = document.getElementById('couponError');
                const okEl = document.getElementById('couponSuccess');
                errEl.style.display = 'none';
                okEl.style.display = 'none';

                if (!code) {
                    errEl.textContent = 'Please enter a coupon code.';
                    errEl.style.display = 'block';
                    return;
                }

                setCouponLoading(true);

                fetch('/api/coupon/apply', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': PAGE_DATA.csrfToken
                    },
                    body: JSON.stringify({ code })
                })
                    .then(r => r.json())
                    .then(data => {
                        setCouponLoading(false);
                        if (data.success) {
                            okEl.innerHTML = `<i class="bi bi-check-circle-fill"></i> Coupon applied! You saved ₹${data.discount.toLocaleString('en-IN')}`;
                            okEl.style.display = 'block';
                            /* Reload after a visible moment so user sees the confirmation */
                            setTimeout(() => location.reload(), 1200);
                        } else {
                            errEl.textContent = data.message || 'Invalid or expired coupon.';
                            errEl.style.display = 'block';
                        }
                    })
                    .catch(() => {
                        setCouponLoading(false);
                        errEl.textContent = 'Something went wrong. Try again.';
                        errEl.style.display = 'block';
                    });
            }

            /* FIX: remove coupon calls the server, not just a UI toggle */
            function removeCoupon() {
                fetch('/api/coupon/remove', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': PAGE_DATA.csrfToken
                    }
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Could not remove coupon',
                                text: data.message || 'Please try again.',
                                background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7'
                            });
                        }
                    })
                    .catch(() => location.reload());
            }

            function toggleCoupons(e) {
                e.preventDefault();
                openCouponModal();
            }

            /* ── Coupon Modal ──────────────────────── */
            function openCouponModal() {
                document.getElementById('couponModalOverlay').classList.add('show');
                document.body.style.overflow = 'hidden';
            }

            function closeCouponModal(e) {
                if (e && e.target !== e.currentTarget) return;
                document.getElementById('couponModalOverlay').classList.remove('show');
                document.body.style.overflow = '';
            }

            /* FIX: sets the input value AND immediately triggers the apply flow */
            function applyCouponFromModal(code) {
                closeCouponModal();
                const inputEl = document.getElementById('couponInput');
                if (inputEl) {
                    inputEl.value = code;
                    applyCoupon();
                }
            }

            /* ── Place Order ────────────────────────── */
            function placeOrder() {
                if (!selectedAddressId) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Address Required',
                        text: 'Please select a delivery address.',
                        background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7'
                    });
                    return;
                }

                const paymentLabel = selectedPayment === 'COD' ? 'Cash on Delivery' : selectedPayment;

                Swal.fire({
                    title: 'Confirm Order',
                    text: `Place this order with ${paymentLabel}?`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#4f6ef7',
                    cancelButtonColor: '#252a42',
                    confirmButtonText: 'Yes, Place Order',
                    background: '#111422',
                    color: '#f0f2ff'
                }).then(result => {
                    if (result.isConfirmed) {
                        if (selectedPayment === 'Razorpay') {
                            openRazorpayGateway();
                        } else {
                            executePlaceOrder();
                        }
                    }
                });
            }

            function setPlaceOrderLoading(loading, label) {
                const btn = document.getElementById('placeOrderBtn');
                btn.disabled = loading;
                btn.innerHTML = loading
                    ? `<span class="spinner-border spinner-border-sm me-2"></span>${label}`
                    : `Place Order &nbsp;·&nbsp; ₹${Number(PAGE_DATA.totalAmount).toLocaleString('en-IN')} <span class="arrow">→</span>`;
            }

            function openRazorpayGateway() {
                setPlaceOrderLoading(true, 'Initializing Razorpay…');

                fetch('/checkout/create-razorpay-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': PAGE_DATA.csrfToken },
                    body: JSON.stringify({ amount: PAGE_DATA.totalAmount })
                })
                    .then(res => res.json())
                    .then(data => {
                        if (!data.success) {
                            setPlaceOrderLoading(false);
                            return Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Error generating order', background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7' });
                        }

                        /* FIX: prefill from the selected address card, not the modal inputs */
                        const selectedCard = document.querySelector('.address-card.selected');
                        const prefillName = selectedCard?.querySelector('.addr-name')?.textContent?.trim() || '';

                        const options = {
                            key: PAGE_DATA.razorpayKey,
                            amount: data.order.amount,
                            currency: 'INR',
                            name: 'ZYROX',
                            description: 'Purchase Checkout',
                            order_id: data.order.id,
                            handler: function (response) {
                                setPlaceOrderLoading(true, 'Verifying Payment…');
                                const orderAmount = data.order.amount / 100;
                                fetch('/checkout/verify-razorpay', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': PAGE_DATA.csrfToken },
                                    body: JSON.stringify(response)
                                })
                                    .then(r => r.json())
                                    .then(verifyData => {
                                        if (verifyData.success) {
                                            executePlaceOrder();
                                        } else {
                                            const params = new URLSearchParams({ 
                                                reason: 'Payment signature verification failed', 
                                                amount: orderAmount,
                                                isBuyNow: '<%= isBuyNow %>'
                                            });
                                            window.location.href = '/payment-failed?' + params.toString();
                                        }
                                    })
                                    .catch(() => {
                                        window.location.href = '/payment-failed?reason=error+during+verification&isBuyNow=<%= isBuyNow %>';
                                    });
                            },
                            prefill: { name: prefillName },
                            theme: { color: '#4f6ef7' },
                            modal: {
                                ondismiss: function () {
                                    setPlaceOrderLoading(false);
                                    Swal.fire({
                                        icon: 'warning',
                                        title: 'Payment Cancelled',
                                        text: 'You closed the payment window. Retry or go back to cart?',
                                        showCancelButton: true,
                                        confirmButtonText: 'Retry Payment',
                                        cancelButtonText: 'Back to Cart',
                                        confirmButtonColor: '#4f6ef7',
                                        cancelButtonColor: '#252a42',
                                        background: '#111422',
                                        color: '#f0f2ff'
                                    }).then(r => { if (!r.isConfirmed) window.location.href = '/cart'; });
                                }
                            }
                        };

                        const rzp = new window.Razorpay(options);

                        rzp.on('payment.failed', function (resp) {
                            setPlaceOrderLoading(true, 'Recording failed attempt...');
                            const reason = resp.error?.description || resp.error?.reason || 'Payment was declined';
                            const amount = (data.order.amount / 100);

                            fetch('/checkout/record-failed-order', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': PAGE_DATA.csrfToken },
                                body: JSON.stringify({
                                    addressId: selectedAddressId,
                                    reason: reason,
                                    amount: amount,
                                    isBuyNow: '<%= isBuyNow %>' === 'true'
                                })
                            })
                            .then(res => res.json())
                            .then(recordData => {
                                const params = new URLSearchParams({ 
                                    reason, 
                                    amount,
                                    orderId: recordData.displayOrderId,
                                    dbOrderId: recordData.orderId,
                                    isBuyNow: '<%= isBuyNow %>'
                                });
                                window.location.href = '/payment-failed?' + params.toString();
                            })
                            .catch(() => {
                                window.location.href = `/payment-failed?reason=${encodeURIComponent(reason)}&amount=${amount}&isBuyNow=<%= isBuyNow %>`;
                            });
                        });

                        rzp.open();
                    })
                    .catch(() => {
                        setPlaceOrderLoading(false);
                        Swal.fire({ icon: 'error', title: 'Network Error', text: 'Please try again.', background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7' });
                    });
            }

            function executePlaceOrder() {
                setPlaceOrderLoading(true, 'Placing Order…');

                fetch('/checkout/place-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': PAGE_DATA.csrfToken },
                    body: JSON.stringify({
                        addressId: selectedAddressId,
                        paymentMethod: selectedPayment   /* FIX: always consistent casing */
                    })
                })
                    .then(res => {
                        if (!res.ok && res.headers.get('content-type')?.includes('text/html')) {
                            window.location.href = '/signin';
                            return Promise.reject(new Error('session_expired'));
                        }
                        return res.json();
                    })
                    .then(data => {
                        if (data.success) {
                            window.location.href = '/order-success/' + data.orderId;
                        } else {
                            Swal.fire({
                                icon: 'error', title: 'Order Failed',
                                text: data.message || 'Could not place order. Please try again.',
                                background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7'
                            });
                            setPlaceOrderLoading(false);
                        }
                    })
                    .catch(err => {
                        if (err.message === 'session_expired') return;
                        Swal.fire({
                            icon: 'error', title: 'Network Error',
                            text: 'Something went wrong. Please try again.',
                            background: '#111422', color: '#f0f2ff', confirmButtonColor: '#4f6ef7'
                        });
                        setPlaceOrderLoading(false);
                    });
            }

            /* ── Address Modal ──────────────────────── */
            const addressModal = new bootstrap.Modal(document.getElementById('addAddressModal'));

            function openAddModal() {
                document.getElementById('modalTitle').textContent = 'Add New Address';
                document.getElementById('saveBtn').textContent = 'Save Address';
                document.getElementById('addr_id').value = '';
                document.getElementById('addr_fullName').value = '';
                document.getElementById('addr_phone').value = '';
                document.getElementById('addr_line1').value = '';
                document.getElementById('addr_line2').value = '';
                document.getElementById('addr_city').value = '';
                document.getElementById('addr_state').value = '';
                document.getElementById('addr_pin').value = '';
                document.getElementById('addr_default').checked = false;
                document.querySelector('input[name="addressType"][value="home"]').checked = true;
                document.getElementById('addrError').style.display = 'none';
                addressModal.show();
            }

            function openEditModal(btn) {
                /* FIX: parse from the button's data-addr (already HTML-safe via EJS escape) */
                let addr;
                try {
                    addr = JSON.parse(btn.getAttribute('data-addr'));
                } catch (e) {
                    return;
                }

                document.getElementById('modalTitle').textContent = 'Edit Address';
                document.getElementById('saveBtn').textContent = 'Update Address';
                document.getElementById('addr_id').value = addr._id;
                document.getElementById('addr_fullName').value = addr.name || '';
                document.getElementById('addr_phone').value = addr.phone || '';
                document.getElementById('addr_line1').value = addr.houseName || '';
                document.getElementById('addr_line2').value = addr.locality || '';
                document.getElementById('addr_city').value = addr.city || '';
                document.getElementById('addr_state').value = addr.state || '';
                document.getElementById('addr_pin').value = addr.pincode || '';
                document.getElementById('addr_default').checked = !!addr.isDefault;
                document.getElementById('addrError').style.display = 'none';

                const typeVal = (addr.addressType || 'home').toLowerCase();
                const typeRadio = document.querySelector(`input[name="addressType"][value="${typeVal}"]`);
                if (typeRadio) typeRadio.checked = true;

                addressModal.show();
            }

            function saveAddress() {
                const addrId = document.getElementById('addr_id').value;
                const addrTypeInput = document.querySelector('input[name="addressType"]:checked');
                const fields = {
                    name: document.getElementById('addr_fullName').value.trim(),
                    phone: document.getElementById('addr_phone').value.trim(),
                    houseName: document.getElementById('addr_line1').value.trim(),
                    locality: document.getElementById('addr_line2').value.trim(),
                    city: document.getElementById('addr_city').value.trim(),
                    pincode: document.getElementById('addr_pin').value.trim(),
                    state: document.getElementById('addr_state').value.trim(),
                    country: document.getElementById('addr_country').value.trim(),
                    addressType: addrTypeInput ? addrTypeInput.value : 'home',
                    isDefault: document.getElementById('addr_default').checked
                };

                const errEl = document.getElementById('addrError');
                errEl.style.display = 'none';

                if (!fields.name || !fields.phone || !fields.houseName || !fields.locality || !fields.city || !fields.pincode || !fields.state) {
                    errEl.textContent = 'All fields are required.';
                    errEl.style.display = 'block';
                    return;
                }

                if (!/^\d{10}$/.test(fields.phone)) {
                    errEl.textContent = 'Enter a valid 10-digit phone number.';
                    errEl.style.display = 'block';
                    return;
                }

                if (!/^\d{6}$/.test(fields.pincode)) {
                    errEl.textContent = 'Enter a valid 6-digit pincode.';
                    errEl.style.display = 'block';
                    return;
                }

                const url = addrId ? `/address-edit/${addrId}` : '/address-add';

                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'X-CSRF-Token': PAGE_DATA.csrfToken
                    },
                    body: JSON.stringify(fields)
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            errEl.textContent = data.message || 'Failed to save address.';
                            errEl.style.display = 'block';
                        }
                    })
                    .catch(() => { errEl.textContent = 'Network error.'; errEl.style.display = 'block'; });
            }

            /* ── Keyboard accessibility: close coupon modal on Esc ── */
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeCouponModal();
            });
            /* ── Auto-Place Order (from Retry Payment) ── */
            document.addEventListener('DOMContentLoaded', () => {
                const urlParams = new URLSearchParams(window.location.search);
                if (urlParams.get('autoPlace') === 'true') {
                    // Slight delay to ensure all scripts and data (like address selection) are fully loaded
                    setTimeout(() => {
                        const placeOrderBtn = document.getElementById('placeOrderBtn');
                        if (placeOrderBtn && !placeOrderBtn.disabled) {
                            console.log('Auto-triggering placeOrder from Retry Payment flow...');
                            placeOrder();
                        }
                    }, 1000);
                }
            });
        </script>
</body>

</html>