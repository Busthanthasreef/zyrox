<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products — Zyrox</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    :root {
      --bg: #111318;
      --bg-card: #1a1d24;
      --bg-card-h: #1f2330;
      --accent: #c8883a;
      --text: #f0f0f2;
      --sub: #70788a;
      --muted: #44505e;
      --border: rgba(255, 255, 255, .08);
      --border2: rgba(255, 255, 255, .13);
      --navbar-h: 70px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      font-family: 'Inter', sans-serif;
      color: var(--text);
      min-height: 100vh;
      padding-top: var(--navbar-h);
    }

    .page-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 32px 28px 60px;
    }

    .topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 6px;
    }

    .topbar-left {
      flex: 1;
    }

    .page-heading {
      font-size: 1.55rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 10px;
    }

    .active-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 6px;
    }

    .active-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1.5px solid var(--border2);
      border-radius: 6px;
      padding: 4px 13px;
      font-size: .76rem;
      color: var(--text);
      white-space: nowrap;
    }

    .active-pill a {
      color: var(--sub);
      text-decoration: none;
      font-size: .65rem;
      line-height: 1;
      transition: color .18s;
    }

    .active-pill a:hover {
      color: #e63946;
    }

    .result-count {
      font-size: .78rem;
      color: var(--sub);
      margin-top: 4px;
    }

    .sort-wrap {
      position: relative;
      flex-shrink: 0;
    }

    .sort-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      background: transparent;
      border: 2px solid var(--text);
      border-radius: 6px;
      padding: 9px 22px;
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: .85rem;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: border-color .2s, color .2s;
    }

    .sort-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .sort-dd {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      background: #13151c;
      border: 1px solid var(--border2);
      border-radius: 10px;
      min-width: 210px;
      z-index: 400;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(0, 0, 0, .75);
      animation: fadeDown .15s ease;
    }

    @keyframes fadeDown {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .sort-dd.open {
      display: block;
    }

    .sort-opt {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 16px;
      font-size: .82rem;
      color: var(--sub);
      text-decoration: none;
      cursor: pointer;
      transition: background .15s, color .15s;
    }

    .sort-opt:hover {
      background: rgba(255, 255, 255, .05);
      color: var(--text);
    }

    .sort-opt.active {
      color: var(--accent);
    }

    .sort-opt .tick {
      font-size: .65rem;
      display: none;
      color: var(--accent);
    }

    .sort-opt.active .tick {
      display: inline;
    }

    .filter-toggle-row {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
    }

    .filter-toggle-btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: var(--bg-card);
      border: 1px solid var(--border2);
      border-radius: 8px;
      padding: 8px 16px;
      font-size: .78rem;
      font-weight: 600;
      color: var(--text);
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: border-color .2s;
    }

    .filter-toggle-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .drawer-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.55);
      z-index: 800;
      backdrop-filter: blur(2px);
    }

    .drawer-overlay.open {
      display: block;
    }

    .filter-drawer {
      position: fixed;
      top: 0;
      left: 0;
      height: 100%;
      width: 320px;
      max-width: 90vw;
      background: #13151c;
      border-right: 1px solid var(--border2);
      z-index: 900;
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
    }

    .filter-drawer.open {
      transform: translateX(0);
    }

    .drawer-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 20px 14px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: #13151c;
      z-index: 10;
    }

    .drawer-header-title {
      font-size: .95rem;
      font-weight: 700;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .drawer-close-btn {
      background: transparent;
      border: 1px solid var(--border2);
      border-radius: 7px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--sub);
      font-size: .8rem;
      transition: color .2s, border-color .2s;
    }

    .drawer-close-btn:hover {
      color: var(--text);
      border-color: var(--text);
    }

    .drawer-body {
      padding: 20px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    .drawer-section-title {
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .5px;
      color: var(--sub);
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .drawer-actions {
      padding: 16px 20px;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
      position: sticky;
      bottom: 0;
      background: #13151c;
    }

    .cb-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px 10px;
    }

    .cb-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 4px 0;
      cursor: pointer;
    }

    .cb-row label {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      font-size: .78rem;
      color: var(--sub);
      transition: color .18s;
    }

    .cb-row:hover label {
      color: var(--text);
    }

    .cb-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 15px;
      height: 15px;
      border: 1.5px solid rgba(255, 255, 255, .2);
      border-radius: 3px;
      background: transparent;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
      transition: all .15s;
    }

    .cb-row input[type="checkbox"]:checked {
      background: var(--accent);
      border-color: var(--accent);
    }

    .cb-row input[type="checkbox"]:checked::after {
      content: '✓';
      position: absolute;
      top: -1px;
      left: 1px;
      color: #fff;
      font-size: .55rem;
      font-weight: 900;
    }

    .cb-count {
      font-size: .65rem;
      color: var(--muted);
    }

    .pills-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }

    .pill-btn {
      background: transparent;
      border: 1.5px solid rgba(255, 255, 255, .13);
      border-radius: 6px;
      color: var(--sub);
      font-size: .73rem;
      font-weight: 500;
      padding: 5px 11px;
      cursor: pointer;
      transition: all .18s;
      font-family: 'Inter', sans-serif;
    }

    .pill-btn:hover {
      border-color: var(--accent);
      color: var(--text);
    }

    .pill-btn.active {
      background: rgba(200, 136, 58, .15);
      border-color: rgba(200, 136, 58, .55);
      color: var(--accent);
      font-weight: 600;
    }

    .price-range-wrap {
      position: relative;
      height: 4px;
      background: rgba(255, 255, 255, .1);
      border-radius: 4px;
      margin: 12px 0 8px;
    }

    .price-range-fill {
      position: absolute;
      height: 100%;
      background: var(--accent);
      border-radius: 4px;
      pointer-events: none;
    }

    .price-range-input {
      -webkit-appearance: none;
      appearance: none;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: transparent;
      outline: none;
      cursor: pointer;
      pointer-events: none;
    }

    .price-range-input::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 15px;
      height: 15px;
      background: var(--accent);
      border-radius: 50%;
      border: 2px solid #13151c;
      box-shadow: 0 0 6px rgba(200, 136, 58, .5);
      pointer-events: all;
      cursor: pointer;
    }

    .price-labels {
      display: flex;
      justify-content: space-between;
      font-size: .72rem;
      color: var(--sub);
    }

    .btn-apply-filters {
      background: var(--accent);
      border: none;
      border-radius: 7px;
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: .8rem;
      font-weight: 700;
      padding: 9px 18px;
      cursor: pointer;
      transition: opacity .2s;
    }

    .btn-apply-filters:hover {
      opacity: .88;
    }

    .btn-clear-filters {
      background: transparent;
      border: 1px solid var(--border2);
      border-radius: 7px;
      color: var(--sub);
      font-family: 'Inter', sans-serif;
      font-size: .78rem;
      padding: 8px 18px;
      cursor: pointer;
      transition: color .2s, border-color .2s;
      text-align: center;
      text-decoration: none;
      display: block;
    }

    .btn-clear-filters:hover {
      color: var(--text);
      border-color: var(--text);
    }

    /* ── Product Grid ── */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    .product-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      cursor: pointer;
      position: relative;
      transition: background .25s, border-color .25s, transform .25s, box-shadow .25s;
    }

    .product-card:hover {
      background: var(--bg-card-h);
      border-color: rgba(255, 255, 255, .14);
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, .4);
    }

    /* Inactive card — subtle dimming overlay */
    .product-card.is-inactive {
      opacity: .75;
    }

    .product-card.is-inactive:hover {
      transform: none;
      box-shadow: none;
      cursor: default;
    }

    .card-img-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 4/3;
      background: var(--bg-card);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .35s ease;
    }

    .product-card:hover .card-img-wrap img {
      transform: scale(1.04);
    }

    .product-card.is-inactive:hover .card-img-wrap img {
      transform: none;
    }

    .img-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      color: var(--muted);
      font-size: .72rem;
      gap: 8px;
    }

    .img-placeholder i {
      font-size: 2rem;
      opacity: .25;
    }

    .card-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      font-size: .63rem;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 5px;
      text-transform: uppercase;
      z-index: 5;
      letter-spacing: .3px;
    }

    .badge-sale {
      background: #e63946;
      color: #fff;
    }

    .badge-new {
      background: #4ade80;
      color: #0a1a10;
    }

    .badge-hot {
      background: var(--accent);
      color: #fff;
    }

    .badge-best {
      background: rgba(255, 255, 255, .12);
      color: var(--text);
      border: 1px solid rgba(255, 255, 255, .2);
    }

    .wishlist-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: rgba(30, 34, 45, .75);
      border: 1px solid rgba(255, 255, 255, .12);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 5;
      color: var(--sub);
      font-size: .7rem;
      transition: color .2s, background .2s;
    }

    .wishlist-btn:hover,
    .wishlist-btn.active {
      color: #e63946;
      background: rgba(230, 57, 70, .2);
    }

    .card-body {
      padding: 14px 15px 15px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .card-brand {
      font-size: .72rem;
      color: var(--sub);
      text-transform: lowercase;
    }

    .card-name {
      font-size: .98rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
    }

    .card-specs {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 2px;
    }

    .spec-chip {
      font-size: .68rem;
      font-weight: 500;
      color: var(--sub);
      background: rgba(255, 255, 255, .06);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 5px;
      padding: 3px 9px;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
      padding-top: 10px;
    }

    .card-price-col {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .card-price-old {
      font-size: .68rem;
      color: var(--muted);
      text-decoration: line-through;
    }

    .card-price {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
    }

    .out-label {
      font-size: .72rem;
      color: #e63946;
      font-weight: 600;
    }

    /* ── Unavailable label (replaces cart button for inactive products) ── */
    .unavailable-label {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: .68rem;
      font-weight: 700;
      color: #e63946;
      background: rgba(230, 57, 70, .1);
      border: 1px solid rgba(230, 57, 70, .25);
      border-radius: 7px;
      padding: 6px 10px;
      white-space: nowrap;
      flex-shrink: 0;
      letter-spacing: .2px;
    }

    .unavailable-label i {
      font-size: .65rem;
    }

    .btn-cart {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--accent);
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #fff;
      font-size: .8rem;
      flex-shrink: 0;
      transition: transform .18s, opacity .18s, background .2s;
    }

    .btn-cart:hover:not(:disabled) {
      transform: scale(1.1);
    }

    .btn-cart:disabled {
      opacity: .3;
      cursor: not-allowed;
    }

    .btn-cart.maxed {
      background: var(--muted);
      cursor: not-allowed;
      opacity: .6;
    }

    .btn-cart.maxed:hover {
      transform: none;
    }

    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 80px 20px;
      color: var(--muted);
    }

    .empty-state i {
      font-size: 2.8rem;
      opacity: .25;
      display: block;
      margin-bottom: 16px;
    }

    .empty-state p {
      font-size: .9rem;
    }

    .pagination-wrap {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      padding: 38px 0 10px;
      flex-wrap: wrap;
    }

    .btn-buy-now {
      background: #ff6a00;
      color: #fff;
      border: none;
      padding: 6px 10px;
      margin-left: 6px;
      border-radius: 6px;
      font-size: 0.75rem;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .btn-buy-now:hover {
      background: #e85d00;
    }

    .pg-btn {
      min-width: 38px;
      height: 38px;
      padding: 0 11px;
      border-radius: 7px;
      border: 1px solid var(--border2);
      background: var(--bg-card);
      color: var(--sub);
      font-family: 'Inter', sans-serif;
      font-size: .82rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background .18s, color .18s;
    }

    .pg-btn:hover:not(.pg-disabled):not(.pg-active) {
      background: rgba(255, 255, 255, .07);
      color: var(--text);
    }

    .pg-btn.pg-active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      font-weight: 700;
    }

    .pg-btn.pg-disabled {
      opacity: .3;
      pointer-events: none;
    }

    @media (max-width: 1200px) {
      .product-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 800px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .page-content {
        padding: 20px 14px 40px;
      }
    }

    @media (max-width: 480px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      .page-heading {
        font-size: 1.2rem;
      }
    }
  </style>
</head>

<body>

  <%- include('../../partials/user/navigationbar', { user, cartItemCount, currentPage: 'products' , categories }) %>

    <% const PRICE_MAX_VAL=219999; const PRICE_MIN_VAL=0; const curMax=(activeFilters.maxPrice &&
      parseInt(activeFilters.maxPrice) < PRICE_MAX_VAL) ? parseInt(activeFilters.maxPrice) : PRICE_MAX_VAL; const
      curSort=activeFilters.sort || '' ; const curSearch=activeFilters.search || '' ; const
      curBrands=activeFilters.brands || []; const curRAMs=activeFilters.rams || []; const
      curStorages=activeFilters.storages || []; const curColors=activeFilters.colors || []; function qs(overrides) {
      const base={ sort: curSort, search: curSearch, maxPrice: curMax, brand: curBrands, ram: curRAMs, storage:
      curStorages, color: curColors, page: currentPage }; const m=Object.assign({}, base, overrides); const p=new
      URLSearchParams(); if (m.sort) p.set('sort', m.sort); if (m.search) p.set('search', m.search); if (m.maxPrice <
      PRICE_MAX_VAL) p.set('maxPrice', m.maxPrice); if (m.page && m.page> 1) p.set('page', m.page);
      (m.brand || []).forEach(v => p.append('brand', v));
      (m.ram || []).forEach(v => p.append('ram', v));
      (m.storage || []).forEach(v => p.append('storage', v));
      (m.color || []).forEach(v => p.append('color', v));
      const s = p.toString();
      return '/products' + (s ? '?' + s : '');
      }

      const rmBrand = b => qs({ brand: curBrands.filter(v => v !== b), page: 1 });
      const rmRAM = r => qs({ ram: curRAMs.filter(v => v !== r), page: 1 });
      const rmStorage = s => qs({ storage: curStorages.filter(v => v !== s), page: 1 });
      const rmColor = c => qs({ color: curColors.filter(v => v !== c), page: 1 });

      const disc = (price, old) => Math.round(((old - price) / old) * 100);

      const totalActive = curBrands.length + curRAMs.length + curStorages.length
      + curColors.length + (curMax < PRICE_MAX_VAL ? 1 : 0) + (curSearch ? 1 : 0); const
        headingText=curBrands.length===1 ? curBrands[0] : 'Categories' ; %>

        <div class="page-content">

          <!-- TOP BAR -->
          <div class="topbar">
            <div class="topbar-left">
              <h1 class="page-heading">
                <%= headingText %>
              </h1>

              <% if (totalActive> 0) { %>
                <div class="active-pills">
                  <% curBrands.forEach(b=> { %>
                    <span class="active-pill">
                      <%= b %> <a href="<%= rmBrand(b) %>">✕</a>
                    </span>
                    <% }) %>
                      <% curRAMs.forEach(r=> { %>
                        <span class="active-pill">
                          <%= r %>GB <a href="<%= rmRAM(r) %>">✕</a>
                        </span>
                        <% }) %>
                          <% curStorages.forEach(s=> { %>
                            <span class="active-pill">
                              <%= s %>GB <a href="<%= rmStorage(s) %>">✕</a>
                            </span>
                            <% }) %>
                              <% curColors.forEach(c=> { %>
                                <span class="active-pill">
                                  <%= c %> <a href="<%= rmColor(c) %>">✕</a>
                                </span>
                                <% }) %>
                                  <% if (curMax < PRICE_MAX_VAL) { %>
                                    <span class="active-pill">
                                      Max ₹<%= Number(curMax).toLocaleString('en-IN') %>
                                        <a href="<%= qs({ maxPrice: PRICE_MAX_VAL, page: 1 }) %>">✕</a>
                                    </span>
                                    <% } %>
                                      <% if (curSearch) { %>
                                        <span class="active-pill">"<%= curSearch %>" <a
                                              href="<%= qs({ search: '', page: 1 }) %>">✕</a></span>
                                        <% } %>
                </div>
                <% } %>

                  <div class="result-count">
                    <%= totalProducts %> product<%= totalProducts !==1 ? 's' : '' %> found
                  </div>
            </div>

            <!-- Sort -->
            <div class="sort-wrap">
              <button class="sort-btn" onclick="toggleSort(event)">
                Sort <i class="fas fa-sort"></i>
              </button>
              <div class="sort-dd" id="sortDD">
                <% [ { val: '' , label: 'Default' }, { val: 'price_asc' , label: 'Price: Low → High' }, {
                  val: 'price_desc' , label: 'Price: High → Low' }, { val: 'name_asc' , label: 'Name: A–Z' }, {
                  val: 'name_desc' , label: 'Name: Z–A' }, ].forEach(o=> { %>
                  <a href="<%= qs({ sort: o.val, page: 1 }) %>"
                    class="sort-opt <%= curSort === o.val ? 'active' : '' %>">
                    <%= o.label %> <span class="tick">✓</span>
                  </a>
                  <% }) %>
              </div>
            </div>
          </div>

          <!-- FILTER TOGGLE -->
          <div class="filter-toggle-row">
            <button class="filter-toggle-btn" onclick="toggleFilterPanel()">
              <i class="fas fa-sliders-h"></i>
              Filters
              <% if (totalActive> 0) { %>
                <span style="background:var(--accent);color:#fff;border-radius:50%;width:18px;height:18px;
                       display:inline-flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:800;">
                  <%= totalActive %>
                </span>
                <% } %>
            </button>
          </div>

          <!-- DRAWER OVERLAY -->
          <div class="drawer-overlay" id="drawerOverlay" onclick="closeFilterDrawer()"></div>

          <!-- FILTER DRAWER -->
          <div class="filter-drawer" id="filterDrawer">
            <div class="drawer-header">
              <span class="drawer-header-title">
                <i class="fas fa-sliders-h"></i>
                Filters
                <% if (totalActive> 0) { %>
                  <span
                    style="background:var(--accent);color:#fff;border-radius:50%;width:18px;height:18px;
                         display:inline-flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:800;">
                    <%= totalActive %>
                  </span>
                  <% } %>
              </span>
              <button class="drawer-close-btn" onclick="closeFilterDrawer()">
                <i class="fas fa-times"></i>
              </button>
            </div>

            <form id="filterForm" method="GET" action="/products" style="display:flex;flex-direction:column;flex:1;">
              <% if (curSort) { %><input type="hidden" name="sort" value="<%= curSort %>">
                <% } %>
                  <% if (curSearch) { %><input type="hidden" name="search" value="<%= curSearch %>">
                    <% } %>

                      <div class="drawer-body">

                        <!-- CATEGORIES -->
                        <% if (sidebarData && sidebarData.brands && sidebarData.brands.length> 0) { %>
                          <div>
                            <div class="drawer-section-title">Categories</div>
                            <div class="cb-grid">
                              <% sidebarData.brands.forEach(brand=> { %>
                                <div class="cb-row">
                                  <label>
                                    <input type="checkbox" name="brand" value="<%= brand.name %>"
                                      <%=curBrands.includes(brand.name) ? 'checked' : '' %>>
                                    <span>
                                      <%= brand.name %>
                                    </span>
                                  </label>
                                  <% if (brand.count !=null) { %><span class="cb-count">
                                      <%= brand.count %>
                                    </span>
                                    <% } %>
                                </div>
                                <% }) %>
                            </div>
                          </div>
                          <% } %>

                            <!-- RAM -->
                            <% if (sidebarData && sidebarData.rams && sidebarData.rams.length> 0) { %>
                              <div>
                                <div class="drawer-section-title">RAM</div>
                                <div class="pills-wrap">
                                  <% sidebarData.rams.forEach(ram=> { %>
                                    <button type="button"
                                      class="pill-btn <%= curRAMs.includes(String(ram)) ? 'active' : '' %>"
                                      onclick="togglePill(this,'ram','<%= ram %>')">
                                      <%= ram %>GB
                                    </button>
                                    <% }) %>
                                </div>
                                <% curRAMs.forEach(r=> { %>
                                  <input type="hidden" name="ram" value="<%= r %>" data-pill="ram-<%= r %>">
                                  <% }) %>
                              </div>
                              <% } %>

                                <!-- STORAGE -->
                                <% if (sidebarData && sidebarData.storages && sidebarData.storages.length> 0) { %>
                                  <div>
                                    <div class="drawer-section-title">Storage</div>
                                    <div class="pills-wrap">
                                      <% sidebarData.storages.forEach(s=> { %>
                                        <button type="button"
                                          class="pill-btn <%= curStorages.includes(String(s)) ? 'active' : '' %>"
                                          onclick="togglePill(this,'storage','<%= s %>')">
                                          <%= s>= 1000 ? (s/1000)+'TB' : s+'GB' %>
                                        </button>
                                        <% }) %>
                                    </div>
                                    <% curStorages.forEach(s=> { %>
                                      <input type="hidden" name="storage" value="<%= s %>" data-pill="storage-<%= s %>">
                                      <% }) %>
                                  </div>
                                  <% } %>

                                    <!-- COLOR -->
                                    <% if (sidebarData && sidebarData.colors && sidebarData.colors.length> 0) { %>
                                      <div>
                                        <div class="drawer-section-title">Color</div>
                                        <div class="cb-grid">
                                          <% sidebarData.colors.forEach(color=> { %>
                                            <div class="cb-row">
                                              <label>
                                                <input type="checkbox" name="color" value="<%= color %>"
                                                  <%=curColors.includes(color) ? 'checked' : '' %>>
                                                <span>
                                                  <%= color %>
                                                </span>
                                              </label>
                                            </div>
                                            <% }) %>
                                        </div>
                                      </div>
                                      <% } %>

                                        <!-- PRICE RANGE -->
                                        <div>
                                          <div class="drawer-section-title">Price Range</div>
                                          <div class="price-range-wrap">
                                            <div class="price-range-fill" id="priceFill"
                                              style="left:0;width:<%= Math.round((curMax/PRICE_MAX_VAL)*100) %>%;">
                                            </div>
                                            <input type="range" class="price-range-input" min="<%= PRICE_MIN_VAL %>"
                                              max="<%= PRICE_MAX_VAL %>" step="500" value="<%= curMax %>"
                                              oninput="updatePrice(this)">
                                          </div>
                                          <input type="hidden" name="maxPrice" id="maxPriceInput" value="<%= curMax %>">
                                          <div class="price-labels">
                                            <span>₹<%= Number(PRICE_MIN_VAL).toLocaleString('en-IN') %></span>
                                            <span id="priceMaxLabel">₹<%= Number(curMax).toLocaleString('en-IN') %>
                                            </span>
                                          </div>
                                        </div>

                      </div><!-- /.drawer-body -->

                      <div class="drawer-actions">
                        <button type="submit" class="btn-apply-filters">Apply Filters</button>
                        <a href="/products<% if (curSort) { %>?sort=<%= curSort %><% } %>"
                          class="btn-clear-filters">Clear All</a>
                      </div>
            </form>
          </div>

          <!-- PRODUCT GRID -->
          <% if (products && products.length> 0) { %>
            <div class="product-grid">
              <% products.forEach(product=> {
                const isInactive = product.status && product.status !== 'active';
                %>
                <div class="product-card <%= isInactive ? 'is-inactive' : '' %>"
                  onclick="<%= isInactive ? '' : `window.location='/product/${product.id}?variant=${product.variantId}'` %>">

                  <!-- Image -->
                  <div class="card-img-wrap">
                    <% if (product.image && product.image !=='/images/placeholder.png' ) { %>
                      <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy"
                        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                      <div class="img-placeholder" style="display:none;position:absolute;inset:0;">
                        <i class="fas fa-image"></i><span>Image not available</span>
                      </div>
                      <% } else { %>
                        <div class="img-placeholder">
                          <i class="fas fa-image"></i><span>Image not available</span>
                        </div>
                        <% } %>

                          <!-- Badge -->
                          <% if (!isInactive && product.oldPrice && product.price && product.price < product.oldPrice) {
                            %>
                            <span class="card-badge badge-sale">-<%= disc(product.price, product.oldPrice) %>%
                                OFF</span>
                            <% } else if (!isInactive && product.badge) { %>
                              <% const bl=product.badge.toLowerCase(); let bc='badge-best' ; if (bl==='new' )
                                bc='badge-new' ; if (bl==='hot' ) bc='badge-hot' ; if (bl==='sale' ) bc='badge-sale' ;
                                %>
                                <span class="card-badge <%= bc %>">
                                  <%= product.badge %>
                                </span>
                                <% } %>

                                  <!-- Wishlist — hidden for inactive products -->
                                  <% if (!isInactive) { %>
                                    <button class="wishlist-btn"
                                      onclick="event.stopPropagation(); toggleWishlist(this,'<%= product.id %>')"
                                      title="Add to wishlist">
                                      <i class="fas fa-heart"></i>
                                    </button>
                                    <% } %>
                  </div>

                  <!-- Body -->
                  <div class="card-body">
                    <div class="card-brand">
                      <%= product.brand %>
                    </div>
                    <div class="card-name">
                      <%= product.name %>
                    </div>

                    <% if (product.ram || product.storage) { %>
                      <div class="card-specs">
                        <% if (product.ram) { %>
                          <span class="spec-chip">
                            <%= product.ram %>GB RAM
                          </span>
                          <% } %>
                            <% if (product.storage) { %>
                              <span class="spec-chip">
                                <%= product.storage %>GB
                              </span>
                              <% } %>
                      </div>
                      <% } %>

                        <div class="card-footer">
                          <div class="card-price-col">
                            <% if (!isInactive && product.oldPrice) { %>
                              <span class="card-price-old">₹<%= product.oldPrice.toLocaleString('en-IN') %></span>
                              <% } %>

                                <% if (!isInactive && product.stock===0) { %>
                                  <span class="out-label">Out of Stock</span>
                                  <% } else if (!isInactive && product.price) { %>
                                    <span class="card-price">₹<%= product.price.toLocaleString('en-IN') %></span>
                                    <% } %>
                          </div>

                          <% if (isInactive) { %>
                            <span class="unavailable-label">
                              <i class="fas fa-ban"></i> Currently Unavailable
                            </span>
                            <% } else { %>

                              <!-- 🛒 Add to Cart -->
                               <%if(user){%>
                              <button class="btn-cart" id="cart-btn-<%= product.variantId %>" <%=product.stock===0
                                ? 'disabled' : '' %>
                                onclick="event.stopPropagation(); addToCart('<%= product.id %>','<%= product.variantId
                                    %>',this)">
                                    <i class="fas fa-shopping-cart"></i>
                              </button>
                              <%}else{%>
                                <button  >
                                    <i class="fa fa-add"></i>
                               </button>
                                <%}%>

                              <!-- ⚡ Buy Now -->
                              <button class="btn-buy-now" <%=product.stock===0 ? 'disabled' : '' %>
                                onclick="event.stopPropagation(); buyNow('<%= product.id %>','<%= product.variantId %>
                                    ')">
                                    Buy Now
                              </button>

                              <% } %>
                        </div>
                  </div>

                </div>
                <% }) %>
            </div>

            <% } else { %>
              <div class="product-grid">
                <div class="empty-state">
                  <i class="fas fa-box-open"></i>
                  <p>No products found matching your filters.</p>
                  <a href="/products"
                    style="color:var(--accent);font-size:.82rem;margin-top:10px;display:inline-block;">
                    Clear all filters
                  </a>
                </div>
              </div>
              <% } %>

                <!-- PAGINATION -->
                <% if (totalPages> 1) { %>
                  <div class="pagination-wrap">
                    <a class="pg-btn <%= currentPage <= 1 ? 'pg-disabled' : '' %>"
                      href="<%= qs({ page: currentPage - 1 }) %>">
                      <i class="fas fa-chevron-left" style="font-size:.62rem;"></i>
                    </a>

                    <% for (let p=1; p <=totalPages; p++) { const near=Math.abs(p - currentPage) <=1; const edge=p===1
                      || p===totalPages; const ellL=p===currentPage - 2 && currentPage> 3;
                      const ellR = p === currentPage + 2 && currentPage < totalPages - 1; if (!near && !edge) { if (ellL
                        || ellR) { %>
                        <span class="pg-btn pg-disabled">…</span>
                        <% } continue; } %>
                          <a class="pg-btn <%= p === currentPage ? 'pg-active' : '' %>" href="<%= qs({ page: p }) %>">
                            <%= p %>
                          </a>
                          <% } %>

                            <a class="pg-btn <%= currentPage >= totalPages ? 'pg-disabled' : '' %>"
                              href="<%= qs({ page: currentPage + 1 }) %>">
                              <i class="fas fa-chevron-right" style="font-size:.62rem;"></i>
                            </a>
                  </div>
                  <% } %>

        </div><!-- /.page-content -->

        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

        <script>
          const cartQuantities = <% - JSON.stringify(cartQuantityMap || {}) %>;
          const MAX_QTY = 3;

          // On page load — silently gray out buttons already at max
          (function initCartBtns() {
            Object.entries(cartQuantities).forEach(([variantId, qty]) => {
              if (qty >= MAX_QTY) {
                const btn = document.getElementById('cart-btn-' + variantId);
                if (btn) markMaxed(btn);
              }
            });
          })();

          // Gray out button — cart icon stays, no tick mark
          function markMaxed(btn) {
            btn.classList.add('maxed');
            btn.disabled = true;
            btn.title = 'Maximum quantity (3) reached';
          }

          /* ── Sort dropdown ── */
          function toggleSort(e) {
            e.stopPropagation();
            document.getElementById('sortDD').classList.toggle('open');
          }
          document.addEventListener('click', () =>
            document.getElementById('sortDD')?.classList.remove('open')
          );

          /* ── Filter drawer ── */
          function toggleFilterPanel() {
            const drawer = document.getElementById('filterDrawer');
            const overlay = document.getElementById('drawerOverlay');
            if (drawer.classList.contains('open')) {
              closeFilterDrawer();
            } else {
              drawer.classList.add('open');
              overlay.classList.add('open');
              document.body.style.overflow = 'hidden';
            }
          }

          function closeFilterDrawer() {
            document.getElementById('filterDrawer').classList.remove('open');
            document.getElementById('drawerOverlay').classList.remove('open');
            document.body.style.overflow = '';
          }

          document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeFilterDrawer();
          });

          /* ── Price slider ── */
          function updatePrice(slider) {
            const val = parseInt(slider.value);
            const PMAX = <%= PRICE_MAX_VAL || 219999 %>;
            const pct = (val / PMAX) * 100;
            const fill = document.getElementById('priceFill');
            if (fill) fill.style.width = pct + '%';
            const inp = document.getElementById('maxPriceInput');
            if (inp) inp.value = val;
            const lbl = document.getElementById('priceMaxLabel');
            if (lbl) lbl.textContent = '₹' + val.toLocaleString('en-IN');
          }

          /* ── RAM / Storage pill toggle ── */
          function togglePill(btn, name, value) {
            const form = document.getElementById('filterForm');
            const isOn = !btn.classList.contains('active');
            btn.classList.toggle('active', isOn);
            if (isOn) {
              const inp = document.createElement('input');
              inp.type = 'hidden';
              inp.name = name;
              inp.value = value;
              inp.dataset.pill = name + '-' + value;
              form.appendChild(inp);
            } else {
              form.querySelectorAll(`[data-pill="${name}-${value}"]`).forEach(el => el.remove());
            }
          }

          /* ── Add to cart (AJAX) with 3-item limit ── */
          async function addToCart(productId, variantId, btn) {
            const currentQty = cartQuantities[variantId] || 0;

            // Already at max before request — show Swal immediately
            if (currentQty >= MAX_QTY) {
              markMaxed(btn);
              Swal.fire({
                icon: 'warning',
                title: 'Maximum Quantity Reached',
                html: `<span style="color:#70788a">You can only add up to <strong style="color:#c8883a">${MAX_QTY}</strong> units of this product to your cart.</span>`,
                background: '#141416',
                color: '#eaeaea',
                confirmButtonColor: '#c8883a',
                confirmButtonText: 'View Cart',
                showCancelButton: true,
                cancelButtonText: 'Continue Shopping',
                cancelButtonColor: '#44505e'
              }).then(result => {
                if (result.isConfirmed) window.location.href = '/cart';
              });
              return;
            }

            // Show spinner while request is in flight
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            try {
              const res = await fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, variantId, quantity: 1 })
              });
              const data = await res.json();

              if (data.requiresAuth || data.redirect) {
                window.location.href = '/signin';
                return;
              }

              if (!data.success) {
                Swal.fire({
                  icon: 'error',
                  title: 'Oops!',
                  text: data.message || 'Something went wrong. Please try again.',
                  background: '#141416',
                  color: '#eaeaea',
                  confirmButtonColor: '#c8883a'
                });
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-shopping-cart"></i>';
                return;
              }

              // Update local quantity tracker
              cartQuantities[variantId] = (cartQuantities[variantId] || 0) + 1;

              // Update navbar cart count badge
              const badge = document.querySelector('.cart-badge');
              if (badge && data.cartCount !== undefined) badge.textContent = data.cartCount;

              const newQty = cartQuantities[variantId];

              if (newQty >= MAX_QTY) {
                // Just hit the limit — gray out button, fire Swal
                markMaxed(btn);
                Swal.fire({
                  icon: 'info',
                  title: 'Cart Limit Reached!',
                  html: `<span style="color:#70788a">You've added the maximum of <strong style="color:#c8883a">${MAX_QTY}</strong> units for this product.</span>`,
                  background: '#141416',
                  color: '#eaeaea',
                  confirmButtonColor: '#c8883a',
                  confirmButtonText: 'View Cart',
                  showCancelButton: true,
                  cancelButtonText: 'Continue Shopping',
                  cancelButtonColor: '#44505e'
                }).then(result => {
                  if (result.isConfirmed) window.location.href = '/cart';
                });
              } else {
                // Normal success — restore button, show toast
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-shopping-cart"></i>';
                Swal.fire({
                  toast: true,
                  position: 'top-end',
                  icon: 'success',
                  title: 'Added to cart!',
                  html: `<span style="font-size:.75rem;color:#70788a">${MAX_QTY - newQty} more can be added</span>`,
                  showConfirmButton: false,
                  timer: 2000,
                  background: '#141416',
                  color: '#eaeaea',
                  iconColor: '#00d4a0'
                });

                setTimeout(() => {
                  window.location.reload();
                }, 1500);
              }

            } catch (err) {
              window.location.href = '/signin';
            }
          }

          /* ── Wishlist toggle ── */
          function toggleWishlist(btn, productId) {
            btn.classList.toggle('active');
            const on = btn.classList.contains('active');
            Swal.fire({
              toast: true,
              position: 'top-end',
              icon: 'success',
              title: on ? 'Added to wishlist' : 'Removed from wishlist',
              showConfirmButton: false,
              timer: 1600,
              background: '#1a1d24',
              color: '#f0f0f2',
              iconColor: '#4ade80'
            });
          }
        </script>
</body>

</html>