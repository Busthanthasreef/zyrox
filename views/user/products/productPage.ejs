<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products — Zyrox</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    :root {
      --bg: #0d0f14;
      --bg-card: #16181e;
      --bg-card-h: #1c1f26;
      --accent: #c8883a;
      --accent-rgb: 200, 136, 58;
      --accent-lt: rgba(200, 136, 58, .12);
      --green: #00d4a0;
      --green-lt: rgba(0, 212, 160, .08);
      --red: #e63946;
      --red-lt: rgba(230, 57, 70, .08);
      --text: #f0f0f2;
      --text-dim: #c5c5c5;
      --sub: #8b949e;
      --muted: #484f58;
      --border: rgba(255, 255, 255, .06);
      --border2: rgba(255, 255, 255, .1);
      --navbar-h: 70px;
      --radius-sm: 8px;
      --radius-lg: 16px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      font-family: 'Inter', sans-serif;
      color: var(--text);
      min-height: 100vh;
      padding-top: var(--navbar-h);
    }

    .page-content {
      max-width: 1700px;
      margin: 0 auto;
      padding: 32px 30px 60px;
    }

    /* LAYOUT */
    .main-row {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 28px;
      width: 100%;
      margin-top: 20px;
    }




    .sidebar-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .sidebar-title {
      font-size: 1rem;
      font-weight: 700;
    }

    .clear-all {
      font-size: .79rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
      transition: opacity .2s;
    }

    .clear-all:hover {
      opacity: .75;
      text-decoration: underline;
    }

    .sidebar-section {
      padding-bottom: 18px;
      margin-bottom: 18px;
      border-bottom: 1px solid var(--border);
    }

    .sidebar-section:last-child {
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 0;
    }

    .sidebar-section-title {
      font-size: .75rem;
      font-weight: 800;
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .sidebar-section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, rgba(212, 175, 55, 0.3), transparent);
    }

    /* Checkbox rows */
    .cb-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 5px 0;
      cursor: pointer;
    }

    .cb-row label {
      display: flex;
      align-items: center;
      gap: 9px;
      cursor: pointer;
      font-size: .83rem;
      color: #b0b0b0;
      transition: color .18s;
      flex: 1;
    }

    .cb-row:hover label {
      color: var(--text);
    }

    .cb-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 16px;
      height: 16px;
      border: 1.5px solid rgba(255, 255, 255, .15);
      border-radius: 4px;
      background: transparent;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
      transition: all .2s;
    }

    .cb-row input[type="checkbox"]:checked {
      background: var(--accent);
      border-color: var(--accent);
    }

    .cb-row input[type="checkbox"]:checked::after {
      content: '\2713';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #fff;
      font-size: .58rem;
      font-weight: 900;
    }

    .cb-count {
      font-size: .71rem;
      color: var(--muted);
      background: rgba(255, 255, 255, .05);
      border-radius: 4px;
      padding: 1px 6px;
    }

    /* Pill buttons */
    .pills-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .pill-btn {
      background: transparent;
      border: 1.5px solid rgba(255, 255, 255, .13);
      border-radius: 6px;
      color: var(--sub);
      font-size: .71rem;
      font-weight: 500;
      padding: 4px 10px;
      cursor: pointer;
      transition: all .18s;
      font-family: 'Inter', sans-serif;
    }

    .pill-btn:hover {
      border-color: var(--accent);
      color: var(--text);
    }

    .pill-btn.active {
      background: rgba(200, 136, 58, .15);
      border-color: rgba(200, 136, 58, .55);
      color: var(--accent);
      font-weight: 600;
    }

    /* Price inputs */
    .price-inputs-row {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }

    .p-input-group {
      flex: 1;
    }

    .p-input-group label {
      font-size: 0.65rem;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
      display: block;
      font-weight: 700;
    }

    .p-input-wrap {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 4px 8px;
    }

    .p-input-wrap span {
      font-size: .8rem;
      color: var(--muted);
      margin-right: 4px;
    }

    .p-input-wrap input {
      background: transparent;
      border: none;
      color: var(--text);
      font-size: .85rem;
      width: 100%;
      outline: none;
      font-weight: 500;
      font-family: 'Inter', sans-serif;
    }

    .p-input-wrap input::-webkit-inner-spin-button,
    .p-input-wrap input::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    /* Grid Loading state */
    #productContainer {
      position: relative;
      transition: opacity 0.3s ease;
    }

    #productContainer.is-loading {
      opacity: 0.5;
      pointer-events: none;
    }

    .loading-overlay {
      display: none;
      position: absolute;
      top: 100px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 100;
      background: var(--bg-card);
      padding: 15px 25px;
      border-radius: 12px;
      border: 1px solid var(--border2);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    #productContainer.is-loading .loading-overlay {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .price-labels {
      display: flex;
      justify-content: space-between;
      font-size: .77rem;
      color: var(--text);
      font-weight: 500;
    }

    .no-data {
      font-size: .77rem;
      color: var(--muted);
      font-style: italic;
    }

    /* CONTENT */
    .content-area {
      flex: 1;
      min-width: 0;
    }

    /* TOPBAR */
    .topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 6px;
    }

    .topbar-left {
      flex: 1;
    }

    .page-heading {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .active-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 6px;
    }

    .active-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1.5px solid var(--border2);
      border-radius: 6px;
      padding: 4px 12px;
      font-size: .74rem;
    }

    .active-pill a {
      color: var(--sub);
      text-decoration: none;
      font-size: .64rem;
      transition: color .18s;
    }

    .active-pill a:hover {
      color: #e63946;
    }

    .result-count {
      font-size: .76rem;
      color: var(--sub);
      margin-top: 4px;
    }

    /* Sort */
    .sort-wrap {
      position: relative;
      flex-shrink: 0;
    }

    .sort-btn {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-card);
      border: 1px solid var(--border2);
      border-radius: 12px;
      padding: 10px 20px;
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: .85rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.3s ease;
      backdrop-filter: blur(10px);
    }

    .sort-btn:hover {
      border-color: var(--accent);
      background: rgba(var(--accent-rgb), 0.05);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .sort-btn i {
      font-size: .76rem;
      color: var(--sub);
      transition: transform .2s;
    }

    .sort-wrap:hover .sort-btn i {
      transform: rotate(180deg);
      color: var(--accent);
    }

    .sort-dd {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      background: var(--bg-card);
      border: 1px solid var(--border2);
      border-radius: 12px;
      min-width: 200px;
      z-index: 1000;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0, 0, 0, .8);
      padding: 6px;
    }

    .sort-wrap:hover .sort-dd {
      display: block;
    }

    .sort-opt {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 13px;
      font-size: .8rem;
      color: var(--sub);
      text-decoration: none;
      border-radius: 8px;
      transition: all .15s;
    }

    .sort-opt:hover {
      background: rgba(200, 136, 58, .08);
      color: var(--text);
    }

    .sort-opt.active {
      background: rgba(200, 136, 58, .15);
      color: var(--accent);
      font-weight: 600;
    }

    .sort-opt .tick {
      font-size: .72rem;
      color: var(--accent);
      opacity: 0;
    }

    .sort-opt.active .tick {
      opacity: 1;
    }

    /* PRODUCT GRID */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .product-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      cursor: pointer;
      position: relative;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      backdrop-filter: blur(10px);
    }

    .product-card:hover {
      background: var(--bg-card-h);
      border-color: rgba(var(--accent-rgb), 0.3);
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(var(--accent-rgb), 0.1);
    }

    .product-card.is-inactive {
      opacity: .7;
      cursor: default;
    }

    .product-card.is-inactive:hover {
      transform: none;
      box-shadow: none;
    }

    .card-img-wrap {
      position: relative;
      width: 100%;
      height: 160px;
      background: var(--bg-card);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .product-card:hover .card-img-wrap img {
      transform: scale(1.1);
    }

    .product-card.is-inactive:hover .card-img-wrap img {
      transform: none;
    }

    .img-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      color: var(--muted);
      font-size: .69rem;
      gap: 7px;
    }

    .img-placeholder i {
      font-size: 1.8rem;
      opacity: .2;
    }

    .card-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      font-size: .59rem;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 5px;
      text-transform: uppercase;
      letter-spacing: .3px;
      z-index: 5;
    }

    .badge-sale {
      background: #e63946;
      color: #fff;
    }

    .badge-new {
      background: #4ade80;
      color: #0a1a10;
    }

    .badge-hot {
      background: var(--accent);
      color: #fff;
    }

    .badge-best {
      background: rgba(255, 255, 255, .12);
      color: var(--text);
      border: 1px solid rgba(255, 255, 255, .2);
    }

    .wishlist-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: rgba(13, 15, 20, .7);
      border: 1px solid rgba(255, 255, 255, .12);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 5;
      color: var(--sub);
      font-size: .67rem;
      transition: color .2s, background .2s;
    }

    .wishlist-btn:hover,
    .wishlist-btn.active {
      color: #e63946;
      background: rgba(230, 57, 70, .2);
    }

    .card-body {
      padding: 10px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .card-brand {
      font-size: .62rem;
      color: var(--sub);
      text-transform: lowercase;
    }

    .card-name {
      font-size: .8rem;
      font-weight: 600;
      line-height: 1.3;
    }

    .card-specs {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 3px;
    }

    .spec-chip {
      font-size: .59rem;
      font-weight: 500;
      color: var(--sub);
      background: rgba(255, 255, 255, .06);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 4px;
      padding: 2px 6px;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
      padding-top: 10px;
      flex-wrap: wrap;
      gap: 8px;
    }

    .card-price-col {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .card-price-old {
      font-size: .65rem;
      color: var(--muted);
      text-decoration: line-through;
    }

    .card-price {
      font-size: .93rem;
      font-weight: 700;
      color: var(--text);
    }

    .out-label {
      font-size: .7rem;
      color: #e63946;
      font-weight: 600;
    }

    .unavailable-label {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: .66rem;
      font-weight: 700;
      color: #e63946;
      background: rgba(230, 57, 70, .1);
      border: 1px solid rgba(230, 57, 70, .25);
      border-radius: 7px;
      padding: 5px 9px;
      white-space: nowrap;
    }

    .stock-status-wrap {
      margin-top: 10px;
      display: flex;
    }

    .stock-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: .62rem;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 6px;
      text-transform: uppercase;
      letter-spacing: .2px;
    }

    .badge-in-stock {
      background: var(--green-lt);
      color: var(--green);
      border: 1px solid rgba(0, 212, 160, .15);
    }

    .badge-low-stock {
      background: var(--accent-lt);
      color: var(--accent);
      border: 1px solid rgba(200, 136, 58, .2);
    }

    .badge-out-stock {
      background: var(--red-lt);
      color: var(--red);
      border: 1px solid rgba(230, 57, 70, .15);
    }

    .btn-view {
      padding: 8px 12px;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), #b38f2d);
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      color: #000;
      font-weight: 700;
      font-size: .75rem;
      width: 100%;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(var(--accent-rgb), 0.2);
    }

    .btn-cart:hover:not(:disabled) {
      transform: scale(1.02);
      box-shadow: 0 6px 20px rgba(var(--accent-rgb), 0.4);
      filter: brightness(1.1);
    }

    .btn-cart:disabled {
      opacity: .2;
      cursor: not-allowed;
      filter: grayscale(1);
    }

    .btn-cart.maxed {
      background: var(--muted);
      cursor: not-allowed;
      opacity: .6;
    }

    .btn-cart.maxed:hover {
      transform: none;
    }

    .btn-buy-now {
      background: rgba(255, 255, 255, 0.05);
      color: var(--text);
      border: 1px solid var(--border2);
      padding: 8px 12px;
      border-radius: 8px;
      font-size: .75rem;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
    }

    .btn-buy-now:hover:not(:disabled) {
      background: rgba(255, 255, 255, 0.1);
      border-color: var(--text);
    }

    .btn-buy-now:disabled {
      opacity: .3;
      cursor: not-allowed;
    }

    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 80px 20px;
      color: var(--muted);
    }

    .empty-state i {
      font-size: 2.6rem;
      opacity: .2;
      display: block;
      margin-bottom: 14px;
    }

    .empty-state p {
      font-size: .88rem;
    }

    /* PAGINATION */
    .pagination-wrap {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      padding: 36px 0 10px;
      flex-wrap: wrap;
    }

    .pg-btn {
      min-width: 37px;
      height: 37px;
      padding: 0 10px;
      border-radius: 7px;
      border: 1px solid var(--border2);
      background: var(--bg-card);
      color: var(--sub);
      font-family: 'Inter', sans-serif;
      font-size: .8rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background .18s, color .18s;
    }

    .pg-btn:hover:not(.pg-disabled):not(.pg-active) {
      background: rgba(255, 255, 255, .07);
      color: var(--text);
    }

    .pg-btn.pg-active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      font-weight: 700;
    }

    .pg-btn.pg-disabled {
      opacity: .3;
      pointer-events: none;
    }

    /* RESPONSIVE */
    @media (max-width: 1200px) {
      .product-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 900px) {
      .main-row {
        flex-direction: column;
      }

      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 480px) {
      .product-grid {
        grid-template-columns: 1fr;
      }

      .page-content {
        padding: 20px 16px 40px;
      }
    }
  </style>
</head>

<body>

  <%- include('../../partials/user/navigationbar', { user, cartItemCount, currentPage: 'products' , categories }) %>

    <% const PRICE_MAX_VAL=219999; const PRICE_MIN_VAL=0; const curMax=(activeFilters.maxPrice &&
      parseInt(activeFilters.maxPrice) < PRICE_MAX_VAL) ? parseInt(activeFilters.maxPrice) : PRICE_MAX_VAL; const
      curMin=(activeFilters.minPrice && parseInt(activeFilters.minPrice)> PRICE_MIN_VAL)
      ? parseInt(activeFilters.minPrice) : PRICE_MIN_VAL;

      const curSort = activeFilters.sort || '';
      const curSearch = activeFilters.search || '';
      const curBrands = activeFilters.brands || [];
      const curColors = activeFilters.colors || [];

      function qs(overrides) {
      const base = {
      sort: curSort, search: curSearch,
      minPrice: curMin, maxPrice: curMax,
      brand: curBrands, color: curColors,
      page: currentPage
      };
      const m = Object.assign({}, base, overrides);
      const p = new URLSearchParams();
      if (m.sort) p.set('sort', m.sort);
      if (m.search) p.set('search', m.search);
      if (m.minPrice > PRICE_MIN_VAL) p.set('minPrice', m.minPrice);
      if (m.maxPrice < PRICE_MAX_VAL) p.set('maxPrice', m.maxPrice); if (m.page && m.page> 1) p.set('page', m.page);
        (m.brand || []).forEach(v => p.append('brand', v));
        (m.color || []).forEach(v => p.append('color', v));
        const s = p.toString();
        return '/products' + (s ? '?' + s : '');
        }

        const rmBrand = b => qs({ brand: curBrands.filter(v => v !== b), page: 1 });
        const rmColor = c => qs({ color: curColors.filter(v => v !== c), page: 1 });

        const disc = (price, old) => Math.round(((old - price) / old) * 100);

        const totalActive = curBrands.length + curColors.length + (curSearch ? 1 : 0);
        const headingText = curBrands.length === 1 ? curBrands[0] : 'All Products';

        const safeSidebar = sidebarData || {};
        const safeBrands = safeSidebar.brands || [];
        const safeColors = safeSidebar.colors || [];
        %>

        <div class="page-content">

          <!-- TOPBAR -->
          <div class="topbar">
            <div class="topbar-left">
              <h1 class="page-heading">
                <%= headingText %>
              </h1>

              <% if (totalActive> 0) { %>
                <div class="active-pills">
                  <% curBrands.forEach(b=> { %>
                    <span class="active-pill">
                      <%= b %> <a href="<%= rmBrand(b) %>">&#x2715;</a>
                    </span>
                    <% }) %>
                      <% curColors.forEach(c=> { %>
                        <span class="active-pill">
                          <%= c %> <a href="<%= rmColor(c) %>">&#x2715;</a>
                        </span>
                        <% }) %>
                          <% if (curSearch) { %>
                            <span class="active-pill">&ldquo;<%= curSearch %>&rdquo; <a
                                  href="<%= qs({ search: '', page: 1 }) %>">&#x2715;</a></span>
                            <% } %>
                </div>
                <% } %>

                  <div class="result-count">
                    <%= totalProducts %> product<%= totalProducts !==1 ? 's' : '' %> found
                  </div>
            </div>

            <!-- Sort -->
            <div class="sort-wrap">
              <button class="sort-btn">
                <% const sortLabels=[ { val: '' , label: 'Default' }, { val: 'price_asc' ,
                  label: 'Price: Low \u2192 High' }, { val: 'price_desc' , label: 'Price: High \u2192 Low' }, {
                  val: 'name_asc' , label: 'Name: A\u2013Z' }, { val: 'name_desc' , label: 'Name: Z\u2013A' }, ]; %>
                  Sort: <%= (sortLabels.find(o=> o.val === curSort) || sortLabels[0]).label %>
                    <i class="fas fa-chevron-down"></i>
              </button>
              <div class="sort-dd">
                <% sortLabels.forEach(o=> { %>
                  <a href="<%= qs({ sort: o.val, page: 1 }) %>"
                    class="sort-opt <%= curSort === o.val ? 'active' : '' %>">
                    <%= o.label %> <i class="fas fa-check tick"></i>
                  </a>
                  <% }) %>
              </div>
            </div>
          </div>

          <!-- MAIN ROW -->
          <div class="main-row">



            <!-- ===== SIDEBAR ===== -->

            <aside>
              <div style="border-color: #ffffff;">

                <form id="filterForm" method="GET" action="/products">
                  <% if (curSort) { %><input type="hidden" name="sort" value="<%= curSort %>">
                    <% } %>
                      <% if (curSearch) { %><input type="hidden" name="search" value="<%= curSearch %>">
                        <% } %>

                          <div class="sidebar-header">
                            <span class="sidebar-title">Filter by</span>
                            <a href="/products<% if (curSort) { %>?sort=<%= curSort %><% } %>" class="clear-all">Clear
                              All</a>
                          </div>

                          <!-- BRANDS (CATEGORIES) -->
                          <div class="sidebar-section">
                            <div class="sidebar-section-title">Brands</div>
                            <% if (safeBrands.length> 0) { %>
                              <% safeBrands.forEach(brand=> { %>
                                <div class="cb-row">
                                  <label>
                                    <input type="checkbox" name="brand" value="<%= brand.name %>"
                                      <%=curBrands.includes(brand.name) ? 'checked' : '' %>
                                    onchange="handlePriceSubmit()">
                                    <span>
                                      <%= brand.name %>
                                    </span>
                                  </label>
                                  <span class="cb-count">
                                    <%= brand.count %>
                                  </span>
                                </div>
                                <% }) %>
                                  <% } else { %>
                                    <span class="no-data">No categories available</span>
                                    <% } %>
                          </div>

                          <!-- PRICE RANGE -->
                          <div class="sidebar-section">
                            <div class="sidebar-section-title">Price Range</div>
                            <div class="price-inputs-row">
                              <div class="p-input-group">
                                <label for="minPrice">Min</label>
                                <div class="p-input-wrap">
                                  <span>₹</span>
                                  <input type="number" name="minPrice" id="minPriceInput" value="<%= curMin %>"
                                    min="<%= PRICE_MIN_VAL %>" max="<%= PRICE_MAX_VAL %>" step="1"
                                    onchange="this.form.submit()">
                                </div>
                              </div>
                              <div class="p-input-group">
                                <label for="maxPrice">Max</label>
                                <div class="p-input-wrap">
                                  <span>₹</span>
                                  <input type="number" name="maxPrice" id="maxPriceInput" value="<%= curMax %>"
                                    min="<%= PRICE_MIN_VAL %>" max="<%= PRICE_MAX_VAL %>" step="1"
                                    onchange="this.form.submit()">
                                </div>
                              </div>
                            </div>
                          </div>


                          <!-- COLOR -->
                          <div class="sidebar-section">
                            <div class="sidebar-section-title">Color</div>
                            <% if (safeColors.length> 0) { %>
                              <% safeColors.forEach(color=> { %>
                                <div class="cb-row">
                                  <label>
                                    <input type="checkbox" name="color" value="<%= color %>"
                                      <%=curColors.includes(color) ? 'checked' : '' %>
                                    onchange="handlePriceSubmit()">
                                    <span>
                                      <%= color %>
                                    </span>
                                  </label>
                                </div>
                                <% }) %>
                                  <% } else { %>
                                    <span class="no-data">No color options</span>
                                    <% } %>
                          </div>

                          <div style="margin-top:25px; padding-top:15px; border-top:1px solid var(--border);">
                            <button type="submit" class="btn-cart"
                              style="background: linear-gradient(135deg, var(--accent), #e2a654); color: #000; box-shadow: 0 4px 15px rgba(200, 136, 58, 0.2);">
                              <i class="fas fa-filter"></i> Apply Filters
                            </button>
                          </div>
                </form>
              </div>
            </aside>
            <!-- ===== PRODUCTS ===== -->
            <div class="content-area" id="productContainer">
              <div class="loading-overlay">
                <i class="fas fa-circle-notch fa-spin"></i>
                <span>Updating results...</span>
              </div>

              <% if (products && products.length> 0) { %>
                <div class="product-grid">
                  <% products.forEach(product=> {
                    const isInactive = product.status && product.status !== 'active';
                    %>
                    <div class="product-card <%= isInactive ? 'is-inactive' : '' %>"
                      onclick="<%= isInactive ? 'void(0)' : `window.location='/product/${product.id}?variant=${product.variantId}'` %>">

                      <div class="card-img-wrap">
                        <% if (product.image && product.image !=='/images/placeholder.png' ) { %>
                          <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                          <div class="img-placeholder" style="display:none;position:absolute;inset:0;">
                            <i class="fas fa-image"></i><span>No image</span>
                          </div>
                          <% } else { %>
                            <div class="img-placeholder">
                              <i class="fas fa-image"></i><span>No image</span>
                            </div>
                            <% } %>

                              <% if (!isInactive && product.oldPrice && product.price < product.oldPrice) { %>
                                <span class="card-badge badge-sale">-<%= disc(product.price, product.oldPrice) %>%
                                    OFF</span>
                                <% } else if (!isInactive && product.badge) { const bl=product.badge.toLowerCase(); let
                                  bc='badge-best' ; if (bl==='new' ) bc='badge-new' ; if (bl==='hot' ) bc='badge-hot' ;
                                  if (bl==='sale' ) bc='badge-sale' ; %>
                                  <span class="card-badge <%= bc %>">
                                    <%= product.badge %>
                                  </span>
                                  <% } %>

                                    <% if (!isInactive) { %>
                                      <button class="wishlist-btn"
                                        onclick="event.stopPropagation(); toggleWishlist(this,'<%= product.id %>')"
                                        title="Wishlist">
                                        <i class="fas fa-heart"></i>
                                      </button>
                                      <% } %>
                      </div>

                      <div class="card-body">
                        <div class="card-brand">
                          <%= product.brand %>
                        </div>
                        <div class="card-name">
                          <%= product.name %>
                        </div>

                            <div class="stock-status-wrap">
                              <% if (isInactive) { %>
                                <!-- Skip if inactive (handled in footer) -->
                                <% } else if (product.stock> 10) { %>
                                  <span class="stock-badge badge-in-stock">
                                    <i class="fas fa-check-circle"></i> In Stock
                                  </span>
                                  <% } else if (product.stock> 5) { %>
                                    <span class="stock-badge badge-low-stock">
                                      <i class="fas fa-exclamation-triangle"></i> Low stock
                                    </span>
                                    <% } else if (product.stock> 0) { %>
                                      <span class="stock-badge badge-low-stock">
                                        <i class="fas fa-exclamation-triangle"></i> Only <%= product.stock %> left
                                      </span>
                                      <% } else { %>
                                        <span class="stock-badge badge-out-stock">
                                          <i class="fas fa-times-circle"></i> Out of Stock
                                        </span>
                                        <% } %>
                            </div>

                            <div class="card-footer">
                              <div class="card-price-col">
                                <% if (!isInactive && product.oldPrice) { %>
                                  <span class="card-price-old">&#8377;<%= product.oldPrice.toLocaleString('en-IN') %>
                                  </span>
                                  <% } %>
                                    <% if (!isInactive && product.stock===0) { %>
                                      <span class="out-label">Out of Stock</span>
                                      <% } else if (!isInactive && product.price) { %>
                                        <span class="card-price">&#8377;<%= product.price.toLocaleString('en-IN') %>
                                        </span>
                                        <% } %>
                              </div>

                              <% if (isInactive) { %>
                                <span class="unavailable-label"><i class="fas fa-ban"></i> Unavailable</span>
                                <% } else { %>
                                  <div style="display:flex;flex-direction:column;gap:8px;width:100%;margin-top:12px;">
                                    <% if (user) { %>
                                      <button class="btn-view" id="viewDetails" 
                                            onclick="<%=`window.location='/product/${product.id}?variant=${product.variantId}'` %>">
                                            <i class="fas fa-eye"></i> View Details
                                      </button>
                                      <button class="btn-buy-now" %>
                                        onclick="event.stopPropagation(); buyNow('<%= product.productId %>', '<%=
                                            product.variantId %>', <%= product.stock %>)">
                                              Quick Buy
                                      </button>
                                      <% } else { %>
                                        <button class="btn-view"  id="viewDetails"
                                          onclick="<%=`window.location='/product/${product.id}?variant=${product.variantId}'` %>">
                                          <i class="fas fa-shopping-cart"></i> View Details
                                        </button>
                                        <button class="btn-buy-now"
                                          onclick="event.stopPropagation(); window.location.href='/signin'">
                                          Quick Buy
                                        </button>
                                        <% } %>
                                  </div>
                                  <% } %>
                            </div>
                      </div>

                    </div>
                    <% }) %>
                </div>

                <% } else { %>
                  <div class="product-grid">
                    <div class="empty-state">
                      <i class="fas fa-box-open"></i>
                      <p>No products found matching your filters.</p>
                      <a href="/products"
                        style="color:var(--accent);font-size:.81rem;margin-top:12px;display:inline-block;">
                        Clear all filters
                      </a>
                    </div>
                  </div>
                  <% } %>

                    <!-- PAGINATION -->
                    <% if (totalPages> 1) { %>
                      <div class="pagination-wrap">
                        <a class="pg-btn <%= currentPage <= 1 ? 'pg-disabled' : '' %>"
                          href="<%= qs({ page: currentPage - 1 }) %>">
                          <i class="fas fa-chevron-left" style="font-size:.6rem;"></i>
                        </a>
                        <% for (let p=1; p <=totalPages; p++) { const near=Math.abs(p - currentPage) <=1; const
                          edge=p===1 || p===totalPages; const ellL=p===currentPage - 2 && currentPage> 3;
                          const ellR = p === currentPage + 2 && currentPage < totalPages - 1; if (!near && !edge) { if
                            (ellL || ellR) { %>
                            <span class="pg-btn pg-disabled">&hellip;</span>
                            <% } continue; } %>
                              <a class="pg-btn <%= p === currentPage ? 'pg-active' : '' %>"
                                href="<%= qs({ page: p }) %>">
                                <%= p %>
                              </a>
                              <% } %>
                                <a class="pg-btn <%= currentPage >= totalPages ? 'pg-disabled' : '' %>"
                                  href="<%= qs({ page: currentPage + 1 }) %>">
                                  <i class="fas fa-chevron-right" style="font-size:.6rem;"></i>
                                </a>
                      </div>
                      <% } %>

            </div>
          </div>
        </div>

        <script>
          const cartQuantities = <% - JSON.stringify(cartQuantityMap || {}) %>;
          const MAX_QTY = <%= MAX_CART_QTY %>;
          const JS_PRICE_MAX = 219999;
          const JS_MIN_GAP = 5000;

          function handlePriceSubmit() {
            showLoading();
            document.getElementById('filterForm').submit();
          }

          function showLoading() {
            const container = document.getElementById('productContainer');
            if (container) container.classList.add('is-loading');
          }



          // Initialize maxed buttons
          Object.entries(cartQuantities).forEach(([vid, qty]) => {
            if (qty >= MAX_QTY) {
              const btn = document.getElementById('cart-btn-' + vid);
              if (btn) markMaxed(btn);
            }
          });

          function markMaxed(btn) {
            btn.classList.add('maxed');
            btn.disabled = true;
            btn.title = 'Maximum quantity reached';
          }

          const swalBase = {
            background: '#141416',
            color: '#eaeaea',
            confirmButtonColor: '#c8883a',
            cancelButtonColor: '#3a3a4a',
          };

          function showLimitSwal(canAddMore) {
            const isHard = canAddMore <= 0;
            Swal.fire({
              ...swalBase,
              icon: isHard ? 'warning' : 'success',
              title: isHard ? 'Cart Limit Reached' : 'Added to Cart',
              html: isHard
                ? `<span style="color:#70788a">You already have the maximum of <strong style="color:#c8883a">${MAX_QTY}</strong> units in your cart.</span>`
                : `<span style="color:#70788a">Product added successfully! You can still add <strong style="color:#c8883a">${canAddMore}</strong> more.</span>`,
              confirmButtonText: 'View Cart',
              showCancelButton: true,
              cancelButtonText: 'Continue Shopping',
            }).then(r => { if (r.isConfirmed) window.location.href = '/cart'; });
          }


         
          function buyNow(productId, variantId, stock) {
            if (stock <= 1) {
              Swal.fire({
                ...swalBase,
                icon: 'warning',
                title: 'Unavailable',
                text: stock === 1
                  ? 'This item requires a minimum of 1 unit to stay in inventory.'
                  : 'This item is currently out of stock.'
              });
              return;
            }
            window.location.href = `/checkout?product=${productId}&variant=${variantId}&qty=1`;
          }

          function showLimitSwal(remaining, stockLimit = 3) {
            const isFull = remaining <= 0;
            const limitVal = Math.min(MAX_QTY, stockLimit);

            Swal.fire({
              ...swalBase,
              toast: true,
              position: 'top-end',
              icon: isFull ? 'warning' : 'success',
              title: isFull ? 'Limit Reached' : 'Added to cart!',
              html: isFull
                ? `<span style="font-size:.76rem;color:var(--text-dim)">You can only add up to <strong style="color:#c8883a">${limitVal}</strong> units of this item.</span>`
                : `<span style="font-size:.76rem;color:var(--text-dim)">You can add <strong style="color:#c8883a">${remaining}</strong> more unit${remaining === 1 ? '' : 's'}</span>`,
              showConfirmButton: false,
              timer: 2500,
              timerProgressBar: true,
              iconColor: isFull ? '#c8883a' : '#00d4a0',
            });
          }

          function toggleWishlist(btn, productId) {
            btn.classList.toggle('active');
            const on = btn.classList.contains('active');
            Swal.fire({
              toast: true, position: 'top-end', icon: 'success',
              title: on ? 'Added to wishlist' : 'Removed from wishlist',
              showConfirmButton: false, timer: 1600,
              background: '#1a1d24', color: '#f0f0f2', iconColor: '#4ade80'
            });
          }
        </script>
</body>

</html>