<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products — Zyrox</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    :root {
      --bg: #0d0f14;
      --bg-card: #16181e;
      --bg-card-h: #1c1f26;
      --accent: #4f6ef7;
      --accent-rgb: 200, 136, 58;
      --accent-lt: rgba(200, 136, 58, .12);
      --green: #00d4a0;
      --green-lt: rgba(0, 212, 160, .08);
      --red: #e63946;
      --red-lt: rgba(230, 57, 70, .08);
      --text: #f0f0f2;
      --text-dim: #c5c5c5;
      --sub: #8b949e;
      --muted: #484f58;
      --border: rgba(255, 255, 255, .06);
      --border2: rgba(255, 255, 255, .1);
      --navbar-h: 70px;
      --radius-sm: 8px;
      --radius-lg: 16px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      font-family: 'Inter', sans-serif;
      color: var(--text);
      min-height: 100vh;
      padding-top: var(--navbar-h);
    }

    .page-content {
      max-width: 1700px;
      margin: 0 auto;
      padding: 32px 30px 60px;
    }

    /* LAYOUT */
    .main-row {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 28px;
      width: 100%;
      margin-top: 20px;
    }




    .sidebar-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .sidebar-title {
      font-size: 1rem;
      font-weight: 700;
    }

    .clear-all {
      font-size: .79rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
      transition: opacity .2s;
    }

    .clear-all:hover {
      opacity: .75;
      text-decoration: underline;
    }

    .sidebar-section {
      padding-bottom: 18px;
      margin-bottom: 18px;
      border-bottom: 1px solid var(--border);
    }

    .sidebar-section:last-child {
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 0;
    }

    .sidebar-section-title {
      font-size: .75rem;
      font-weight: 800;
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .sidebar-section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, rgba(212, 175, 55, 0.3), transparent);
    }

    /* Checkbox rows */
    .cb-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 5px 0;
      cursor: pointer;
    }

    .cb-row label {
      display: flex;
      align-items: center;
      gap: 9px;
      cursor: pointer;
      font-size: .83rem;
      color: #b0b0b0;
      transition: color .18s;
      flex: 1;
    }

    .cb-row:hover label {
      color: var(--text);
    }

    .cb-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 16px;
      height: 16px;
      border: 1.5px solid rgba(255, 255, 255, .15);
      border-radius: 4px;
      background: transparent;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
      transition: all .2s;
    }

    .cb-row input[type="checkbox"]:checked {
      background: var(--accent);
      border-color: var(--accent);
    }

    .cb-row input[type="checkbox"]:checked::after {
      content: '\2713';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #fff;
      font-size: .58rem;
      font-weight: 900;
    }

    .cb-count {
      font-size: .71rem;
      color: var(--muted);
      background: rgba(255, 255, 255, .05);
      border-radius: 4px;
      padding: 1px 6px;
    }

    /* Pill buttons */
    .pills-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .pill-btn {
      background: transparent;
      border: 1.5px solid rgba(255, 255, 255, .13);
      border-radius: 6px;
      color: var(--sub);
      font-size: .71rem;
      font-weight: 500;
      padding: 4px 10px;
      cursor: pointer;
      transition: all .18s;
      font-family: 'Inter', sans-serif;
    }

    .pill-btn:hover {
      border-color: var(--accent);
      color: var(--text);
    }

    .pill-btn.active {
      background: rgba(200, 136, 58, .15);
      border-color: rgba(200, 136, 58, .55);
      color: var(--accent);
      font-weight: 600;
    }

    /* Price inputs */
    .price-inputs-row {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }

    .p-input-group {
      flex: 1;
    }

    .p-input-group label {
      font-size: 0.65rem;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
      display: block;
      font-weight: 700;
    }

    .p-input-wrap {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 4px 8px;
    }

    .p-input-wrap span {
      font-size: .8rem;
      color: var(--muted);
      margin-right: 4px;
    }

    .p-input-wrap input {
      background: transparent;
      border: none;
      color: var(--text);
      font-size: .85rem;
      width: 100%;
      outline: none;
      font-weight: 500;
      font-family: 'Inter', sans-serif;
    }

    .p-input-wrap input::-webkit-inner-spin-button,
    .p-input-wrap input::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    /* Grid Loading state */
    #productContainer {
      position: relative;
      transition: opacity 0.3s ease;
    }

    #productContainer.is-loading {
      opacity: 0.5;
      pointer-events: none;
    }

    .loading-overlay {
      display: none;
      position: absolute;
      top: 100px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 100;
      background: var(--bg-card);
      padding: 15px 25px;
      border-radius: 12px;
      border: 1px solid var(--border2);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    #productContainer.is-loading .loading-overlay {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .price-labels {
      display: flex;
      justify-content: space-between;
      font-size: .77rem;
      color: var(--text);
      font-weight: 500;
    }

    .no-data {
      font-size: .77rem;
      color: var(--muted);
      font-style: italic;
    }

    /* CONTENT */
    .content-area {
      flex: 1;
      min-width: 0;
    }

    /* TOPBAR */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 12px;
    }

    .topbar-right-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .topbar-left {
      flex: 1;
    }

    .page-heading {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .active-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 6px;
    }

    .active-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1.5px solid var(--border2);
      border-radius: 6px;
      padding: 4px 12px;
      font-size: .74rem;
    }

    .active-pill a {
      color: var(--sub);
      text-decoration: none;
      font-size: .64rem;
      transition: color .18s;
    }

    .active-pill a:hover {
      color: #e63946;
    }

    .result-count {
      font-size: .76rem;
      color: var(--sub);
      margin-top: 4px;
    }

    /* Sort */
    .sort-wrap {
      position: relative;
      flex-shrink: 0;
    }

    .sort-btn {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-card);
      border: 1px solid var(--border2);
      border-radius: 12px;
      padding: 10px 20px;
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: .85rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.3s ease;
      backdrop-filter: blur(10px);
    }

    .sort-btn:hover {
      border-color: var(--accent);
      background: rgba(var(--accent-rgb), 0.05);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .sort-btn i {
      font-size: .76rem;
      color: var(--sub);
      transition: transform .2s;
    }

    .sort-wrap:hover .sort-btn i {
      transform: rotate(180deg);
      color: var(--accent);
    }

    .sort-dd {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      background: var(--bg-card);
      border: 1px solid var(--border2);
      border-radius: 12px;
      min-width: 200px;
      z-index: 1000;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0, 0, 0, .8);
      padding: 6px;
    }

    .sort-wrap:hover .sort-dd {
      display: block;
    }

    .sort-opt {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 13px;
      font-size: .8rem;
      color: var(--sub);
      text-decoration: none;
      border-radius: 8px;
      transition: all .15s;
    }

    .sort-opt:hover {
      background: rgba(200, 136, 58, .08);
      color: var(--text);
    }

    .sort-opt.active {
      background: rgba(200, 136, 58, .15);
      color: var(--accent);
      font-weight: 600;
    }

    .sort-opt .tick {
      font-size: .72rem;
      color: var(--accent);
      opacity: 0;
    }

    .sort-opt.active .tick {
      opacity: 1;
    }

    /* PRODUCT GRID */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .product-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      cursor: pointer;
      position: relative;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      backdrop-filter: blur(10px);
    }

    .product-card:hover {
      background: var(--bg-card-h);
      border-color: rgba(var(--accent-rgb), 0.3);
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(var(--accent-rgb), 0.1);
      animation: smoothShake 0.6s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
    }

    @keyframes smoothShake {
      0%, 100% { transform: translateY(-8px) rotate(0deg); }
      15% { transform: translateY(-8px) rotate(1deg); }
      30% { transform: translateY(-8px) rotate(-1deg); }
      45% { transform: translateY(-8px) rotate(0.6deg); }
      60% { transform: translateY(-8px) rotate(-0.6deg); }
      75% { transform: translateY(-8px) rotate(0.3deg); }
    }

    .product-card.is-inactive {
      opacity: .7;
      cursor: default;
    }

    .product-card.is-inactive:hover {
      transform: none;
      box-shadow: none;
    }

    .card-img-wrap {
      position: relative;
      width: 100%;
      height: 200px;
      background: transparent;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 15px;
    }

    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .product-card:hover .card-img-wrap img {
      transform: scale(1.1);
    }

    .product-card.is-inactive:hover .card-img-wrap img {
      transform: none;
    }

    .img-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      color: var(--muted);
      font-size: .69rem;
      gap: 7px;
    }

    .img-placeholder i {
      font-size: 1.8rem;
      opacity: .2;
    }

    .card-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      font-size: .59rem;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 5px;
      text-transform: uppercase;
      letter-spacing: .3px;
      z-index: 5;
    }

    .badge-sale {
      background: #e63946;
      color: #fff;
    }

    .badge-new {
      background: #4ade80;
      color: #0a1a10;
    }

    .badge-hot {
      background: var(--accent);
      color: #fff;
    }

    .badge-best {
      background: rgba(255, 255, 255, .12);
      color: var(--text);
      border: 1px solid rgba(255, 255, 255, .2);
    }

    .wishlist-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: rgba(13, 15, 20, .7);
      border: 1px solid rgba(255, 255, 255, .12);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 5;
      color: var(--sub);
      font-size: .67rem;
      transition: color .2s, background .2s;
    }

    .wishlist-btn:hover,
    .wishlist-btn.active {
      color: #e63946;
      background: rgba(230, 57, 70, .2);
    }

    .card-body {
      padding: 10px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .card-brand {
      font-size: .62rem;
      color: var(--sub);
      text-transform: lowercase;
    }

    .card-name {
      font-size: .8rem;
      font-weight: 600;
      line-height: 1.3;
    }

    .card-specs {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 3px;
    }

    .spec-chip {
      font-size: .59rem;
      font-weight: 500;
      color: var(--sub);
      background: rgba(255, 255, 255, .06);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 4px;
      padding: 2px 6px;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
      padding-top: 10px;
      flex-wrap: wrap;
      gap: 8px;
    }

    .card-price-col {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .card-price-old {
      font-size: .65rem;
      color: var(--muted);
      text-decoration: line-through;
    }

    .card-price {
      font-size: .93rem;
      font-weight: 700;
      color: var(--text);
    }

    .out-label {
      font-size: .7rem;
      color: #e63946;
      font-weight: 600;
    }

    .unavailable-label {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: .66rem;
      font-weight: 700;
      color: #e63946;
      background: rgba(230, 57, 70, .1);
      border: 1px solid rgba(230, 57, 70, .25);
      border-radius: 7px;
      padding: 5px 9px;
      white-space: nowrap;
    }

    .stock-status-wrap {
      margin-top: 10px;
      display: flex;
    }

    .stock-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: .62rem;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 6px;
      text-transform: uppercase;
      letter-spacing: .2px;
    }

    .badge-in-stock {
      background: var(--green-lt);
      color: var(--green);
      border: 1px solid rgba(0, 212, 160, .15);
    }

    .badge-low-stock {
      background: var(--accent-lt);
      color: orangered;
      border: 1px solid rgba(200, 136, 58, .2);
    }

    .badge-out-stock {
      background: var(--red-lt);
      color: var(--red);
      border: 1px solid rgba(230, 57, 70, .15);
    }

    .btn-view {
      padding: 8px 12px;
      border-radius: 8px;
      background: linear-gradient(135deg, #0ce0a1);
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      color: #000;
      font-weight: 700;
      font-size: .75rem;
      width: 100%;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(var(--accent-rgb), 0.2);
    }

    .btn-cart:hover:not(:disabled) {
      transform: scale(1.02);
      box-shadow: 0 6px 20px rgba(var(--accent-rgb), 0.4);
      filter: brightness(1.1);
    }

    .btn-cart:disabled {
      opacity: .2;
      cursor: not-allowed;
      filter: grayscale(1);
    }

    .btn-cart.maxed {
      background: var(--muted);
      cursor: not-allowed;
      opacity: .6;
    }

    .btn-cart.maxed:hover {
      transform: none;
    }



    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 80px 20px;
      color: var(--muted);
    }

    .empty-state i {
      font-size: 2.6rem;
      opacity: .2;
      display: block;
      margin-bottom: 14px;
    }

    .empty-state p {
      font-size: .88rem;
    }

    /* PAGINATION */
    .pagination-wrap {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      padding: 36px 0 10px;
      flex-wrap: wrap;
    }

    .pg-btn {
      min-width: 37px;
      height: 37px;
      padding: 0 10px;
      border-radius: 7px;
      border: 1px solid var(--border2);
      background: var(--bg-card);
      color: var(--sub);
      font-family: 'Inter', sans-serif;
      font-size: .8rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background .18s, color .18s;
    }

    .pg-btn:hover:not(.pg-disabled):not(.pg-active) {
      background: rgba(255, 255, 255, .07);
      color: var(--text);
    }

    .pg-btn.pg-active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      font-weight: 700;
    }

    .pg-btn.pg-disabled {
      opacity: .3;
      pointer-events: none;
    }

    /* RESPONSIVE */

    @media (max-width: 1200px) {
      .product-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 992px) {
      .main-row {
        flex-direction: column !important;
      }

      /* Desktop sidebar hidden on tablet/mobile, we'll use offcanvas */
      .desktop-sidebar {
        display: none !important;
      }

      .product-grid {
        grid-template-columns: repeat(3, 1fr) !important;
        gap: 15px;
      }


      .topbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .topbar-left {
        flex: 1;
        min-width: 0;
      }

      .search-wrap {
        order: 2;
        width: 100%; /* Default to full width on very small, then side by side */
        max-width: 100% !important;
      }

      @media (min-width: 480px) {
        .search-wrap {
          width: auto;
          flex: 0 0 180px;
        }
      }

      .topbar-right-actions {
        order: 3;
        display: flex;
        gap: 10px;
        width: 100%;
      }

      .topbar-right-actions>div,
      .topbar-right-actions>button {
        flex: 1;
      }
    }

    @media (max-width: 768px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr) !important;
        gap: 10px;
      }
    }


    @media (max-width: 575px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr) !important;
      }


      .page-content {
        padding: 15px 16px 40px !important;
      }

      .card-img-wrap {
        height: 200px !important;
      }
    }
  </style>
</head>

<body>

  <%- include('../../partials/user/navigationbar', { user, cartItemCount, currentPage: 'products' , categories }) %>

    <% const PRICE_MAX_VAL=999999; const PRICE_MIN_VAL=0; const curMax=(activeFilters.maxPrice &&
      parseInt(activeFilters.maxPrice) < PRICE_MAX_VAL) ? parseInt(activeFilters.maxPrice) : PRICE_MAX_VAL; const
      curMin=(activeFilters.minPrice && parseInt(activeFilters.minPrice)> PRICE_MIN_VAL)
      ? parseInt(activeFilters.minPrice) : PRICE_MIN_VAL;

      const curSort = activeFilters.sort || '';
      const curSearch = activeFilters.search || '';
      const curBrands = activeFilters.brands || [];
      const curColors = activeFilters.colors || [];

      function qs(overrides) {
      const base = {
      sort: curSort, search: curSearch,
      minPrice: curMin, maxPrice: curMax,
      brand: curBrands, color: curColors,
      page: currentPage
      };
      const m = Object.assign({}, base, overrides);
      const p = new URLSearchParams();
      if (m.sort) p.set('sort', m.sort);
      if (m.search) p.set('search', m.search);
      if (m.minPrice > PRICE_MIN_VAL) p.set('minPrice', m.minPrice);
      if (m.maxPrice < PRICE_MAX_VAL) p.set('maxPrice', m.maxPrice); if (m.page && m.page> 1) p.set('page', m.page);
        (m.brand || []).forEach(v => p.append('brand', v));
        (m.color || []).forEach(v => p.append('color', v));
        const s = p.toString();
        return '/products' + (s ? '?' + s : '');
        }

        const rmBrand = b => qs({ brand: curBrands.filter(v => v !== b), page: 1 });
        const rmColor = c => qs({ color: curColors.filter(v => v !== c), page: 1 });

        const disc = (price, old) => Math.round(((old - price) / old) * 100);

        const totalActive = curBrands.length + curColors.length + (curSearch ? 1 : 0);
        const headingText = curBrands.length === 1 ? curBrands[0] : 'All Products';

        const safeSidebar = sidebarData || {};
        const safeBrands = safeSidebar.brands || [];
        const safeColors = safeSidebar.colors || [];
        %>

        <div class="page-content">

          <!-- TOPBAR -->
          <div class="topbar">
            <div class="topbar-left">
              <h1 class="page-heading">
                <%= headingText %>
              </h1>

              <% if (totalActive> 0) { %>
                <div class="active-pills">
                  <% curBrands.forEach(b=> { %>
                    <span class="active-pill">
                      <%= b %> <a href="<%= rmBrand(b) %>">&#x2715;</a>
                    </span>
                    <% }) %>
                      <% curColors.forEach(c=> { %>
                        <span class="active-pill">
                          <%= c %> <a href="<%= rmColor(c) %>">&#x2715;</a>
                        </span>
                        <% }) %>
                          <% if (curSearch) { %>
                            <span class="active-pill">&ldquo;<%= curSearch %>&rdquo; <a
                                  href="<%= qs({ search: '', page: 1 }) %>">&#x2715;</a></span>
                            <% } %>
                </div>
                <% } %>

                  <div class="result-count">
                    <%= totalProducts %> product<%= totalProducts !==1 ? 's' : '' %> found
                  </div>
            </div>

            <!-- Search bar (always visible on product page) -->
            <div class="search-wrap" style="position:relative;flex:1;max-width:320px;">
              <input type="text" id="productSearchInput" placeholder="Search products…" value="<%= curSearch %>"
                autocomplete="off"
                style="width:100%;background:var(--bg-card);border:1px solid var(--border2);border-radius:12px;padding:10px 60px 10px 16px;color:var(--text);font-family:'Inter',sans-serif;font-size:.85rem;outline:none;transition:border-color .2s;"
                onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border2)'">
              <button type="button" id="clearSearchBtn"
                style="position:absolute;right:38px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--sub);font-size:.8rem;cursor:pointer;display:<%= curSearch ? 'block' : 'none' %>;padding:0;line-height:1;">
                <i class="fas fa-times-circle"></i>
              </button>
              <button type="button" id="submitSearchBtn"
                style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--sub);font-size:.9rem;cursor:pointer;padding:0;line-height:1;transition:color .2s;"
                onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--sub)'">
                <i class="fas fa-search"></i>
              </button>
            </div>

            <!-- Sort & Filter actions -->
            <div class="topbar-right-actions">
              <!-- Filter button (Mobile/Tablet only) -->
              <button class="sort-btn d-lg-none" type="button" data-bs-toggle="offcanvas"
                data-bs-target="#filterOffcanvas">
                <i class="fas fa-filter"></i>
                Filter
              </button>

              <div class="sort-wrap">
                <button class="sort-btn" type="button">
                  <% const sortLabels=[ { val: '' , label: 'Default' }, { val: 'price_asc' , label: 'Price: Low \u2192 High'
                    }, { val: 'price_desc' , label: 'Price: High \u2192 Low' }, { val: 'name_asc' , label: 'Name: A\u2013Z'
                    }, { val: 'name_desc' , label: 'Name: Z\u2013A' }, ]; %>
                    Sort: <%= (sortLabels.find(o=> o.val === curSort) || sortLabels[0]).label %>
                      <i class="fas fa-chevron-down"></i>
                </button>
                <div class="sort-dd">
                  <% sortLabels.forEach(o=> { %>
                    <span class="sort-opt <%= curSort === o.val ? 'active' : '' %>" onclick="applySort('<%= o.val %>')">
                      <%= o.label %> <i class="fas fa-check tick"></i>
                    </span>
                    <% }) %>
                </div>
              </div>
            </div>
          </div>


          <!-- MAIN ROW -->
          <div class="main-row">
            <!-- ===== DESKTOP SIDEBAR ===== -->
            <aside class="desktop-sidebar d-none d-lg-block">
              <%- include('../../partials/user/productFilterForm', { curSort, curSearch, safeBrands, curBrands,
                PRICE_MIN_VAL, PRICE_MAX_VAL, curMin, curMax, safeColors, curColors, isMobile: false }) %>
            </aside>

            <!-- ===== MOBILE/TABLET SIDEBAR (OFFCANVAS) ===== -->
            <div class="offcanvas offcanvas-start bg-dark text-white" tabindex="-1" id="filterOffcanvas"
              aria-labelledby="filterOffcanvasLabel" style="width: 300px;">
              <div class="offcanvas-header border-bottom border-secondary">
                <h5 class="offcanvas-title fw-bold" id="filterOffcanvasLabel">Filter Options</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"
                  aria-label="Close"></button>
              </div>
              <div class="offcanvas-body">
                <%- include('../../partials/user/productFilterForm', { curSort, curSearch, safeBrands, curBrands,
                  PRICE_MIN_VAL, PRICE_MAX_VAL, curMin, curMax, safeColors, curColors, isMobile: true, suffix: 'Mobile'
                  }) %>
              </div>
            </div>

            <!-- ===== PRODUCTS ===== -->
            <div class="content-area" id="productContainer">
              <div class="loading-overlay">
                <i class="fas fa-circle-notch fa-spin"></i>
                <span>Updating results...</span>
              </div>

              <% if (products && products.length> 0) { %>
                <div class="product-grid">
                  <% products.forEach(product=> {
                    const isInactive = product.status && product.status !== 'active';
                    %>
                    <div class="product-card <%= isInactive ? 'is-inactive' : '' %>">


                      <div class="card-img-wrap"
                        onclick="event.preventDefault(); event.stopPropagation();  window.location='/product/<%= product.id %>?variant=<%= product.variantId %>'">
                        <% if (product.image && product.image !=='/images/placeholder.png' ) { %>
                          <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                          <div class="img-placeholder" style="display:none;position:absolute;inset:0;">

                          </div>
                          <% } else { %>
                            <div class="img-placeholder">
                              <i class="fas fa-image"></i><span>No image</span>
                            </div>
                            <% } %>

                              <% if (!isInactive && product.originalPrice && product.price < product.originalPrice) { %>
                                <span class="card-badge badge-sale">-<%= disc(product.price, product.originalPrice) %>%
                                    OFF</span>
                                <% } else if (!isInactive && product.badge) { const bl=product.badge.toLowerCase(); let
                                  bc='badge-best' ; if (bl==='new' ) bc='badge-new' ; if (bl==='hot' ) bc='badge-hot' ;
                                  if (bl==='sale' ) bc='badge-sale' ; %>
                                  <span class="card-badge <%= bc %>">
                                    <%= product.badge %>
                                  </span>
                                  <% } %>


                      </div>

                      <div class="card-body">
                        <div class="card-brand">
                          <%= product.brand %>
                        </div>
                        <div class="card-name">
                          <%= product.name %>
                        </div>

                        <div class="stock-status-wrap">
                          <% if (isInactive) { %>
                            <!-- Skip if inactive (handled in footer) -->
                            <% } else if (product.stock> 10) { %>
                              <span class="stock-badge badge-in-stock">
                                <i class="fas fa-check-circle"></i> In Stock
                              </span>
                              <% } else if (product.stock> 5) { %>
                                <span class="stock-badge badge-low-stock">
                                  <i class="fas fa-exclamation-triangle"></i> Low stock
                                </span>
                                <% } else if (product.stock> 0) { %>
                                  <span class="stock-badge badge-low-stock">
                                    <i class="fas fa-exclamation-triangle"></i> Only <%= product.stock %> left
                                  </span>
                                  <% } else { %>
                                    <span class="stock-badge badge-out-stock">
                                      <i class="fas fa-times-circle"></i> Out of Stock
                                    </span>
                                    <% } %>
                        </div>

                        <div class="card-footer">
                          <div class="card-price-col">
                            <% if (!isInactive && product.originalPrice && product.price < product.originalPrice) { %>
                              <span class="card-price-old">&#8377;<%= product.originalPrice.toLocaleString('en-IN') %>
                              </span>
                              <% } %>
                                <% if (!isInactive && product.stock===0) { %>
                                  <span class="out-label">Out of Stock</span>
                                  <% } else if (!isInactive && product.price) { %>
                                    <span class="card-price">&#8377;<%= product.price.toLocaleString('en-IN') %>
                                    </span>
                                    <% } %>
                          </div>

                          <% if (isInactive) { %>
                            <span class="unavailable-label"><i class="fas fa-ban"></i> Unavailable</span>
                            <% } else { %>
                              <div style="display:flex;flex-direction:column;gap:8px;width:100%;margin-top:12px;">
                                <% const isInWishlist=(typeof wishlistIds !=='undefined' ) &&
                                  wishlistIds.includes(product.id.toString()); %>
                                  <% if (user) { %>
                                    <div style="display:flex; gap:8px; width:100%; height:40px;">
                                      <button class="btn-view" style="flex:1;"
                                        onclick="event.preventDefault(); event.stopPropagation(); window.location='/product/<%= product.id %>?variant=<%= product.variantId %>'">
                                        <i class="fas fa-eye"></i> View Details
                                      </button>
                                      <button class="btn-wish-list"
                                        onclick="event.preventDefault(); event.stopPropagation(); toggleWishlistListing(this, '<%= product.id %>')"
                                        style="display:flex; align-items:center; justify-content:center; width:44px; height:100%; border:1px solid var(--border2); border-radius:var(--radius-sm); background:transparent; color:<%= isInWishlist ? '#e63946' : 'var(--text-dim)' %>; cursor:pointer; transition:all 0.2s;"
                                        onmouseover="this.style.background='rgba(230,57,70,0.1)'; this.style.borderColor='rgba(230,57,70,0.5)'; this.style.color='#e63946'"
                                        onmouseout="if(this.querySelector('i').classList.contains('fas')){ this.style.background='transparent'; this.style.borderColor='var(--border2)'; this.style.color='#e63946'; } else { this.style.background='transparent'; this.style.borderColor='var(--border2)'; this.style.color='var(--text-dim)'; }">
                                        <i class="<%= isInWishlist ? 'fas' : 'far' %> fa-heart"></i>
                                      </button>
                                    </div>

                                    <% } else { %>
                                      <div style="display:flex; gap:8px; width:100%; height:40px;">
                                        <button class="btn-view" style="flex:1;"
                                          onclick="event.preventDefault(); event.stopPropagation(); window.location='/product/<%= product.id %>?variant=<%= product.variantId %>'">
                                          <i class="fas fa-eye"></i> View Details
                                        </button>
                                        <button class="btn-wish-list"
                                          onclick="event.preventDefault(); event.stopPropagation(); toggleWishlistListing(this, '<%= product.id %>')"
                                          style="display:flex; align-items:center; justify-content:center; width:44px; height:100%; border:1px solid var(--border2); border-radius:var(--radius-sm); background:transparent; color:var(--text-dim); cursor:pointer; transition:all 0.2s;"
                                          onmouseover="this.style.background='rgba(230,57,70,0.1)'; this.style.borderColor='rgba(230,57,70,0.5)'; this.style.color='#e63946'"
                                          onmouseout="this.style.background='transparent'; this.style.borderColor='var(--border2)'; this.style.color='var(--text-dim)'">
                                          <i class="far fa-heart"></i>
                                        </button>
                                      </div>

                                      <% } %>
                              </div>
                              <% } %>
                        </div>
                      </div>

                    </div>
                    <% }) %>
                </div>

                <% } else { %>
                  <div class="product-grid">
                    <div class="empty-state">
                      <i class="fas fa-box-open"></i>
                      <p>No products found matching your filters.</p>
                      <a href="/products"
                        style="color:var(--accent);font-size:.81rem;margin-top:12px;display:inline-block;">
                        Clear all filters
                      </a>
                    </div>
                  </div>
                  <% } %>

                    <!-- PAGINATION -->
                    <% if (totalPages> 1) { %>
                      <div class="pagination-wrap">
                        <a class="pg-btn <%= currentPage <= 1 ? 'pg-disabled' : '' %>"
                          href="<%= qs({ page: currentPage - 1 }) %>">
                          <i class="fas fa-chevron-left" style="font-size:.6rem;"></i>
                        </a>
                        <% for (let p=1; p <=totalPages; p++) { const near=Math.abs(p - currentPage) <=1; const
                          edge=p===1 || p===totalPages; const ellL=p===currentPage - 2 && currentPage> 3;
                          const ellR = p === currentPage + 2 && currentPage < totalPages - 1; if (!near && !edge) { if
                            (ellL || ellR) { %>
                            <span class="pg-btn pg-disabled">&hellip;</span>
                            <% } continue; } %>
                              <a class="pg-btn <%= p === currentPage ? 'pg-active' : '' %>"
                                href="<%= qs({ page: p }) %>">
                                <%= p %>
                              </a>
                              <% } %>
                                <a class="pg-btn <%= currentPage >= totalPages ? 'pg-disabled' : '' %>"
                                  href="<%= qs({ page: currentPage + 1 }) %>">
                                  <i class="fas fa-chevron-right" style="font-size:.6rem;"></i>
                                </a>
                      </div>
                      <% } %>

            </div>
          </div>
        </div>
        <input type="hidden" id="cartQtyData" value="<%= JSON.stringify(cartQuantityMap || {}) %>">

        <script>
          const cartQuantities = JSON.parse(document.getElementById('cartQtyData').value || '{}');
          const MAX_QTY = parseInt('<%= MAX_CART_QTY %>', 10);
          const JS_PRICE_MAX = 999999;
          const JS_MIN_GAP = 5000;

          // ── Core navigation: syncs ALL params from both forms then submits ────
          function getActiveForm() {
            // prefer desktop form; fall back to mobile
            return document.getElementById('filterForm') || document.getElementById('filterFormMobile');
          }

          function applySort(val) {
            showLoading();
            // update hidden sort inputs in BOTH forms so they stay in sync
            ['filterForm', 'filterFormMobile'].forEach(id => {
              const f = document.getElementById(id);
              if (!f) return;
              const h = f.querySelector('[name="sort"]') || f.querySelector('#hiddenSort' + (id === 'filterFormMobile' ? 'Mobile' : ''));
              if (h) h.value = val;
            });
            const form = getActiveForm();
            if (form) form.submit();
          }

          function applySearch(val) {
            showLoading();
            ['filterForm', 'filterFormMobile'].forEach(id => {
              const f = document.getElementById(id);
              if (!f) return;
              const h = f.querySelector('[name="search"]') || f.querySelector('#hiddenSearch' + (id === 'filterFormMobile' ? 'Mobile' : ''));
              if (h) h.value = val;
              // reset to page 1
              const pg = f.querySelector('[name="page"]');
              if (pg) pg.value = 1;
            });
            const form = getActiveForm();
            if (form) form.submit();
          }

          function handlePriceSubmit(suffix = '') {
            showLoading();
            const formId = 'filterForm' + suffix;
            const form = document.getElementById(formId);
            if (form) form.submit();
          }

          function showLoading() {
            const container = document.getElementById('productContainer');
            if (container) container.classList.add('is-loading');
          }

          // ── Search box wiring ────────────────────────────────────────────────
          (function () {
            const searchInput = document.getElementById('productSearchInput');
            const clearBtn = document.getElementById('clearSearchBtn');
            const submitBtn = document.getElementById('submitSearchBtn');
            if (!searchInput) return;

            let _timer;
            searchInput.addEventListener('input', function () {
              const val = this.value.trim();
              
              // Show/hide clear button
              if (clearBtn) {
                clearBtn.style.display = val.length > 0 ? 'block' : 'none';
              }

              clearTimeout(_timer);
              _timer = setTimeout(() => applySearch(val), 520);
            });

            searchInput.addEventListener('keydown', function (e) {
              if (e.key === 'Enter') {
                clearTimeout(_timer);
                applySearch(this.value.trim());
              }
            });

            if (submitBtn) {
              submitBtn.addEventListener('click', function() {
                clearTimeout(_timer);
                applySearch(searchInput.value.trim());
              });
            }

            if (clearBtn) {
              clearBtn.addEventListener('click', function() {
                searchInput.value = '';
                this.style.display = 'none';
                clearTimeout(_timer);
                applySearch('');
              });
            }
          })();



          // Initialize maxed buttons
          Object.entries(cartQuantities).forEach(([vid, qty]) => {
            if (qty >= MAX_QTY) {
              const btn = document.getElementById('cart-btn-' + vid);
              if (btn) markMaxed(btn);
            }
          });

          function markMaxed(btn) {
            btn.classList.add('maxed');
            btn.disabled = true;
            btn.title = 'Maximum quantity reached';
          }

          const swalBase = {
            background: '#141416',
            color: '#eaeaea',
            confirmButtonColor: '#4f6ef7',
            cancelButtonColor: '#3a3a4a',
          };




          function showLimitSwal(remaining, stockLimit = 3) {
            const isFull = remaining <= 0;
            const limitVal = Math.min(MAX_QTY, stockLimit);

            Swal.fire({
              ...swalBase,
              toast: true,
              position: 'top-end',
              icon: isFull ? 'warning' : 'success',
              title: isFull ? 'Limit Reached' : 'Added to cart!',
              html: isFull
                ? `<span style="font-size:.76rem;color:var(--text-dim)">You can only add up to <strong style="color:#4f6ef7">${limitVal}</strong> units of this item.</span>`
                : `<span style="font-size:.76rem;color:var(--text-dim)">You can add <strong style="color:#4f6ef7">${remaining}</strong> more unit${remaining === 1 ? '' : 's'}</span>`,
              showConfirmButton: false,
              timer: 2500,
              timerProgressBar: true,
              iconColor: isFull ? '#4f6ef7' : '#00d4a0',
            });
          }

          async function toggleWishlistListing(btn, productId) {
            try {
              const response = await fetch('/wishlist/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
              });

              if (response.status === 401) {
                return Swal.fire({
                  background: '#141416',
                  color: '#eaeaea',
                  confirmButtonColor: '#4f6ef7',
                  icon: 'warning',
                  title: 'Sign In Required',
                  text: 'Please log in to add items to your wishlist.',
                  confirmButtonText: 'Sign In',
                  showCancelButton: true
                }).then(r => { if (r.isConfirmed) window.location.href = '/signin'; });
              }

              const data = await response.json();
              if (data.success) {
                const icon = btn.querySelector('i');

                if (data.action === 'added') {
                  icon.className = 'fas fa-heart';
                  btn.style.color = '#e63946';
                } else {
                  icon.className = 'far fa-heart';
                  btn.style.color = 'var(--text-dim)';
                }

                Swal.fire({
                  toast: true, position: 'top-end', icon: 'success',
                  title: data.action === 'added' ? 'Added to wishlist!' : 'Removed from wishlist',
                  showConfirmButton: false, timer: 1500,
                  background: '#1a1d24', color: '#f0f0f2', iconColor: data.action === 'added' ? '#4ade80' : '#e63946'
                }).then(() => {
                  window.location.reload();
                });
              }
            } catch (err) {
              console.error("Wishlist Toggle Error:", err);
            }
          }

        </script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>


</html>