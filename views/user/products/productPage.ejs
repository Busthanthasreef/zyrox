<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products — Zyrox</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=3">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Product Page Entry Animation -->
  <link rel="stylesheet" href="/userStyles/products/productPageAnimation.css">
  <style>
    .bi-spin {
      display: inline-block;
      animation: bi-spin 1s linear infinite;
    }
    @keyframes bi-spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
  </style>

  <style>
    :root {
      --bg: #0d0f14;
      --bg-card: #16181e;
      --bg-card-h: #040113;
      --accent: #4f6ef7;
      --accent-rgb: 200, 136, 58;
      --accent-lt: rgba(200, 136, 58, .12);
      --green: #00d4a0;
      --green-lt: rgba(0, 212, 160, .08);
      --red: #e63946;
      --red-lt: rgba(230, 57, 70, .08);
      --text: #f0f0f2;
      --text-dim: #c5c5c5;
      --sub: #8b949e;
      --muted: #484f58;
      --border: rgba(255, 255, 255, .06);
      --border2: rgba(255, 255, 255, .1);
      --navbar-h: 70px;
      --radius-sm: 8px;
      --radius-lg: 16px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      font-family: 'Inter', sans-serif;
      color: var(--text);
      min-height: 100vh;
      padding-top: var(--navbar-h);
    }

    .page-content {
      max-width: 1850px;
      margin: 0 auto;
      padding: 32px 30px 60px;
    }

    /* LAYOUT */
    .main-row {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 28px;
      width: 100%;
      margin-top: 20px;
    }




    .sidebar-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .sidebar-title {
      font-size: 1rem;
      font-weight: 700;
    }

    .clear-all {
      font-size: .79rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
      transition: opacity .2s;
    }

    .clear-all:hover {
      opacity: .75;
      text-decoration: underline;
    }

    .sidebar-section {
      padding-bottom: 18px;
      margin-bottom: 18px;
      border-bottom: 1px solid var(--border);
    }

    .sidebar-section:last-child {
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 0;
    }

    .sidebar-section-title {
      font-size: .75rem;
      font-weight: 800;
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* Toggle More Button */
    .toggle-more-btn {
      background: none;
      border: none;
      color: var(--accent);
      font-size: 0.7rem;
      font-weight: 700;
      cursor: pointer;
      padding: 2px 6px;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: all 0.2s;
      border-radius: 4px;
    }

    .toggle-more-btn:hover {
      background: rgba(var(--accent-rgb), 0.1);
      transform: scale(1.05);
    }

    .toggle-more-btn .toggle-icon {
      font-size: 0.6rem;
      transition: transform 0.3s ease;
    }

    /* Checkbox rows */
    .cb-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 5px 0;
      cursor: pointer;
    }

    .cb-row label {
      display: flex;
      align-items: center;
      gap: 9px;
      cursor: pointer;
      font-size: .83rem;
      color: #b0b0b0;
      transition: color .18s;
      flex: 1;
    }

    .cb-row:hover label {
      color: var(--text);
    }

    .cb-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 16px;
      height: 16px;
      border: 1.5px solid rgba(255, 255, 255, .15);
      border-radius: 4px;
      background: transparent;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
      transition: all .2s;
    }

    .cb-row input[type="checkbox"]:checked {
      background: var(--accent);
      border-color: var(--accent);
    }

    .cb-row input[type="checkbox"]:checked::after {
      content: '\2713';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #fff;
      font-size: .58rem;
      font-weight: 900;
    }

    .cb-count {
      font-size: .71rem;
      color: var(--muted);
      background: rgba(255, 255, 255, .05);
      border-radius: 4px;
      padding: 1px 6px;
    }

    /* Pill buttons */
    .pills-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .pill-btn {
      background: transparent;
      border: 1.5px solid rgba(255, 255, 255, .13);
      border-radius: 6px;
      color: var(--sub);
      font-size: .71rem;
      font-weight: 500;
      padding: 4px 10px;
      cursor: pointer;
      transition: all .18s;
      font-family: 'Inter', sans-serif;
    }

    .pill-btn:hover {
      border-color: var(--accent);
      color: var(--text);
    }

    .pill-btn.active {
      background: rgba(200, 136, 58, .15);
      border-color: rgba(200, 136, 58, .55);
      color: var(--accent);
      font-weight: 600;
    }

    /* Price inputs */
    .price-inputs-row {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }

    .p-input-group {
      flex: 1;
    }

    .p-input-group label {
      font-size: 0.65rem;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
      display: block;
      font-weight: 700;
    }

    .p-input-wrap {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 4px 8px;
    }

    .p-input-wrap span {
      font-size: .8rem;
      color: var(--muted);
      margin-right: 4px;
    }

    .p-input-wrap input {
      background: transparent;
      border: none;
      color: var(--text);
      font-size: .85rem;
      width: 100%;
      outline: none;
      font-weight: 500;
      font-family: 'Inter', sans-serif;
    }

    .p-input-wrap input::-webkit-inner-spin-button,
    .p-input-wrap input::-webkit-outer-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    .btn-apply-desktop {
      width: 100%;
      background: var(--accent);
      color: #fff;
      border: none;
      padding: 9px;
      border-radius: var(--radius-sm);
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      letter-spacing: 1px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .btn-apply-desktop:hover {
      background: #3d56c7;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(79, 110, 247, 0.3);
      border-color: rgba(255, 255, 255, 0.2);
    }

    .btn-apply-desktop:active {
      transform: translateY(0);
    }

    /* Grid Loading state */
    #productContainer {
      position: relative;
      transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    #productContainer.is-loading {
      pointer-events: none;
    }

    #productContainer.is-loading>*:not(.loading-overlay) {
      filter: blur(8px) grayscale(0.2);
      opacity: 0.4;
      transition: filter 0.4s ease, opacity 0.4s ease;
    }

    .loading-overlay {
      display: none;
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 9999;
      background: rgba(15, 18, 22, 0.75);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      padding: 40px 60px;
      border-radius: 30px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow:
        0 30px 70px rgba(0, 0, 0, 0.6),
        0 0 40px rgba(79, 110, 247, 0.15),
        inset 0 0 20px rgba(255, 255, 255, 0.05);
      color: var(--text);
      flex-direction: column;
      align-items: center;
      gap: 25px;
      min-width: 260px;
    }

    #productContainer.is-loading .loading-overlay {
      display: flex;
      animation: pzxLoadingPopIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @keyframes pzxLoadingPopIn {
      from {
        opacity: 0;
        transform: translate(-50%, -40%) scale(0.9);
      }

      to {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
    }

    .loading-overlay i {
      font-size: 3rem;
      color: var(--accent);
      filter: drop-shadow(0 0 15px rgba(79, 110, 247, 0.5));
      animation: pzxSpinnerPulse 1.5s ease-in-out infinite;
    }

    @keyframes pzxSpinnerPulse {

      0%,
      100% {
        transform: scale(1) rotate(0deg);
        opacity: 1;
      }

      50% {
        transform: scale(1.1) rotate(180deg);
        opacity: 0.8;
      }
    }

    .loading-overlay span {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      background: linear-gradient(45deg, #fff, var(--accent), #fff);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: pzxTextShimmer 2s linear infinite;
    }

    @keyframes pzxTextShimmer {
      to {
        background-position: 200% center;
      }
    }


    .price-labels {
      display: flex;
      justify-content: space-between;
      font-size: .77rem;
      color: var(--text);
      font-weight: 500;
    }

    .no-data {
      font-size: .77rem;
      color: var(--muted);
      font-style: italic;
    }

    /* CONTENT */
    .content-area {
      flex: 1;
      min-width: 0;
    }

    /* TOPBAR */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 12px;
    }

    .topbar-right-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .topbar-left {
      flex: 1;
    }

    .page-heading {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .active-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 6px;
    }

    .active-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1.5px solid var(--border2);
      border-radius: 6px;
      padding: 4px 12px;
      font-size: .74rem;
    }

    .active-pill a {
      color: var(--sub);
      text-decoration: none;
      font-size: .64rem;
      transition: color .18s;
    }

    .active-pill a:hover {
      color: #e63946;
    }

    .result-count {
      font-size: .76rem;
      color: var(--sub);
      margin-top: 4px;
    }

    /* Sort */
    .sort-wrap {
      position: relative;
      flex-shrink: 0;
    }

    .sort-btn {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-card);
      border: 1px solid var(--border2);
      border-radius: 12px;
      padding: 10px 20px;
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: .85rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.3s ease;
      backdrop-filter: blur(10px);
    }

    .sort-btn:hover {
      border-color: var(--accent);
      background: rgba(var(--accent-rgb), 0.05);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .sort-btn i {
      font-size: .76rem;
      color: var(--sub);
      transition: transform .2s;
    }

    .sort-wrap:hover .sort-btn i {
      transform: rotate(180deg);
      color: var(--accent);
    }

    .sort-dd {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      background: var(--bg-card);
      border: 1px solid var(--border2);
      border-radius: 12px;
      min-width: 200px;
      z-index: 1000;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0, 0, 0, .8);
      padding: 6px;
    }

    .sort-wrap:hover .sort-dd {
      display: block;
    }

    .sort-opt {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 13px;
      font-size: .8rem;
      color: var(--sub);
      text-decoration: none;
      border-radius: 8px;
      transition: all .15s;
    }

    .sort-opt:hover {
      background: rgba(200, 136, 58, .08);
      color: var(--text);
    }

    .sort-opt.active {
      background: rgba(200, 136, 58, .15);
      color: var(--accent);
      font-weight: 600;
    }

    .sort-opt .tick {
      font-size: .72rem;
      color: var(--accent);
      opacity: 0;
    }

    .sort-opt.active .tick {
      opacity: 1;
    }

    /* PRODUCT GRID */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .product-card {
      background: var(--bg-card-h);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      cursor: pointer;
      position: relative;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      backdrop-filter: blur(10px);
      animation: productIdleSwing 4s ease-in-out infinite;
    }

    @keyframes productIdleSwing {

      0%,
      100% {
        transform: translateY(0) rotate(0deg);
      }

      25% {
        transform: translateY(-2px) rotate(0.8deg);
      }

      50% {
        transform: translateY(0) rotate(0deg);
      }

      75% {
        transform: translateY(-2px) rotate(-0.8deg);
      }
    }

    .product-card:hover {
      background: var(--bg-card-h);
      border-color: rgba(var(--accent-rgb), 0.3);
      transform: translateY(-10px) scale(1.03) !important;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(var(--accent-rgb), 0.1);
      animation: productHoverSwing 1.5s ease-in-out infinite;
    }

    @keyframes productHoverSwing {

      0%,
      100% {
        transform: translateY(-10px) scale(1.03) rotate(0deg);
      }

      25% {
        transform: translateY(-10px) scale(1.03) rotate(1.5deg);
      }

      50% {
        transform: translateY(-10px) scale(1.03) rotate(0deg);
      }

      75% {
        transform: translateY(-10px) scale(1.03) rotate(-1.5deg);
      }
    }

    .product-card.is-inactive {
      opacity: .7;
      cursor: default;
    }

    .product-card.is-inactive:hover {
      transform: none;
      box-shadow: none;
    }

    .card-img-wrap {
      position: relative;
      width: 100%;
      height: 180px;
      /* background: #3d0000; */
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px;
      border-radius: 40px;
    }

    .productImage {}

    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 30px;

    }

    .product-card.is-inactive:hover .card-img-wrap img {
      transform: none;
    }

    .img-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      color: var(--muted);
      font-size: .69rem;
      gap: 7px;
    }

    .img-placeholder i {
      font-size: 1.8rem;
      opacity: .2;
    }

    .card-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      font-size: .59rem;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 5px;
      text-transform: uppercase;
      letter-spacing: .3px;
      z-index: 5;
    }

    .badge-sale {
      background: #e63946;
      color: #fff;
    }

    .badge-new {
      background: #4ade80;
      color: #0a1a10;
    }

    .badge-hot {
      background: var(--accent);
      color: #fff;
    }

    .badge-best {
      background: rgba(255, 255, 255, .12);
      color: var(--text);
      border: 1px solid rgba(255, 255, 255, .2);
    }

    .wishlist-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: rgba(13, 15, 20, .7);
      border: 1px solid rgba(255, 255, 255, .12);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 5;
      color: var(--sub);
      font-size: .67rem;
      transition: color .2s, background .2s;
    }

    .wishlist-btn:hover,
    .wishlist-btn.active {
      color: #e63946;
      background: rgba(230, 57, 70, .2);
    }

    .card-body {
      padding: 8px 12px 12px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .card-brand {
      font-size: .6rem;
      color: var(--sub);
      text-transform: lowercase;
      letter-spacing: 0.5px;
    }

    .card-name {
      font-size: .78rem;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: 2px;
    }

    .card-specs {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 3px;
    }

    .spec-chip {
      font-size: .59rem;
      font-weight: 500;
      color: var(--sub);
      background: rgba(255, 255, 255, .06);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 4px;
      padding: 2px 6px;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
      padding-top: 10px;
      flex-wrap: wrap;
      gap: 8px;
    }

    .card-price-col {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .card-price-old {
      font-size: .65rem;
      color: var(--muted);
      text-decoration: line-through;
    }

    .card-price {
      font-size: .93rem;
      font-weight: 700;
      color: var(--text);
    }

    .out-label {
      font-size: .7rem;
      color: #e63946;
      font-weight: 600;
    }

    .unavailable-label {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: .66rem;
      font-weight: 700;
      color: #e63946;
      background: rgba(230, 57, 70, .1);
      border: 1px solid rgba(230, 57, 70, .25);
      border-radius: 7px;
      padding: 5px 9px;
      white-space: nowrap;
    }

    .stock-status-wrap {
      margin-top: 10px;
    }

    .btn-add-cart-quick {
      background: var(--accent);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius-sm);
      padding: 8px 12px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      flex: 1;
      height: 40px;
    }

    .btn-add-cart-quick:hover:not(:disabled) {
      background: #3d56c7;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(79, 110, 247, 0.3);
    }

    .btn-add-cart-quick:active:not(:disabled) {
      transform: translateY(0);
    }

    .btn-add-cart-quick:disabled,
    .btn-add-cart-quick.is-out-of-stock {
      background: var(--muted);
      cursor: not-allowed;
      opacity: 0.6;
      filter: grayscale(1);
    }

    .btn-add-cart-quick.is-out-of-stock:hover {
      transform: none;
      box-shadow: none;
    }

    .stock-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: .58rem;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 50px;
      text-transform: uppercase;
      letter-spacing: .4px;
      border: 1px solid transparent;
    }

    .badge-in-stock {
      background: var(--green-lt);
      color: var(--green);
      border-color: rgba(0, 212, 160, .15);
    }

    .badge-low-stock {
      background: var(--accent-lt);
      color: orangered;
      border-color: rgba(200, 136, 58, .2);
    }

    .badge-out-stock {
      background: var(--red-lt);
      color: var(--red);
      border-color: rgba(230, 57, 70, .15);
    }

    .btn-view {
      padding: 8px 12px;
      border-radius: 8px;
      background: linear-gradient(135deg, #0ce0a1, #00d4a0);
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      color: #000000;
      font-weight: 700;
      font-size: .75rem;
      width: 100%;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(0, 212, 160, 0.2);
    }

    .btn-view:hover {
      transform: scale(1.02);
      box-shadow: 0 6px 20px rgba(0, 212, 160, 0.4);
      filter: brightness(1.1);
    }

    .btn-cart:hover:not(:disabled) {
      transform: scale(1.02);
      box-shadow: 0 6px 20px rgba(var(--accent-rgb), 0.4);
      filter: brightness(1.1);
    }

    .btn-cart:disabled {
      opacity: .2;
      cursor: not-allowed;
      filter: grayscale(1);
    }

    .btn-add-cart-quick.maxed {
      background: var(--muted) !important;
      cursor: not-allowed !important;
      opacity: .6;
      transform: none !important;
      box-shadow: none !important;
    }

    .btn-add-cart-quick.maxed:hover {
      transform: none !important;
    }



    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 80px 20px;
      color: var(--muted);
    }

    .empty-state i {
      font-size: 2.6rem;
      opacity: .2;
      display: block;
      margin-bottom: 14px;
    }

    .empty-state p {
      font-size: .88rem;
    }

    /* PAGINATION */
    .pagination-wrap {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      padding: 36px 0 10px;
      flex-wrap: wrap;
    }

    .pg-btn {
      min-width: 37px;
      height: 37px;
      padding: 0 10px;
      border-radius: 7px;
      border: 1px solid var(--border2);
      background: var(--bg-card);
      color: var(--sub);
      font-family: 'Inter', sans-serif;
      font-size: .8rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background .18s, color .18s;
    }

    .pg-btn:hover:not(.pg-disabled):not(.pg-active) {
      background: rgba(255, 255, 255, .07);
      color: var(--text);
    }

    .pg-btn.pg-active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      font-weight: 700;
    }

    .pg-btn.pg-disabled {
      opacity: .3;
      pointer-events: none;
    }

    /* RESPONSIVE */

    @media (max-width: 2200px) {
      .product-grid {
        grid-template-columns: repeat(8, 2fr);
      }
    }

    @media (max-width: 1800px) {
      .product-grid {
        grid-template-columns: repeat(6, 2fr);
      }
    }

    @media (max-width: 1500px) {
      .product-grid {
        grid-template-columns: repeat(4, 2fr);
      }
    }

    @media (max-width: 1200px) {
      .product-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 992px) {
      .main-row {
        flex-direction: column !important;
      }

      /* Desktop sidebar hidden on tablet/mobile, we'll use offcanvas */
      .desktop-sidebar {
        display: none !important;
      }

      .product-grid {
        grid-template-columns: repeat(3, 1fr) !important;
        gap: 15px;
      }


      .topbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .topbar-left {
        flex: 1;
        min-width: 0;
      }

      .search-wrap {
        order: 2;
        width: 100%;
        /* Default to full width on very small, then side by side */
        max-width: 100% !important;
      }

      @media (min-width: 480px) {
        .search-wrap {
          width: auto;
          flex: 0 0 180px;
        }
      }

      .topbar-right-actions {
        order: 3;
        display: flex;
        gap: 10px;
        width: 100%;
      }

      .topbar-right-actions>div,
      .topbar-right-actions>button {
        flex: 1;
      }
    }

    @media (max-width: 768px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr) !important;
        gap: 10px;
      }

      .card-img-wrap {
        height: 160px !important;
      }
    }


    @media (max-width: 575px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr) !important;
      }


      .page-content {
        padding: 15px 16px 40px !important;
      }

      .card-img-wrap {
        height: 200px !important;
      }
    }
  </style>
</head>

<body>

  <%- include('../../partials/user/navigationbar', { user, cartItemCount, currentPage: 'products' , categories }) %>

    <% const PRICE_MAX_VAL=999999; const PRICE_MIN_VAL=0; const curMax=(activeFilters.maxPrice &&
      parseInt(activeFilters.maxPrice) < PRICE_MAX_VAL) ? parseInt(activeFilters.maxPrice) : PRICE_MAX_VAL; const
      curMin=(activeFilters.minPrice && parseInt(activeFilters.minPrice)> PRICE_MIN_VAL)
      ? parseInt(activeFilters.minPrice) : PRICE_MIN_VAL;

      const curSort = activeFilters.sort || '';
      const curSearch = activeFilters.search || '';
      const curBrands = activeFilters.brands || [];
      const curColors = activeFilters.colors || [];

      function qs(overrides) {
      const base = {
      sort: curSort, search: curSearch,
      minPrice: curMin, maxPrice: curMax,
      brand: curBrands, color: curColors,
      page: currentPage
      };
      const m = Object.assign({}, base, overrides);
      const p = new URLSearchParams();
      if (m.sort) p.set('sort', m.sort);
      if (m.search) p.set('search', m.search);
      if (m.minPrice > PRICE_MIN_VAL) p.set('minPrice', m.minPrice);
      if (m.maxPrice < PRICE_MAX_VAL) p.set('maxPrice', m.maxPrice); if (m.page && m.page> 1) p.set('page', m.page);
        (m.brand || []).forEach(v => p.append('brand', v));
        (m.color || []).forEach(v => p.append('color', v));
        const s = p.toString();
        return '/products' + (s ? '?' + s : '');
        }

        const rmBrand = b => qs({ brand: curBrands.filter(v => v !== b), page: 1 });
        const rmColor = c => qs({ color: curColors.filter(v => v !== c), page: 1 });

        const disc = (price, old) => Math.round(((old - price) / old) * 100);

        const totalActive = curBrands.length + curColors.length + (curSearch ? 1 : 0);
        const headingText = curBrands.length === 1 ? curBrands[0] : 'All Products';

        const safeSidebar = sidebarData || {};
        const safeBrands = safeSidebar.brands || [];
        const safeColors = safeSidebar.colors || [];
        %>

        <div class="page-content">

          <!-- TOPBAR -->
          <div class="topbar">
            <div class="topbar-left">
              <h1 class="page-heading">
                <%= headingText %>
              </h1>

              <% if (totalActive> 0) { %>
                <div class="active-pills">
                  <% curBrands.forEach(b=> { %>
                    <span class="active-pill">
                      <%= b %> <a href="<%= rmBrand(b) %>">&#x2715;</a>
                    </span>
                    <% }) %>
                      <% curColors.forEach(c=> { %>
                        <span class="active-pill">
                          <%= c %> <a href="<%= rmColor(c) %>">&#x2715;</a>
                        </span>
                        <% }) %>
                          <% if (curSearch) { %>
                            <span class="active-pill">&ldquo;<%= curSearch %>&rdquo; <a
                                  href="<%= qs({ search: '', page: 1 }) %>">&#x2715;</a></span>
                            <% } %>
                </div>
                <% } %>

                  <div class="result-count">
                    <%= totalProducts %> product<%= totalProducts !==1 ? 's' : '' %> found
                  </div>
            </div>

            <!-- Search bar (always visible on product page) -->
            <div class="search-wrap" style="position:relative;flex:1;max-width:320px;">
              <input type="text" id="productSearchInput" placeholder="Search products…" value="<%= curSearch %>"
                autocomplete="off"
                style="width:100%;background:var(--bg-card);border:1px solid var(--border2);border-radius:12px;padding:10px 60px 10px 16px;color:var(--text);font-family:'Inter',sans-serif;font-size:.85rem;outline:none;transition:border-color .2s;"
                onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border2)'">
              <button type="button" id="clearSearchBtn"
                style="position:absolute;right:38px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--sub);font-size:.8rem;cursor:pointer;display:<%= curSearch ? 'block' : 'none' %>;padding:0;line-height:1;">
                <i class="bi bi-x-circle"></i>
              </button>
              <button type="button" id="submitSearchBtn"
                style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--sub);font-size:.9rem;cursor:pointer;padding:0;line-height:1;transition:color .2s;"
                onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--sub)'">
                <i class="bi bi-search"></i>
              </button>
            </div>

            <!-- Sort & Filter actions -->
            <div class="topbar-right-actions">
              <!-- Filter button (Mobile/Tablet only) -->
              <button class="sort-btn d-lg-none" type="button" data-bs-toggle="offcanvas"
                data-bs-target="#filterOffcanvas">
                <i class="bi bi-filter"></i>
                Filter
              </button>

              <div class="sort-wrap">
                <button class="sort-btn" type="button">
                  <% const sortLabels=[ { val: '' , label: 'Newest First' }, { val: 'price_asc' ,
                    label: 'Price: Low \u2192 High' }, { val: 'price_desc' , label: 'Price: High \u2192 Low' }, {
                    val: 'name_asc' , label: 'Name: A\u2013Z' }, { val: 'name_desc' , label: 'Name: Z\u2013A' }, ]; %>
                    Sort: <%= (sortLabels.find(o=> o.val === curSort) || sortLabels[0]).label %>
                      <i class="bi bi-chevron-down"></i>
                </button>
                <div class="sort-dd">
                  <% sortLabels.forEach(o=> { %>
                    <span class="sort-opt <%= curSort === o.val ? 'active' : '' %>" onclick="applySort('<%= o.val %>')">
                      <%= o.label %> <i class="bi bi-check tick"></i>
                    </span>
                    <% }) %>
                </div>
              </div>
            </div>
          </div>


          <!-- MAIN ROW -->
          <div class="main-row">
            <!-- ===== DESKTOP SIDEBAR ===== -->
            <aside class="desktop-sidebar d-none d-lg-block">
              <%- include('../../partials/user/productFilterForm', { curSort, curSearch, safeBrands, curBrands,
                PRICE_MIN_VAL, PRICE_MAX_VAL, curMin, curMax, safeColors, curColors, isMobile: false }) %>
            </aside>

            <!-- ===== MOBILE/TABLET SIDEBAR (OFFCANVAS) ===== -->
            <div class="offcanvas offcanvas-start bg-dark text-white" tabindex="-1" id="filterOffcanvas"
              aria-labelledby="filterOffcanvasLabel" style="width: 300px;">
              <div class="offcanvas-header border-bottom border-secondary">
                <h5 class="offcanvas-title fw-bold" id="filterOffcanvasLabel">Filter Options</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"
                  aria-label="Close"></button>
              </div>
              <div class="offcanvas-body">
                <%- include('../../partials/user/productFilterForm', { curSort, curSearch, safeBrands, curBrands,
                  PRICE_MIN_VAL, PRICE_MAX_VAL, curMin, curMax, safeColors, curColors, isMobile: true, suffix: 'Mobile'
                  }) %>
              </div>
            </div>

            <!-- ===== PRODUCTS ===== -->
            <div class="content-area product-page-animation" id="productContainer">
              <div class="loading-overlay">
                <i class="spinner-border spinner-border-sm"></i>
                <span>Updating results...</span>
              </div>

              <% if (products && products.length> 0) { %>
                <div class="product-grid">
                  <% products.forEach(product=> {
                    const isInactive = product.status && product.status !== 'active';
                    %>
                    <div class="product-card <%= isInactive ? 'is-inactive' : '' %>">


                      <div class="card-img-wrap"
                        onclick="event.preventDefault(); event.stopPropagation();  window.location='/product/<%= product.id %>?variant=<%= product.variantId %>'">
                        <% if (product.image && product.image !=='/images/placeholder.png' ) { %>
                          <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                          <div class="img-placeholder" style="display:none;position:absolute;inset:0;">

                          </div>
                          <% } else { %>
                            <div class="img-placeholder">
                              <i class="bi bi-image"></i><span>No image</span>
                            </div>
                            <% } %>

                              <% if (!isInactive && product.originalPrice && product.price < product.originalPrice) { %>
                                <span class="card-badge badge-sale">
                                  <% if (product.offerType==='flat' ) { %>
                                    ₹<%= (product.originalPrice - product.price).toLocaleString('en-IN') %> OFF
                                      <% } else { %>
                                        -<%= disc(product.price, product.originalPrice) %>% OFF
                                          <% } %>
                                </span>
                                <% } else if (!isInactive && product.badge) { const bl=product.badge.toLowerCase(); let
                                  bc='badge-best' ; if (bl==='new' ) bc='badge-new' ; if (bl==='hot' ) bc='badge-hot' ;
                                  if (bl==='sale' ) bc='badge-sale' ; %>
                                  <span class="card-badge <%= bc %>">
                                    <%= product.badge %>
                                  </span>
                                  <% } %>


                      </div>

                      <div class="card-body">
                        <div class="card-brand">
                          <%= product.brand %>
                        </div>
                        <div class="card-name">
                          <%= product.name %>
                        </div>

                        <div class="stock-status-wrap">
                          <% if (isInactive) { %>
                            <!-- Skip if inactive (handled in footer) -->
                            <% } else if (product.stock> 7) { %>
                              <span class="stock-badge badge-in-stock">
                                <i class="bi bi-check-circle-fill"></i> In Stock
                              </span>
                              <% } else if (product.stock> 3 ){ %>
                                <span class="stock-badge badge-low-stock">
                                  <i class="bi bi-exclamation-triangle"></i> Low stock
                                </span>
                                <% } else if (product.stock> 0) { %>
                                  <span class="stock-badge badge-low-stock">
                                    <i class="bi bi-exclamation-triangle"></i> Only <%= product.stock %> left
                                  </span>
                                  <% } else { %>
                                    <span class="stock-badge badge-out-stock">
                                      <i class="bi bi-x-circle"></i> Out of Stock
                                    </span>
                                    <% } %>
                        </div>

                        <div class="card-footer">
                          <div class="card-price-col">
                            <% if (!isInactive && product.originalPrice && product.price < product.originalPrice) { %>
                              <span class="card-price-old">&#8377;<%= product.originalPrice.toLocaleString('en-IN') %>
                              </span>
                              <% } %>
                                <% if (!isInactive && product.stock===0) { %>
                                  <span class="out-label">Out of Stock</span>
                                  <% } else if (!isInactive && product.price) { %>
                                    <span class="card-price">&#8377;<%= product.price.toLocaleString('en-IN') %>
                                    </span>
                                    <% } %>
                          </div>

                          <% if (isInactive) { %>
                             <span class="unavailable-label"><i class="bi bi-slash-circle"></i> Unavailable</span>
                            <% } else { %>
                              <div style="display:flex; flex-direction:column; gap:8px; width:100%; margin-top:12px;">
                                <div style="display:flex; gap:8px; width:100%;">
                                  <button class="btn-add-cart-quick <%= product.stock <= 0 ? 'is-out-of-stock' : '' %>"
                                    onclick="event.preventDefault(); event.stopPropagation(); quickAddToCart(this, '<%= product.id %>', '<%= product.variantId %>', '<%= product.stock %>')"
                                    id="cart-btn-<%= product.variantId %>">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                  </button>
                                </div>
                                <div style="display:flex; gap:8px; width:100%;">
                                  <button class="btn-view" style="flex:1;"
                                    onclick="event.preventDefault(); event.stopPropagation(); window.location='/product/<%= product.id %>?variant=<%= product.variantId %>'">
                                    <i class="bi bi-eye"></i> Details
                                  </button>

                                  <% const isInWishlist=(typeof wishlistIds !=='undefined' ) &&
                                    wishlistIds.includes(product.id.toString()); %>
                                    <button class="btn-wish-list"
                                      onclick="event.preventDefault(); event.stopPropagation(); toggleWishlistListing(this, '<%= product.id %>')"
                                      style="display:flex; align-items:center; justify-content:center; width:44px; height:40px; border:1px solid var(--border2); border-radius:var(--radius-sm); background:transparent; color:<%= isInWishlist ? '#e63946' : 'var(--text-dim)' %>; cursor:pointer; transition:all 0.2s;"
                                      onmouseover="this.style.background='rgba(230,57,70,0.1)'; this.style.borderColor='rgba(230,57,70,0.5)'; this.style.color='#e63946'"
                                      onmouseout="if(this.querySelector('i').classList.contains('bi-heart-fill')){ this.style.background='transparent'; this.style.borderColor='var(--border2)'; this.style.color='#e63946'; } else { this.style.background='transparent'; this.style.borderColor='var(--border2)'; this.style.color='var(--text-dim)'; }">
                                      <i class="bi <%= isInWishlist ? 'bi-heart-fill' : 'bi-heart' %>"></i>
                                    </button>
                                </div>

                              </div>
                              <% } %>

                        </div>
                      </div>

                    </div>
                    <% }) %>
                </div>

                <% } else { %>
                  <div class="product-grid">
                    <div class="empty-state">
                      <i class="bi bi-box-seam"></i>
                      <p>No products found matching your filters.</p>
                      <a href="/products"
                        style="color:var(--accent);font-size:.81rem;margin-top:12px;display:inline-block;">
                        Clear all filters
                      </a>
                    </div>
                  </div>
                  <% } %>

                    <!-- PAGINATION -->
                    <% if (totalPages> 1) { %>
                      <div class="pagination-wrap">
                        <a class="pg-btn <%= currentPage <= 1 ? 'pg-disabled' : '' %>"
                          href="<%= qs({ page: currentPage - 1 }) %>">
                          <i class="bi bi-chevron-left" style="font-size:.6rem;"></i>
                        </a>
                        <% for (let p=1; p <=totalPages; p++) { const near=Math.abs(p - currentPage) <=1; const
                          edge=p===1 || p===totalPages; const ellL=p===currentPage - 2 && currentPage> 3;
                          const ellR = p === currentPage + 2 && currentPage < totalPages - 1; if (!near && !edge) { if
                            (ellL || ellR) { %>
                            <span class="pg-btn pg-disabled">&hellip;</span>
                            <% } continue; } %>
                              <a class="pg-btn <%= p === currentPage ? 'pg-active' : '' %>"
                                href="<%= qs({ page: p }) %>">
                                <%= p %>
                              </a>
                              <% } %>
                                <a class="pg-btn <%= currentPage >= totalPages ? 'pg-disabled' : '' %>"
                                  href="<%= qs({ page: currentPage + 1 }) %>">
                                  <i class="bi bi-chevron-right" style="font-size:.6rem;"></i>
                                </a>
                      </div>
                      <% } %>

            </div>
          </div>
        </div>
        <input type="hidden" id="cartQtyData" value="<%= JSON.stringify(cartQuantityMap || {}) %>">

        <script>
          const cartQuantities = JSON.parse(document.getElementById('cartQtyData').value || '{}');
          const MAX_QTY = parseInt('<%= MAX_CART_QTY %>', 10);
          const JS_PRICE_MAX = 999999;
          const JS_MIN_GAP = 5000;

          // ── Core navigation: syncs ALL params from both forms then submits ────
          function getActiveForm() {
            // prefer desktop form; fall back to mobile
            return document.getElementById('filterForm') || document.getElementById('filterFormMobile');
          }

          function applySort(val) {
            showLoading();
            // update hidden sort inputs in BOTH forms so they stay in sync
            ['filterForm', 'filterFormMobile'].forEach(id => {
              const f = document.getElementById(id);
              if (!f) return;
              const h = f.querySelector('[name="sort"]') || f.querySelector('#hiddenSort' + (id === 'filterFormMobile' ? 'Mobile' : ''));
              if (h) h.value = val;
            });
            const form = getActiveForm();
            if (form) form.submit();
          }

          function applySearch(val) {
            showLoading();
            ['filterForm', 'filterFormMobile'].forEach(id => {
              const f = document.getElementById(id);
              if (!f) return;
              const h = f.querySelector('[name="search"]') || f.querySelector('#hiddenSearch' + (id === 'filterFormMobile' ? 'Mobile' : ''));
              if (h) h.value = val;
              // reset to page 1
              const pg = f.querySelector('[name="page"]');
              if (pg) pg.value = 1;
            });
            const form = getActiveForm();
            if (form) form.submit();
          }

          function handlePriceSubmit(suffix = '') {
            showLoading();
            const formId = 'filterForm' + suffix;
            const form = document.getElementById(formId);
            if (form) form.submit();
          }

          function showLoading() {
            const container = document.getElementById('productContainer');
            if (container) container.classList.add('is-loading');
          }

          // ── Toggle More/Less Items (Brands & Colors) ────────────────────────
          function toggleMoreItems(containerId, button) {
            const container = document.getElementById(containerId);
            if (!container) return;

            const hiddenItems = container.querySelectorAll('.hidden-item');
            const toggleText = button.querySelector('.toggle-text');
            const toggleIcon = button.querySelector('.toggle-icon');

            const isExpanded = hiddenItems[0]?.style.display !== 'none';

            hiddenItems.forEach(item => {
              item.style.display = isExpanded ? 'none' : 'flex';
            });

            if (toggleText) {
              toggleText.textContent = isExpanded ? 'More' : 'Less';
            }

            if (toggleIcon) {
              toggleIcon.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
            }
          }

          // ── Search box wiring ────────────────────────────────────────────────
          (function () {
            const searchInput = document.getElementById('productSearchInput');
            const clearBtn = document.getElementById('clearSearchBtn');
            const submitBtn = document.getElementById('submitSearchBtn');
            if (!searchInput) return;

            let _timer;
            searchInput.addEventListener('input', function () {
              const val = this.value.trim();

              // Show/hide clear button
              if (clearBtn) {
                clearBtn.style.display = val.length > 0 ? 'block' : 'none';
              }

              clearTimeout(_timer);
              _timer = setTimeout(() => applySearch(val), 520);
            });

            searchInput.addEventListener('keydown', function (e) {
              if (e.key === 'Enter') {
                clearTimeout(_timer);
                applySearch(this.value.trim());
              }
            });

            if (submitBtn) {
              submitBtn.addEventListener('click', function () {
                clearTimeout(_timer);
                applySearch(searchInput.value.trim());
              });
            }

            if (clearBtn) {
              clearBtn.addEventListener('click', function () {
                searchInput.value = '';
                this.style.display = 'none';
                clearTimeout(_timer);
                applySearch('');
              });
            }
          })();



          // Initialize maxed buttons
          Object.entries(cartQuantities).forEach(([vid, qty]) => {
            if (qty >= MAX_QTY) {
              const btn = document.getElementById('cart-btn-' + vid);
              if (btn) markMaxed(btn);
            }
          });

          function markMaxed(btn) {
            btn.classList.add('maxed');
            btn.disabled = true;
            btn.title = 'Maximum quantity reached';
          }

          const swalBase = {
            background: '#141416',
            color: '#eaeaea',
            confirmButtonColor: '#4f6ef7',
            cancelButtonColor: '#3a3a4a',
          };




          function showLimitSwal(remaining, stockLimit = 3) {
            const isFull = remaining <= 0;
            const limitVal = Math.min(MAX_QTY, stockLimit);

            Swal.fire({
              ...swalBase,
              toast: true,
              position: 'top-end',
              icon: isFull ? 'warning' : 'success',
              title: isFull ? 'Limit Reached' : 'Added to cart!',
              html: isFull
                ? `<span style="font-size:.76rem;color:var(--text-dim)">You can only add up to <strong style="color:#4f6ef7">${limitVal}</strong> units of this item.</span>`
                : `<span style="font-size:.76rem;color:var(--text-dim)">You can add <strong style="color:#4f6ef7">${remaining}</strong> more unit${remaining === 1 ? '' : 's'}</span>`,
              showConfirmButton: false,
              timer: 2500,
              timerProgressBar: true,
              iconColor: isFull ? '#4f6ef7' : '#00d4a0',
            });
          }

          async function addToCartListing(btn, productId, variantId) {
            try {
              if (btn.disabled) return;

              // Loading state
              const originalContent = btn.innerHTML;
              btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i>';
              btn.disabled = true;

              const response = await fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, variantId, quantity: 1 })
              });

              const result = await response.json();

              // Restore button
              btn.innerHTML = originalContent;
              btn.disabled = false;

              if (result.requiresAuth || response.status === 401) {
                return Swal.fire({
                  ...swalBase,
                  icon: 'info',
                  title: 'Sign In Required',
                  text: 'Please log in to add items to your cart.',
                  confirmButtonText: 'Sign In',
                  showCancelButton: true,
                  cancelButtonText: 'Do it later'
                }).then(r => {
                  if (r.isConfirmed) {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                    redirectTo(`/signin`);
                  }
                });
              }

              if (result.success) {
                // Update local tracking
                const currentQty = (cartQuantities[variantId] || 0) + 1;
                cartQuantities[variantId] = currentQty;

                showLimitSwal(MAX_QTY - currentQty, result.stockLimit);

                if (currentQty >= MAX_QTY || currentQty >= result.stockLimit) {
                  markMaxed(btn);
                }

                // Update cart count dynamically from server response
                const cartBadge = document.querySelector('.cart-badge');
                if (cartBadge && result.cartCount !== undefined) {
                  cartBadge.textContent = result.cartCount;
                  cartBadge.style.display = 'flex';
                }
              } else {
                if (result.limitReached) {
                  markMaxed(btn);
                  Swal.fire({
                    ...swalBase,
                    icon: 'warning',
                    title: 'Limit Reached',
                    text: result.message
                  });
                } else {
                  Swal.fire({
                    ...swalBase,
                    icon: 'error',
                    title: 'Oops...',
                    text: result.message || 'Failed to add to cart'
                  });
                }
              }
            } catch (error) {
              console.error("Add to Cart Error:", error);
              btn.disabled = false;
              btn.innerHTML = '<i class="bi bi-cart-plus"></i>';
            }
          }

          async function toggleWishlistListing(btn, productId) {
            try {
              const response = await fetch('/wishlist/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
              });

              if (response.status === 401) {
                return Swal.fire({
                  background: '#141416',
                  color: '#eaeaea',
                  confirmButtonColor: '#4f6ef7',
                  icon: 'warning',
                  title: 'Sign In Required',
                  text: 'Please log in to add items to your wishlist.',
                  confirmButtonText: 'Sign In',
                  showCancelButton: true
                }).then(r => { if (r.isConfirmed) window.location.href = '/signin'; });
              }

              const data = await response.json();
              if (data.success) {
                const icon = btn.querySelector('i');

                const badge = document.getElementById('wishBtn')
                if (data.action === 'added') {
                  icon.className = 'bi bi-heart-fill';
                  if (badge) {
                    badge.innerText = Number(badge.innerText || 0) + 1;
                    badge.style.display = 'flex';
                  }
                  btn.style.color = '#e63946';
                } else {
                  icon.className = 'bi bi-heart';
                  if (badge) {
                    const newCount = Math.max(0, Number(badge.innerText || 0) - 1);
                    badge.innerText = newCount;
                    if (newCount === 0) badge.style.display = 'none';
                  }
                  btn.style.color = 'var(--text-dim)';
                }

                Swal.fire({
                  toast: true, position: 'top-end', icon: 'success',
                  title: data.action === 'added' ? 'Added to wishlist!' : 'Removed from wishlist',
                  showConfirmButton: false, timer: 1500,
                  background: '#1a1d24', color: '#f0f0f2', iconColor: data.action === 'added' ? '#4ade80' : '#e63946'
                })

              }
            } catch (err) {
              console.error("Wishlist Toggle Error:", err);
            }
          }

          async function quickAddToCart(btn, pid, vid, stock) {
            if (Number(stock) <= 0) {
              Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'info',
                title: "out of stock items can't add to cart",
                showConfirmButton: false,
                timer: 3000,
                background: '#1a1d24',
                color: '#f0f0f2',
                iconColor: '#ff9800'
              });
              return;
            }
            if (btn.disabled) return;

            // Check login state
            const isLoggedIn = '<%= typeof user !== "undefined" && !!user %>' === 'true';
            if (!isLoggedIn) {
              return Swal.fire({
                ...swalBase,
                icon: 'info',
                title: 'Sign In Required',
                text: 'Please log in to add items to your cart.',
                confirmButtonText: 'Sign In',
                showCancelButton: true,
                cancelButtonText: 'Do it later'
              }).then(r => {
                if (r.isConfirmed) {
                  btn.disabled = true;
                  btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Loading...';
                  redirectTo(`/signin`);
                }
              });
            }

            const currentInCart = cartQuantities[vid] || 0;
            const maxAllowed = Math.min(MAX_QTY, stock);

            if (currentInCart >= maxAllowed) {
              if (currentInCart >= stock) {
                Swal.fire({
                  ...swalBase,
                  icon: 'warning',
                  title: 'Out of Stock',
                  html: `You already have all <strong>${stock}</strong> available units in your cart.`,
                  confirmButtonText: 'View Cart',
                  showCancelButton: true,
                  cancelButtonText: 'Continue Shopping'
                }).then(r => { if (r.isConfirmed) window.location.href = '/cart'; });
              } else {
                Swal.fire({
                  ...swalBase,
                  icon: 'warning',
                  title: 'Limit Reached',
                  html: `You already have the maximum of <strong>${MAX_QTY}</strong> units in your cart.`,
                  confirmButtonText: 'View Cart',
                  showCancelButton: true,
                  cancelButtonText: 'Continue Shopping'
                }).then(r => { if (r.isConfirmed) window.location.href = '/cart'; });
              }
              return;
            }

            // Loading state
            const originalContent = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i>';

            try {
              const res = await fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: pid, variantId: vid, quantity: 1 })
              });

              const data = await res.json();
              btn.disabled = false;
              btn.innerHTML = originalContent;

              if (data.requiresAuth || data.redirect) {
                redirectTo(`/signin?returnTo=${encodeURIComponent(window.location.pathname + window.location.search)}`);
                return;
              }

              if (!data.success) {
                Swal.fire({
                  ...swalBase,
                  icon: 'error',
                  title: 'Error',
                  text: data.message || 'Could not add to cart.'
                });
                return;
              }

              // Update local state
              cartQuantities[vid] = data.newQty;
              if (data.newQty >= maxAllowed) markMaxed(btn);

              // Update navbar
              const badge = document.querySelector('.cart-badge');
              if (badge && data.cartCount !== undefined) {
                badge.textContent = data.cartCount;
                badge.style.display = data.cartCount > 0 ? 'flex' : 'none';
              }

              // Success feedback
              const remaining = maxAllowed - data.newQty;
              showLimitSwal(remaining, stock);

            } catch (err) {
              btn.disabled = false;
              btn.innerHTML = originalContent;
              console.error('Quick Add Error:', err);
              Swal.fire({ ...swalBase, icon: 'error', title: 'Error', text: 'Something went wrong.' });
            }
          }

        </script>

        <!-- ═══ PRODUCT PAGE EXPLOSION + REASSEMBLY ANIMATION ENGINE ═══
             Scope: .products-animation-scope only.
             No global CSS touched. No EJS modified. No libraries.
             12-fragment grid explosion, soft scatter, smooth reassembly.
        ═══════════════════════════════════════════════════════════════ -->
        <script>
          (function () {
            'use strict';

            /* ── Config ── */
            const COLS = 4;    // fragment columns
            const ROWS = 3;    // fragment rows  → 12 pieces total
            const SCATTER_PX = 42;   // max scatter distance in px
            const EXPLODE_MS = 180;  // delay before explosion starts (card visible first)
            const REASSEM_MS = 2200; // delay before reassembly starts
            const REMOVE_MS = 2900; // delay before overlay removed
            const STAGGER_CARD = 90;   // ms between each card's animation
            const isMobile = window.innerWidth <= 768;
            const prefersRed = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            /* ── Scatter vectors: 12 pieces get pseudo-random directions ── */
            const SCATTER_DIRS = [
              [-1.2, -1.4], [0, -1.6], [0.8, -1.4], [1.4, -1.2],
              [-1.6, -0.2], [0.3, -0.5], [-0.3, 0.4], [1.6, 0.3],
              [-1.3, 1.2], [-0.2, 1.5], [0.9, 1.3], [1.3, 1.1]
            ];

            /* =================================================================
               ZYROX — Product Listing Page: Modern Animation Engine
               Flow: Staggered Zoom-In → Subtle Swing → Interactive Hover
               ================================================================= */
            /* =================================================================
               ZYROX — Product Listing Page: Modern Animation Engine
               Flow: Staggered Zoom-In → Subtle Swing → Interactive Hover
               ================================================================= */
            (function () {
              const CONFIG = {
                INITIAL_DELAY: 100,   // Reduced delay for faster visibility
                STAGGER_DELAY: 70,    // Faster stagger
                OBSERVER_THRESH: 0.01,
              };

              function startAnimations(cards) {
                if (!cards || !cards.length) return;

                // Step 1: Force hide them just before starting the stagger
                // This prevents the "blank screen" if JS fails earlier
                cards.forEach(card => {
                  card.style.opacity = '0';
                  card.style.transform = 'scale(0)';
                });

                // Step 2: Staggered reveal
                setTimeout(() => {
                  cards.forEach((card, index) => {
                    setTimeout(() => {
                      card.classList.add('animate-in');
                      card.style.opacity = ''; // Let CSS take over
                      card.style.transform = '';
                    }, index * CONFIG.STAGGER_DELAY);
                  });
                }, CONFIG.INITIAL_DELAY);
              }

              function initProductPageAnimations() {
                const scope = document.querySelector('.product-page-animation');
                if (!scope) return;

                const cards = scope.querySelectorAll('.product-card');
                if (!cards.length) return;

                // Mark as found but don't hide yet
                let hasStarted = false;

                const observer = new IntersectionObserver((entries) => {
                  entries.forEach(entry => {
                    if (entry.isIntersecting && !hasStarted) {
                      hasStarted = true;
                      observer.disconnect();
                      startAnimations(cards);
                    }
                  });
                }, {
                  threshold: CONFIG.OBSERVER_THRESH,
                  rootMargin: '150px'
                });

                observer.observe(scope);

                // Safety Fallback: Ensure visibility after 1s
                setTimeout(() => {
                  if (!hasStarted) {
                    hasStarted = true;
                    observer.disconnect();
                    startAnimations(cards);
                  }
                }, 1000);

                // Cursor-based tilt
                if (window.innerWidth > 1024) {
                  cards.forEach(card => {
                    card.addEventListener('mousemove', (e) => {
                      if (!card.classList.contains('animate-in')) return;
                      const rect = card.getBoundingClientRect();
                      const x = e.clientX - rect.left;
                      const y = e.clientY - rect.top;
                      const xPercent = (x / rect.width - 0.5) * 8;
                      const yPercent = (y / rect.height - 0.5) * -8;
                      card.style.transform = `translateY(-8px) scale(1.04) rotateY(${xPercent}deg) rotateX(${yPercent}deg)`;
                    });
                    card.addEventListener('mouseleave', () => {
                      card.style.transform = '';
                    });
                  });
                }
              }

              // Run immediately or on DOMContentLoaded
              if (document.readyState === 'complete' || document.readyState === 'interactive') {
                initProductPageAnimations();
              } else {
                document.addEventListener('DOMContentLoaded', initProductPageAnimations);
              }
            })();
        </script>
