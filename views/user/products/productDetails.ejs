        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
        <script>
            /* ── GALLERY & ZOOM ── */
            const mainImgWrap = document.getElementById('mainImgWrap');
            const mainImg = document.getElementById('mainImg');
            const lens = document.getElementById('zoomLens');
            const result = document.getElementById('zoomResult');

            function setMainImg(src, thumbEl) {
                mainImg.src = src;
                document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
                if (thumbEl) thumbEl.classList.add('active');
                // Update zoom background
                result.style.backgroundImage = `url('${src}')`;
            }

            // Initialize Zoom
            function initZoom() {
                if (window.innerWidth < 992) return; // Disable zoom on mobile

                mainImgWrap.addEventListener('mousemove', moveLens);
                mainImgWrap.addEventListener('mouseenter', () => {
                    lens.style.display = 'block';
                    result.style.display = 'block';
                    result.style.backgroundImage = `url('${mainImg.src}')`;
                });
                mainImgWrap.addEventListener('mouseleave', () => {
                    lens.style.display = 'none';
                    result.style.display = 'none';
                });

                function moveLens(e) {
                    const rect = mainImgWrap.getBoundingClientRect();
                    let x = e.pageX - rect.left - window.scrollX;
                    let y = e.pageY - rect.top - window.scrollY;

                    // Keep lens inside bounds
                    const lensW = lens.offsetWidth;
                    const lensH = lens.offsetHeight;

                    x = Math.max(0, Math.min(x - lensW / 2, rect.width - lensW));
                    y = Math.max(0, Math.min(y - lensH / 2, rect.height - lensH));

                    lens.style.left = x + 'px';
                    lens.style.top = y + 'px';

                    // Calculate ratios
                    const cx = result.offsetWidth / lensW;
                    const cy = result.offsetHeight / lensH;

                    result.style.backgroundSize = (rect.width * cx) + 'px ' + (rect.height * cy) + 'px';
                    result.style.backgroundPosition = `-${x * cx}px -${y * cy}px`;
                }
            }

            initZoom();
            window.addEventListener('resize', initZoom);

            /* ── QUANTITY ── */
            const MAX_QTY = <%= variant.stock || 0 %>;
            function changeQty(delta) {
                const inp = document.getElementById('qtyVal');
                if (!inp) return;
                let v = parseInt(inp.value) + delta;
                v = Math.max(1, Math.min(v, MAX_QTY));
                inp.value = v;
                document.getElementById('qtyMinus').disabled = v <= 1;
                document.getElementById('qtyPlus').disabled = v >= MAX_QTY;
            }

            /* ── ADD TO CART ── */
            function addToCart(productId, variantId) {
                const qty = parseInt(document.getElementById('qtyVal')?.value || 1);
                fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, variantId, quantity: qty })
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.requiresAuth || data.redirect) { window.location.href = '/signin'; return; }
                        if (!data.success) {
                            Swal.fire({
                                icon: 'error', title: 'Error', text: data.message || 'Something went wrong',
                                background: '#141416', color: '#eaeaea'
                            });
                            return;
                        }
                        const badge = document.querySelector('.cart-badge');
                        if (badge && data.cartCount !== undefined) badge.textContent = data.cartCount;
                        Swal.fire({
                            toast: true, position: 'top-end', icon: 'success',
                            title: 'Added to cart!', showConfirmButton: false, timer: 1800,
                            background: '#141416', color: '#eaeaea', iconColor: '#00d4a0'
                        });
                    })
                    .catch(() => { window.location.href = '/signin'; });
            }

            /* ── BUY NOW ── */
            function buyNow(productId, variantId) {
                const qty = parseInt(document.getElementById('qtyVal')?.value || 1);
                fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, variantId, quantity: qty })
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.requiresAuth || data.redirect) { window.location.href = '/signin'; return; }
                        if (!data.success) {
                            Swal.fire({
                                icon: 'error', title: 'Error', text: data.message || 'Something went wrong',
                                background: '#141416', color: '#eaeaea'
                            });
                            return;
                        }
                        window.location.href = '/cart';
                    })
                    .catch(() => { window.location.href = '/signin'; });
            }
        </script>
</body>

</html>