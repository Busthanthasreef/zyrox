<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= variant.productId.productName %> — Zyrox
    </title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=3">
    <meta name="description" content="<%= variant.productId.description %>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .bi-spin {
            display: inline-block;
            animation: bi-spin 1s linear infinite;
        }
        @keyframes bi-spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>

    <style>
        /* ── Design Tokens ────────────────────────────────────────── */
        :root {
            --bg: #0b0c0e;
            --bg-card: #141416;
            --bg-raised: #1c1c1f;
            --accentt: #6366f1;
            --accent: #4f6ef7;
            --accent-lt: rgba(99, 102, 241, .15);
            --accent-glow: rgba(99, 102, 241, .25);
            --green: #10b981;
            --green-lt: rgba(16, 185, 129, .12);
            --red: #ef4444;
            --red-lt: rgba(239, 68, 68, .1);
            --amber: #f59e0b;
            --amber-lt: rgba(245, 158, 11, .12);
            --text: #f1f5f9;
            --text-dim: #94a3b8;
            --muted: #475569;
            --border: rgba(255, 255, 255, .06);
            --border-hi: rgba(255, 255, 255, .12);
            --radius-sm: 8px;
            --radius: 12px;
            --radius-lg: 20px;
            --navbar-h: 70px;
            --trans: all .25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--bg);
            font-family: 'Inter', sans-serif;
            color: var(--text);
            margin-top: var(--navbar-h);
            -webkit-font-smoothing: antialiased;
        }

        /* ── Breadcrumb ───────────────────────────────────────────── */
        .breadcrumb-bar {
            height: 38px;
            background: rgba(255, 255, 255, .025);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
        }

        .breadcrumb-bar .container {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: .7rem;
            color: var(--muted);
        }

        .breadcrumb-bar a {
            color: var(--muted);
            text-decoration: none;
            transition: color .2s;
        }

        .breadcrumb-bar a:hover {
            color: var(--accent);
        }

        .breadcrumb-bar .sep {
            font-size: .5rem;
            opacity: .5;
        }

        .breadcrumb-bar .current {
            color: var(--text-dim);
        }

        /* ── Page Layout ──────────────────────────────────────────── */
        .pd-wrap {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
            gap: 48px;
            padding: 40px 0 60px;
        }

        /* ═══════════════════════════════════════════════════════════
           GALLERY
        ═══════════════════════════════════════════════════════════ */
        .gallery {
            position: sticky;
            top: calc(var(--navbar-h) + 20px);
            display: flex;
            flex-direction: column;
            gap: 14px;
            align-self: start;
        }

        .gallery-main {
            position: relative;
            aspect-ratio: 1 / 1;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            cursor: crosshair;
            user-select: none;
        }

        .gallery-main::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, transparent 60%, var(--accent-lt));
            pointer-events: none;
        }

        #mainImg {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 28px;
            pointer-events: none;
            transition: transform 0.3s ease;
            transform-origin: 50% 50%;
            display: block;
            border-radius: 16px;
        }

        .zoom-hint {
            position: absolute;
            bottom: 12px;
            right: 14px;
            font-size: .6rem;
            color: var(--muted);
            background: rgba(0, 0, 0, .5);
            padding: 4px 9px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 5px;
            pointer-events: none;
            opacity: 1;
            transition: opacity .3s;
            z-index: 10;
            backdrop-filter: blur(6px);
        }

        .stock-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: .55rem;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 12px;
            text-transform: uppercase;
            letter-spacing: .3px;
        }

        .badge-in-stock {
            background-color: #50ff4d4d;
            color: #09ff1a;
            border: 1px solid rgba(9, 255, 26, 0.2);
        }

        .badge-out-stock {
            background-color: #ff494978;
            color: red;
            border: 1px solid rgba(255, 73, 73, 0.3);
        }

        .badge-low-stock {
            background-color: rgba(255, 166, 0, 0.386);
            color: orange;
            border: 1px solid rgba(255, 166, 0, 0.4);
        }

        .gallery-main:hover .zoom-hint {
            opacity: 0;
        }

        /* ── Thumbnails ─────────────────────────────────────────── */
        .gallery-thumbs {
            display: flex;
            gap: 10px;
            overflow-x: auto;
            padding-bottom: 4px;
        }

        .gallery-thumbs::-webkit-scrollbar { height: 3px; }
        .gallery-thumbs::-webkit-scrollbar-track { background: transparent; }
        .gallery-thumbs::-webkit-scrollbar-thumb { background: var(--border-hi); border-radius: 3px; }

        .thumb {
            flex-shrink: 0;
            width: 72px;
            height: 72px;
            border-radius: 12px;
            border: 2px solid transparent;
            background: var(--bg-card);
            overflow: hidden;
            cursor: pointer;
            transition: var(--trans);
            position: relative;
        }

        .thumb::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 10px;
            transition: background .2s;
        }

        .thumb:hover::after { background: var(--accent-lt); }

        .thumb img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 7px;
            pointer-events: none;
            transition: transform .25s;
            border-radius: 8px;
        }

        .thumb:hover img { transform: scale(1.06); }

        .thumb.active {
            border-color: var(--accentt);
            box-shadow: 0 0 0 1px var(--accent-glow);
        }

        .thumb.active img { transform: scale(1.04); }

        /* ── Fullscreen Overlay ─────────────────────────────────── */
        .fs-overlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0, 0, 0, .94);
            align-items: center;
            justify-content: center;
            cursor: zoom-out;
            backdrop-filter: blur(4px);
        }

        .fs-overlay.open { display: flex; }

        .fs-overlay img {
            max-width: 88vw;
            max-height: 88vh;
            object-fit: contain;
            border-radius: var(--radius);
            box-shadow: 0 0 80px var(--accent-glow);
            animation: fsIn .25s ease;
        }

        @keyframes fsIn {
            from { opacity: 0; transform: scale(.93); }
            to   { opacity: 1; transform: scale(1); }
        }

        .fs-close {
            position: absolute;
            top: 20px;
            right: 24px;
            background: rgba(255, 255, 255, .06);
            border: 1px solid rgba(255, 255, 255, .1);
            color: #fff;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            font-size: 1.1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--trans);
        }

        .fs-close:hover { background: rgba(255, 255, 255, .14); }

        .fs-counter {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: .72rem;
            color: var(--muted);
            background: rgba(0, 0, 0, .5);
            padding: 5px 14px;
            border-radius: 20px;
            pointer-events: none;
        }

        /* ═══════════════════════════════════════════════════════════
           PRODUCT INFO
        ═══════════════════════════════════════════════════════════ */
        .pd-info {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .pd-brand {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--accentt);
            text-transform: uppercase;
        }

        .pd-name {
            font-size: 1.65rem;
            font-weight: 800;
            line-height: 1.2;
            color: var(--text);
            margin-top: 5px;
        }

        .pd-price {
            display: flex;
            flex-direction: column;
            gap: 2px;
            align-items: flex-start;
        }

        .price-main {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--green);
            letter-spacing: -.5px;
            line-height: 1.1;
        }

        .price-old {
            font-size: 1.1rem;
            color: var(--text-dim);
            text-decoration: line-through;
            opacity: 0.8;
            font-weight: 500;
        }

        .price-save {
            font-size: .75rem;
            font-weight: 700;
            padding: 4px 12px;
            background: var(--green-lt);
            color: var(--green);
            border-radius: 20px;
            border: 1px solid rgba(16, 185, 129, .2);
        }

        .price-row-current {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .offer-amount-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: .75rem;
            font-weight: 700;
            padding: 6px 14px;
            background: var(--accent-lt);
            color: var(--accentt);
            border-radius: 8px;
            border: 1px solid var(--accent-glow);
            margin-bottom: 12px;
            backdrop-filter: blur(4px);
        }

        .stock-row {
            margin-top: -8px;
            display: flex;
            align-items: center;
        }

        .stock-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: .75rem;
            font-weight: 600;
            padding: 5px 12px;
            border-radius: 20px;
        }

        .pd-divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 8px 0;
        }

        /* ── Variant Selector ──────────────────────────────────── */
        .variant-block { display: flex; flex-direction: column; gap: 24px; }

        .variant-section-title {
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            color: var(--muted);
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .variant-row { display: flex; flex-wrap: wrap; gap: 8px; }

        .v-chip {
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--border-hi);
            background: var(--bg-card);
            color: var(--text-dim);
            font-size: .8rem;
            font-family: 'Inter', sans-serif;
            font-weight: 500;
            cursor: pointer;
            transition: var(--trans);
            line-height: 1;
        }

        .v-chip:hover:not(.v-disabled) {
            border-color: var(--accent);
            color: var(--accentt);
            background: var(--accent-lt);
        }

        .v-chip.v-selected {
            border-color: var(--accentt);
            background: var(--accent-lt);
            color: var(--accentt);
            font-weight: 700;
            box-shadow: 0 0 0 1px var(--accent-glow);
        }

        .v-chip.v-disabled {
            opacity: .3;
            cursor: not-allowed;
            text-decoration: line-through;
            pointer-events: none;
        }

        .v-color-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            padding: 7px 12px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--border-hi);
            background: var(--bg-card);
            transition: var(--trans);
            font-size: .8rem;
            font-family: 'Inter', sans-serif;
            color: var(--text-dim);
        }

        .v-color-wrap:hover:not(.v-disabled) {
            border-color: var(--accentt);
            color: var(--accentt);
        }

        .v-color-wrap.v-selected {
            border-color: var(--accentt);
            background: var(--accent-lt);
            color: var(--text);
            font-weight: 600;
            box-shadow: 0 0 0 1px var(--accent-glow);
        }

        .v-color-wrap.v-disabled {
            opacity: .3;
            cursor: not-allowed;
            pointer-events: none;
            text-decoration: line-through;
        }

        .color-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: 1.5px solid rgba(255, 255, 255, .2);
            flex-shrink: 0;
        }

        .variant-msg {
            display: none;
            align-items: center;
            gap: 10px;
            padding: 11px 15px;
            border-radius: var(--radius-sm);
            font-size: .82rem;
            line-height: 1.4;
            margin-top: 4px;
        }

        .variant-msg.show { display: flex; }

        .variant-msg.msg-unavail {
            background: var(--red-lt);
            border: 1px solid rgba(230, 57, 70, .22);
            color: var(--red);
        }

        .variant-msg.msg-stock {
            background: var(--amber-lt);
            border: 1px solid rgba(245, 158, 11, .25);
            color: var(--amber);
        }

        /* ── Action Sections ────────────────────────────────────── */
        .pd-price-stack { display: flex; flex-direction: column; gap: 16px; }
        .offer-row { display: flex; align-items: center; }
        .pd-purchase-section { display: flex; flex-direction: column; gap: 16px; margin-top: 20px; }
        .qty-selection-row { display: flex; align-items: center; gap: 16px; }

        /* ── Quantity ──────────────────────────────────────────── */
        .qty-row { display: flex; align-items: center; gap: 16px; }

        .qty-label {
            font-size: .72rem;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            width: 60px;
        }

        .qty-ctrl {
            display: flex;
            align-items: center;
            border: 1.5px solid var(--border-hi);
            border-radius: var(--radius-sm);
            overflow: hidden;
            background: var(--bg-card);
        }

        .qty-btn {
            background: transparent;
            border: none;
            border-radius: 0;
            color: var(--text);
            width: 36px;
            height: 36px;
            cursor: pointer;
            transition: background .15s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .78rem;
        }

        .qty-btn:hover:not(:disabled) { background: var(--border-hi); }
        .qty-btn:disabled { opacity: .3; cursor: not-allowed; }

        .qty-val {
            width: 44px;
            text-align: center;
            font-size: .95rem;
            font-weight: 700;
            background: transparent;
            border: none;
            border-left: 1px solid var(--border-hi);
            border-right: 1px solid var(--border-hi);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            padding: 0;
            height: 36px;
        }

        /* ── Action Buttons ────────────────────────────────────── */
        .action-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .btn-cart,
        .btn-buy {
            height: 52px;
            border-radius: var(--radius-sm);
            font-size: .88rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--trans);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            font-family: 'Inter', sans-serif;
            letter-spacing: .2px;
        }

        .btn-cart {
            border: 1.5px solid var(--accentt);
            background: transparent;
            color: var(--accentt);
        }

        .btn-cart:hover:not(:disabled) {
            background: var(--accent-lt);
            box-shadow: 0 0 20px var(--accent-glow);
        }

        .btn-buy {
            border: none;
            background: var(--accentt);
            color: #fff;
        }

        .btn-buy:hover:not(:disabled) {
            background: #4f46e5;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px var(--accent-glow);
        }

        .btn-cart:disabled,
        .btn-buy:disabled {
            opacity: .3;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-cart:active:not(:disabled) { transform: scale(.98); }
        .btn-buy:active:not(:disabled)  { transform: translateY(0) scale(.98); }

        .btn-wishlist {
            width: 100%;
            height: 52px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--border-hi);
            background: var(--bg-card);
            color: var(--text-dim);
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
        }

        .btn-wishlist:hover {
            background: var(--bg-raised);
            border-color: var(--border-hi);
        }

        .btn-wishlist.active i   { color: var(--red); }
        .btn-wishlist.active span { color: var(--red); opacity: 0.9; }

        /* ── Trust Badges ──────────────────────────────────────── */
        .trust-row {
            display: flex;
            gap: 0;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
        }

        .trust-item {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 12px 14px;
            border-right: 1px solid var(--border);
        }

        .trust-item:last-child { border-right: none; }

        .trust-item i {
            font-size: 1.1rem;
            color: var(--accentt);
            flex-shrink: 0;
        }

        .trust-item-text { display: flex; flex-direction: column; }

        .trust-item-text strong {
            font-size: .75rem;
            font-weight: 600;
            color: var(--text);
        }

        .trust-item-text span {
            font-size: .62rem;
            color: var(--muted);
        }

        /* ═══════════════════════════════════════════════════════════
           PRODUCT SECTIONS
        ═══════════════════════════════════════════════════════════ */
        .pd-section {
            border-top: 1px solid var(--border);
            padding-top: 36px;
            margin-top: 36px;
        }

        .section-title {
            font-size: .65rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 16px;
            display: block;
        }

        .pd-desc-text {
            font-size: .93rem;
            line-height: 1.78;
            color: var(--text-dim);
        }

        .specs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(145px, 1fr));
            gap: 10px;
        }

        .spec-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 14px;
            transition: border-color .2s;
        }

        .spec-card:hover { border-color: var(--border-hi); }

        .spec-lbl {
            font-size: .58rem;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .spec-val {
            font-size: .88rem;
            font-weight: 600;
            color: var(--text);
        }

        /* ── Related Products ───────────────────────────────────── */
        .related-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 18px;
            margin-top: 18px;
        }

        .related-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            transition: var(--trans);
            text-decoration: none;
            display: flex;
            flex-direction: column;
        }

        .related-card:hover {
            border-color: var(--accentt);
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0, 0, 0, .4);
        }

        .related-img {
            aspect-ratio: 1/1;
            padding: 14px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .related-img img { width: 100%; height: 100%; object-fit: contain; }

        .related-info {
            padding: 14px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .related-name {
            font-size: .85rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 6px;
            flex: 1;
            line-height: 1.4;
        }

        .related-price {
            font-size: .95rem;
            font-weight: 700;
            color: var(--green);
        }

        .related-old {
            font-size: .75rem;
            color: var(--muted);
            text-decoration: line-through;
            margin-left: 6px;
        }

        /* ── Responsive ─────────────────────────────────────────── */
        @media (max-width: 992px) {
            .pd-wrap {
                grid-template-columns: 1fr;
                padding: 20px 0 40px;
                gap: 32px;
            }

            .gallery { position: static; }

            .related-grid { grid-template-columns: repeat(2, 1fr); }

            .trust-row { flex-wrap: wrap; }

            .trust-item {
                flex: none;
                width: 50%;
                border-bottom: 1px solid var(--border);
            }

            .trust-item:nth-child(2) { border-right: none; }

            .trust-item:last-child {
                border-bottom: none;
                width: 100%;
            }
        }

        @media (max-width: 576px) {
            .action-row { grid-template-columns: 1fr; }
            .pd-name { font-size: 1.4rem; }
        }
    </style>
</head>

<body>

    <%- include('../../partials/user/navigationbar', { user, cartItemCount, currentPage: 'products', categories }) %>

    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
        <div class="container">
            <a href="/">Home</a>
            <i class="bi bi-chevron-right sep"></i>
            <a href="/products">Products</a>
            <i class="bi bi-chevron-right sep"></i>
            <% if (variant.productId.categoryId) { %>
                <a href="/products?category=<%= encodeURIComponent(variant.productId.categoryId.categoryName) %>">
                    <%= variant.productId.categoryId.categoryName %>
                </a>
                <i class="fas fa-chevron-right sep"></i>
            <% } %>
            <span class="current"><%= variant.productId.productName %></span>
        </div>
    </div>

    <main class="container">
        <div class="pd-wrap">

            <!-- ═══════════════════════════════════════════════════
                 LEFT — GALLERY
            ═══════════════════════════════════════════════════════ -->
            <section class="gallery">
                <% const images = (variant.images && variant.images.length > 0 && variant.IsActive !== false)
                    ? variant.images
                    : ['/images/placeholder.png']; %>

                <div class="gallery-main" id="mainImgWrap" role="img"
                    aria-label="<%= variant.productId.productName %> — main image">
                    <img id="mainImg" src="<%= images[0] %>" alt="<%= variant.productId.productName %>"
                        title="Hover to zoom · Click to fullscreen">
                    <span class="zoom-hint">
                        <i class="bi bi-zoom-in"></i> Hover to zoom
                    </span>
                </div>

                <div class="gallery-thumbs">
                    <% images.forEach((img, i) => { %>
                        <div class="thumb <%= i === 0 ? 'active' : '' %>" data-src="<%= img %>"
                            data-idx="<%= i %>" role="button" tabindex="0"
                            aria-label="View image <%= i + 1 %> of <%= images.length %>">
                            <img src="<%= img %>" alt="Product image <%= i + 1 %>">
                        </div>
                    <% }) %>
                </div>
            </section>

            <!-- ═══════════════════════════════════════════════════
                 RIGHT — INFO
            ═══════════════════════════════════════════════════════ -->
            <section class="pd-info">

                <!-- 1. Header -->
                <div class="pd-header-group">
                    <div class="pd-brand">
                        <%= variant.productId.categoryId
                            ? (variant.productId.categoryId.categoryName || 'Zyrox')
                            : 'Zyrox' %>
                    </div>
                    <h1 class="pd-name"><%= variant.productId.productName %></h1>
                </div>

                <hr class="pd-divider">

                <!-- 2. Price & Stock -->
                <div class="pd-price-stack">
                    <% if (variant.bestOffer) { %>
                        <div class="offer-row">
                            <div class="offer-amount-badge">
                                <i class="bi bi-tag"></i> SAVE ₹<%= (variant.price - variant.discountedPrice).toLocaleString('en-IN') %>
                            </div>
                        </div>
                    <% } %>

                    <div class="pd-price" id="priceBlock">
                        <% if (variant.bestOffer && variant.price > variant.discountedPrice) { %>
                            <span class="price-old" id="priceOld">
                                ₹<%= Number(variant.price).toLocaleString('en-IN') %>
                            </span>
                        <% } else { %>
                            <span class="price-old" id="priceOld" style="display:none"></span>
                        <% } %>

                        <div class="price-row-current">
                            <span class="price-main" id="priceMain">
                                ₹<%= variant.discountedPrice
                                    ? Number(variant.discountedPrice).toLocaleString('en-IN')
                                    : Number(variant.price).toLocaleString('en-IN') %>
                            </span>
                            <% if (variant.bestOffer && variant.price > variant.discountedPrice) { %>
                                <% if (variant.bestOffer.discountType === 'flat') { %>
                                    <span class="price-save" id="priceSave">₹<%= (variant.price - variant.discountedPrice).toLocaleString('en-IN') %> OFF</span>
                                <% } else { %>
                                    <% const savings = Math.round(((variant.price - variant.discountedPrice) / variant.price) * 100); %>
                                    <span class="price-save" id="priceSave"><%= savings %>% OFF</span>
                                <% } %>
                            <% } else { %>
                                <span class="price-save" id="priceSave" style="display:none"></span>
                            <% } %>
                        </div>
                    </div>

                    <div class="stock-row" id="stockBlock">
                        <% if (variant.stock > 7) { %>
                            <span class="stock-badge badge-in-stock">
                                <i class="bi bi-check-circle-fill"></i> In Stock
                            </span>
                        <% } else if (variant.stock > 3) { %>
                            <span class="stock-badge badge-low-stock">
                                <i class="bi bi-exclamation-triangle-fill"></i> Only <%= parseInt(variant.stock) %> left
                            </span>
                        <% } else { %>
                            <span class="stock-badge badge-out-stock">
                                <i class="bi bi-x-circle-fill"></i> Out of Stock
                            </span>
                        <% } %>
                    </div>
                </div>

                <hr class="pd-divider">

                <!-- 3. Variant Selectors -->
                <% if (allVariants && allVariants.length > 0) { %>
                    <div class="variant-block" id="variantBlock">
                        <div id="ramSection">
                            <div class="variant-section-title">RAM (GB)</div>
                            <div class="variant-row" id="ramRow"></div>
                        </div>
                        <div id="storageSection">
                            <div class="variant-section-title">Storage (GB)</div>
                            <div class="variant-row" id="storageRow"></div>
                        </div>
                        <div id="colorSection">
                            <div class="variant-section-title">Color</div>
                            <div class="variant-row" id="colorRow"></div>
                        </div>
                        <div class="variant-msg" id="variantMsg">
                            <i class="bi bi-exclamation-circle-fill" style="flex-shrink:0"></i>
                            <span id="variantMsgText"></span>
                        </div>
                    </div>
                <% } %>

                <!-- 4. Purchase Actions -->
                <div class="pd-purchase-section">
                    <div class="qty-selection-row" id="qtyBlock" <%- variant.stock < 1 ? 'style="display:none"' : '' %>>
                        <span class="qty-label">Quantity</span>
                        <div class="qty-ctrl">
                            <button class="qty-btn" id="qtyMinus" onclick="changeQty(-1)" aria-label="Decrease">
                                <i class="bi bi-dash"></i>
                            </button>
                            <input type="text" class="qty-val" id="qtyVal" value="1" readonly>
                            <button class="qty-btn" id="qtyPlus" onclick="changeQty(1)" aria-label="Increase">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                    </div>

                    <div class="action-row">
                        <button type="button" class="btn-cart" id="btnAddToCart"
                            onclick="addToCart()"
                            <%- variant.stock === 0 ? 'disabled' : '' %>
                            data-pid="<%= variant.productId._id %>"
                            data-vid="<%= variant._id %>">
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                        <button type="button" class="btn-buy" id="btnBuyNow"
                            onclick="buyNow()"
                            <%- variant.stock <= 0 ? 'disabled' : '' %>
                            data-pid="<%= variant.productId._id %>"
                            data-vid="<%= variant._id %>">
                            <i class="bi bi-lightning"></i> Buy Now
                        </button>
                    </div>

                    <button class="btn-wishlist <%= isInWishlist ? 'active' : '' %>" id="btnWishlist"
                        onclick="toggleWishlistDetail('<%= variant.productId._id %>')">
                        <i class="bi <%= isInWishlist ? 'bi-heart-fill' : 'bi-heart' %>"></i>
                        <span id="wishlistText">
                            <%= isInWishlist ? 'Remove from Wishlist' : 'Add to Wishlist' %>
                        </span>
                    </button>
                </div>

                <!-- Trust Badges -->
                <div class="trust-row">
                    <div class="trust-item">
                        <i class="bi bi-truck"></i>
                        <div class="trust-item-text">
                            <strong>Fast Delivery</strong>
                            <span>2–4 business days</span>
                        </div>
                    </div>
                    <div class="trust-item">
                        <i class="bi bi-shield-check"></i>
                        <div class="trust-item-text">
                            <strong>Secure Payment</strong>
                            <span>SSL encrypted</span>
                        </div>
                    </div>
                    <div class="trust-item">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        <div class="trust-item-text">
                            <strong>Easy Returns</strong>
                            <span>7-day return policy</span>
                        </div>
                    </div>
                </div>

            </section>
        </div>

        <!-- Description -->
        <div class="pd-section">
            <span class="section-title">Product Description</span>
            <div class="pd-desc-text"><%= variant.productId.description %></div>
        </div>

        <!-- Specifications -->
        <div class="pd-section">
            <span class="section-title">Technical Specifications</span>
            <div class="specs-grid">
                <% if (variant.processor) { %>
                    <div class="spec-card">
                        <div class="spec-lbl">Processor</div>
                        <div class="spec-val"><%= variant.processor %></div>
                    </div>
                <% } %>
                <% if (variant.RAM) { %>
                    <div class="spec-card">
                        <div class="spec-lbl">Memory (RAM)</div>
                        <div class="spec-val"><%= parseInt(variant.RAM, 10) %> GB</div>
                    </div>
                <% } %>
                <% if (variant.storage) { %>
                    <div class="spec-card">
                        <div class="spec-lbl">Internal Storage</div>
                        <div class="spec-val"><%= parseInt(variant.storage, 10) %> GB</div>
                    </div>
                <% } %>
                <% if (variant.color) { %>
                    <div class="spec-card">
                        <div class="spec-lbl">Color</div>
                        <div class="spec-val"><%= variant.color %></div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Related Products -->
        <div class="pd-section" style="margin-bottom: 64px;">
            <h4 style="font-family:'Inter',sans-serif;font-weight:800;font-size:1.2rem;margin-bottom:4px;">
                You May Also Like
            </h4>
            <span class="section-title">Related Products</span>

            <% if (relatedProducts && relatedProducts.length > 0) { %>
                <div class="related-grid">
                    <% relatedProducts.forEach(product => { %>
                        <a href="/product/<%= product._id %>?variant=<%= product.displayVariant._id %>"
                            class="related-card">
                            <div class="related-img">
                                <img src="<%= product.displayVariant.images[0] || '/images/placeholder.png' %>"
                                    alt="<%= product.productName %>" loading="lazy">
                            </div>
                            <div class="related-info">
                                <div class="related-name"><%= product.productName %></div>
                                <div style="display:flex;align-items:baseline;gap:4px;">
                                    <span class="related-price">
                                        ₹<%= Number(product.displayVariant.discountedPrice || product.displayVariant.price).toLocaleString('en-IN') %>
                                    </span>
                                    <% if (product.displayVariant.bestOffer && product.displayVariant.price > product.displayVariant.discountedPrice) { %>
                                        <span class="related-old">
                                            ₹<%= Number(product.displayVariant.price).toLocaleString('en-IN') %>
                                        </span>
                                    <% } %>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            <% } else { %>
                <div style="margin-top:16px;padding:32px;border:1px dashed var(--border);border-radius:var(--radius);text-align:center;color:var(--muted);">
                    <i class="bi bi-box-seam" style="font-size:1.6rem;opacity:.4;display:block;margin-bottom:8px;"></i>
                    No related products available right now.
                </div>
            <% } %>
        </div>

    </main>

    <!-- Fullscreen Overlay -->
    <div class="fs-overlay" id="fsOverlay" role="dialog" aria-modal="true" aria-label="Full size image">
        <button class="fs-close" id="fsClose" aria-label="Close"><i class="bi bi-x"></i></button>
        <img id="fsImg" src="" alt="">
        <div class="fs-counter" id="fsCounter"></div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

    <!-- ═══════════════════════════════════════════════════════════
         SECURE DATA INJECTION — server data via JSON script tags
    ═══════════════════════════════════════════════════════════════ -->
    <script id="__data_variants__" type="application/json"><%- JSON.stringify(
        (allVariants || []).map(v => ({
            _id:       String(v._id),
            productId: String(v.productId && v.productId._id ? v.productId._id : v.productId),
            RAM:       v.RAM     != null ? Number(v.RAM)     : null,
            storage:   v.storage != null ? Number(v.storage) : null,
            color:     v.color   || null,
            price:     v.discountedPrice ? Number(v.discountedPrice) : Number(v.price) || 0,
            oldPrice:  (v.bestOffer && v.price > v.discountedPrice) ? Number(v.price) : null,
            stock:     Number(v.stock)   || 0,
            images:    Array.isArray(v.images) ? v.images : [],
            IsActive:  v.IsActive !== false
        }))
    ).replace(/<\/script>/gi, '<\\/script>') %></script>

    <script id="__data_currentVid__"   type="application/json">"<%- String(variant._id).replace(/"/g, '') %>"</script>
    <script id="__data_cartQty__"      type="application/json"><%= parseInt((cartQuantityMap || {})[String(variant._id)] || 0, 10) %></script>
    <script id="__data_stockQty__"     type="application/json"><%= parseInt(variant.stock || 0, 10) %></script>
    <script id="__data_maxCartQty__"   type="application/json"><%= parseInt(MAX_CART_QTY, 10) %></script>
    <script id="__data_isLoggedIn__"   type="application/json"><%= typeof user !== 'undefined' && !!user %></script>

    <script>
    /* ═══════════════════════════════════════════════════════════════
       BOOT — parse safe server data
    ═══════════════════════════════════════════════════════════════ */
    const ALL_VARIANTS  = JSON.parse(document.getElementById('__data_variants__').textContent);
    const CURRENT_VID   = JSON.parse(document.getElementById('__data_currentVid__').textContent);
    const MAX_CART_QTY  = JSON.parse(document.getElementById('__data_maxCartQty__').textContent);
    const IS_LOGGED_IN  = JSON.parse(document.getElementById('__data_isLoggedIn__').textContent);

    // alreadyInCart = units of the CURRENT variant already in cart (from SSR)
    let alreadyInCart = JSON.parse(document.getElementById('__data_cartQty__').textContent) || 0;

    // Active selection state
    let selRAM     = null;
    let selStorage = null;
    let selColor   = null;

    // Current resolved variant id
    let currentVariantId = CURRENT_VID;

    // Init selection from current variant
    const initVariant = ALL_VARIANTS.find(v => v._id === CURRENT_VID);
    if (initVariant) {
        selRAM     = initVariant.RAM;
        selStorage = initVariant.storage;
        selColor   = initVariant.color;
    }

    /* ═══════════════════════════════════════════════════════════════
       GALLERY
    ═══════════════════════════════════════════════════════════════ */
    const mainImgWrap = document.getElementById('mainImgWrap');
    const mainImg     = document.getElementById('mainImg');
    const fsOverlay   = document.getElementById('fsOverlay');
    const fsImg       = document.getElementById('fsImg');
    const fsCounter   = document.getElementById('fsCounter');
    const fsClose     = document.getElementById('fsClose');

    let thumbEls      = [...document.querySelectorAll('.thumb')];
    let currentImgIdx = 0;
    let allImages     = thumbEls.map(t => t.dataset.src);

    function setMainImage(src, idx) {
        mainImg.style.transition = 'opacity 0.12s ease';
        mainImg.style.opacity    = '0';
        setTimeout(() => {
            mainImg.src          = src;
            mainImg.style.opacity = '1';
        }, 120);

        thumbEls.forEach(t => t.classList.remove('active'));
        if (thumbEls[idx]) thumbEls[idx].classList.add('active');
        currentImgIdx = idx;
    }

    function bindThumbs() {
        thumbEls = [...document.querySelectorAll('.thumb')];
        thumbEls.forEach((t, i) => {
            t.addEventListener('click', () => setMainImage(t.dataset.src, i));
            t.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setMainImage(t.dataset.src, i); }
            });
        });
    }
    bindThumbs();

    /* ── In-place zoom ─────────────────────────────────────────── */
    const ZOOM_SCALE = 2.5;
    let zoomActive   = false;

    mainImgWrap.addEventListener('mouseenter', () => {
        zoomActive = true;
        mainImg.style.transition  = 'transform 0.1s ease';
        mainImg.style.transform   = `scale(${ZOOM_SCALE})`;
    });

    mainImgWrap.addEventListener('mouseleave', () => {
        zoomActive = false;
        mainImg.style.transition    = 'transform 0.3s ease';
        mainImg.style.transform     = 'scale(1)';
        mainImg.style.transformOrigin = '50% 50%';
    });

    mainImgWrap.addEventListener('mousemove', e => {
        if (!zoomActive) return;
        const rect = mainImgWrap.getBoundingClientRect();
        const x    = ((e.clientX - rect.left) / rect.width)  * 100;
        const y    = ((e.clientY - rect.top)  / rect.height) * 100;
        mainImg.style.transformOrigin = `${x}% ${y}%`;
    });

    /* ── Fullscreen ─────────────────────────────────────────────── */
    mainImgWrap.addEventListener('click', () => openFullscreen(currentImgIdx));

    function openFullscreen(idx) {
        fsImg.src          = allImages[idx] || mainImg.src;
        fsImg.alt          = mainImg.alt;
        fsCounter.textContent = allImages.length > 1 ? `${idx + 1} / ${allImages.length}` : '';
        fsOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeFullscreen() {
        fsOverlay.classList.remove('open');
        document.body.style.overflow = '';
    }

    fsClose.addEventListener('click', closeFullscreen);
    fsOverlay.addEventListener('click', e => { if (e.target === fsOverlay) closeFullscreen(); });
    document.addEventListener('keydown', e => {
        if (!fsOverlay.classList.contains('open')) return;
        if (e.key === 'Escape')      closeFullscreen();
        if (e.key === 'ArrowRight')  openFullscreen((currentImgIdx + 1) % allImages.length);
        if (e.key === 'ArrowLeft')   openFullscreen((currentImgIdx - 1 + allImages.length) % allImages.length);
    });

    /* ═══════════════════════════════════════════════════════════════
       COLOR HELPERS
    ═══════════════════════════════════════════════════════════════ */
    const COLOR_MAP = {
        black: '#1a1a1a', white: '#f0f0f0', silver: '#c0c0c0', gold: '#cfb53b',
        blue: '#3a7bd5', red: '#e63946', green: '#2ecc71', yellow: '#f1c40f',
        purple: '#9b59b6', pink: '#e91e8c', orange: '#e67e22', gray: '#7f8c8d',
        grey: '#7f8c8d', midnight: '#1a1a2e', starlight: '#f5f5dc', graphite: '#4b4b4b',
        titanium: '#878681', alpine: '#f0f5f5', pacific: '#006994', coral: '#ff6f61',
        navy: '#003087', rose: '#c5a3a5', deep: '#1c1c3a', space: '#3a3a5c'
    };

    function colorToCss(name) {
        if (!name) return '#888';
        const lower = name.toLowerCase();
        for (const [key, val] of Object.entries(COLOR_MAP)) {
            if (lower.includes(key)) return val;
        }
        return '#888';
    }

    /* ═══════════════════════════════════════════════════════════════
       VARIANT SELECTOR
    ═══════════════════════════════════════════════════════════════ */
    const ramRow       = document.getElementById('ramRow');
    const storageRow   = document.getElementById('storageRow');
    const colorRow     = document.getElementById('colorRow');
    const variantMsg   = document.getElementById('variantMsg');
    const variantMsgText = document.getElementById('variantMsgText');

    function uniqueSorted(arr) {
        return [...new Set(arr.filter(v => v != null))]
            .sort((a, b) => (Number(a) - Number(b)) || String(a).localeCompare(String(b)));
    }

    const allRAMs     = uniqueSorted(ALL_VARIANTS.map(v => v.RAM));
    const allStorages = uniqueSorted(ALL_VARIANTS.map(v => v.storage));
    const allColors   = uniqueSorted(ALL_VARIANTS.map(v => v.color));

    function findVariant(ram, storage, color) {
        return ALL_VARIANTS.find(v =>
            Number(v.RAM)     === Number(ram)     &&
            Number(v.storage) === Number(storage) &&
            v.color           === color
        ) || null;
    }

    function isReachable(key, val) {
        if (key === 'RAM') {
            return ALL_VARIANTS.some(v => Number(v.RAM) === Number(val));
        }
        if (key === 'storage') {
            return ALL_VARIANTS.some(v =>
                Number(v.storage) === Number(val) &&
                (selRAM == null || Number(v.RAM) === Number(selRAM))
            );
        }
        if (key === 'color') {
            return ALL_VARIANTS.some(v =>
                v.color === val &&
                (selRAM     == null || Number(v.RAM)     === Number(selRAM))     &&
                (selStorage == null || Number(v.storage) === Number(selStorage))
            );
        }
        return false;
    }

    function isReachableWith(key, val, ram, storage) {
        if (key === 'storage') {
            return ALL_VARIANTS.some(v =>
                Number(v.storage) === Number(val) &&
                (ram == null || Number(v.RAM) === Number(ram))
            );
        }
        if (key === 'color') {
            return ALL_VARIANTS.some(v =>
                v.color === val &&
                (ram     == null || Number(v.RAM)     === Number(ram))     &&
                (storage == null || Number(v.storage) === Number(storage))
            );
        }
        return false;
    }

    function renderRAM() {
        if (!ramRow) return;
        ramRow.innerHTML = '';
        allRAMs.forEach(ram => {
            const reachable = isReachable('RAM', ram);
            const selected  = selRAM != null && Number(selRAM) === Number(ram);

            const btn = document.createElement('button');
            btn.className   = 'v-chip' + (selected ? ' v-selected' : '') + (!reachable ? ' v-disabled' : '');
            btn.textContent = ram + ' GB';
            btn.dataset.val = ram;
            if (!reachable) { btn.disabled = true; btn.title = 'Not available'; }

            btn.addEventListener('click', () => {
                if (!reachable) return;
                selRAM = Number(ram);
                if (selStorage != null && !isReachableWith('storage', selStorage, selRAM, null)) selStorage = null;
                if (selColor   != null && !isReachableWith('color',   selColor,   selRAM, selStorage)) selColor = null;

                const match = (selRAM && selStorage && selColor) ? findVariant(selRAM, selStorage, selColor) : null;
                if (match) {
                    window.location.href = `/product/${match.productId}?variant=${match._id}`;
                } else {
                    renderAll();
                    resolveVariant();
                }
            });
            ramRow.appendChild(btn);
        });
    }

    function renderStorage() {
        if (!storageRow) return;
        storageRow.innerHTML = '';
        allStorages.forEach(storage => {
            const reachable = isReachable('storage', storage);
            const selected  = selStorage != null && Number(selStorage) === Number(storage);

            const btn = document.createElement('button');
            btn.className   = 'v-chip' + (selected ? ' v-selected' : '') + (!reachable ? ' v-disabled' : '');
            btn.textContent = storage + ' GB';
            btn.dataset.val = storage;
            if (!reachable) { btn.disabled = true; btn.title = 'Not available for selected RAM'; }

            btn.addEventListener('click', () => {
                if (!reachable) return;
                selStorage = Number(storage);
                if (selColor != null && !isReachableWith('color', selColor, selRAM, selStorage)) selColor = null;

                const match = (selRAM && selStorage && selColor) ? findVariant(selRAM, selStorage, selColor) : null;
                if (match) {
                    window.location.href = `/product/${match.productId}?variant=${match._id}`;
                } else {
                    renderAll();
                    resolveVariant();
                }
            });
            storageRow.appendChild(btn);
        });
    }

    function renderColors() {
        if (!colorRow) return;
        colorRow.innerHTML = '';
        allColors.forEach(color => {
            const reachable = isReachable('color', color);
            const selected  = selColor === color;

            const wrap = document.createElement('div');
            wrap.className = 'v-color-wrap' + (selected ? ' v-selected' : '') + (!reachable ? ' v-disabled' : '');
            if (!reachable) wrap.title = 'Not available for selected options';

            const dot = document.createElement('span');
            dot.className      = 'color-dot';
            dot.style.background = colorToCss(color);
            if (['white', 'starlight'].includes(color.toLowerCase())) {
                dot.style.border = '1.5px solid rgba(255,255,255,.4)';
            }

            const label = document.createElement('span');
            label.textContent = color;

            wrap.appendChild(dot);
            wrap.appendChild(label);

            if (reachable) {
                wrap.addEventListener('click', () => {
                    selColor = color;
                    const match = (selRAM && selStorage && selColor) ? findVariant(selRAM, selStorage, selColor) : null;
                    if (match) {
                        window.location.href = `/product/${match.productId}?variant=${match._id}`;
                    } else {
                        renderAll();
                        resolveVariant();
                    }
                });
            }
            colorRow.appendChild(wrap);
        });
    }

    function renderAll() {
        renderRAM();
        renderStorage();
        renderColors();
    }

    /* ── Resolve variant from current selection ────────────────── */
    function resolveVariant() {
        if (!variantMsg) return;
        variantMsg.classList.remove('show', 'msg-unavail', 'msg-stock');

        if (selRAM == null || selStorage == null || selColor == null) return;

        const match = findVariant(selRAM, selStorage, selColor);

        if (!match) {
            variantMsgText.textContent =
                `No product available for ${selRAM} GB RAM · ${selStorage} GB · ${selColor}. ` +
                `Please choose a different combination.`;
            variantMsg.classList.add('show', 'msg-unavail');
            setActionsDisabled(true);
            return;
        }

        if (!match.IsActive) {
            variantMsgText.textContent = 'This product is unavailable.';
            variantMsg.classList.add('show', 'msg-unavail');
            setActionsDisabled(true);

            const sb = document.getElementById('stockBlock');
            if (sb) sb.innerHTML = '';
            const qtyBlock = document.getElementById('qtyBlock');
            if (qtyBlock) qtyBlock.style.display = 'none';

            setMainImage('/images/placeholder.png', 0);
            const thumbsContainer = document.querySelector('.gallery-thumbs');
            if (thumbsContainer) thumbsContainer.innerHTML = '';
            allImages.length = 0;
            allImages.push('/images/placeholder.png');

            updateURL(match);
            currentVariantId = match._id;
            // FIX: don't reset alreadyInCart here — fetch from cartQuantityMap or leave unchanged
            return;
        }

        if (match.stock <= 0) {
            variantMsgText.textContent = 'This variant is currently out of stock. Check back soon.';
            variantMsg.classList.add('show', 'msg-stock');
            setActionsDisabled(true);
            updatePriceUI(match);
            updateStockUI(match);
            const qtyBlock = document.getElementById('qtyBlock');
            if (qtyBlock) qtyBlock.style.display = 'none';
            updateButtonVariant(match);
            updateURL(match);
            currentVariantId = match._id;
            // Reset alreadyInCart to 0 when switching to a new out-of-stock variant
            // (page will reload on next add anyway, so this is safe)
            alreadyInCart = 0;
            return;
        }

        variantMsg.classList.remove('show');
        updatePriceUI(match);
        updateStockUI(match);
        updateButtonVariant(match);
        updateQtyBlock(match);
        updateGalleryImages(match);
        updateURL(match);

        currentVariantId = match._id;
        // FIX: reset to 0 only when switching to a NEW variant (not the initial load variant)
        // On next add success, alreadyInCart is updated from server response
        if (match._id !== CURRENT_VID) {
            alreadyInCart = 0;
        }

        setActionsDisabled(false);
    }

    /* ── UI updaters ───────────────────────────────────────────── */
    function updatePriceUI(v) {
        const priceMain = document.getElementById('priceMain');
        const oldEl     = document.getElementById('priceOld');
        const saveEl    = document.getElementById('priceSave');

        if (priceMain) priceMain.textContent = '₹' + Number(v.price).toLocaleString('en-IN');

        if (v.oldPrice && v.oldPrice > v.price) {
            const pct = Math.round(((v.oldPrice - v.price) / v.oldPrice) * 100);
            if (oldEl)  { oldEl.textContent  = '₹' + Number(v.oldPrice).toLocaleString('en-IN'); oldEl.style.display  = ''; }
            if (saveEl) { saveEl.textContent = pct + '% OFF'; saveEl.style.display = ''; }
        } else {
            if (oldEl)  oldEl.style.display  = 'none';
            if (saveEl) saveEl.style.display = 'none';
        }
    }

    function updateStockUI(v) {
        const sb = document.getElementById('stockBlock');
        if (!sb) return;
        if (v.stock > 10) {
            sb.innerHTML = `<span class="stock-badge badge-in-stock"><i class="bi bi-check-circle-fill"></i> In Stock</span>`;
        } else if (v.stock > 0) {
            sb.innerHTML = `<span class="stock-badge badge-low-stock"><i class="bi bi-exclamation-triangle-fill"></i> Only ${v.stock} left</span>`;
        } else {
            sb.innerHTML = `<span class="stock-badge badge-out-stock"><i class="bi bi-x-circle-fill"></i> Sold Out</span>`;
        }
    }

    function updateButtonVariant(v) {
        ['btnAddToCart', 'btnBuyNow'].forEach(id => {
            const btn = document.getElementById(id);
            if (btn) { btn.dataset.pid = v.productId; btn.dataset.vid = v._id; }
        });
    }

    function updateQtyBlock(v) {
        const qtyBlock = document.getElementById('qtyBlock');
        const qtyVal   = document.getElementById('qtyVal');

        if (!qtyBlock) return;

        if (v.stock <= 0) {
            qtyBlock.style.display = 'none';
            return;
        }

        qtyBlock.style.display = 'flex';
        const maxQty = Math.min(MAX_CART_QTY, v.stock);

        if (qtyVal) qtyVal.value = '1';

        const minus = document.getElementById('qtyMinus');
        const plus  = document.getElementById('qtyPlus');
        if (minus) minus.disabled = true;
        if (plus)  plus.disabled  = (maxQty <= 1);
    }

    function updateGalleryImages(v) {
        if (!v.images || v.images.length === 0) return;

        setMainImage(v.images[0], 0);

        const thumbsContainer = document.querySelector('.gallery-thumbs');
        if (!thumbsContainer) return;
        thumbsContainer.innerHTML = '';

        v.images.forEach((src, i) => {
            const d = document.createElement('div');
            d.className   = 'thumb' + (i === 0 ? ' active' : '');
            d.dataset.src = src;
            d.dataset.idx = String(i);
            d.setAttribute('role', 'button');
            d.setAttribute('tabindex', '0');
            d.setAttribute('aria-label', `View image ${i + 1} of ${v.images.length}`);
            d.innerHTML   = `<img src="${src}" alt="Product image ${i + 1}">`;
            d.addEventListener('click',   () => setMainImage(src, i));
            d.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setMainImage(src, i); }
            });
            thumbsContainer.appendChild(d);
        });

        // Rebind thumbEls reference and sync allImages
        bindThumbs();
        allImages.length = 0;
        v.images.forEach(s => allImages.push(s));
    }

    function updateURL(v) {
        const url = `/product/${encodeURIComponent(v.productId)}?variant=${encodeURIComponent(v._id)}`;
        window.history.replaceState({ variantId: v._id }, '', url);
    }

    function setActionsDisabled(off) {
        ['btnAddToCart', 'btnBuyNow'].forEach(id => {
            const btn = document.getElementById(id);
            if (btn) btn.disabled = off;
        });
    }

    // Initial render
    renderAll();
    resolveVariant();

    /* ═══════════════════════════════════════════════════════════════
       QUANTITY CONTROL
    ═══════════════════════════════════════════════════════════════ */
    function getCurrentStock() {
        const v = ALL_VARIANTS.find(x => x._id === currentVariantId);
        return v ? v.stock : (parseInt(document.getElementById('__data_stockQty__').textContent, 10) || 0);
    }

    function changeQty(delta) {
        const inp = document.getElementById('qtyVal');
        if (!inp) return;

        const stock  = getCurrentStock();
        const maxQty = Math.min(MAX_CART_QTY, stock);
        const current = parseInt(inp.value, 10);

        if (delta > 0 && current >= maxQty) {
            if (current >= stock) {
                Swal.fire({
                    ...swalBase,
                    icon: 'warning',
                    title: 'Out of Stock',
                    html: `Only <strong>${stock}</strong> units are available in stock.`,
                    confirmButtonText: 'Got it'
                });
            } else {
                Swal.fire({
                    ...swalBase,
                    icon: 'warning',
                    title: 'Quantity Limit Reached',
                    html: `You can only buy up to <strong>${MAX_CART_QTY}</strong> units of this product at once.`,
                    confirmButtonText: 'Got it'
                });
            }
            return;
        }

        const newVal = Math.max(1, Math.min(current + delta, maxQty));
        inp.value = newVal;

        const minus = document.getElementById('qtyMinus');
        const plus  = document.getElementById('qtyPlus');
        if (minus) minus.disabled = (newVal <= 1);
        if (plus)  plus.disabled  = (newVal >= maxQty);
    }

    /* ═══════════════════════════════════════════════════════════════
       SWEETALERT BASE CONFIG
    ═══════════════════════════════════════════════════════════════ */
    const swalBase = {
        background:           '#1c1c1f',
        color:                '#f1f5f9',
        confirmButtonColor:   '#6366f1',
        cancelButtonColor:    '#334155',
    };

    /* ═══════════════════════════════════════════════════════════════
       ADD TO CART
    ═══════════════════════════════════════════════════════════════ */
    async function addToCart() {
        const btn = document.getElementById('btnAddToCart');
        if (!btn || btn.disabled) return;

        const pid = btn.dataset.pid;
        const vid = btn.dataset.vid;

        if (!pid || !vid) {
            Swal.fire({ ...swalBase, icon: 'error', title: 'Error', text: 'Product information missing. Please refresh the page.' });
            return;
        }

        // Check login state
        if (!IS_LOGGED_IN) {
            return Swal.fire({
                ...swalBase,
                icon: 'info',
                title: 'Sign In Required',
                text: 'Please log in to add items to your cart.',
                confirmButtonText: 'Sign In',
                showCancelButton: true,
                cancelButtonText: 'Do it later'
            }).then(r => {
                if (r.isConfirmed) {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                    redirectTo(`/signin?returnTo=${encodeURIComponent(currentPath)}`);
                }
            });
        }

        // Pre-flight: already at max for this variant?
        const stock = getCurrentStock();
        const maxAllowed = Math.min(MAX_CART_QTY, stock);
        
        if (alreadyInCart >= maxAllowed) {
            if (alreadyInCart >= stock) {
                Swal.fire({
                    ...swalBase,
                    icon: 'warning',
                    title: 'Out of Stock',
                    html: `You already have all <strong>${stock}</strong> available units in your cart.`,
                    confirmButtonText: 'View Cart',
                    showCancelButton: true,
                    cancelButtonText: 'Continue Shopping'
                }).then(r => {
                    if (r.isConfirmed) {
                        btn.disabled = true;
                        btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                        redirectTo('/cart');
                    }
                });
            } else {
                Swal.fire({
                    ...swalBase,
                    icon: 'warning',
                    title: 'Cart Limit Reached',
                    html: `You already have the maximum of <strong>${MAX_CART_QTY}</strong> units in your cart.`,
                    confirmButtonText: 'View Cart',
                    showCancelButton: true,
                    cancelButtonText: 'Continue Shopping'
                }).then(r => {
                    if (r.isConfirmed) {
                        btn.disabled = true;
                        btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                        redirectTo('/cart');
                    }
                });
            }
            return;
        }

        // Loading state
        btn.disabled   = true;
        btn.innerHTML  = '<i class="bi bi-arrow-repeat bi-spin"></i> Adding…';

        try {
            const res = await fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    productId: pid,
                    variantId: vid,
                    quantity:  1          // always 1 per click; backend increments
                })
            });

            // Parse JSON safely
            let data;
            try {
                data = await res.json();
            } catch {
                throw new Error(`HTTP ${res.status} — non-JSON response`);
            }

            // Restore button
            btn.disabled  = false;
            btn.innerHTML = '<i class="bi bi-cart-plus"></i> Add to Cart';

            // Auth redirect from server
            if (data.requiresAuth || data.redirect) {
                const currentPath = window.location.pathname + window.location.search;
                redirectTo(`/signin?returnTo=${encodeURIComponent(currentPath)}`);
                return;
            }

            // Failure cases
            if (!data.success) {
                if (data.limitReached) {
                    alreadyInCart = MAX_CART_QTY;
                    Swal.fire({
                        ...swalBase,
                        icon: 'warning',
                        title: 'Cart Limit Reached',
                        html: `<span style="color:var(--text-dim)">${data.message || `You can only add up to <strong>${MAX_CART_QTY}</strong> units.`}</span>`,
                        confirmButtonText: 'View Cart',
                        showCancelButton: true,
                        cancelButtonText: 'Continue Shopping'
                    }).then(r => {
                        if (r.isConfirmed) {
                            btn.disabled = true;
                            btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                            redirectTo('/cart');
                        }
                    });
                    return;
                }

                Swal.fire({
                    ...swalBase,
                    icon: 'error',
                    title: 'Could not add to cart',
                    text: data.message || 'Something went wrong. Please try again.'
                });
                return;
            }

            /* ── SUCCESS ─────────────────────────────────────── */
            // Update local tracker with server truth
            alreadyInCart = data.newQty;

            // Update navbar badge (FIX: server now returns distinct item count)
            const badge = document.querySelector('.cart-badge');
            if (badge && data.cartCount !== undefined) {
                badge.textContent = data.cartCount;
                badge.style.display = data.cartCount > 0 ? 'flex' : 'none';
            }

            const stock = getCurrentStock();
            const maxAllowed = Math.min(MAX_CART_QTY, stock);
            const canAddMore = maxAllowed - alreadyInCart;

            if (canAddMore <= 0) {
                btn.disabled = true;
                btn.title = 'Limit reached';
                btn.style.opacity = '0.6';
                btn.style.cursor = 'not-allowed';
            }

            const toastHtml = canAddMore <= 0
                ? `<span style="font-size:.76rem;color:var(--text-dim)">You've reached the ${alreadyInCart >= stock ? 'stock' : 'maximum'} limit for this product.</span>`
                : `<span style="font-size:.76rem;color:var(--text-dim)">You can add <strong style="color:#4f6ef7">${canAddMore}</strong> more unit${canAddMore === 1 ? '' : 's'}</span>`;

            Swal.fire({
                ...swalBase,
                toast:            true,
                position:         'top-end',
                icon:             'success',
                title:            'Added to cart!',
                html:             toastHtml,
                showConfirmButton: false,
                timer:            2000,
                timerProgressBar: true,
                iconColor:        '#00d4a0',
            });

        } catch (err) {
            btn.disabled  = false;
            btn.innerHTML = '<i class="bi bi-cart-plus"></i> Add to Cart';
            console.error('addToCart error:', err);
            Swal.fire({
                ...swalBase,
                icon:  'error',
                title: 'Error',
                text:  'Something went wrong. Please try again.',
            });
        }
    }

    /* ═══════════════════════════════════════════════════════════════
       BUY NOW
    ═══════════════════════════════════════════════════════════════ */
    function buyNow() {
        const btn = document.getElementById('btnBuyNow');
        if (!btn || btn.disabled) return;

        const pid = btn.dataset.pid;
        const vid = btn.dataset.vid;
        const qty = parseInt(document.getElementById('qtyVal')?.value || '1', 10);

        if (!pid || !vid) return;

        if (!IS_LOGGED_IN) {
            return Swal.fire({
                ...swalBase,
                icon: 'info',
                title: 'Sign In Required',
                text: 'Please log in to proceed with purchase.',
                confirmButtonText: 'Sign In',
                showCancelButton: true,
                cancelButtonText: 'Do it later'
            }).then(r => {
                if (r.isConfirmed) {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                    const currentPath = window.location.pathname + window.location.search;
                    redirectTo(`/signin?returnTo=${encodeURIComponent(currentPath)}`);
                }
            });
        }

        btn.disabled  = true;
        btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing…';

        redirectTo(`/checkout/buy-now?product=${encodeURIComponent(pid)}&variant=${encodeURIComponent(vid)}&qty=${qty}`);
    }

    /* ═══════════════════════════════════════════════════════════════
       WISHLIST TOGGLE
    ═══════════════════════════════════════════════════════════════ */
    async function toggleWishlistDetail(productId) {
        const btn  = document.getElementById('btnWishlist');
        const icon = btn.querySelector('i');
        const text = document.getElementById('wishlistText');

        const originalIconClass = icon.className;
        const originalText      = text.textContent;

        btn.style.pointerEvents = 'none';
        icon.className          = 'bi bi-arrow-repeat bi-spin';
        text.textContent        = 'Processing...';

        try {
            const response = await fetch('/wishlist/toggle', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ productId })
            });

            if (response.status === 401) {
                icon.className          = originalIconClass;
                text.textContent        = originalText;
                btn.style.pointerEvents = '';

                return Swal.fire({
                    background:           '#141416',
                    color:                '#eaeaea',
                    confirmButtonColor:   '#4f6ef7',
                    icon:                 'warning',
                    title:                'Sign In Required',
                    text:                 'Please log in to add items to your wishlist.',
                    confirmButtonText:    'Sign In',
                    showCancelButton:     true
                }).then(r => { if (r.isConfirmed) window.location.href = '/signin'; });
            }

            const data = await response.json();

            if (data.success) {
                const isAdded = data.action === 'added';

                btn.classList.toggle('active', isAdded);
                icon.className      = isAdded ? 'bi bi-heart-fill' : 'bi bi-heart';
                icon.style.color    = isAdded ? '#e63946' : '';
                text.textContent    = isAdded ? 'Remove from Wishlist' : 'Add to Wishlist';

                // Update navbar wishlist badge if it exists
                const wishBadge = document.getElementById('wishBtn');
                if (wishBadge) {
                    const currentCount = parseInt(wishBadge.textContent || '0', 10);
                    const newCount = isAdded ? currentCount + 1 : Math.max(0, currentCount - 1);
                    wishBadge.textContent = newCount;
                    wishBadge.style.display = newCount > 0 ? 'flex' : 'none';
                }

                Swal.fire({
                    toast:              true,
                    position:           'top-end',
                    icon:               'success',
                    title:              isAdded ? 'Added to wishlist!' : 'Removed from wishlist',
                    showConfirmButton:   false,
                    timer:              2000,
                    background:         '#1a1d24',
                    color:              '#f0f0f2',
                    iconColor:          isAdded ? '#4ade80' : '#e63946'
                });
            } else {
                icon.className   = originalIconClass;
                text.textContent = originalText;
            }

        } catch (err) {
            console.error('Wishlist Toggle Error:', err);
            icon.className          = originalIconClass;
            text.textContent        = originalText;
        } finally {
            btn.style.pointerEvents = '';
        }
    }
    </script>
</body>
</html>
