<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Addresses - Zyrox</title>
  <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
  <link rel="stylesheet" href="/userStyles/address/userAddress.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
  <div class="main-container">
    <%- include('../../partials/user/profileSidebar', { activePage: 'address' }) %>

      <main class="main-wrapper">
        <div id="profile-card-container">

          <div class="d-flex justify-content-between align-items-center mb-5">
            <h3 class="m-0" style="color: white;">Shipping Addresses</h3>
            <a href="/address-add" class="btn-add">
              <i class="fa-solid fa-plus"></i> Add New Address
            </a>
          </div>

          <div class="card" style="background-color: rgb(0, 0, 0);">
            <% if (address && address.length> 0) { %>
              <div class="address-list">
                <% address.forEach(function(addr) { %>

                  <div class="address-card <%= addr.isDefault ? 'active' : '' %>" id="address-<%= addr._id %>">
                    <div class="card-topbar">
                      <div class="topbar-left">
                        <div class="custom-radio-wrap">
                          <input type="radio" name="defaultAddress" id="radio-<%= addr._id %>" class="default-radio"
                            <%=addr.isDefault ? 'checked' : '' %>
                          onclick="setDefaultAddress('<%= addr._id %>')"/>
                            <label for="radio-<%= addr._id %>" class="radio-label"></label>
                        </div>

                        <span class="status-badge <%= addr.isDefault ? 'default' : 'set-default' %>"
                          onclick="setDefaultAddress('<%= addr._id %>')">
                          <% if (addr.isDefault) { %>
                            <i class="bi bi-patch-check-fill me-1"></i> Default
                            <% } else { %>
                              Set as Default
                              <% } %>
                        </span>
                      </div>

                      <span class="type-tag">
                        <i
                          class="fa-solid fa-<%= addr.addressType === 'Work' ? 'briefcase' : addr.addressType === 'Others' ? 'map-pin' : 'house' %> me-1"></i>
                        <%= addr.addressType %>
                      </span>
                    </div>

                    <div class="card-body-inner">
                      <div class="addr-left">
                        <p class="customer-name">
                          <%= addr.name %>
                        </p>
                        <div class="addr-detail-block">
                          <div class="addr-row">
                            <span class="dot"></span>
                            <span>
                              <%= addr.houseName %>, <%= addr.locality %>
                            </span>
                          </div>
                          <div class="addr-row">
                            <span style="width: 8px; flex-shrink: 0;"></span>
                            <span>
                              <%= addr.city %>, <%= addr.state %>
                                  <%= addr.pincode %>
                            </span>
                          </div>
                        </div>
                      </div>

                      <div class="addr-center">
                        <div class="phone-block">
                          <div class="ph-num">
                            <i class="fa-solid fa-phone"></i>
                            <%= addr.phone %>
                          </div>
                          <div class="ph-country">
                            <%= addr.country %>
                          </div>
                        </div>
                      </div>

                      <div class="addr-right">
                        <div class="action-btns">
                          <a href="/address-edit/<%= addr._id %>" class="btn-action-sm btn-edit-sm" title="Edit">
                            <i class="fa-solid fa-pen"></i>
                          </a>
                          <button class="btn-action-sm btn-delete-sm" onclick="deleteAddress('<%= addr._id %>')"
                            title="Delete">
                            <i class="fa-solid fa-trash"></i>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>

                  <% }); %>
              </div>

              <% if (totalPages> 1) { %>
                <div class="pagination-container mt-5">
                  <a href="/address?page=<%= currentPage - 1 %>"
                    class="pagination-link ajax-link <%= currentPage === 1 ? 'disabled' : '' %>">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                  <% for (let i=1; i <=totalPages; i++) { %>
                    <a href="/address?page=<%= i %>"
                      class="pagination-link ajax-link <%= currentPage === i ? 'active' : '' %>">
                      <%= i %>
                    </a>
                    <% } %>
                      <a href="/address?page=<%= currentPage + 1 %>"
                        class="pagination-link ajax-link <%= currentPage === totalPages ? 'disabled' : '' %>">
                        <i class="bi bi-chevron-right"></i>
                      </a>
                </div>
                <% } %>

                  <% } else { %>
                    <div class="empty-state">
                      <div class="empty-icon-wrap">
                        <i class="fa-solid fa-location-dot"></i>
                      </div>
                      <h4 class="fw-bold text-white mb-2">No addresses saved</h4>
                      <p class="text-muted mb-4">You haven't added any shipping addresses to your account yet.</p>
                      <a href="/address-add" class="btn-add-empty">
                        <i class="fa-solid fa-plus me-2"></i> Add Your First Address
                      </a>
                    </div>
                    <% } %>
          </div>
        </div>
      </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/userProfile.js"></script>
</body>

</html>