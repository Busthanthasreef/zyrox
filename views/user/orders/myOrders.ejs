<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders | Zyrox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">

    <style>
        :root {
            --bg-dark: #0a0c16;
            --bg-content: #111422;
            --accent-blue: #3b71ca;
            --text-main: #ffffff;
            --text-muted: #a0a8c0;
            --border-color: rgba(255, 255, 255, 0.1);
        }

        body,
        html {
            height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            overflow: hidden;
        }

        .main-wrapper {
            display: flex;
            height: 100vh;
            width: 100%;
        }

        .sidebar-container {
            width: 280px;
            min-width: 280px;
            background-color: var(--bg-dark);
            height: 100vh;
            border-right: 1px solid var(--border-color);
        }

        .content-area {
            flex-grow: 1;
            height: 100vh;
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            box-sizing: border-box;
        }

        .content-card {
            background: var(--bg-content);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        .table-responsive {
            flex-grow: 1;
            overflow-y: auto;
            margin-top: 1rem;
        }

        .table-responsive::-webkit-scrollbar {
            width: 6px;
        }

        .table-responsive::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }

        .table {
            color: var(--text-main);
            margin-bottom: 0;
        }

        .table thead th {
            background: rgba(255, 255, 255, 0.03);
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
            text-transform: uppercase;
            font-size: 0.7rem;
            padding: 0.75rem 0.5rem;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .table tbody td {
            padding: 0.75rem 0.5rem;
            background: transparent;
            color: var(--text-main);
            border-bottom: 1px solid var(--border-color);
            font-size: 0.85rem;
            vertical-align: middle;
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
            white-space: nowrap;
        }

        .status-pending {
            background: rgba(255, 193, 7, 0.1);
            color: #ffc107;
        }

        .status-failed {
            background: rgba(220, 53, 69, 0.1);
            color: #dc3545;
        }

        .status-success {
            background: rgba(40, 167, 69, 0.1);
            color: #28a745;
        }

        /* Pagination Design */
        .pagination-container {
            padding: 1rem 0 0.5rem 0;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            flex-shrink: 0;
            background: var(--bg-content);
            border-top: 1px solid var(--border-color);
        }

        .pag-link {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-muted);
            text-decoration: none;
            border: 1px solid var(--border-color);
            transition: 0.2s;
            background: rgba(255, 255, 255, 0.02);
        }

        .pag-link:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.05);
            border-color: #555;
        }

        .pag-link.active {
            background: var(--accent-blue);
            color: #fff;
            border-color: var(--accent-blue);
        }

        .pag-link.disabled {
            opacity: 0.3;
            pointer-events: none;
        }

        @media (max-width: 992px) {
            .sidebar-container {
                display: none;
            }
        }
    </style>
</head>

<body>

    <div class="main-wrapper">
        <aside class="sidebar-container">
            <%- include('../../partials/user/profileSidebar', { activePage: 'orders' }) %>
        </aside>

        <main class="content-area">
            <div class="content-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h4 class="fw-bold mb-1" style="color:#fff">My Orders</h4>
                        <p class="text-muted small mb-0">Review your purchase history and track items</p>
                    </div>
                    <a href="/products" class="btn btn-outline-primary btn-sm px-3" style="border-radius: 8px;">
                        Continue Shopping
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th width="5%">#</th>
                                <th width="15%">Order ID</th>
                                <th width="12%">Items</th>
                                <th width="12%">Amount</th>
                                <th width="15%">Status</th>
                                <th width="12%">Date</th>
                                <th width="15%">Payment</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(orders && orders.length> 0) { %>
                                <% orders.forEach((order, ind)=> { %>
                                    <tr>
                                        <td class="text-muted">
                                            <%= (page - 1) * 5 + (ind + 1) %>
                                        </td>
                                        <td><span class="fw-bold">#<%= order.orderId %></span></td>
                                        <td>
                                            <%= order.items.length %>
                                                <%= order.items.length===1 ? 'item' : 'items' %>
                                        </td>
                                        <td class="fw-bold">₹<%= (order.finalPrice || order.subtotal).toFixed(2) %>
                                        </td>
                                        <td>
                                            <% const s=order.orderStatus; let badge='status-success' ; if
                                                (s.includes('Pending') || s.includes('Request') ||
                                                s.includes('Processing')) badge='status-pending' ; else if
                                                (s.includes('Cancelled')) badge='status-failed' ; %>
                                                <span class="status-badge <%= badge %>">
                                                    <%= order.orderStatus %>
                                                </span>
                                        </td>
                                        <td class="text-muted">
                                            <%= new Date(order.createdAt).toLocaleDateString('en-GB') %>
                                        </td>
                                        <td>
                                            <% if(order.paymentStatus==='Pending' || order.paymentStatus==='Processing'
                                                ) { %>
                                                <span class="status-badge status-pending">Pending</span>
                                                <% } else if(order.paymentStatus==='Cancelled' ||
                                                    order.paymentStatus==='Failed' ) { %>
                                                    <span class="status-badge status-failed">Failed</span>
                                                    <% } else { %>
                                                        <span class="status-badge status-success">Paid</span>
                                                        <% } %>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-1">
                                                <a href="/myOrders/order?id=<%= order._id %>"
                                                    class="btn btn-outline-primary btn-sm px-2"
                                                    title="View Details">View</a>
                                                <% if(order.orderStatus==='Pending' || order.orderStatus==='Processing'
                                                    ) { %>
                                                    <button onclick="openCancelModal('<%= order._id %>')"
                                                        class="btn btn-outline-danger btn-sm px-2">Cancel</button>
                                                    <% } %>
                                                        <% if(order.orderStatus==='Delivered' ) { %>
                                                            <button onclick="openReturnModal('<%= order._id %>')"
                                                                class="btn btn-outline-warning btn-sm px-2">Return</button>
                                                            <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="8" class="text-center py-5">
                                                    <div class="text-muted"><i class="fas fa-box-open mb-3"
                                                            style="font-size: 2rem;"></i><br>No orders found</div>
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- User Side Pagination -->
                <% if (totalPages> 1) { %>
                    <div class="pagination-container">
                        <a href="?page=<%= page - 1 %>" class="pag-link <%= page === 1 ? 'disabled' : '' %>">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                        <% for(let i=Math.max(1, page - 1); i <=Math.min(totalPages, page + 1); i++) { %>
                            <a href="?page=<%= i %>" class="pag-link <%= page === i ? 'active' : '' %>">
                                <%= i %>
                            </a>
                            <% } %>
                                <a href="?page=<%= page + 1 %>"
                                    class="pag-link <%= page >= totalPages ? 'disabled' : '' %>">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                    </div>
                    <% } %>
            </div>
        </main>
    </div>

    <!-- Cancel Modal -->
    <div class="modal fade" id="cancelModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-white">Cancel Order</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-white">
                    <label class="form-label text-muted small">SELECT REASON</label>
                    <select id="cancelReason" class="form-select bg-dark text-white border-secondary mb-3"
                        onchange="handleOtherOption('cancel')">
                        <option value="">Choose a reason...</option>
                        <option>Found cheaper elsewhere</option>
                        <option>Delivery is too slow</option>
                        <option>Changed my mind</option>
                        <option>Ordered by mistake</option>
                        <option value="Others">Others</option>
                    </select>
                    <div id="cancelOtherContainer" style="display: none;">
                        <textarea id="cancelOtherReason" class="form-control bg-dark text-white border-secondary"
                            rows="3" placeholder="Tell us more..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                    <button class="btn btn-danger btn-sm px-4" onclick="confirmCancel()">Confirm Cancellation</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentOrderId = null;

        function openCancelModal(id) { currentOrderId = id; new bootstrap.Modal(document.getElementById('cancelModal')).show(); }

        function handleOtherOption(type) {
            const sel = document.getElementById(`${type}Reason`).value;
            document.getElementById(`${type}OtherContainer`).style.display = sel === "Others" ? "block" : "none";
        }

        function confirmCancel() {
            const sel = document.getElementById('cancelReason').value;
            const other = document.getElementById('cancelOtherReason').value.trim();
            const reason = sel === "Others" ? other : sel;
            if (!reason) return Swal.fire('Error', 'Please provide a reason', 'error');

            axios.post('/cancel-order', { orderId: currentOrderId, reason })
                .then(r => { if (r.data.success) location.reload(); })
                .catch(e => Swal.fire('Error', 'Failed to cancel', 'error'));
        }
    </script>
</body>

</html>