<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Orders</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
        rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
    <style>
        :root {
            --bg: #f0f2f7;
            --surface: #ffffff;
            --card: #ffffff;
            --sidebar: #181c2e;
            --border: #e4e8f0;
            --accent: #3b6ef8;
            --accent2: #6c47ff;
            --green: #0fba81;
            --yellow: #f59e0b;
            --red: #ef4444;
            --orange: #f97316;
            --text: #111827;
            --muted: #6b7280;
            --light: #9ca3af;
            --tag-bg: #eef1fc;
            --sidebar-w: 240px;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar);
            min-height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            display: flex;
            flex-direction: column;
            z-index: 100
        }

        .sidebar-brand {
            padding: 26px 24px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, .07)
        }

        .sidebar-brand .logo {
            font-size: 1.2rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -.5px
        }

        .sidebar-brand .logo span {
            color: var(--accent)
        }

        .sidebar-brand .sub {
            font-size: .7rem;
            color: rgba(255, 255, 255, .3);
            margin-top: 2px
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1
        }

        .nav-label {
            font-size: .62rem;
            color: rgba(255, 255, 255, .25);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 0 12px;
            margin: 16px 0 6px
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: rgba(255, 255, 255, .45);
            font-size: .84rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
            margin-bottom: 2px
        }

        .nav-item i {
            font-size: 1rem;
            width: 18px
        }

        .nav-item:hover {
            background: rgba(255, 255, 255, .06);
            color: rgba(255, 255, 255, .8)
        }

        .nav-item.active {
            background: var(--accent);
            color: #fff
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid rgba(255, 255, 255, .07)
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px
        }

        .user-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: .75rem;
            color: #fff;
            flex-shrink: 0
        }

        .user-name {
            font-size: .82rem;
            font-weight: 600;
            color: rgba(255, 255, 255, .8)
        }

        .user-email {
            font-size: .68rem;
            color: rgba(255, 255, 255, .3)
        }

        /* Main */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh
        }

        /* Topbar */
        .topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 14px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50
        }

        .page-title {
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -.3px
        }

        .page-title span {
            color: var(--muted);
            font-weight: 400;
            font-size: .8rem;
            margin-left: 8px
        }

        .search-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 8px 14px;
            width: 320px;
            transition: border-color .2s
        }

        .search-bar:focus-within {
            border-color: var(--accent)
        }

        .search-bar i {
            color: var(--light);
            font-size: .9rem
        }

        .search-bar input {
            border: none;
            background: transparent;
            outline: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: .85rem;
            color: var(--text);
            width: 100%
        }

        .search-bar input::placeholder {
            color: var(--light)
        }

        /* Content */
        .content {
            padding: 28px 32px;
            flex: 1
        }

        /* Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 28px
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0
        }

        .stat-val {
            font-size: 1.4rem;
            font-weight: 800;
            line-height: 1
        }

        .stat-label {
            font-size: .73rem;
            color: var(--muted);
            margin-top: 3px
        }

        /* Filter bar */
        .filter-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap
        }

        .filter-btn {
            padding: 7px 18px;
            border-radius: 100px;
            border: 1.5px solid var(--border);
            background: var(--surface);
            color: var(--muted);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: .8rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .18s
        }

        .filter-btn:hover {
            border-color: var(--accent);
            color: var(--accent)
        }

        .filter-btn.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
            font-weight: 600
        }

        /* Table */
        .table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden
        }

        .table-card table {
            margin: 0
        }

        .table-card thead tr {
            background: var(--bg)
        }

        .table-card thead th {
            font-size: .72rem;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: var(--muted);
            font-weight: 600;
            padding: 12px 18px;
            border-bottom: 1px solid var(--border);
            white-space: nowrap
        }

        .table-card tbody td {
            padding: 15px 18px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
            font-size: .85rem
        }

        .table-card tbody tr:last-child td {
            border-bottom: none
        }

        .table-card tbody tr {
            transition: background .15s;
            cursor: pointer
        }

        .table-card tbody tr:hover {
            background: #f7f9ff
        }

        .order-id-tag {
            font-family: 'JetBrains Mono', monospace;
            font-size: .75rem;
            font-weight: 500;
            color: var(--accent);
            background: var(--tag-bg);
            padding: 3px 9px;
            border-radius: 6px;
            letter-spacing: .3px;
            display: inline-block
        }

        .order-name {
            font-weight: 600;
            font-size: .88rem
        }

        .order-sub {
            font-size: .75rem;
            color: var(--muted);
            margin-top: 2px
        }

        /* Badges */
        .badge-pill {
            padding: 4px 12px;
            border-radius: 100px;
            font-size: .72rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 5px
        }

        .badge-pill::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block
        }

        .s-delivered {
            background: #ecfdf5;
            color: #065f46
        }

        .s-delivered::before {
            background: var(--green)
        }

        .s-processing {
            background: #fffbeb;
            color: #92400e
        }

        .s-processing::before {
            background: var(--yellow)
        }

        .s-shipped {
            background: #eff6ff;
            color: #1e40af
        }

        .s-shipped::before {
            background: var(--accent)
        }

        .s-cancelled {
            background: #fef2f2;
            color: #991b1b
        }

        .s-cancelled::before {
            background: var(--red)
        }

        .s-returned {
            background: #fff7ed;
            color: #9a3412
        }

        .s-returned::before {
            background: var(--orange)
        }

        /* Action buttons */
        .act-btn {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: 1.5px solid var(--border);
            background: transparent;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .9rem;
            color: var(--muted);
            transition: all .15s;
            margin-right: 4px
        }

        .act-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--tag-bg)
        }

        .act-btn.danger:hover {
            border-color: var(--red);
            color: var(--red);
            background: #fef2f2
        }

        .act-btn.warn:hover {
            border-color: var(--orange);
            color: var(--orange);
            background: #fff7ed
        }

        /* Modals */
        .modal-content {
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden
        }

        .modal-header {
            background: var(--bg);
            border-bottom: 1px solid var(--border);
            padding: 20px 26px
        }

        .modal-header .modal-title {
            font-weight: 700;
            font-size: 1rem
        }

        .modal-body {
            padding: 26px
        }

        .modal-footer {
            border-top: 1px solid var(--border);
            padding: 16px 26px;
            background: var(--bg)
        }

        /* Detail modal */
        .detail-section {
            margin-bottom: 22px
        }

        .detail-section-title {
            font-size: .7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            font-weight: 600;
            margin-bottom: 10px
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 12px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px
        }

        .info-item label {
            font-size: .7rem;
            color: var(--muted);
            display: block;
            margin-bottom: 3px
        }

        .info-item span {
            font-size: .88rem;
            font-weight: 600
        }

        .item-row {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border)
        }

        .item-row:last-child {
            border-bottom: none
        }

        .item-thumb {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
            border: 1px solid var(--border)
        }

        .item-name {
            font-size: .88rem;
            font-weight: 600
        }

        .item-variant {
            font-size: .74rem;
            color: var(--muted);
            margin-top: 2px
        }

        .item-qty {
            font-size: .74rem;
            color: var(--muted);
            margin-top: 3px
        }

        .item-price {
            margin-left: auto;
            font-weight: 700;
            font-size: .95rem;
            flex-shrink: 0
        }

        .item-cancel-btn {
            padding: 4px 12px;
            border-radius: 7px;
            border: 1.5px solid var(--red);
            background: transparent;
            color: var(--red);
            font-size: .72rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
            margin-left: 10px;
            flex-shrink: 0;
            font-family: 'Plus Jakarta Sans', sans-serif
        }

        .item-cancel-btn:hover {
            background: var(--red);
            color: #fff
        }

        .summary-box {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px 18px;
            margin-top: 16px
        }

        .sum-row {
            display: flex;
            justify-content: space-between;
            font-size: .84rem;
            color: var(--muted);
            padding: 4px 0
        }

        .sum-row.total {
            border-top: 1px solid var(--border);
            margin-top: 8px;
            padding-top: 10px;
            font-size: 1rem;
            font-weight: 700;
            color: var(--text)
        }

        .sum-row.total span:last-child {
            color: var(--accent)
        }

        /* Timeline */
        .timeline {
            display: flex;
            align-items: flex-start;
            margin: 16px 0
        }

        .tl-step {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative
        }

        .tl-step:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 14px;
            left: 50%;
            width: 100%;
            height: 2px;
            background: var(--border)
        }

        .tl-step.done:not(:last-child)::after {
            background: var(--green)
        }

        .tl-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--border);
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .75rem;
            z-index: 1;
            position: relative
        }

        .tl-step.done .tl-dot {
            border-color: var(--green);
            background: var(--green);
            color: #fff
        }

        .tl-step.current .tl-dot {
            border-color: var(--accent);
            background: var(--accent);
            color: #fff
        }

        .tl-label {
            font-size: .68rem;
            color: var(--muted);
            margin-top: 6px;
            text-align: center;
            font-weight: 500
        }

        .tl-step.done .tl-label,
        .tl-step.current .tl-label {
            color: var(--text);
            font-weight: 600
        }

        /* Reason option */
        .reason-option {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            cursor: pointer;
            margin-bottom: 8px;
            transition: all .15s
        }

        .reason-option:hover {
            border-color: var(--accent);
            background: var(--tag-bg)
        }

        .reason-option.selected {
            border-color: var(--accent);
            background: var(--tag-bg)
        }

        .reason-option input[type=radio] {
            accent-color: var(--accent)
        }

        /* Tags */
        .item-returned-tag {
            font-size: .68rem;
            padding: 2px 8px;
            border-radius: 5px;
            background: #fff7ed;
            color: var(--orange);
            border: 1px solid #fed7aa;
            font-weight: 600;
            margin-left: 8px
        }

        .item-cancelled-tag {
            font-size: .68rem;
            padding: 2px 8px;
            border-radius: 5px;
            background: #fef2f2;
            color: var(--red);
            border: 1px solid #fecaca;
            font-weight: 600;
            margin-left: 8px
        }

        /* Buttons */
        .btn-primary-c {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 600;
            font-size: .84rem;
            padding: 9px 20px;
            cursor: pointer;
            transition: opacity .15s;
            display: inline-flex;
            align-items: center;
            gap: 6px
        }

        .btn-primary-c:hover {
            opacity: .88
        }

        .btn-danger-c {
            background: var(--red);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 600;
            font-size: .84rem;
            padding: 9px 20px;
            cursor: pointer;
            transition: opacity .15s;
            display: inline-flex;
            align-items: center;
            gap: 6px
        }

        .btn-danger-c:hover {
            opacity: .88
        }

        .btn-outline-c {
            background: transparent;
            color: var(--text);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 500;
            font-size: .84rem;
            padding: 9px 20px;
            cursor: pointer;
            transition: all .15s;
            display: inline-flex;
            align-items: center;
            gap: 6px
        }

        .btn-outline-c:hover {
            border-color: var(--accent);
            color: var(--accent)
        }

        /* Empty */
        .empty-state {
            text-align: center;
            padding: 80px;
            color: var(--muted)
        }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 12px;
            color: var(--light)
        }

        /* Toast */
        .toast-container {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 9999
        }

        .toast-msg {
            background: var(--sidebar);
            color: #fff;
            padding: 12px 20px;
            border-radius: 12px;
            font-size: .84rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 8px;
            animation: slideUp .3s ease;
            box-shadow: 0 8px 24px rgba(0, 0, 0, .18)
        }

        .toast-msg.success i {
            color: var(--green)
        }

        .toast-msg.danger i {
            color: var(--red)
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(12px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        textarea.form-control {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: .84rem;
            border-color: var(--border);
            border-radius: 10px;
            resize: none;
            outline: none
        }

        textarea.form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(59, 110, 248, .1)
        }
    </style>
</head>

<body>

    
    <%- include('../../partials/user/profileSidebar', { activePage: 'My Orders' }) %>

        <!-- Main -->
        <div class="main">
            <div class="topbar">
                <div class="page-title">My Orders<span>All your purchases in one place</span></div>
                <div class="search-bar">
                    <i class="bi bi-search"></i>
                    <input type="text" id="searchInput" placeholder="Search by Order ID or product name…"
                        oninput="applyFilters()" />
                </div>
            </div>

            <div class="content">
                <div class="stats-row" id="statsRow"></div>
                <div class="filter-bar">
                    <button class="filter-btn active" data-f="all" onclick="setFilter(this)">All Orders</button>
                    <button class="filter-btn" data-f="processing" onclick="setFilter(this)">Processing</button>
                    <button class="filter-btn" data-f="shipped" onclick="setFilter(this)">Shipped</button>
                    <button class="filter-btn" data-f="delivered" onclick="setFilter(this)">Delivered</button>
                    <button class="filter-btn" data-f="cancelled" onclick="setFilter(this)">Cancelled</button>
                    <button class="filter-btn" data-f="returned" onclick="setFilter(this)">Returned</button>
                </div>
                <div class="table-card">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Order Summary</th>
                                <th>Date</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="ordersBody"></tbody>
                    </table>
                    <div class="empty-state d-none" id="emptyState">
                        <i class="bi bi-bag-x"></i>
                        <p>No orders match your search or filter.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="toast-container" id="toastCont"></div>

        <!-- ORDER DETAIL MODAL -->
        <div class="modal fade" id="detailModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <div>
                            <div class="modal-title" id="detailTitle">Order Details</div>
                            <span class="order-id-tag mt-1 d-inline-block" id="detailId"></span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn-primary-c" onclick="downloadInvoice()"><i
                                    class="bi bi-download"></i>Download
                                Invoice</button>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                    </div>
                    <div class="modal-body">
                        <div class="detail-section">
                            <div class="detail-section-title">Order Tracking</div>
                            <div class="timeline" id="detailTimeline"></div>
                        </div>
                        <div class="detail-section">
                            <div class="detail-section-title">Order Information</div>
                            <div class="info-grid" id="detailInfo"></div>
                        </div>
                        <div class="detail-section">
                            <div class="detail-section-title">Items</div>
                            <div id="detailItems"></div>
                        </div>
                        <div class="summary-box" id="detailSummary"></div>
                        <div id="detailActions" class="mt-3 d-flex gap-2"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CANCEL MODAL -->
        <div class="modal fade" id="cancelModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered" style="max-width:480px">
                <div class="modal-content">
                    <div class="modal-header">
                        <div class="modal-title" id="cancelModalTitle">Cancel Order</div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted mb-3" style="font-size:.85rem" id="cancelModalDesc"></p>
                        <div id="cancelReasonList"></div>
                        <div class="mt-3">
                            <label
                                style="font-size:.78rem;color:var(--muted);margin-bottom:4px;display:block">Additional
                                notes (optional)</label>
                            <textarea id="cancelNoteInput" class="form-control" rows="3"
                                placeholder="Any extra details…"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-outline-c" data-bs-dismiss="modal">Back</button>
                        <button class="btn-danger-c" id="confirmCancelBtn">Confirm Cancellation</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- RETURN MODAL -->
        <div class="modal fade" id="returnModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered" style="max-width:480px">
                <div class="modal-content">
                    <div class="modal-header">
                        <div class="modal-title">Return Order</div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted mb-3" style="font-size:.85rem">Select a reason <span
                                class="text-danger fw-semibold">*required</span></p>
                        <div id="returnReasonList"></div>
                        <div class="mt-3">
                            <label style="font-size:.78rem;color:var(--muted);margin-bottom:4px;display:block">Describe
                                the
                                issue <span class="text-danger">*</span></label>
                            <textarea id="returnNoteInput" class="form-control" rows="3"
                                placeholder="Please describe what went wrong…"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-outline-c" data-bs-dismiss="modal">Back</button>
                        <button class="btn-primary-c" id="confirmReturnBtn">Submit Return Request</button>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            // ── DATA ─────────────────────────────────────────────────────────
            let orders = [
                {
                    id: 'ORD-2025-8821', date: '2025-06-18', status: 'delivered', name: 'Electronics Bundle',
                    address: '12/A Garden Lane, Kozhikode, KL 673001', payment: 'UPI · GPay', shipping: 0, discount: 500,
                    items: [
                        { id: 'i1', emoji: '🎧', name: 'Sony WH-1000XM5 Headphones', variant: 'Midnight Black', qty: 1, price: 24990, stock: 14, status: 'active' },
                        { id: 'i2', emoji: '🔌', name: 'Anker 65W Charger', variant: 'White', qty: 2, price: 1499, stock: 30, status: 'active' },
                    ]
                },
                {
                    id: 'ORD-2025-7714', date: '2025-06-10', status: 'shipped', name: 'Fashion & Accessories',
                    address: '45B Hilltop Colony, Malappuram, KL 676505', payment: 'Credit Card · HDFC', shipping: 99, discount: 0,
                    items: [
                        { id: 'i3', emoji: '👟', name: 'Nike Air Max 270', variant: 'Size UK-9 · White/Blue', qty: 1, price: 8995, stock: 8, status: 'active' },
                        { id: 'i4', emoji: '👜', name: 'Fossil Leather Wallet', variant: 'Dark Brown', qty: 1, price: 2499, stock: 20, status: 'active' },
                        { id: 'i5', emoji: '🕶️', name: 'Ray-Ban Wayfarer', variant: 'Classic Black', qty: 1, price: 6500, stock: 5, status: 'active' },
                    ]
                },
                {
                    id: 'ORD-2025-6603', date: '2025-05-29', status: 'processing', name: 'Home & Kitchen',
                    address: '7 Rose Street, Tirur, KL 676101', payment: 'Cash on Delivery', shipping: 49, discount: 200,
                    items: [
                        { id: 'i6', emoji: '☕', name: 'Morphy Richards Coffee Maker', variant: '800W · Black', qty: 1, price: 3299, stock: 6, status: 'active' },
                        { id: 'i7', emoji: '🍳', name: 'Prestige Non-Stick Pan Set', variant: '3-Piece', qty: 1, price: 1799, stock: 12, status: 'active' },
                    ]
                },
                {
                    id: 'ORD-2025-5509', date: '2025-05-14', status: 'cancelled', name: 'Books & Stationery',
                    address: '2 College Road, Kondotty, KL 673638', payment: 'UPI · PhonePe', shipping: 40, discount: 0,
                    cancelReason: 'Changed my mind',
                    items: [
                        { id: 'i8', emoji: '📘', name: 'Clean Code by Robert Martin', variant: 'Paperback', qty: 1, price: 699, stock: 51, status: 'cancelled' },
                        { id: 'i9', emoji: '📓', name: 'Leuchtturm1917 Notebook', variant: 'A5 · Dotted · Navy', qty: 2, price: 1200, stock: 20, status: 'cancelled' },
                        { id: 'i10', emoji: '✒️', name: 'Lamy Safari Fountain Pen', variant: 'Charcoal', qty: 1, price: 1850, stock: 8, status: 'cancelled' },
                    ]
                },
                {
                    id: 'ORD-2025-4412', date: '2025-04-30', status: 'delivered', name: 'Fitness Equipment',
                    address: '12/A Garden Lane, Kozhikode, KL 673001', payment: 'Net Banking · SBI', shipping: 0, discount: 150,
                    items: [
                        { id: 'i11', emoji: '🏋️', name: 'Boldfit Resistance Bands', variant: '5 Levels', qty: 1, price: 799, stock: 25, status: 'active' },
                        { id: 'i12', emoji: '🧘', name: 'Yoga Mat Premium 6mm', variant: 'Purple', qty: 1, price: 1299, stock: 10, status: 'active' },
                    ]
                },
                {
                    id: 'ORD-2025-3301', date: '2025-04-02', status: 'returned', name: 'Skincare Essentials',
                    address: '12/A Garden Lane, Kozhikode, KL 673001', payment: 'UPI · GPay', shipping: 0, discount: 0,
                    returnReason: 'Product was damaged', returnNote: 'The serum bottle was cracked on arrival.',
                    items: [
                        { id: 'i13', emoji: '🧴', name: 'CeraVe Moisturising Cream', variant: '250ml', qty: 2, price: 899, stock: 42, status: 'returned' },
                        { id: 'i14', emoji: '🌿', name: 'Minimalist Niacinamide Serum', variant: '30ml', qty: 1, price: 649, stock: 23, status: 'returned' },
                    ]
                },
            ];

            const cancelReasons = ['Changed my mind', 'Found a better price', 'Ordered by mistake', 'Delivery too long', 'Duplicate order', 'Other'];
            const returnReasons = ['Product was damaged', 'Wrong item received', 'Not as described', 'Missing accessories', 'Quality issues', 'Other'];

            // ── HELPERS ──────────────────────────────────────────────────────
            const fmt = n => '₹' + Number(n).toLocaleString('en-IN');
            const fmtDate = d => new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
            const subtotal = o => o.items.reduce((s, i) => s + (i.price * i.qty), 0);
            const getTotal = o => subtotal(o) + o.shipping - o.discount;

            const badgeHTML = {
                delivered: '<span class="badge-pill s-delivered">Delivered</span>',
                processing: '<span class="badge-pill s-processing">Processing</span>',
                shipped: '<span class="badge-pill s-shipped">Shipped</span>',
                cancelled: '<span class="badge-pill s-cancelled">Cancelled</span>',
                returned: '<span class="badge-pill s-returned">Returned</span>',
            };

            const tlSteps = {
                processing: ['Placed', 'Processing', 'Shipped', 'Delivered'],
                shipped: ['Placed', 'Processing', 'Shipped', 'Delivered'],
                delivered: ['Placed', 'Processing', 'Shipped', 'Delivered'],
                cancelled: ['Placed', 'Cancelled'],
                returned: ['Placed', 'Delivered', 'Return Requested', 'Returned'],
            };
            const tlDone = { processing: 1, shipped: 2, delivered: 3, cancelled: 1, returned: 3 };

            let currentFilter = 'all', openOrderId = null;
            let cancelTarget = null, returnTarget = null;
            let selCancelReason = '', selReturnReason = '';

            // ── STATS ────────────────────────────────────────────────────────
            function renderStats() {
                const c = { processing: 0, shipped: 0, delivered: 0, cancelled: 0 };
                orders.forEach(o => { if (c[o.status] !== undefined) c[o.status]++ });
                const items = [
                    { label: 'Total Orders', val: orders.length, icon: 'bi-bag', bg: '#eff6ff', ic: '#3b6ef8' },
                    { label: 'Delivered', val: c.delivered, icon: 'bi-check-circle', bg: '#ecfdf5', ic: '#0fba81' },
                    { label: 'In Transit', val: c.shipped + c.processing, icon: 'bi-truck', bg: '#fffbeb', ic: '#f59e0b' },
                    { label: 'Cancelled', val: c.cancelled, icon: 'bi-x-circle', bg: '#fef2f2', ic: '#ef4444' },
                ];
                document.getElementById('statsRow').innerHTML = items.map(s => `
    <div class="stat-card">
      <div class="stat-icon" style="background:${s.bg}"><i class="bi ${s.icon}" style="color:${s.ic}"></i></div>
      <div><div class="stat-val">${s.val}</div><div class="stat-label">${s.label}</div></div>
    </div>`).join('');
            }

            // ── TABLE ────────────────────────────────────────────────────────
            function applyFilters() {
                const q = document.getElementById('searchInput').value.toLowerCase().trim();
                let list = orders;
                if (currentFilter !== 'all') list = list.filter(o => o.status === currentFilter);
                if (q) list = list.filter(o => o.id.toLowerCase().includes(q) || o.name.toLowerCase().includes(q) || o.items.some(i => i.name.toLowerCase().includes(q)));
                renderTable(list);
            }
            function setFilter(btn) {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentFilter = btn.dataset.f;
                applyFilters();
            }
            function renderTable(list) {
                const tbody = document.getElementById('ordersBody');
                const empty = document.getElementById('emptyState');
                if (!list.length) { tbody.innerHTML = ''; empty.classList.remove('d-none'); return }
                empty.classList.add('d-none');
                tbody.innerHTML = list.map(o => {
                    const cnt = o.items.reduce((s, i) => s + i.qty, 0);
                    const canCancel = ['processing', 'shipped'].includes(o.status);
                    const canReturn = o.status === 'delivered';
                    return `<tr onclick="openDetail('${o.id}')">
      <td><span class="order-id-tag">${o.id}</span></td>
      <td><div class="order-name">${o.name}</div>
        <div class="order-sub">${o.items.slice(0, 2).map(i => i.name).join(', ')}${o.items.length > 2 ? ` +${o.items.length - 2} more` : ''}</div></td>
      <td style="white-space:nowrap;color:var(--muted);font-size:.83rem">${fmtDate(o.date)}</td>
      <td style="font-size:.83rem">${cnt} item${cnt > 1 ? 's' : ''}</td>
      <td style="font-weight:700">${fmt(getTotal(o))}</td>
      <td>${badgeHTML[o.status] || ''}</td>
      <td onclick="event.stopPropagation()">
        <button class="act-btn" title="View Details" onclick="openDetail('${o.id}')"><i class="bi bi-eye"></i></button>
        <button class="act-btn" title="Download Invoice" onclick="downloadInvoiceFor('${o.id}')" style="color:var(--green)"><i class="bi bi-download"></i></button>
        ${canCancel ? `<button class="act-btn danger" title="Cancel Order" onclick="openCancelModal('${o.id}',null)"><i class="bi bi-x-lg"></i></button>` : ''}
        ${canReturn ? `<button class="act-btn warn" title="Return Order" onclick="openReturnModal('${o.id}')"><i class="bi bi-arrow-return-left"></i></button>` : ''}
      </td>
    </tr>`;
                }).join('');
            }

            // ── DETAIL MODAL ─────────────────────────────────────────────────
            function openDetail(id) {
                const o = orders.find(x => x.id === id); if (!o) return;
                openOrderId = id;
                document.getElementById('detailTitle').textContent = o.name;
                document.getElementById('detailId').textContent = o.id;

                // Timeline
                const steps = tlSteps[o.status] || [];
                const done = tlDone[o.status] || 0;
                document.getElementById('detailTimeline').innerHTML = steps.map((s, i) => {
                    const cls = i < done ? 'done' : i === done ? 'current' : '';
                    const icon = i < done ? '<i class="bi bi-check2"></i>' : i === done ? '<i class="bi bi-circle-fill" style="font-size:.45rem"></i>' : '';
                    return `<div class="tl-step ${cls}"><div class="tl-dot">${icon}</div><div class="tl-label">${s}</div></div>`;
                }).join('');

                // Info
                let extra = '';
                if (o.cancelReason) extra += `<div class="info-item"><label>Cancel Reason</label><span>${o.cancelReason}</span></div>`;
                if (o.returnReason) extra += `<div class="info-item"><label>Return Reason</label><span>${o.returnReason}</span></div>`;
                if (o.returnNote) extra += `<div class="info-item" style="grid-column:1/-1"><label>Return Details</label><span>${o.returnNote}</span></div>`;
                document.getElementById('detailInfo').innerHTML = `
    <div class="info-item"><label>Order Date</label><span>${fmtDate(o.date)}</span></div>
    <div class="info-item"><label>Status</label><span>${badgeHTML[o.status]}</span></div>
    <div class="info-item"><label>Payment</label><span>${o.payment}</span></div>
    <div class="info-item" style="grid-column:1/-1"><label>Delivery Address</label><span>${o.address}</span></div>
    ${extra}`;

                // Items
                const canItemCancel = ['processing', 'shipped'].includes(o.status);
                document.getElementById('detailItems').innerHTML = o.items.map(item => {
                    let tag = '';
                    if (item.status === 'cancelled') tag = '<span class="item-cancelled-tag">Cancelled</span>';
                    if (item.status === 'returned') tag = '<span class="item-returned-tag">Returned</span>';
                    const cBtn = canItemCancel && item.status === 'active'
                        ? `<button class="item-cancel-btn" onclick="openCancelModal('${o.id}','${item.id}')">Cancel Item</button>` : '';
                    return `<div class="item-row">
      <div class="item-thumb">${item.emoji}</div>
      <div style="flex:1">
        <div class="item-name">${item.name}${tag}</div>
        <div class="item-variant">${item.variant}</div>
        <div class="item-qty">Qty: ${item.qty} &nbsp;·&nbsp; Stock after: ${item.stock}</div>
      </div>
      <div class="item-price">${fmt(item.price * item.qty)}</div>
      ${cBtn}
    </div>`;
                }).join('');

                // Summary
                const active = o.items.filter(i => i.status === 'active');
                const activeSub = active.reduce((s, i) => s + (i.price * i.qty), 0);
                const cancelledRef = o.items.filter(i => i.status === 'cancelled').reduce((s, i) => s + (i.price * i.qty), 0);
                const allGone = active.length === 0;
                document.getElementById('detailSummary').innerHTML = `
    <div class="sum-row"><span>Subtotal</span><span>${fmt(subtotal(o))}</span></div>
    ${cancelledRef > 0 ? `<div class="sum-row"><span style="color:var(--red)">Cancelled items (refund)</span><span style="color:var(--red)">− ${fmt(cancelledRef)}</span></div>` : ''}
    <div class="sum-row"><span>Shipping</span><span>${o.shipping === 0 ? '<span style="color:var(--green)">Free</span>' : fmt(o.shipping)}</span></div>
    ${o.discount > 0 ? `<div class="sum-row"><span>Discount</span><span style="color:var(--green)">− ${fmt(o.discount)}</span></div>` : ''}
    <div class="sum-row total"><span>Total</span><span>${fmt(allGone ? 0 : activeSub + o.shipping - o.discount)}</span></div>`;

                // Action buttons
                const actDiv = document.getElementById('detailActions');
                actDiv.innerHTML = '';
                if (o.status === 'delivered') {
                    const btn = document.createElement('button');
                    btn.className = 'btn-outline-c';
                    btn.innerHTML = '<i class="bi bi-arrow-return-left"></i>Request Return';
                    btn.onclick = () => { bootstrap.Modal.getInstance(document.getElementById('detailModal'))?.hide(); openReturnModal(id) };
                    actDiv.appendChild(btn);
                }
                if (['processing', 'shipped'].includes(o.status)) {
                    const btn = document.createElement('button');
                    btn.className = 'btn-danger-c';
                    btn.innerHTML = '<i class="bi bi-x-circle"></i>Cancel Entire Order';
                    btn.onclick = () => { bootstrap.Modal.getInstance(document.getElementById('detailModal'))?.hide(); openCancelModal(id, null) };
                    actDiv.appendChild(btn);
                }

                new bootstrap.Modal(document.getElementById('detailModal')).show();
            }

            // ── CANCEL MODAL ─────────────────────────────────────────────────
            function openCancelModal(orderId, itemId) {
                cancelTarget = { orderId, itemId }; selCancelReason = '';
                document.getElementById('cancelNoteInput').value = '';
                const o = orders.find(x => x.id === orderId);
                document.getElementById('cancelModalTitle').textContent = itemId ? `Cancel Item — ${o?.items.find(i => i.id === itemId)?.name || ''}` : `Cancel Order ${orderId}`;
                document.getElementById('cancelModalDesc').textContent = itemId
                    ? 'Choose a reason for cancelling this item (optional). Stock will be restored.'
                    : 'Choose a reason for cancellation (optional). Stock will be fully restored.';
                document.getElementById('cancelReasonList').innerHTML = cancelReasons.map(r => `
    <div class="reason-option" onclick="selectReason(this,'cancel','${r}')">
      <input type="radio" name="cR" value="${r}"/><span style="font-size:.85rem">${r}</span>
    </div>`).join('');
                document.getElementById('confirmCancelBtn').onclick = doCancel;
                new bootstrap.Modal(document.getElementById('cancelModal')).show();
            }
            function selectReason(el, type, val) {
                el.closest('[id$="ReasonList"]').querySelectorAll('.reason-option').forEach(e => e.classList.remove('selected'));
                el.classList.add('selected'); el.querySelector('input').checked = true;
                if (type === 'cancel') selCancelReason = val; else selReturnReason = val;
            }
            function doCancel() {
                const { orderId, itemId } = cancelTarget;
                const o = orders.find(x => x.id === orderId); if (!o) return;
                const reason = selCancelReason || document.getElementById('cancelNoteInput').value.trim() || '';
                if (itemId) {
                    const item = o.items.find(i => i.id === itemId);
                    if (item) { item.stock += item.qty; item.status = 'cancelled'; }
                    if (o.items.every(i => i.status === 'cancelled')) { o.status = 'cancelled'; o.cancelReason = reason; }
                } else {
                    o.items.forEach(i => { if (i.status === 'active') { i.stock += i.qty; i.status = 'cancelled'; } });
                    o.status = 'cancelled'; o.cancelReason = reason;
                }
                bootstrap.Modal.getInstance(document.getElementById('cancelModal'))?.hide();
                toast('success', 'bi-check-circle-fill', itemId ? 'Item cancelled. Stock restored.' : 'Order cancelled. Stock fully restored.');
                renderStats(); applyFilters();
            }

            // ── RETURN MODAL ─────────────────────────────────────────────────
            function openReturnModal(orderId) {
                returnTarget = orderId; selReturnReason = '';
                document.getElementById('returnNoteInput').value = '';
                document.getElementById('returnReasonList').innerHTML = returnReasons.map(r => `
    <div class="reason-option" onclick="selectReason(this,'return','${r}')">
      <input type="radio" name="rR" value="${r}"/><span style="font-size:.85rem">${r}</span>
    </div>`).join('');
                document.getElementById('confirmReturnBtn').onclick = doReturn;
                new bootstrap.Modal(document.getElementById('returnModal')).show();
            }
            function doReturn() {
                const note = document.getElementById('returnNoteInput').value.trim();
                if (!selReturnReason) { toast('danger', 'bi-exclamation-circle-fill', 'Please select a return reason.'); return; }
                if (!note) { toast('danger', 'bi-exclamation-circle-fill', 'Please describe the issue (required for returns).'); return; }
                const o = orders.find(x => x.id === returnTarget); if (!o) return;
                o.status = 'returned'; o.returnReason = selReturnReason; o.returnNote = note;
                o.items.forEach(i => i.status = 'returned');
                bootstrap.Modal.getInstance(document.getElementById('returnModal'))?.hide();
                toast('success', 'bi-arrow-return-left', 'Return request submitted successfully.');
                renderStats(); applyFilters();
            }

            // ── INVOICE PDF ──────────────────────────────────────────────────
            function downloadInvoiceFor(id) { const o = orders.find(x => x.id === id); if (o) genPDF(o); }
            function downloadInvoice() { const o = orders.find(x => x.id === openOrderId); if (o) genPDF(o); }

            function genPDF(o) {
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF({ unit: 'mm', format: 'a4' });
                const W = 210, pad = 18;

                // Header
                doc.setFillColor(24, 28, 46); doc.rect(0, 0, W, 40, 'F');
                doc.setTextColor(255, 255, 255); doc.setFontSize(22); doc.setFont('helvetica', 'bold');
                doc.text('ShopHub', pad, 18);
                doc.setFontSize(8); doc.setFont('helvetica', 'normal'); doc.setTextColor(160, 170, 200);
                doc.text('Customer Portal  ·  shophub.example.com', pad, 25);
                doc.setFontSize(18); doc.setFont('helvetica', 'bold'); doc.setTextColor(255, 255, 255);
                doc.text('INVOICE', W - pad, 18, { align: 'right' });
                doc.setFontSize(8); doc.setFont('helvetica', 'normal'); doc.setTextColor(160, 170, 200);
                doc.text(o.id, W - pad, 25, { align: 'right' });
                doc.text('Date: ' + fmtDate(o.date), W - pad, 30, { align: 'right' });

                // Status chip
                const sc = { delivered: [15, 186, 129], processing: [245, 158, 11], shipped: [59, 110, 248], cancelled: [239, 68, 68], returned: [249, 115, 22] };
                const col = sc[o.status] || [120, 120, 120];
                doc.setFillColor(...col); doc.roundedRect(pad, 46, 38, 9, 2, 2, 'F');
                doc.setTextColor(255, 255, 255); doc.setFontSize(8); doc.setFont('helvetica', 'bold');
                doc.text(o.status.toUpperCase(), pad + 19, 51.8, { align: 'center' });

                // Bill to
                doc.setTextColor(107, 114, 128); doc.setFontSize(7); doc.setFont('helvetica', 'bold'); doc.text('BILL TO', pad, 64);
                doc.setTextColor(17, 24, 39); doc.setFontSize(10); doc.setFont('helvetica', 'bold'); doc.text('Arjun Kumar', pad, 70);
                doc.setFont('helvetica', 'normal'); doc.setFontSize(8.5); doc.setTextColor(55, 65, 81);
                doc.text(o.address, pad, 76, { maxWidth: 95 });
                doc.text('Payment: ' + o.payment, pad, 87);

                // Items table
                const rows = o.items.map(i => [
                    i.name, i.variant, String(i.qty), fmt(i.price), fmt(i.price * i.qty),
                    i.status !== 'active' ? i.status.toUpperCase() : ''
                ]);
                doc.autoTable({
                    startY: 95,
                    head: [['Product', 'Variant', 'Qty', 'Unit Price', 'Total', 'Note']],
                    body: rows, theme: 'grid',
                    headStyles: { fillColor: [24, 28, 46], textColor: 255, fontSize: 8, fontStyle: 'bold' },
                    bodyStyles: { fontSize: 8.5, textColor: [17, 24, 39] },
                    columnStyles: { 0: { cellWidth: 62 }, 1: { cellWidth: 38 }, 2: { cellWidth: 12, halign: 'center' }, 3: { cellWidth: 24, halign: 'right' }, 4: { cellWidth: 24, halign: 'right' }, 5: { cellWidth: 22, halign: 'center' } },
                    margin: { left: pad, right: pad },
                    alternateRowStyles: { fillColor: [247, 249, 255] },
                });

                const fy = doc.lastAutoTable.finalY + 10;

                // Summary box
                doc.setFillColor(240, 242, 247); doc.roundedRect(W - pad - 72, fy, 72, 52, 3, 3, 'F');
                const sRows = [['Subtotal', fmt(subtotal(o))], ['Shipping', o.shipping === 0 ? 'Free' : fmt(o.shipping)], ['Discount', o.discount > 0 ? '- ' + fmt(o.discount) : 'None'], ['TOTAL', fmt(getTotal(o))]];
                let sy = fy + 10;
                sRows.forEach(([l, v], idx) => {
                    const bold = idx === 3;
                    doc.setFont('helvetica', bold ? 'bold' : 'normal'); doc.setFontSize(bold ? 10 : 8.5);
                    doc.setTextColor(bold ? 27 : 100, bold ? 40 : 116, bold ? 80 : 139); doc.text(l, W - pad - 68, sy);
                    doc.setTextColor(bold ? 59 : 17, bold ? 110 : 24, bold ? 248 : 39); doc.text(v, W - pad - 4, sy, { align: 'right' });
                    sy += bold ? 0 : 9;
                    if (bold) { doc.setDrawColor(200, 208, 230); doc.line(W - pad - 70, sy - 5, W - pad - 2, sy - 5); sy += 7; }
                });

                // Footer
                const ph = doc.internal.pageSize.height;
                doc.setFillColor(240, 242, 247); doc.rect(0, ph - 16, W, 16, 'F');
                doc.setTextColor(156, 163, 175); doc.setFontSize(7.5); doc.setFont('helvetica', 'normal');
                doc.text('Thank you for shopping with ShopHub!  ·  support@shophub.example.com', W / 2, ph - 9, { align: 'center' });
                doc.text('Computer-generated invoice — no signature required.', W / 2, ph - 5, { align: 'center' });

                doc.save('Invoice_' + o.id + '.pdf');
                toast('success', 'bi-download', 'Invoice saved as Invoice_' + o.id + '.pdf');
            }

            // ── TOAST ────────────────────────────────────────────────────────
            function toast(type, icon, msg) {
                const c = document.getElementById('toastCont');
                const el = document.createElement('div');
                el.className = 'toast-msg ' + type;
                el.innerHTML = `<i class="bi ${icon}"></i>${msg}`;
                c.appendChild(el);
                setTimeout(() => el.remove(), 3500);
            }

            // ── INIT ─────────────────────────────────────────────────────────
            renderStats();
            applyFilters();
        </script>
</body>

</html>