<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tax Invoice | Order #<%= order.orderId %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background: #fdfdfd;
            padding: 40px;
            color: #111;
        }

        .invoice-box {
            max-width: 1000px;
            margin: auto;
            background: #fff;
            padding: 30px;
            border: 1px solid #efefef;
        }

        .header-line {
            border-bottom: 2px solid #000;
            margin-bottom: 25px;
        }

        .label-text {
            font-size: 13px;
            font-weight: 800;
            color: #000;
            margin-bottom: 2px;
        }

        .value-text {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #333;
        }

        .inv-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 30px;
        }

        .inv-table th {
            border-top: 2px solid #444;
            border-bottom: 2px solid #444;
            padding: 12px 10px;
            font-size: 11px;
            font-weight: 800;
            text-align: center;
            text-transform: uppercase;
        }

        .inv-table td {
            padding: 15px 10px;
            font-size: 12px;
            vertical-align: top;
            border-bottom: 1px solid #eee;
        }

        .summary-row td {
            border-top: 2px solid #444;
            border-bottom: 2px solid #444;
            font-weight: 800;
            padding: 10px;
        }

        .grand-total-box {
            margin-top: 30px;
            text-align: right;
        }

        .no-print-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #111;
            color: #fff;
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            transition: 0.3s;
            z-index: 100;
        }

        .no-print-btn:hover {
            background: #333;
            transform: translateY(-2px);
        }

        @media print {
            .no-print-btn {
                display: none;
            }

            body {
                padding: 0;
            }

            .invoice-box {
                border: none;
                box-shadow: none;
            }
        }
    </style>
</head>

<body>

    <button onclick="downloadPDF()" class="no-print-btn">
        <i class="fas fa-file-pdf"></i> Download Official Bill
    </button>

    <div class="invoice-box" id="invoice">
        <!-- Top Details -->
        <div class="flex justify-between items-start mb-8">
            <div class="w-1/2">
                <p class="label-text">Order ID:</p>
                <p class="value-text">
                    <%= order.orderId %>
                </p>

                <p class="label-text">Order Date:</p>
                <p class="value-text">
                    <%= new Date(order.createdAt).toLocaleDateString('en-GB') %>
                </p>

                <p class="label-text">Invoice Date:</p>
                <p class="value-text">
                    <%= new Date().toLocaleDateString('en-GB') %>
                </p>

                <p class="label-text">PAN:</p>
                <p class="value-text">AACCU3841N</p>

                <p class="label-text">CIN:</p>
                <p class="value-text">U74999UP2019PTC182407</p>
            </div>
            <div class="w-1/2">
                <p class="label-text">Billing Address</p>
                <p class="value-text" style="line-height: 1.5; font-weight: 500;">
                    <%= order.shippingAddress.fullName %><br>
                        <%= order.shippingAddress.houseName %>(H), <%= order.shippingAddress.locality %>,<br>
                                <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%=
                                            order.shippingAddress.pincode %><br>
                                            Phone: <%= order.shippingAddress.phone %>
                </p>
            </div>
        </div>

        <!-- Horizontal Line -->
        <div class="header-line"></div>

        <!-- Items Table -->
        <table class="inv-table">
            <thead>
                <tr>
                    <th class="text-left" style="width: 45%;">Description</th>
                    <th>Qty</th>
                    <th class="text-right">Unit Price ₹</th>
                    <th class="text-right">Taxable <br> value ₹</th>
                    <th class="text-right">IGST (18%) ₹</th>
                    <th class="text-right">Total ₹</th>
                </tr>
            </thead>
            <tbody>
                <% order.items.forEach(item=> {
                    const taxable = item.total / 1.18;
                    const igst = item.total - taxable;
                    %>
                    <tr>
                        <td class="text-left font-semibold">
                            <%= item.name %>
                                <p class="text-[10px] text-gray-500 font-normal">
                                    [Variant: <%= item.RAM %>GB/<%= item.storage %>GB | Color: <%= item.color %>]
                                </p>
                                <p class="text-[10px] text-gray-400 font-normal">SAC: 851799</p>
                        </td>
                        <td class="text-center font-bold">
                            <%= item.quantity %>
                        </td>
                        <td class="text-right">
                            <%= item.price.toFixed(2) %>
                        </td>
                        <td class="text-right">
                            <%= taxable.toFixed(2) %>
                        </td>
                        <td class="text-right">
                            <%= igst.toFixed(2) %>
                        </td>
                        <td class="text-right font-bold">
                            <%= item.total.toFixed(2) %>
                        </td>
                    </tr>
                    <% }) %>

                        <!-- Summary rows -->
                        <tr class="summary-row">
                            <td colspan="4" class="text-right border-t-2 border-black">Subtotal</td>
                            <td colspan="2" class="text-right border-t-2 border-black">₹<%= order.subtotal.toFixed(2) %>
                            </td>
                        </tr>
                        <% if (order.discount> 0) { %>
                            <tr>
                                <td colspan="4" class="text-right py-2">Coupon/Discount</td>
                                <td colspan="2" class="text-right py-2 text-green-600">- ₹<%= order.discount.toFixed(2)
                                        %>
                                </td>
                            </tr>
                            <% } %>
                                <tr>
                                    <td colspan="4" class="text-right py-2">Shipping</td>
                                    <td colspan="2" class="text-right py-2">
                                        <%= order.shippingCharge===0 ? 'FREE' : '₹' + order.shippingCharge.toFixed(2) %>
                                    </td>
                                </tr>
            </tbody>
        </table>

        <!-- Grand Total Section -->
        <div class="grand-total-box flex justify-end items-center gap-10 mt-6 border-t-2 border-black pt-4">
            <span class="text-xl font-medium">Grand Total</span>
            <span class="text-3xl font-black text-blue-900">₹<%= order.finalPrice.toLocaleString('en-IN') %>.00</span>
        </div>

        <div class="mt-4 text-[11px] text-gray-500">
            <p><strong>Payment Method:</strong>
                <%= order.paymentMethod %>
            </p>
            <p><strong>Payment Status:</strong>
                <%= order.paymentStatus %>
            </p>
            <p><strong>Amount in Words:</strong> Indian Rupees Only</p>
        </div>

        <!-- Authorized Signatory Section -->
        <div class="flex flex-col items-end mt-8">
            <p class="text-sm font-bold text-gray-800 mb-2">Zyrox E-Commerce Solutions</p>
            <div class="border border-gray-100 p-2 bg-gray-50">
                <div style="width: 180px; height: 60px; position:relative; overflow:hidden;">
                    <svg viewBox="0 0 500 150" preserveAspectRatio="none" style="height: 100%; width: 100%;">
                        <path d="M50,100 Q150,50 250,100 T450,100" fill="none" stroke="#2b448a" stroke-width="6" />
                    </svg>
                    <p style="position:absolute; bottom:0; right:0; font-size:8px; opacity:0.3;">DIGITALLY SIGNED</p>
                </div>
            </div>
            <p class="text-sm font-bold text-black mt-2">Authorized Signatory</p>
        </div>
    </div>

    <!-- FontAwesome for the PDF icon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <script>
        function downloadPDF() {
            const element = document.getElementById('invoice');
            const opt = {
                margin: 0.2,
                filename: 'Zyrox_Tax_Invoice_<%= order.orderId %>.pdf',
                image: { type: 'jpeg', quality: 1 },
                html2canvas: { scale: 3, useCORS: true, letterRendering: true },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
            };
            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>

</html>