<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Receipt | Order #<%= order.orderId %></title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=3">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #1a2a4d;
            --accent-color: #4f6ef7;
            --text-dark: #1f2937;
            --text-light: #6b7280;
            --border-color: #e5e7eb;
            --success-bg: #ecfdf5;
            --success-text: #059669;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
            margin: 0;
            padding: 40px 20px;
            color: var(--text-dark);
        }

        .receipt-actions {
            max-width: 850px;
            margin: 0 auto 20px auto;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .btn-action {
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            border: none;
            text-decoration: none;
        }

        .btn-download {
            background-color: var(--primary-color);
            color: white;
        }

        .btn-download:hover {
            background-color: #111b33;
            transform: translateY(-1px);
        }

        .btn-print {
            background-color: white;
            color: var(--text-dark);
            border: 1px solid var(--border-color);
        }

        .btn-print:hover {
            background-color: #f9fafb;
        }

        .receipt-container {
            max-width: 850px;
            margin: 0 auto;
            background-color: white;
            padding: 60px;
            border-radius: 4px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            position: relative;
        }

        .receipt-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 50px;
        }

        .brand {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .brand-logo {
            font-size: 2rem;
            font-weight: 900;
            color: var(--primary-color);
            letter-spacing: -1px;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-logo i {
            color: var(--accent-color);
            font-size: 1.8rem;
        }

        .brand-tagline {
            font-size: 0.8rem;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .receipt-title-box {
            text-align: right;
        }

        .receipt-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--primary-color);
            margin: 0 0 10px 0;
            text-transform: uppercase;
        }

        .receipt-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 50px;
        }

        .info-section-title {
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 8px;
        }

        .info-content p {
            margin: 4px 0;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .info-content .name {
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 8px;
        }

        .order-meta {
            text-align: right;
        }

        .meta-item {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .meta-label {
            font-weight: 600;
            color: var(--text-light);
        }

        .meta-value {
            font-weight: 700;
            min-width: 140px;
        }

        .status-badge-paid {
            background-color: var(--success-bg);
            color: var(--success-text);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 40px;
        }

        .items-table th {
            background-color: #f9fafb;
            padding: 15px;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
        }

        .items-table td {
            padding: 20px 15px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: top;
        }

        .item-desc {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .item-name {
            font-weight: 700;
            font-size: 1rem;
            color: var(--primary-color);
        }

        .item-meta {
            font-size: 0.8rem;
            color: var(--text-light);
        }

        .text-center { text-align: center; }
        .text-right { text-align: right; }

        .summary-container {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 50px;
        }

        .summary-box {
            width: 350px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            font-size: 1rem;
        }

        .summary-label {
            color: var(--text-light);
            font-weight: 500;
        }

        .summary-value {
            font-weight: 600;
            color: var(--text-dark);
        }

        .summary-row.total {
            margin-top: 15px;
            padding-top: 20px;
            border-top: 2px solid var(--primary-color);
            font-size: 1.5rem;
            font-weight: 900;
        }

        .summary-row.total .summary-label {
            color: var(--primary-color);
            font-weight: 800;
        }

        .summary-row.total .summary-value {
            color: var(--primary-color);
            font-weight: 900;
        }

        .payment-footer {
            border-top: 1px solid var(--border-color);
            padding-top: 30px;
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 40px;
        }

        .payment-method-box {
            background-color: #f9fafb;
            padding: 20px;
            border-radius: 8px;
        }

        .payment-method-title {
            font-size: 0.8rem;
            font-weight: 800;
            color: var(--text-light);
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .payment-method-value {
            font-weight: 700;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .transaction-note {
            margin-top: 15px;
            font-size: 0.85rem;
            line-height: 1.6;
            color: var(--text-light);
        }

        .signature-box {
            text-align: right;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .signature-img {
            width: 150px;
            height: 60px;
            margin-bottom: 10px;
            opacity: 0.8;
        }

        .signature-line {
            width: 200px;
            height: 1px;
            background-color: var(--border-color);
            margin-bottom: 10px;
        }

        .signatory-name {
            font-weight: 800;
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        .signatory-title {
            font-size: 0.75rem;
            color: var(--text-light);
        }

        .thanks-msg {
            margin-top: 60px;
            text-align: center;
            font-size: 0.9rem;
            color: var(--text-light);
            border-top: 1px dashed var(--border-color);
            padding-top: 30px;
        }

        .thanks-msg a {
            color: var(--accent-color);
            text-decoration: none;
            font-weight: 600;
        }

        /* Loading overlay shown while PDF is generating */
        #pdf-loading-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(243, 244, 246, 0.92);
            z-index: 9999;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 16px;
        }
        #pdf-loading-overlay.active {
            display: flex;
        }
        .spinner {
            width: 48px;
            height: 48px;
            border: 4px solid #e5e7eb;
            border-top-color: var(--primary-color);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media print {
            body { background-color: white; padding: 0; }
            .receipt-actions { display: none; }
            #pdf-loading-overlay { display: none !important; }
            .receipt-container { box-shadow: none; padding: 0; }
        }
    </style>
</head>

<body>

    <!-- Loading overlay for auto-download -->
    <div id="pdf-loading-overlay">
        <div class="spinner"></div>
        <p style="font-family: Inter, sans-serif; font-weight: 700; color: #1a2a4d; font-size: 1rem;">Generating your invoice…</p>
    </div>

    <div class="receipt-actions">
        <button onclick="window.print()" class="btn-action btn-print">
            <i class="fas fa-print"></i> Print
        </button>
        <button id="save-pdf-btn" onclick="downloadPDF()" class="btn-action btn-download">
            <i class="fas fa-download"></i> Save as PDF
        </button>
    </div>

    <div class="receipt-container" id="receipt">
        <div class="receipt-header">
            <div class="brand">
                <div class="brand-logo">
                    <i class="fas fa-bolt"></i> ZYROX
                </div>
                <div class="brand-tagline">Premium E-Commerce Experience</div>
            </div>
            <div class="receipt-title-box">
                <h1 class="receipt-title">Order Invoice</h1>
                <div class="order-meta">
                    <div class="meta-item">
                        <span class="meta-label">Receipt No:</span>
                        <span class="meta-value">REC-<%= order.orderId.substring(order.orderId.length - 8).toUpperCase() %></span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Date:</span>
                        <span class="meta-value"><%= new Date(order.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Order ID:</span>
                        <span class="meta-value">#<%= order.orderId %></span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Payment Status:</span>
                        <span class="meta-value">
                            <% if (order.paymentStatus === 'Paid') { %>
                                <span class="status-badge-paid">● PAID</span>
                            <% } else if (order.paymentStatus === 'Refunded') { %>
                                <span class="status-badge-paid" style="background:#eff6ff; color:#2563eb;">● REFUNDED</span>
                            <% } else if (order.paymentStatus === 'Failed') { %>
                                <span class="status-badge-paid" style="background:#fef2f2; color:#dc2626;">● FAILED</span>
                            <% } else { %>
                                <span class="status-badge-paid" style="background:#fffbeb; color:#d97706;">● <%= order.paymentStatus.toUpperCase() %></span>
                            <% } %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="receipt-info-grid">
            <div class="info-column">
                <h3 class="info-section-title">Customer Information</h3>
                <div class="info-content">
                    <p class="name"><%= order.shippingAddress.fullName %></p>
                    <p><%= order.shippingAddress.houseName %>(H), <%= order.shippingAddress.locality %></p>
                    <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
                    <p>Phone: <%= order.shippingAddress.phone %></p>
                    <p>Email: <%= user.email %></p>
                </div>
            </div>
            <div class="info-column">
                <h3 class="info-section-title">Billing From</h3>
                <div class="info-content">
                    <p class="name">Zyrox mobile store pvt ltd</p>
                    <p>PAN: AACCU3841N</p>
                    <p>CIN: U74999UP2019PTC182407</p>
                    <p>Contact: +91 9074105805</p>
                    <p>Email: zyroxmobilestore@gmail.com</p>
                </div>
            </div>
        </div>

        <table class="items-table">
            <thead>
                <tr>
                    <th style="width: 45%;">Item Description</th>
                    <th class="text-center">Qty</th>
                    <th class="text-right">Unit Price</th>
                    <th class="text-center" style="font-size: 0.65rem;">Status</th>
                    <th class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                <% order.items.forEach((item, index) => { %>
                    <tr>
                        <td>
                            <div class="item-desc">
                                <span class="item-name"><%= index + 1 %>. <%= item.name %></span>
                                <span class="item-meta">
                                    <% if (item.RAM) { %>RAM: <%= item.RAM %>GB | <% } %>
                                    <% if (item.storage) { %>Storage: <%= item.storage %>GB | <% } %>
                                    <% if (item.color) { %>Color: <%= item.color %><% } %>
                                </span>
                            </div>
                        </td>
                        <td class="text-center"><%= item.quantity %></td>
                        <td class="text-right">&#8377;<%= item.price.toLocaleString('en-IN') %></td>
                        <td class="text-center" style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase;">
                            <% if (['Cancelled', 'Cancellation Requested'].includes(item.status)) { %>
                                <span style="color: #ef4444;"><%= item.status === 'Cancelled' ? 'Cancelled' : 'Cancel Req' %></span>
                            <% } else if (['Returned', 'Return Requested'].includes(item.status)) { %>
                                <span style="color: #f59e0b;"><%= item.status === 'Returned' ? 'Returned' : 'Return Req' %></span>
                            <% } else if (item.status === 'Delivered') { %>
                                <span style="color: #10b981;">Delivered</span>
                            <% } else { %>
                                <span style="color: #6b7280;"><%= item.status %></span>
                            <% } %>
                        </td>
                        <td class="text-right">&#8377;<%= (item.price * item.quantity).toLocaleString('en-IN') %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="summary-container">
            <div class="summary-box">
                <% 
                    let deductionAmount = 0;
                    if (order.orderStatus === 'Cancelled' || order.orderStatus === 'Returned') {
                        deductionAmount = order.finalPrice;
                    } else {
                        order.items.forEach(item => {
                            if (['Cancelled', 'Returned'].includes(item.status)) {
                                let rAmount = item.total;
                                if (order.couponDiscount > 0 && order.subtotal > 0) {
                                    const proportion = item.total / order.subtotal;
                                    const itemCouponDiscount = order.couponDiscount * proportion;
                                    rAmount = item.total - itemCouponDiscount;
                                }
                                deductionAmount += rAmount;
                            }
                        });
                    }
                    deductionAmount = Math.round(deductionAmount);
                    const isRefund = ['Paid', 'Refunded'].includes(order.paymentStatus) && ['Online', 'Wallet'].includes(order.paymentMethod);
                    const deductionLabel = isRefund ? 'Refunded Amount' : 'Cancelled Amount';
                %>
                <div class="summary-row">
                    <span class="summary-label">Subtotal:</span>
                    <span class="summary-value">&#8377;<%= order.subtotal.toLocaleString('en-IN') %></span>
                </div>
                <% if (order.discount > 0) { %>
                    <div class="summary-row">
                        <span class="summary-label">Coupon Discount:</span>
                        <span class="summary-value" style="color: #059669;">- &#8377;<%= order.discount.toLocaleString('en-IN') %></span>
                    </div>
                <% } %>
                <div class="summary-row">
                    <span class="summary-label">Shipping Fee:</span>
                    <span class="summary-value"><%= order.shippingCharge === 0 ? 'FREE' : '₹' + order.shippingCharge.toLocaleString('en-IN') %></span>
                </div>
                <% if (deductionAmount > 0) { %>
                    <div class="summary-row">
                        <span class="summary-label"><%= deductionLabel %>:</span>
                        <span class="summary-value" style="color: #3b82f6;">- &#8377;<%= deductionAmount.toLocaleString('en-IN') %></span>
                    </div>
                <% } %>
                <div class="summary-row total">
                    <span class="summary-label">Grand Total:</span>
                    <% const finalNet = Math.max(0, order.finalPrice - deductionAmount); %>
                    <% if (finalNet === 0 && deductionAmount > 0) { %>
                        <span class="summary-value" style="font-size: 1.1rem; color: #3b82f6; text-transform: uppercase;"><%= isRefund ? 'FULLY REFUNDED' : 'FULLY CANCELLED' %></span>
                    <% } else { %>
                        <span class="summary-value">&#8377;<%= finalNet.toLocaleString('en-IN') %></span>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="payment-footer">
            <div class="payment-details">
                <div class="payment-method-box">
                    <div class="payment-method-title">Payment Method</div>
                    <div class="payment-method-value">
                        <% if (order.paymentMethod === 'Online') { %>
                            <i class="fas fa-credit-card"></i> Online Payment (Razorpay)
                        <% } else if (order.paymentMethod === 'Wallet') { %>
                            <i class="fas fa-wallet"></i> Zyrox Wallet
                        <% } else { %>
                            <i class="fas fa-money-bill-wave"></i> <%= order.paymentMethod %>
                        <% } %>
                    </div>
                </div>
                <div class="transaction-note">
                    <strong>Transaction Status:</strong> 
                    <% if (order.paymentStatus === 'Paid') { %>
                        Payment Received. Your order is confirmed and awaiting shipment. 
                        A tracking number will be provided once your items are dispatched.
                    <% } else if (order.paymentStatus === 'Failed') { %>
                        Payment Failed. The transaction was not completed successfully. 
                        Please retry payment or contact support if the amount was debited.
                    <% } else if (order.paymentStatus === 'Refunded') { %>
                        Payment Refunded. The transaction amount has been credited back to Wallet.
                    <% } else if (order.orderStatus === 'Cancelled') { %>
                        Order Cancelled. This order has been voided.
                    <% } else { %>
                        Payment Pending. Please complete the payment to process your order.
                    <% } %>
                </div>
            </div>
            <div class="signature-box">
                <div class="signature-img">
                    <svg viewBox="0 0 500 150" preserveAspectRatio="none" style="height: 100%; width: 100%;">
                        <path d="M50,100 Q150,50 250,100 T450,100" fill="none" stroke="#2b448a" stroke-width="4" />
                        <path d="M80,80 Q180,30 280,80 T480,80" fill="none" stroke="#2b448a" stroke-width="2" opacity="0.5" />
                    </svg>
                </div>
                <div class="signature-line"></div>
                <span class="signatory-name">Authorized Signatory</span>
                <span class="signatory-title">Zyrox E-Commerce Solutions</span>
            </div>
        </div>

        <div class="thanks-msg">
            Thank you for shopping with Zyrox! For support, email: <a href="mailto:support@zyrox.com">support@zyrox.com</a><br>
            Visit us at <a href="https://zyrox.busthan.online">www.zyrox.com</a>. All purchases subject to terms.
        </div>
    </div>

    <script>
        function downloadPDF(autoClose) {
            const overlay = document.getElementById('pdf-loading-overlay');
            const btn = document.getElementById('save-pdf-btn');

            overlay.classList.add('active');
            if (btn) {
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating...';
                btn.disabled = true;
            }

            const element = document.getElementById('receipt');
            const opt = {
                margin: [0, 0],
                filename: 'Zyrox_Invoice_<%= order.orderId %>.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: {
                    scale: 2,
                    useCORS: true,
                    letterRendering: true,
                    logging: false
                },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(element).save().then(() => {
                overlay.classList.remove('active');
                if (btn) {
                    btn.innerHTML = '<i class="fas fa-download"></i> Save as PDF';
                    btn.disabled = false;
                }
                // If opened as a download tab, close it after PDF is saved
                if (autoClose) {
                    setTimeout(() => window.close(),0);
                }
            });
        }

        // Auto-trigger download if opened with ?download=true
        window.addEventListener('load', function () {
            const params = new URLSearchParams(window.location.search);
            if (params.get('download') === 'true') {
                // Small delay to ensure fonts/styles are fully loaded
                setTimeout(() => downloadPDF(true), 100);
            }
        });
    </script>
</body>

</html>
