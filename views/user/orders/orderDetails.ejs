<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details | Zyrox</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Bootstrap CSS for Modals -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        body {
            background-color: #0d1117;
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            padding-top: 100px;
        }


        .glass-card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 12px;
        }

        .badge-status-green {
            background: rgba(46, 160, 67, 0.15);
            color: #3fb950;
            border: 1px solid rgba(46, 160, 67, 0.3);
        }

        .badge-status-yellow {
            background: rgba(210, 153, 34, 0.15);
            color: #d29922;
            border: 1px solid rgba(210, 153, 34, 0.3);
        }

        .badge-status-red {
            background: rgba(248, 81, 73, 0.15);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, 0.3);
        }

        .badge-variant {
            background: #0d1117;
            border: 1px solid #30363d;
            color: #8b949e;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 0.65rem;
            text-transform: uppercase;
        }

        .badge-variant b {
            color: #ffffff;
            margin-left: 4px;
        }

        .stepper-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #30363d;
            position: relative;
            z-index: 2;
        }

        .stepper-dot.active {
            background: #58a6ff;
            box-shadow: 0 0 10px rgba(88, 166, 255, 0.5);
        }

        .stepper-line {
            flex-grow: 1;
            height: 2px;
            background: #30363d;
            margin: 0 4px;
            position: relative;
            top: -1px;
        }

        .stepper-line.active {
            background: #58a6ff;
        }

        .stepper-text {
            font-size: 0.65rem;
            color: #8b949e;
            margin-top: 8px;
            font-weight: 500;
        }

        .stepper-text.active {
            color: #ffffff;
        }

        .modal-content {
            background-color: #161b22 !important;
            border: 1px solid #30363d !important;
            border-radius: 16px;
        }

        .modal-header {
            border-bottom: 1px solid #30363d !important;
        }

        .modal-footer {
            border-top: 1px solid #30363d !important;
        }

        .form-select {
            background-color: #0d1117 !important;
            border: 1px solid #30363d !important;
            color: #000000 !important;
        }

        .form-select:focus {
            border-color: #58a6ff !important;
            box-shadow: 0 0 0 2px rgba(88, 166, 255, 0.25) !important;
        }

        /* ── Reason dropdown color chips ── */
        #actionReason option[value="mistake"] {
            color: #f59e0b;
        }

        #actionReason option[value="better_price"] {
            color: #3b82f6;
        }

        #actionReason option[value="change_mind"] {
            color: #a855f7;
        }

        #actionReason option[value="defective"] {
            color: #ef4444;
        }

        #actionReason option[value="other"] {
            color: #10b981;
        }

        /* ── Others input slide-in ── */
        #othersWrapper {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
            opacity: 0;
        }

        #othersWrapper.show {
            max-height: 120px;
            opacity: 1;
        }

        #othersInput {
            width: 100%;
            margin-top: 12px;
            padding: 10px 14px;
            background: #0d1117;
            border: 1.5px solid #30363d;
            border-radius: 10px;
            color: #ffffff;
            font-size: 0.8rem;
            font-family: 'Inter', sans-serif;
            resize: none;
            transition: border-color 0.2s;
        }

        #othersInput:focus {
            outline: none;
            border-color: #58a6ff;
        }

        #othersInput.error {
            border-color: #ef4444;
        }

        /* ── Stock Status Badges ── */
        .stock-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 9px;
            border-radius: 6px;
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .stock-pill.in-stock {
            background: rgba(46, 160, 67, .12);
            color: #3fb950;
            border: 1px solid rgba(46, 160, 67, .3);
        }

        .stock-pill.low-stock {
            background: rgba(210, 153, 34, .12);
            color: #d29922;
            border: 1px solid rgba(210, 153, 34, .3);
        }

        .stock-pill.out-stock {
            background: rgba(248, 81, 73, .12);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, .3);
        }
    </style>
</head>

<body class="p-4 md:p-8 pt-[56px]">
    <%- include('../../partials/user/navigationbar') %>
    <div class="max-w-6xl mx-auto" id="order-dashboard">
        <!-- Back Button -->
        <div class="mb-8">
            <a href="/myOrders"
                class="inline-flex items-center gap-2 px-6 py-2 border border-[#30363d] rounded-lg text-sm font-semibold hover:bg-[#161b22] transition">
                <i class="fas fa-arrow-left"></i> Back to Orders
            </a>
        </div>

        <!-- Order Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div class="flex items-center gap-4">
                <h1 class="text-3xl font-extrabold tracking-tight">Order ID: <span class="text-white">
                        <%= order.orderId %>
                    </span></h1>
                <% 
                    let hC = '#ffc107'; 
                    const os = order.orderStatus.toLowerCase(); 
                    if (os.includes('pending')) hC = '#fd7e14';
                    else if (os.includes('processing')) hC = '#ffc107'; 
                    else if (os.includes('shipped')) hC = '#0ea5e9'; 
                    else if (os.includes('delivered')) hC = '#22c55e'; 
                    else if (os.includes('cancel')) hC = '#ef4444'; 
                    else if (os.includes('return')) hC = '#f59e0b'; 
                    else if (os.includes('failed')) hC = '#ef4444'; 
                %>
                    <div class="flex flex-col items-start gap-2">
                        <span class="px-3 py-1 rounded-full text-[0.7rem] font-bold border"
                            style="border-color: <%= hC %>; color: <%= hC %>; background: <%= hC %>1a">
                            <i class="fas fa-circle text-[6px] mr-1 align-middle"></i>
                            <%= order.orderStatus %>
                        </span>

                    </div>
            </div>

            <!-- Top Desktop Actions -->
            <div class="hidden lg:flex items-center gap-3">
                <% if (order.paymentStatus === 'Paid') { %>
                    <button onclick="downloadInvoiceBill(event)" 
                        class="px-5 py-2.5 bg-blue-600/10 border border-blue-600/50 text-blue-400 rounded-xl font-bold hover:bg-blue-600 hover:text-white transition uppercase tracking-wider text-[0.65rem] flex items-center gap-2">
                        <i class="fas fa-download"></i> Download
                    </button>
                <% } %>
                <% if (['Pending', 'Processing'].includes(order.orderStatus)) { %>
                    <button onclick="handleCancelEntireOrder()" 
                        class="px-5 py-2.5 bg-red-600/10 border border-red-600/50 text-red-500 rounded-xl font-bold hover:bg-red-600 hover:text-white transition uppercase tracking-wider text-[0.65rem]">
                        Cancel Order
                    </button>
                <% } %>
                <% if (order.orderStatus === 'Delivered') { %>
                    <% 
                        const delivDate = order.deliveredAt || order.updatedAt;
                        const daysSince = Math.floor((Date.now() - new Date(delivDate).getTime()) / (1000 * 60 * 60 * 24));
                    %>
                    <% if (daysSince <= 7) { %>
                        <button onclick="handleReturnEntireOrder()" 
                            class="px-5 py-2.5 bg-orange-600/10 border border-orange-600/50 text-orange-500 rounded-xl font-bold hover:bg-orange-600 hover:text-white transition uppercase tracking-wider text-[0.65rem]">
                            Return Order
                        </button>
                    <% } %>
                <% } %>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Side: Product Cards -->
            <div class="lg:col-span-2 space-y-6">
                <% (order.items || []).forEach(item=> { %>
                    <div class="glass-card p-4">
                        <div class="flex flex-col md:flex-row gap-4">
                            <div class="w-full md:w-20 h-20 flex-shrink-0">
                                <img src="<%= item.image %>" class="w-full h-full object-contain rounded-lg bg-black/10"
                                    alt="">
                            </div>
                            <div class="flex-grow">
                                <div class="mb-1">
                                    <h2 class="text-base font-bold text-white uppercase tracking-tight">
                                        <%= item.name %>
                                    </h2>
                                    <% 
                                        const iS = (item.status || order.orderStatus).toLowerCase(); 
                                        let iC = '#ffc107';
                                        if (iS.includes('pending')) iC = '#fd7e14'; 
                                        else if (iS.includes('processing')) iC = '#ffc107'; 
                                        else if (iS.includes('shipped')) iC = '#0ea5e9'; 
                                        else if (iS.includes('delivered')) iC = '#22c55e'; 
                                        else if (iS.includes('cancel')) iC = '#ef4444'; 
                                        else if (iS.includes('return')) iC = '#f59e0b';
                                        else if (iS.includes('failed')) iC = '#ef4444'; 
                                    %>
                                        <div class="text-[0.6rem] font-black uppercase tracking-widest mt-1"
                                            style="color: <%= iC %>">
                                            <%= item.status || order.orderStatus %>
                                        </div>
                                </div>
                                <div class="flex justify-between items-start mb-1">
                                    <div class="flex-grow"></div>
                                    <div class="text-right flex flex-col items-end gap-2">
                                        <span class="text-lg font-black text-white">₹<%=
                                                item.total.toLocaleString('en-IN') %></span>
                                        <% if (['Pending', 'Processing' ].includes(item.status) &&
                                            !['Cancelled', 'Returned' , 'Cancellation Requested' , 'Return Requested'
                                            ].includes(item.status)) { %>
                                            <button
                                                onclick="openItemModal('<%= item._id %>', '<%= item.name %>', 'cancel')"
                                                class="px-3 py-1 bg-red-600/10 border border-red-600/50 text-red-500 rounded-lg text-[0.6rem] font-black uppercase tracking-widest hover:bg-red-600 hover:text-white transition duration-300">
                                                Cancel Item
                                            </button>
                                            <% } else if (item.status==='Delivered' ) { %>
                                                <% const itemDelivDate=item.deliveredAt || order.deliveredAt ||
                                                    order.updatedAt; const itemDaysSince=Math.floor((Date.now() - new
                                                    Date(itemDelivDate).getTime()) / (1000 * 60 * 60 * 24)); %>
                                                    <% if (itemDaysSince <=7) { %>
                                                        <button
                                                            onclick="openItemModal('<%= item._id %>', '<%= item.name %>', 'return')"
                                                            class="px-3 py-1 bg-orange-600/10 border border-orange-600/50 text-orange-500 rounded-lg text-[0.6rem] font-black uppercase tracking-widest hover:bg-orange-600 hover:text-white transition duration-300">
                                                            Return Item
                                                        </button>
                                                        <% } else { %>
                                                            <div
                                                                class="text-[0.6rem] font-black text-gray-500 uppercase tracking-widest text-right">
                                                                RETURN EXPIRED
                                                            </div>
                                                            <% } %>
                                                                <% } else if (['Cancelled', 'Cancellation Requested'
                                                                    ].includes(item.status)) { %>
                                                                    <div
                                                                        class="text-[0.6rem] font-black text-red-500 uppercase tracking-widest text-right">
                                                                        <%= item.status==='Cancelled' ? 'ITEM CANCELLED'
                                                                            : 'CANCELLATION PENDING' %>
                                                                    </div>
                                                                    <% } else if (['Returned', 'Return Requested'
                                                                        ].includes(item.status)) { %>
                                                                        <div
                                                                            class="text-[0.6rem] font-black text-orange-500 uppercase tracking-widest text-right">
                                                                            <%= item.status==='Returned'
                                                                                ? 'ITEM RETURNED' : 'RETURN PENDING' %>
                                                                        </div>
                                                                        <% } %>
                                    </div>
                                </div>
                                <% const itemStock=(stockMap && item.variant) ? (stockMap[String(item.variant)] ?? null)
                                    : null; %>
                                    <% if (itemStock !==null) { %>
                                        <div class="flex items-center gap-2 mb-2">
                                            <span
                                                class="text-[0.55rem] font-black uppercase tracking-widest text-[#8b949e]">Stock
                                                Status:</span>
                                            <% if (itemStock> 10) { %>
                                                <span class="stock-pill in-stock">
                                                    <i class="fas fa-circle-check" style="font-size:0.55rem"></i> In
                                                    Stock
                                                </span>
                                                <% } else if (itemStock> 5) { %>
                                                    <span class="stock-pill low-stock">
                                                        <i class="fas fa-triangle-exclamation"
                                                            style="font-size:0.55rem"></i> Low Stock
                                                    </span>
                                                    <% } else if (itemStock> 0) { %>
                                                        <span class="stock-pill low-stock">
                                                            <i class="fas fa-triangle-exclamation"
                                                                style="font-size:0.55rem"></i>
                                                            <%= itemStock %> Left
                                                        </span>
                                                        <% } else { %>
                                                            <span class="stock-pill out-stock">
                                                                <i class="fas fa-circle-xmark"
                                                                    style="font-size:0.55rem"></i> Out of Stock
                                                            </span>
                                                            <% } %>
                                        </div>
                                        <% } %>
                                            <div class="flex flex-wrap items-center gap-2 mb-2">
                                                <span
                                                    class="bg-[#0d1117] border border-[#30363d] px-2 py-0.5 rounded text-[0.6rem] font-bold text-gray-400">
                                                    QTY: <span class="text-white ml-1">
                                                        <%= item.quantity %>
                                                    </span>
                                                </span>
                                                <div class="flex gap-1">
                                                    <div class="badge-variant" style="padding: 2px 6px;">RAM: <b>
                                                            <%= item.RAM %>
                                                        </b></div>
                                                    <div class="badge-variant" style="padding: 2px 6px;">STORAGE: <b>
                                                            <%= item.storage %>
                                                        </b></div>
                                                    <div class="badge-variant" style="padding: 2px 6px;">COLOR: <b>
                                                            <%= item.color %>
                                                        </b></div>
                                                </div>
                                            </div>
                                            <div class="mt-4">
                                                <div class="flex items-center justify-between relative px-2">
                                                    <% let steps=['Pending', 'Processing' , 'Shipped' , 'Delivered' ];
                                                        let itemS=item.status || order.orderStatus; if
                                                        (itemS.includes('Return')) { steps[3]=itemS; } else if
                                                        (itemS.includes('Cancel')) { steps=['Pending', itemS]; } let
                                                        cIdx=steps.indexOf(itemS); if(cIdx===-1) cIdx=steps.length - 1;
                                                        %>
                                                        <% steps.forEach((step, i)=> { %>
                                                            <div class="flex flex-col items-center">
                                                                <div
                                                                    class="stepper-dot <%= i <= cIdx ? 'active' : '' %>">
                                                                </div>
                                                                <span
                                                                    class="stepper-text <%= i <= cIdx ? 'active' : '' %>">
                                                                    <%= step %>
                                                                </span>
                                                            </div>
                                                            <% if(i < steps.length - 1) { %>
                                                                <div
                                                                    class="stepper-line <%= i < cIdx ? 'active' : '' %>">
                                                                </div>
                                                                <% } %>
                                                                    <% }) %>
                                                </div>
                                            </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>

            <!-- Right Side: Sidebar -->
            <div class="space-y-6 no-download">
                <div class="glass-card p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <i class="fas fa-circle text-blue-500 text-[8px]"></i>
                        <h3 class="text-lg font-bold">Shipping Address</h3>
                    </div>
                    <div class="space-y-3 text-sm text-[#8b949e]">
                        <p class="text-white font-medium"><i class="far fa-user mr-2"></i>
                            <%= order.shippingAddress.fullName %>
                        </p>
                        <p><i class="fas fa-phone-alt mr-2"></i>
                            <%= order.shippingAddress.phone %>
                        </p>
                        <div class="flex items-start gap-2">
                            <i class="fas fa-map-marker-alt mt-1"></i>
                            <div>
                                <p class="text-white font-medium">
                                    <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %>
                                </p>
                                <p class="mt-1 leading-relaxed">
                                    <%= order.shippingAddress.houseName %>(h), <%= order.shippingAddress.locality %>,
                                            <%= order.shippingAddress.pincode %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-card p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <i class="fas fa-file-invoice text-blue-500 text-[8px]"></i>
                        <h3 class="text-lg font-bold">Price Details</h3>
                    </div>
                    <div class="space-y-4 text-sm">
                        <div class="flex justify-between"><span>Subtotal</span><span class="text-white font-bold">₹<%=
                                    order.subtotal.toLocaleString('en-IN') %></span></div>
                        <div class="flex justify-between text-red-500"><span>Discount</span><span>-₹<%= (order.discount
                                    || 0).toLocaleString('en-IN') %></span></div>
                        <div class="flex justify-between text-red-500"><span>Coupon</span><span>-₹<%=
                                    (order.couponDiscount || 0).toLocaleString('en-IN') %></span></div>
                        <div class="flex justify-between pb-4 border-b border-[#30363d]"><span>Tax (GST)</span><span
                                class="text-white font-bold">₹<%= (order.tax || 0).toLocaleString('en-IN') %></span>
                        </div>
                        <div class="flex justify-between items-center pt-2">
                            <span class="text-xl font-extrabold uppercase">Total</span>
                            <span class="text-2xl font-extrabold text-white">₹<%= order.finalPrice.toLocaleString('en-IN') %></span>
                        </div>
                    </div>
                </div>



                <div class="space-y-3">
                    <% if (['Pending', 'Processing' ].includes(order.orderStatus)) { %>
                        <button onclick="handleCancelEntireOrder()"
                            class="w-full bg-red-600/10 border border-red-600/50 text-red-500 py-3 rounded-xl font-bold hover:bg-red-600 hover:text-white transition uppercase tracking-wider text-xs">Cancel
                            Entire Order</button>
                        <% } %>
                        <% if (order.orderStatus==='Delivered' ) { %>
                            <% 
                                const delivDate = order.deliveredAt || order.updatedAt;
                                const daysSince = Math.floor((Date.now() - new Date(delivDate).getTime()) / (1000 * 60 * 60 * 24));
                            %>
                            <% if (daysSince <= 7) { %>
                                <button onclick="handleReturnEntireOrder()" 
                                    class="w-full bg-orange-600/10 border border-orange-600/50 text-orange-500 py-3 rounded-xl font-bold hover:bg-orange-600 hover:text-white transition uppercase tracking-wider text-xs">
                                    Return Entire Order
                                </button>
                            <% } %>
                            <% } %>
                            <% if (order.paymentStatus === 'Paid') { %>
                                <button onclick="downloadInvoiceBill(event)" 
                                    class="w-full border border-blue-600/50 text-blue-400 py-3 rounded-xl font-bold hover:bg-blue-600 hover:text-white transition uppercase tracking-wider text-xs flex items-center justify-center gap-2">
                                    <i class="fas fa-download"></i> Download Invoice
                                </button>
                            <% } %>
                </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modals (Outside hidden elements) -->
    <div class="modal fade" id="itemActionModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-slate-700">
                    <h5 class="modal-title font-bold text-white uppercase tracking-tighter" id="modalTitle">Cancel Item
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-6">
                    <p class="text-slate-400 text-sm mb-4" id="itemNameText">Are you sure you want to cancel this item?
                    </p>
                    <label class="block text-slate-400 text-xs font-black uppercase tracking-widest mb-2">Select
                        Reason</label>

                    <!-- Colored reason dropdown -->
                    <select id="actionReason" onchange="onReasonChange()"
                        class="form-select w-full rounded-xl py-3 px-4 border-slate-700 focus:outline-none"
                        style="font-weight:600">
                        <option value="" selected disabled style="color:#8b949e">Choose a reason...</option>
                        <option value="mistake" style="color:#f59e0b; background:#161b22">🟡 Mistake purchase</option>
                        <option value="better_price" style="color:#3b82f6; background:#161b22">🔵 Found better price
                        </option>
                        <option value="change_mind" style="color:#a855f7; background:#161b22">🟣 Changed my mind
                        </option>
                        <option value="defective" style="color:#ef4444; background:#161b22">🔴 Product issues</option>
                        <option value="other" style="color:#10b981; background:#161b22">🟢 Others</option>
                    </select>

                    <!-- Others text field (hidden by default) -->
                    <div id="othersWrapper">
                        <textarea id="othersInput" rows="3" placeholder="Please describe your reason here…"></textarea>
                        <p class="text-[0.6rem] text-red-500 font-bold mt-1 hidden" id="othersError">This field is
                            required when selecting "Others".</p>
                    </div>
                </div>
                <div class="modal-footer border-slate-700">
                    <button type="button" class="px-6 py-2 rounded-lg bg-slate-800 text-slate-300 font-bold text-xs"
                        data-bs-dismiss="modal">CLOSE</button>
                    <button type="button" class="px-6 py-2 rounded-lg bg-red-600 text-white font-bold text-xs"
                        id="confirmBtn" onclick="submitItemAction()">CONFIRM ACTION</button>
                </div>
            </div>
        </div>
    </div>


    <!-- ═══ HIDDEN INVOICE (matched with invoice.ejs) ═══ -->
    <div id="zyrox-invoice-print" style="position: absolute; left: -9999px; top: 0; width: 850px; background: white; padding: 60px; color: #1f2937; font-family: 'Inter', sans-serif;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 50px;">
            <div style="display: flex; flex-direction: column; align-items: flex-start;">
                <div style="font-size: 2rem; font-weight: 900; color: #1a2a4d; letter-spacing: -1px; margin-bottom: 5px; display: flex; align-items: center; gap: 10px;">
                    <span style="color: #4f6ef7;">⚡</span> ZYROX
                </div>
                <div style="font-size: 0.8rem; color: #6b7280; text-transform: uppercase; letter-spacing: 2px;">Premium E-Commerce Experience</div>
            </div>
            <div style="text-align: right;">
                <h1 style="font-size: 1.8rem; font-weight: 800; color: #1a2a4d; margin: 0 0 10px 0; text-transform: uppercase;">Payment Receipt</h1>
                <div style="text-align: right;">
                    <div style="display: flex; justify-content: flex-end; gap: 15px; margin-bottom: 8px; font-size: 0.95rem;">
                        <span style="font-weight: 600; color: #6b7280;">Receipt No:</span>
                        <span style="font-weight: 700; min-width: 140px;">REC-<%= order.orderId.substring(order.orderId.length - 8).toUpperCase() %></span>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 15px; margin-bottom: 8px; font-size: 0.95rem;">
                        <span style="font-weight: 600; color: #6b7280;">Date:</span>
                        <span style="font-weight: 700; min-width: 140px;"><%= new Date(order.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 15px; margin-bottom: 8px; font-size: 0.95rem;">
                        <span style="font-weight: 600; color: #6b7280;">Order ID:</span>
                        <span style="font-weight: 700; min-width: 140px;">#<%= order.orderId %></span>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 15px; margin-bottom: 8px; font-size: 0.95rem;">
                        <span style="font-weight: 600; color: #6b7280;">Status:</span>
                        <span style="font-weight: 700; min-width: 140px;">
                            <% if (order.paymentStatus === 'Paid') { %>
                                <span style="background-color: #ecfdf5; color: #059669; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 800;">PAID</span>
                            <% } else if (order.paymentStatus === 'Refunded') { %>
                                <span style="background-color: #eff6ff; color: #2563eb; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 800;">REFUNDED</span>
                            <% } else { %>
                                <span style="background-color: #fffbeb; color: #d97706; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 800;"><%= order.paymentStatus.toUpperCase() %></span>
                            <% } %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 50px;">
            <div>
                <h3 style="font-size: 0.75rem; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;">Customer Information</h3>
                <div style="font-size: 0.95rem; line-height: 1.5;">
                    <p style="font-weight: 700; font-size: 1.1rem; margin-bottom: 8px;"><%= order.shippingAddress.fullName %></p>
                    <p style="margin: 4px 0;"><%= order.shippingAddress.houseName %>(H), <%= order.shippingAddress.locality %></p>
                    <p style="margin: 4px 0;"><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
                    <p style="margin: 4px 0;">Phone: <%= order.shippingAddress.phone %></p>
                    <p style="margin: 4px 0;">Email: <%= user.email %></p>
                </div>
            </div>
            <div>
                <h3 style="font-size: 0.75rem; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;">Billing From</h3>
                <div style="font-size: 0.95rem; line-height: 1.5;">
                    <p style="font-weight: 700; font-size: 1.1rem; margin-bottom: 8px;">Zyrox mobile store pvt ltd</p>
                    <p style="margin: 4px 0;">PAN: AACCU3841N</p>
                    <p style="margin: 4px 0;">CIN: U74999UP2019PTC182407</p>
                    <p style="margin: 4px 0;">Contact: +91 9074105805</p>
                    <p style="margin: 4px 0;">Email: zyroxmobilestore@gmail.com</p>
                </div>
            </div>
        </div>

        <table style="width: 100%; border-collapse: collapse; margin-bottom: 40px;">
            <thead>
                <tr>
                    <th style="background-color: #f9fafb; padding: 15px; text-align: left; font-size: 0.75rem; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb; width: 50%;">Item Description</th>
                    <th style="background-color: #f9fafb; padding: 15px; text-align: center; font-size: 0.75rem; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;">Qty</th>
                    <th style="background-color: #f9fafb; padding: 15px; text-align: right; font-size: 0.75rem; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;">Unit Price</th>
                    <th style="background-color: #f9fafb; padding: 15px; text-align: right; font-size: 0.75rem; font-weight: 800; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;">Total</th>
                </tr>
            </thead>
            <tbody>
                <% order.items.forEach((item, index) => { %>
                    <tr>
                        <td style="padding: 20px 15px; border-bottom: 1px solid #e5e7eb; vertical-align: top;">
                            <div style="font-weight: 700; font-size: 1rem; color: #1a2a4d;"><%= index + 1 %>. <%= item.name %></div>
                            <div style="font-size: 0.8rem; color: #6b7280;">
                                <% if (item.RAM) { %>RAM: <%= item.RAM %>GB | <% } %>
                                <% if (item.storage) { %>Storage: <%= item.storage %>GB | <% } %>
                                <% if (item.color) { %>Color: <%= item.color %><% } %>
                            </div>
                        </td>
                        <td style="padding: 20px 15px; border-bottom: 1px solid #e5e7eb; vertical-align: top; text-align: center;"><%= item.quantity %></td>
                        <td style="padding: 20px 15px; border-bottom: 1px solid #e5e7eb; vertical-align: top; text-align: right;">&#8377;<%= item.price.toLocaleString('en-IN') %></td>
                        <td style="padding: 20px 15px; border-bottom: 1px solid #e5e7eb; vertical-align: top; text-align: right; font-weight: 700;">&#8377;<%= (item.price * item.quantity).toLocaleString('en-IN') %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div style="display: flex; justify-content: flex-end; margin-bottom: 50px;">
            <div style="width: 350px;">
                <div style="display: flex; justify-content: space-between; padding: 10px 0; font-size: 1rem;">
                    <span style="color: #6b7280;">Subtotal:</span>
                    <span style="font-weight: 600;">&#8377;<%= order.subtotal.toLocaleString('en-IN') %></span>
                </div>
                <% if (order.discount > 0) { %>
                    <div style="display: flex; justify-content: space-between; padding: 10px 0; font-size: 1rem;">
                        <span style="color: #6b7280;">Coupon Discount:</span>
                        <span style="font-weight: 600; color: #059669;">- &#8377;<%= order.discount.toLocaleString('en-IN') %></span>
                    </div>
                <% } %>
                <div style="display: flex; justify-content: space-between; padding: 10px 0; font-size: 1rem;">
                    <span style="color: #6b7280;">Shipping Fee:</span>
                    <span style="font-weight: 600;"><%= order.shippingCharge === 0 ? 'FREE' : '₹' + order.shippingCharge.toLocaleString('en-IN') %></span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 20px 0; font-size: 1.5rem; font-weight: 900; border-top: 2px solid #1a2a4d; margin-top: 15px; color: #1a2a4d;">
                    <span>Grand Total:</span>
                    <span>&#8377;<%= order.finalPrice.toLocaleString('en-IN') %></span>
                </div>
            </div>
        </div>

        <div style="border-top: 1px solid #e5e7eb; padding-top: 30px; display: grid; grid-template-columns: 1.5fr 1fr; gap: 40px;">
            <div>
                <div style="background-color: #f9fafb; padding: 20px; border-radius: 8px;">
                    <div style="font-size: 0.8rem; font-weight: 800; color: #6b7280; text-transform: uppercase; margin-bottom: 10px;">Payment Method</div>
                    <div style="font-weight: 700; font-size: 1rem;">
                        <% if (order.paymentMethod === 'Online') { %>Online Payment (Razorpay)
                        <% } else if (order.paymentMethod === 'Wallet') { %>Zyrox Wallet
                        <% } else { %><%= order.paymentMethod %><% } %>
                    </div>
                </div>
                <div style="margin-top: 15px; font-size: 0.85rem; line-height: 1.6; color: #6b7280;">
                    Thank you for shopping with Zyrox! For support: zyroxmobilestore@gmail.com
                </div>
            </div>
            <div style="text-align: right; display: flex; flex-direction: column; align-items: flex-end;">
                <div style="width: 150px; height: 60px; margin-bottom: 10px; opacity: 0.8;">
                    <svg viewBox="0 0 500 150" preserveAspectRatio="none" style="height: 100%; width: 100%;">
                        <path d="M50,100 Q150,50 250,100 T450,100" fill="none" stroke="#2b448a" stroke-width="4" />
                        <path d="M80,80 Q180,30 280,80 T480,80" fill="none" stroke="#2b448a" stroke-width="2" opacity="0.5" />
                    </svg>
                </div>
                <div style="width: 200px; height: 1px; background-color: #e5e7eb; margin-bottom: 10px;"></div>
                <span style="font-weight: 800; font-size: 0.9rem; text-transform: uppercase;">Authorized Signatory</span>
                <span style="font-size: 0.75rem; color: #6b7280;">Zyrox E-Commerce Solutions</span>
            </div>
        </div>
    </div>

    <script>
        let selectedOrder = '<%= order._id %>';
        let selectedItem = null;
        let actionType = '';

        function openItemModal(itemId, itemName, type) {
            selectedItem = itemId;
            actionType = type;
            const title = type === 'cancel' ? 'Cancel Item' : 'Return Item';
            const text = type === 'cancel' ? 'Are you sure you want to cancel the product: ' : 'Are you sure you want to return the product: ';
            const btnClass = type === 'cancel' ? 'px-6 py-2 rounded-lg bg-red-600 text-white font-bold text-xs' : 'px-6 py-2 rounded-lg bg-orange-600 text-white font-bold text-xs';
            const btnText = type === 'cancel' ? 'CONFIRM CANCELLATION' : 'CONFIRM RETURN';

            document.getElementById('modalTitle').innerText = title;
            document.getElementById('itemNameText').innerText = text + itemName + '?';
            document.getElementById('confirmBtn').className = btnClass;
            document.getElementById('confirmBtn').innerText = btnText;

            // Reset dropdown + others field each time modal opens
            document.getElementById('actionReason').value = '';
            const wrapper = document.getElementById('othersWrapper');
            const input = document.getElementById('othersInput');
            const err = document.getElementById('othersError');
            wrapper.classList.remove('show');
            input.value = '';
            input.classList.remove('error');
            err.classList.add('hidden');

            new bootstrap.Modal(document.getElementById('itemActionModal')).show();
        }

        function onReasonChange() {
            const sel = document.getElementById('actionReason').value;
            const wrapper = document.getElementById('othersWrapper');
            const input = document.getElementById('othersInput');
            const err = document.getElementById('othersError');

            if (sel === 'other') {
                wrapper.classList.add('show');
            } else {
                wrapper.classList.remove('show');
                input.classList.remove('error');
                err.classList.add('hidden');
            }
        }

        function submitItemAction() {
            const sel = document.getElementById('actionReason').value;
            const input = document.getElementById('othersInput');
            const err = document.getElementById('othersError');

            if (!sel) {
                return Swal.fire({ title: 'Error', text: 'Please select a reason', icon: 'error', background: '#161b22', color: '#fff' });
            }

            let reason = sel;
            if (sel === 'other') {
                const custom = input.value.trim();
                if (!custom) {
                    input.classList.add('error');
                    err.classList.remove('hidden');
                    input.focus();
                    return;
                }
                reason = custom; // send the actual typed reason
            }

            input.classList.remove('error');
            err.classList.add('hidden');

            const endpoint = actionType === 'cancel' ? '/cancel-item' : '/return-item';
            axios.post(endpoint, { orderId: selectedOrder, itemId: selectedItem, reason })
                .then(res => {
                    if (res.data.success) {
                        Swal.fire({ title: 'Success', text: res.data.message, icon: 'success', timer: 1000, showConfirmButton: false, background: '#161b22', color: '#fff' }).then(() => location.reload());
                    } else {
                        Swal.fire({ title: 'Error', text: res.data.message, icon: 'error', timer: 1000, showConfirmButton: false, background: '#161b22', color: '#fff' });
                    }
                });
        }

        function handleCancelEntireOrder() {
            const reasonOptions = {
                mistake: 'Mistake purchase',
                better_price: ' Found better price',
                change_mind: 'Changed my mind',
                others: ' Others'
            };

            Swal.fire({
                title: 'Cancel Entire Order?',
                text: 'Select a reason for cancellation',
                input: 'select',
                inputOptions: reasonOptions,
                inputPlaceholder: 'Choose a reason…',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#334155',
                confirmButtonText: 'Next →',
                cancelButtonText: 'Go Back',
                background: '#161b22',
                color: '#fff',
                inputValidator: (value) => {
                    if (!value) return 'Please select a reason!';
                }
            }).then(r => {
                if (!r.isConfirmed || !r.value) return;

                if (r.value === 'others') {
                    // Step 2 — ask for custom reason text
                    Swal.fire({
                        title: 'Describe your reason',
                        input: 'textarea',
                        inputPlaceholder: 'Please describe why you want to cancel…',
                        inputAttributes: { maxlength: 300 },
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#334155',
                        confirmButtonText: 'Confirm Cancel',
                        cancelButtonText: 'Go Back',
                        background: '#161b22',
                        color: '#fff',
                        inputValidator: (value) => {
                            if (!value || !value.trim()) return 'Please describe your reason!';
                        }
                    }).then(r2 => {
                        if (r2.isConfirmed && r2.value) {
                            submitCancelOrder(r2.value.trim());
                        }
                    });
                } else {
                    submitCancelOrder(r.value);
                }
            });
        }

        function submitCancelOrder(reason) {
            axios.post('/cancel-order', { orderId: selectedOrder, reason })
                .then(res => {
                    if (res.data.success) {
                        Swal.fire({ title: 'Cancelled!', text: 'Your order has been cancelled.', icon: 'success', background: '#161b22', color: '#fff' })
                            .then(() => location.reload());
                    } else {
                        Swal.fire({ title: 'Error', text: res.data.message, icon: 'error', background: '#161b22', color: '#fff' });
                    }
                });
        }

        function handleReturnEntireOrder() {
            const reasonOptions = {
                defective: 'Product is defective',
                not_as_described: 'Product not as described',
                wrong_item: 'Received wrong item',
                others: ' Others'
            };

            Swal.fire({
                title: 'Return Entire Order?',
                text: 'Select a reason for return',
                input: 'select',
                inputOptions: reasonOptions,
                inputPlaceholder: 'Choose a reason…',
                showCancelButton: true,
                confirmButtonColor: '#f59e0b',
                cancelButtonColor: '#334155',
                confirmButtonText: 'Next →',
                cancelButtonText: 'Go Back',
                background: '#161b22',
                color: '#fff',
                inputValidator: (value) => {
                    if (!value) return 'Please select a reason!';
                }
            }).then(r => {
                if (!r.isConfirmed || !r.value) return;

                if (r.value === 'others') {
                    Swal.fire({
                        title: 'Describe your reason',
                        input: 'textarea',
                        inputPlaceholder: 'Please describe why you want to return…',
                        inputAttributes: { maxlength: 300 },
                        showCancelButton: true,
                        confirmButtonColor: '#f59e0b',
                        cancelButtonColor: '#334155',
                        confirmButtonText: 'Confirm Return',
                        cancelButtonText: 'Go Back',
                        background: '#161b22',
                        color: '#fff',
                        inputValidator: (value) => {
                            if (!value || !value.trim()) return 'Please describe your reason!';
                        }
                    }).then(r2 => {
                        if (r2.isConfirmed && r2.value) {
                            submitReturnOrder(r2.value.trim());
                        }
                    });
                } else {
                    submitReturnOrder(r.value);
                }
            });
        }

        function submitReturnOrder(reason) {
            axios.post('/return-order', { orderId: selectedOrder, reason })
                .then(res => {
                    if (res.data.success) {
                        Swal.fire({ title: 'Return Requested!', text: 'Your return request has been submitted.', icon: 'success', background: '#161b22', color: '#fff' })
                            .then(() => location.reload());
                    } else {
                        Swal.fire({ title: 'Error', text: res.data.message, icon: 'error', background: '#161b22', color: '#fff' });
                    }
                });
        }

        function downloadInvoiceBill(e) {
            const btn = e.currentTarget;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Generating...';
            btn.disabled = true;

            const element = document.getElementById('zyrox-invoice-print');
            const opt = {
                margin: [0, 0],
                filename: 'Zyrox_Invoice_<%= order.orderId %>.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true, letterRendering: true, logging: false },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(element).save().then(() => {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }).catch((error) => {
                console.error("Invoice generation error:", error);
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            });
        }


    </script>
</body>

</html>