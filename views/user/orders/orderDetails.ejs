<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details | Zyrox</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=3">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Bootstrap CSS for Modals -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        body {
            background-color: #0d1117;
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            padding-top: 180px !important;
        }
        
        #order-dashboard {
            position: relative;
            z-index: 1;
        }

        .glass-card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 12px;
        }

        .badge-status-green {
            background: rgba(46, 160, 67, 0.15);
            color: #3fb950;
            border: 1px solid rgba(46, 160, 67, 0.3);
        }

        .badge-status-yellow {
            background: rgba(210, 153, 34, 0.15);
            color: #d29922;
            border: 1px solid rgba(210, 153, 34, 0.3);
        }

        .badge-status-red {
            background: rgba(248, 81, 73, 0.15);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, 0.3);
        }

        .badge-variant {
            background: #0d1117;
            border: 1px solid #30363d;
            color: #8b949e;
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 0.65rem;
            text-transform: uppercase;
        }

        .badge-variant b {
            color: #ffffff;
            margin-left: 4px;
        }

        .stepper-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #30363d;
            position: relative;
            z-index: 2;
        }

        .stepper-dot.active {
            background: #58a6ff;
            box-shadow: 0 0 10px rgba(88, 166, 255, 0.5);
        }

        .stepper-line {
            flex-grow: 1;
            height: 2px;
            background: #30363d;
            margin: 0 4px;
            position: relative;
            top: -1px;
        }

        .stepper-line.active {
            background: #58a6ff;
        }

        .stepper-text {
            font-size: 0.65rem;
            color: #8b949e;
            margin-top: 8px;
            font-weight: 500;
        }

        .stepper-text.active {
            color: #ffffff;
        }

        .stepper-date {
            font-size: 0.58rem;
            color: #58a6ff;
            margin-top: 3px;
            font-weight: 600;
            white-space: nowrap;
            letter-spacing: 0.01em;
        }

        .stepper-time {
            font-size: 0.55rem;
            color: #6e7f96;
            margin-top: 1px;
            font-weight: 500;
            white-space: nowrap;
        }

        .modal-content {
            background-color: #161b22 !important;
            border: 1px solid #30363d !important;
            border-radius: 16px;
        }

        .modal-header {
            border-bottom: 1px solid #30363d !important;
        }

        .modal-footer {
            border-top: 1px solid #30363d !important;
        }

        .form-select {
            background-color: #0d1117 !important;
            border: 1px solid #30363d !important;
            color: #000000 !important;
        }

        .form-select:focus {
            border-color: #58a6ff !important;
            box-shadow: 0 0 0 2px rgba(88, 166, 255, 0.25) !important;
        }

        #actionReason option[value="mistake"]      { color: #f59e0b; }
        #actionReason option[value="better_price"] { color: #3b82f6; }
        #actionReason option[value="change_mind"]  { color: #a855f7; }
        #actionReason option[value="defective"]    { color: #ef4444; }
        #actionReason option[value="other"]        { color: #10b981; }

        #othersWrapper {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
            opacity: 0;
        }

        #othersWrapper.show {
            max-height: 120px;
            opacity: 1;
        }

        #othersInput {
            width: 100%;
            margin-top: 12px;
            padding: 10px 14px;
            background: #0d1117;
            border: 1.5px solid #30363d;
            border-radius: 10px;
            color: #ffffff;
            font-size: 0.8rem;
            font-family: 'Inter', sans-serif;
            resize: none;
            transition: border-color 0.2s;
        }

        #othersInput:focus {
            outline: none;
            border-color: #58a6ff;
        }

        #othersInput.error {
            border-color: #ef4444;
        }

        .stock-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 9px;
            border-radius: 6px;
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .stock-pill.in-stock {
            background: rgba(46, 160, 67, .12);
            color: #3fb950;
            border: 1px solid rgba(46, 160, 67, .3);
        }

        .stock-pill.low-stock {
            background: rgba(210, 153, 34, .12);
            color: #d29922;
            border: 1px solid rgba(210, 153, 34, .3);
        }

        .stock-pill.out-stock {
            background: rgba(248, 81, 73, .12);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, .3);
        }

        /* Retry Styles */
        .btn-retry {
            background: rgba(255, 149, 0, 0.12);
            color: #ff9500;
            border: 1px solid rgba(255, 149, 0, 0.3);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.72rem;
            font-weight: 800;
            text-decoration: none;
            white-space: nowrap;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .btn-retry:hover {
            background: #ff9500;
            color: #fff;
        }

        .retry-timer-text {
            font-size: 11px;
            color: #ff9500;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .retry-timer {
            font-family: 'Inter', monospace;
            background: rgba(255, 149, 0, 0.1);
            padding: 1px 5px;
            border-radius: 4px;
        }

        /* ── SweetAlert Select Fix ── */
        .swal2-select {
            background-color: #1a1f2e !important;
            color: #fff !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 12px !important;
            font-weight: 600 !important;
        }
        .swal2-select option {
            background-color: #1a1f2e !important;
            color: #fff !important;
        }

        /* ── Action Modal Select Fix ── */
        #actionReason {
            background-color: #1a1f2e !important;
            color: #fff !important;
        }
        #actionReason option {
            background-color: #1a1f2e !important;
            color: #fff !important;
            padding: 10px;
        }
    </style>
</head>

<body class="p-4 md:p-8">
    <%- include('../../partials/user/navigationbar') %>
    <div class="max-w-6xl mx-auto mt-32 pt-10" id="order-dashboard">


        <!-- Order Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div class="flex items-center gap-6">
                <a href="/myOrders"
                    class="group flex items-center justify-center w-12 h-12 border border-[#30363d] rounded-2xl text-[#8b949e] hover:bg-white hover:text-black hover:border-white transition-all duration-500 shadow-lg"
                    title="Back to Orders">
                    <i class="bi bi-arrow-left text-xl"></i>
                </a>
                <div>
                    <h1 class="text-3xl font-extrabold tracking-tight">Order ID: <span class="text-white">
                            <%= order.orderId %>
                        </span></h1>
                    <div class="text-[0.65rem] text-[#8b949e] font-bold uppercase tracking-widest mt-1">
                        Placed On: <span class="text-white"><%= new Date(order.createdAt).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %></span>
                    </div>
                </div>
                <% 
                    let hC = '#ffc107'; 
                    const os = order.orderStatus.toLowerCase(); 
                    if (os.includes('pending')) hC = '#fd7e14';
                    else if (os.includes('processing')) hC = '#ffc107'; 
                    else if (os.includes('shipped')) hC = '#0ea5e9'; 
                    else if (os.includes('delivered')) hC = '#22c55e'; 
                    else if (os.includes('cancel')) hC = '#ef4444'; 
                    else if (os.includes('return')) hC = '#f59e0b'; 
                    else if (os.includes('failed')) hC = '#ef4444'; 
                %>
                <div class="flex flex-col items-start gap-2">
                    <div class="flex items-center gap-3">
                        <span class="px-3 py-1 rounded-full text-[0.7rem] font-bold <%= order.orderStatus === 'Cancelled' ? '' : 'border' %>"
                            style="<%= order.orderStatus === 'Cancelled' ? 'border: none;' : 'border-color: ' + hC + ';' %> color: <%= hC %>; background: <%= hC %>1a">
                            <i class="bi bi-circle-fill text-[6px] mr-1 align-middle"></i>
                            <%= order.orderStatus %>
                        </span>

                        <% if (order.paymentStatus === 'Failed' || order.orderStatus === 'Failed') { %>
                            <%
                                const failedTime = order.createdAt;
                                const expiryTime = new Date(new Date(failedTime).getTime() + 20 * 60 * 1000);
                                const now = new Date();
                                const diffMs = expiryTime - now;
                            %>
                            <% if (diffMs > 0) { %>
                                <div class="flex items-center gap-2">
                                    <button onclick="handleRetryPayment('<%= order._id %>', this)" 
                                        class="btn-retry retry-btn">
                                        <i class="bi bi-arrow-clockwise" style="font-size: 10px;"></i> Retry Payment
                                    </button>
                                    <div class="retry-timer-text" data-expiry="<%= expiryTime.toISOString() %>">
                                        <i class="bi bi-clock"></i> <span class="retry-timer"></span>
                                    </div>
                                </div>
                            <% } %>
                        <% } %>
                    </div>
                    <% if (['Cancelled', 'Returned'].includes(order.orderStatus) && order.paymentStatus === 'Refunded') { %>
                        <span class="px-2 py-0.5 rounded text-[0.6rem] font-bold text-blue-400 bg-blue-400/10 border border-blue-400/30">
                            <i class="bi bi-check-circle-fill mr-1"></i> REFUNDED TO WALLET
                        </span>
                    <% } %>
                </div>

            </div>

            <!-- Top Desktop Actions -->
            <div class="hidden lg:flex items-center gap-3">
                <button onclick="downloadInvoice('<%= order._id %>', this)"
                    class="px-5 py-2.5 bg-blue-600/10 border border-blue-600/50 text-blue-400 rounded-xl font-bold hover:bg-blue-600 hover:text-white transition uppercase tracking-wider text-[0.65rem] flex items-center gap-2">
                    <i class="bi bi-download"></i> Download Invoice
                </button>
                <% if (['Pending', 'Processing'].includes(order.orderStatus) && order.paymentStatus !== 'Failed' && order.orderStatus !== 'Failed') { %>
                    <button onclick="handleCancelEntireOrder()"
                        class="px-5 py-2.5 bg-red-600/10 border border-red-600/50 text-red-500 rounded-xl font-bold hover:bg-red-600 hover:text-white transition uppercase tracking-wider text-[0.65rem]">
                        Cancel Entire Order
                    </button>
                <% } %>
                <% if (order.orderStatus === 'Delivered') { %>
                    <%
                        const delivDate = order.deliveredAt || order.updatedAt;
                        const returnExpiry = new Date(new Date(delivDate).getTime() + 7 * 24 * 60 * 60 * 1000);
                        const daysLeft = Math.floor((returnExpiry - Date.now()) / (1000 * 60 * 60 * 24));
                    %>
                    <% if (returnExpiry > Date.now()) { %>
                        <div class="flex flex-col items-center">
                            <button onclick="handleReturnEntireOrder()"
                                class="px-5 py-2.5 bg-orange-600/10 border border-orange-600/50 text-orange-500 rounded-xl font-bold hover:bg-orange-600 hover:text-white transition uppercase tracking-wider text-[0.65rem] return-btn">
                                Return Entire Order
                            </button>
                            <span class="return-timer-text text-[0.6rem] text-gray-400 font-bold mt-1 tracking-wider uppercase" data-expiry="<%= returnExpiry.toISOString() %>">
                                Ends in <span class="return-timer"></span>
                            </span>
                        </div>
                    <% } %>
                <% } %>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Side: Product Cards -->
            <div class="lg:col-span-2 space-y-6">
                <% (order.items || []).forEach(item => { %>
                    <div class="glass-card p-4">
                        <div class="flex flex-col md:flex-row gap-4">
                            <div class="w-full md:w-20 h-20 flex-shrink-0">
                                <img src="<%= item.image %>" class="w-full h-full object-contain rounded-lg bg-black/10" alt="">
                            </div>
                            <div class="flex-grow">
                                <div class="mb-1">
                                    <h2 class="text-base font-bold text-white uppercase tracking-tight">
                                        <%= item.name %>
                                    </h2>
                                    <%
                                        const iS = (item.status || order.orderStatus).toLowerCase();
                                        let iC = '#ffc107';
                                        if (iS.includes('pending')) iC = '#fd7e14';
                                        else if (iS.includes('processing')) iC = '#ffc107';
                                        else if (iS.includes('shipped')) iC = '#0ea5e9';
                                        else if (iS.includes('delivered')) iC = '#22c55e';
                                        else if (iS.includes('cancel')) iC = '#ef4444';
                                        else if (iS.includes('return')) iC = '#f59e0b';
                                        else if (iS.includes('failed')) iC = '#ef4444';
                                    %>
                                    <div class="text-[0.6rem] font-black uppercase tracking-widest mt-1" style="color: '<%= iC %>'">
                                        <%= item.status || order.orderStatus %>
                                    </div>
                                </div>
                                <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mt-3">
                                    <!-- Left: Reason (if any) -->
                                    <div class="flex-grow">
                                        <% 
                                            const reason = item.cancellationReason || item.returnReason || order.cancellationReason || order.returnReason;
                                            const showReason = (['Cancelled', 'Cancellation Requested', 'Returned', 'Return Requested'].includes(item.status) || 
                                                               (['Cancelled', 'Returned'].includes(order.orderStatus) && !item.status)) && reason;
                                        %>
                                        <% if (showReason) { %>
                                            <div class="p-2.5 rounded-lg bg-white/[0.03] border border-white/[0.05] inline-block max-w-full">
                                                <div class="flex items-start gap-2">
                                                    <i class="bi bi-chat-left-text-fill text-[10px] text-gray-500 mt-1"></i>
                                                    <div class="flex flex-col">
                                                        <span class="text-[0.55rem] font-black text-gray-500 uppercase tracking-widest mb-0.5">
                                                            <%= (item.status?.includes('Return') || order.orderStatus?.includes('Return')) ? 'Return' : 'Cancellation' %> Reason:
                                                        </span>
                                                        <span class="text-[0.7rem] font-medium text-gray-300 italic leading-relaxed">
                                                            "<%= reason %>"
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        <% } %>
                                    </div>

                                    <!-- Right: Price & Status Info -->
                                    <div class="text-right flex flex-col items-end gap-2">
                                        <% 
                                            const itemTotal = item.total || 0;
                                            const itemPrice = item.price || 0;
                                            const itemQty = item.quantity || 1;
                                            const originalItemPrice = itemPrice * itemQty;
                                            const hasItemDiscount = originalItemPrice > itemTotal;
                                        %>
                                        <div class="flex flex-col items-end">
                                            <% if (hasItemDiscount) { %>
                                                <span class="text-sm font-bold text-gray-500 line-through">
                                                    ₹<%= originalItemPrice.toLocaleString('en-IN') %>
                                                </span>
                                            <% } %>
                                            <div class="flex items-center gap-2">
                                                <span class="text-lg font-black <%= hasItemDiscount ? 'text-green-400' : 'text-white' %>">
                                                    ₹<%= itemTotal.toLocaleString('en-IN') %>
                                                </span>
                                                <% if (hasItemDiscount) { %>
                                                    <span class="bg-green-400/10 text-green-400 px-2 py-0.5 rounded text-[0.55rem] font-black border border-green-400/30 uppercase tracking-wider">
                                                        <i class="bi bi-tag-fill text-[8px]"></i> OFFER
                                                    </span>
                                                <% } %>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-3 flex-wrap justify-end">
                                            <% if (['Pending', 'Processing'].includes(item.status) &&
                                                !['Cancelled', 'Returned', 'Cancellation Requested', 'Return Requested'].includes(item.status) &&
                                                order.paymentStatus !== 'Failed' && order.orderStatus !== 'Failed') { %>
                                                <button onclick="openItemModal('<%= item._id %>', '<%= item.name %>', 'cancel')"
                                                    class="px-3 py-1 bg-red-600/10 border border-red-600/50 text-red-500 rounded-lg text-[0.6rem] font-black uppercase tracking-widest hover:bg-red-600 hover:text-white transition duration-300">
                                                    Cancel Item
                                                </button>
                                            <% } else if (item.status === 'Delivered') { %>
                                                <% const itemDelivDate = item.deliveredAt || order.deliveredAt || order.updatedAt;
                                                   const itemReturnExpiry = new Date(new Date(itemDelivDate).getTime() + 7 * 24 * 60 * 60 * 1000); %>
                                                <% if (itemReturnExpiry > Date.now()) { %>
                                                    <div class="flex flex-col items-end">
                                                        <button onclick="openItemModal('<%= item._id %>', '<%= item.name %>', 'return')"
                                                            class="px-3 py-1 bg-orange-600/10 border border-orange-600/50 text-orange-500 rounded-lg text-[0.6rem] font-black uppercase tracking-widest hover:bg-orange-600 hover:text-white transition duration-300 return-btn">
                                                            Return Item
                                                        </button>
                                                        <span class="return-timer-text text-[0.55rem] font-black text-gray-500 uppercase tracking-widest text-right mt-1" data-expiry="<%= itemReturnExpiry.toISOString() %>">
                                                            ENDS IN <span class="return-timer"></span>
                                                        </span>
                                                    </div>
                                                <% } else { %>
                                                    <div class="text-[0.6rem] font-black text-gray-500 uppercase tracking-widest">RETURN EXPIRED</div>
                                                <% } %>
                                            <% } else if (['Cancelled', 'Cancellation Requested'].includes(item.status)) { %>
                                                <div class="text-[0.6rem] font-black text-red-500 uppercase tracking-widest">
                                                    <%= item.status.toUpperCase() %>
                                                </div>
                                                <% if (item.status === 'Cancelled' && ['Paid', 'Refunded'].includes(order.paymentStatus) && ['Online', 'Wallet'].includes(order.paymentMethod)) { %>
                                                    <div class="text-[0.55rem] font-black text-blue-400 bg-blue-400/10 px-2 py-0.5 rounded uppercase tracking-widest border border-blue-400/30">
                                                        REFUNDED TO WALLET
                                                    </div>
                                                <% } %>
                                            <% } else if (['Returned', 'Return Requested'].includes(item.status)) { %>
                                                <div class="text-[0.6rem] font-black text-orange-500 uppercase tracking-widest">
                                                    <%= item.status.toUpperCase() %>
                                                </div>
                                                <% if (item.status === 'Returned' && ['Paid', 'Refunded'].includes(order.paymentStatus)) { %>
                                                    <div class="text-[0.55rem] font-black text-blue-400 bg-blue-400/10 px-2 py-0.5 rounded uppercase tracking-widest border border-blue-400/30">
                                                        REFUNDED TO WALLET
                                                    </div>
                                                <% } %>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>

                                <% const itemStock = (stockMap && item.variant) ? (stockMap[String(item.variant)] ?? null) : null; %>
                                <% if (itemStock !== null) { %>
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-[0.55rem] font-black uppercase tracking-widest text-[#8b949e]">Stock Status:</span>
                                        <% if (itemStock > 7) { %>
                                            <span class="stock-pill in-stock"><i class="bi bi-check-circle-fill" style="font-size:0.55rem"></i> In Stock</span>
                                        <% } else if (itemStock > 3) { %>
                                            <span class="stock-pill low-stock"><i class="bi bi-exclamation-triangle-fill" style="font-size:0.55rem"></i> Low Stock</span>
                                        <% } else if (itemStock > 0) { %>
                                            <span class="stock-pill low-stock"><i class="bi bi-exclamation-triangle-fill" style="font-size:0.55rem"></i> <%= itemStock %> Left</span>
                                        <% } else { %>
                                            <span class="stock-pill out-stock"><i class="bi bi-x-circle-fill" style="font-size:0.55rem"></i> Out of Stock</span>
                                        <% } %>
                                    </div>
                                <% } %>
                                <div class="flex flex-wrap items-center gap-2 mb-2">
                                    <span class="bg-[#0d1117] border border-[#30363d] px-2 py-0.5 rounded text-[0.6rem] font-bold text-gray-400">
                                        QTY: <span class="text-white ml-1"><%= item.quantity %></span>
                                    </span>
                                    <div class="flex gap-1">
                                        <div class="badge-variant" style="padding: 2px 6px;">RAM: <b><%= item.RAM %></b></div>
                                        <div class="badge-variant" style="padding: 2px 6px;">STORAGE: <b><%= item.storage %></b></div>
                                        <div class="badge-variant" style="padding: 2px 6px;">COLOR: <b><%= item.color %></b></div>
                                    </div>
                                </div>
                                <div class="mt-4">
                                    <div class="flex items-center justify-between relative px-2">
                                        <% let steps = ['Pending', 'Processing', 'Shipped', 'Delivered'];
                                           let itemS = item.status || order.orderStatus;
                                           if (itemS.includes('Return')) { steps[3] = itemS; }
                                           else if (itemS.includes('Cancel')) { steps = ['Pending', itemS]; }
                                           let cIdx = steps.indexOf(itemS);
                                           if (cIdx === -1) cIdx = steps.length - 1;

                                           // Real timestamps per step — only show for completed steps
                                           const fmtDate = d => d ? new Date(d).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : null;
                                           const fmtTime = d => d ? new Date(d).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit', hour12: true }) : null;

                                           const stepTimestamps = {
                                               'Pending':    order.createdAt,
                                               'Processing': item.processingAt,
                                               'Shipped':    item.shippedAt,
                                               'Delivered':  item.deliveredAt || order.deliveredAt,
                                               'Cancelled':  item.cancelledAt || order.updatedAt,
                                               'Returned':   item.returnedAt  || order.updatedAt,
                                               'Return Requested':       order.updatedAt,
                                               'Cancellation Requested': order.updatedAt,
                                           };
                                        %>
                                        <% steps.forEach((step, i) => { %>
                                            <div class="flex flex-col items-center">
                                                <div class="stepper-dot <%= i <= cIdx ? 'active' : '' %>"></div>
                                                <span class="stepper-text <%= i <= cIdx ? 'active' : '' %>"><%= step %></span>
                                                <% if (i <= cIdx && stepTimestamps[step]) { %>
                                                    <span class="stepper-date"><%= fmtDate(stepTimestamps[step]) %></span>
                                                    <span class="stepper-time"><%= fmtTime(stepTimestamps[step]) %></span>
                                                <% } %>
                                            </div>
                                            <% if (i < steps.length - 1) { %>
                                                <div class="stepper-line <%= i < cIdx ? 'active' : '' %>"></div>
                                            <% } %>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Right Side: Sidebar -->
            <div class="space-y-6 no-download">
                <div class="glass-card p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <i class="bi bi-circle-fill text-blue-500 text-[8px]"></i>
                        <h3 class="text-lg font-bold">Shipping Address</h3>
                    </div>
                    <div class="space-y-3 text-sm text-[#8b949e]">
                        <p class="text-white font-medium"><i class="bi bi-person mr-2"></i><%= order.shippingAddress.fullName %></p>
                        <p><i class="bi bi-telephone mr-2"></i><%= order.shippingAddress.phone %></p>
                        <div class="flex items-start gap-2">
                            <i class="bi bi-geo-alt mt-1"></i>
                            <div>
                                <p class="text-white font-medium"><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %></p>
                                <p class="mt-1 leading-relaxed"><%= order.shippingAddress.houseName %>(h), <%= order.shippingAddress.locality %>, <%= order.shippingAddress.pincode %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-card p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <i class="bi bi-receipt text-blue-500 text-[8px]"></i>
                        <h3 class="text-lg font-bold">Price Details</h3>
                    </div>
                    <% 
                        let deductionAmount = 0;
                        if (order.orderStatus === 'Cancelled' || order.orderStatus === 'Returned') {
                            deductionAmount = order.finalPrice;
                        } else {
                            order.items.forEach(item => {
                                if (['Cancelled', 'Returned'].includes(item.status)) {
                                    let rAmount = item.total;
                                    if (order.couponDiscount > 0 && order.subtotal > 0) {
                                        const proportion = item.total / order.subtotal;
                                        const itemCouponDiscount = order.couponDiscount * proportion;
                                        rAmount = item.total - itemCouponDiscount;
                                    }
                                    deductionAmount += rAmount;
                                }
                            });
                        }
                        deductionAmount = Math.round(deductionAmount);
                        const isRefund = ['Paid', 'Refunded'].includes(order.paymentStatus) && ['Online', 'Wallet'].includes(order.paymentMethod);
                        const deductionLabel = isRefund ? 'Refunded' : 'Cancelled Amount';
                    %>
                    <div class="space-y-4 text-sm">
                        <div class="flex justify-between"><span>Subtotal</span><span class="text-white font-bold">₹<%= order.subtotal.toLocaleString('en-IN') %></span></div>
                        <div class="flex justify-between text-red-500"><span>Discount</span><span>-₹<%= (order.discount || 0).toLocaleString('en-IN') %></span></div>
                        <div class="flex justify-between text-red-500"><span>Coupon</span><span>-₹<%= (order.couponDiscount || 0).toLocaleString('en-IN') %></span></div>
                        <div class="flex justify-between <%= deductionAmount === 0 ? 'pb-4 border-b border-[#30363d]' : '' %>"><span>Tax (GST)</span><span class="text-white font-bold">₹<%= (order.tax || 0).toLocaleString('en-IN') %></span></div>
                        
                        <% if (deductionAmount > 0) { %>
                            <div class="flex justify-between text-blue-400 pb-4 border-b border-[#30363d]"><span><%= deductionLabel %></span><span>-₹<%= deductionAmount.toLocaleString('en-IN') %></span></div>
                        <% } %>

                        <div class="flex justify-between items-center pt-2">
                            <span class="text-xl font-extrabold uppercase">Total</span>
                            <% const finalNet = Math.max(0, order.finalPrice - deductionAmount); %>
                            <% if (finalNet === 0 && deductionAmount > 0) { %>
                                <span class="text-[0.95rem] font-black text-blue-400 uppercase tracking-widest"><%= isRefund ? 'FULLY REFUNDED' : 'FULLY CANCELLED' %></span>
                            <% } else { %>
                                <span class="text-2xl font-extrabold text-white">₹<%= finalNet.toLocaleString('en-IN') %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Item Action Modal -->
    <div class="modal fade" id="itemActionModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-slate-700">
                    <h5 class="modal-title font-bold text-white uppercase tracking-tighter" id="modalTitle">Cancel Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-6">
                    <p class="text-slate-400 text-sm mb-4" id="itemNameText">Are you sure you want to cancel this item?</p>
                    <label class="block text-slate-400 text-xs font-black uppercase tracking-widest mb-2">Select Reason</label>
                    <select id="actionReason" onchange="onReasonChange()"
                        class="form-select w-full rounded-xl py-3 px-4 border-slate-700 focus:outline-none"
                        style="font-weight:600">
                        <option value="" selected disabled style="color:#8b949e">Choose a reason...</option>
                        <option value="Mistake purchase" style="color:#f59e0b; background:#161b22"> Mistake purchase</option>
                        <option value="Found better price" style="color:#3b82f6; background:#161b22"> Found better price</option>
                        <option value="Changed my mind" style="color:#a855f7; background:#161b22"> Changed my mind</option>
                        <option value="Product issues" style="color:#ef4444; background:#161b22"> Product issues</option>
                        <option value="other" style="color:#10b981; background:#161b22"> Others</option>
                    </select>
                    <div id="othersWrapper">
                        <textarea id="othersInput" rows="3" placeholder="Please describe your reason here…"></textarea>
                        <p class="text-[0.6rem] text-red-500 font-bold mt-1 hidden" id="othersError">This field is required when selecting "Others".</p>
                    </div>
                </div>
                <div class="modal-footer border-slate-700">
                    <button type="button" class="px-6 py-2 rounded-lg bg-slate-800 text-slate-300 font-bold text-xs" data-bs-dismiss="modal">CLOSE</button>
                    <button type="button" class="px-6 py-2 rounded-lg bg-red-600 text-white font-bold text-xs" id="confirmBtn" onclick="submitItemAction()">CONFIRM ACTION</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let selectedOrder = '<%= order._id %>';
        let selectedItem = null;
        let actionType = '';

        // ── Invoice Download ──────────────────────────────────────────────────
        // Simply opens the invoice page in a new tab.
        // The invoice page detects ?download=true and auto-triggers html2pdf download.
        function downloadInvoice(orderId, btn) {
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Opening...';
            btn.style.pointerEvents = 'none';

            window.open(`/myOrders/invoice?id=${orderId}&download=true`, '_blank');

            // Restore button after a short delay
            setTimeout(() => {
                btn.innerHTML = originalHtml;
                btn.style.pointerEvents = 'auto';
            }, 3000);
        }

        // ── Item Modal ────────────────────────────────────────────────────────
        function openItemModal(itemId, itemName, type) {
            selectedItem = itemId;
            actionType = type;
            const title   = type === 'cancel' ? 'Cancel Item' : 'Return Item';
            const text    = type === 'cancel' ? 'Are you sure you want to cancel the product: ' : 'Are you sure you want to return the product: ';
            const btnClass = type === 'cancel' ? 'px-6 py-2 rounded-lg bg-red-600 text-white font-bold text-xs' : 'px-6 py-2 rounded-lg bg-orange-600 text-white font-bold text-xs';
            const btnText  = type === 'cancel' ? 'CONFIRM CANCELLATION' : 'CONFIRM RETURN';

            document.getElementById('modalTitle').innerText  = title;
            document.getElementById('itemNameText').innerText = text + itemName + '?';
            document.getElementById('confirmBtn').className  = btnClass;
            document.getElementById('confirmBtn').innerText  = btnText;

            document.getElementById('actionReason').value = '';
            const wrapper = document.getElementById('othersWrapper');
            const input   = document.getElementById('othersInput');
            const err     = document.getElementById('othersError');
            wrapper.classList.remove('show');
            input.value = '';
            input.classList.remove('error');
            err.classList.add('hidden');

            new bootstrap.Modal(document.getElementById('itemActionModal')).show();
        }

        function onReasonChange() {
            const sel     = document.getElementById('actionReason').value;
            const wrapper = document.getElementById('othersWrapper');
            const input   = document.getElementById('othersInput');
            const err     = document.getElementById('othersError');

            if (sel === 'other') {
                wrapper.classList.add('show');
            } else {
                wrapper.classList.remove('show');
                input.classList.remove('error');
                err.classList.add('hidden');
            }
        }

        function submitItemAction() {
            const sel   = document.getElementById('actionReason').value;
            const input = document.getElementById('othersInput');
            const err   = document.getElementById('othersError');

            if (!sel) {
                return Swal.fire({ title: 'Error', text: 'Please select a reason', icon: 'error', background: '#161b22', color: '#fff' });
            }

            let reason = sel;
            if (sel === 'other') {
                const custom = input.value.trim();
                if (!custom) {
                    input.classList.add('error');
                    err.classList.remove('hidden');
                    input.focus();
                    return;
                }
                reason = custom;
            }

            input.classList.remove('error');
            err.classList.add('hidden');

            const endpoint = actionType === 'cancel' ? '/cancel-item' : '/return-item';
            axios.post(endpoint, { orderId: selectedOrder, itemId: selectedItem, reason })
                .then(res => {
                    if (res.data.success) {
                        Swal.fire({ title: 'Success', text: res.data.message, icon: 'success', timer: 1000, showConfirmButton: false, background: '#161b22', color: '#fff' })
                            .then(() => location.reload());
                    } else {
                        Swal.fire({ title: 'Error', text: res.data.message, icon: 'error', timer: 1000, showConfirmButton: false, background: '#161b22', color: '#fff' });
                    }
                });
        }

        // ── Cancel Entire Order ───────────────────────────────────────────────
        function handleCancelEntireOrder() {
            Swal.fire({
                title: 'Cancel Entire Order?',
                html: `
                    <div class="text-left px-2">
                        <p class="text-gray-400 text-[0.7rem] font-bold uppercase tracking-widest mb-3">Select a reason for cancellation</p>
                        <select id="swalCancelReason" class="swal2-select w-full !m-0 !flex" style="background:#1a1f2e; color:#fff; border:1px solid rgba(255,255,255,0.1); border-radius:12px; font-size:0.85rem; padding: 10px;">
                            <option value="" disabled selected>Choose a reason...</option>
                            <option value="Mistake purchase">Mistake purchase</option>
                            <option value="Found better price">Found better price</option>
                            <option value="Changed my mind">Changed my mind</option>
                            <option value="others">Others</option>
                        </select>
                        <div id="swalOthersWrapper" style="display:none; margin-top:20px;">
                            <p class="text-gray-400 text-[0.7rem] font-bold uppercase tracking-widest mb-3">Please specify your reason</p>
                            <textarea id="swalOthersInput" class="swal2-textarea !m-0 !w-full" style="background:#1a1f2e; color:#fff; border:1px solid rgba(255,255,255,0.1); border-radius:12px; font-size:0.85rem; height: 100px; padding: 12px;" placeholder="Describe why you want to cancel..."></textarea>
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#334155',
                confirmButtonText: 'Confirm Cancellation',
                cancelButtonText: 'Go Back',
                background: '#161b22',
                color: '#fff',
                didOpen: () => {
                    const select = document.getElementById('swalCancelReason');
                    const wrapper = document.getElementById('swalOthersWrapper');
                    select.addEventListener('change', () => {
                        if (select.value === 'others') {
                            wrapper.style.display = 'block';
                            setTimeout(() => document.getElementById('swalOthersInput').focus(), 100);
                        } else {
                            wrapper.style.display = 'none';
                        }
                    });
                },
                preConfirm: () => {
                    const select = document.getElementById('swalCancelReason');
                    const others = document.getElementById('swalOthersInput');
                    if (!select.value) {
                        Swal.showValidationMessage('Please select a reason');
                        return false;
                    }
                    if (select.value === 'others' && !others.value.trim()) {
                        Swal.showValidationMessage('Please describe your reason');
                        return false;
                    }
                    return select.value === 'others' ? others.value.trim() : select.value;
                }
            }).then(result => {
                if (result.isConfirmed) {
                    submitCancelOrder(result.value);
                }
            });
        }

        function submitCancelOrder(reason) {
            axios.post('/cancel-order', { orderId: selectedOrder, reason })
                .then(res => {
                    if (res.data.success) {
                        Swal.fire({ title: 'Cancelled!', text: 'Your order has been cancelled.', icon: 'success', background: '#161b22', color: '#fff' })
                            .then(() => location.reload());
                    } else {
                        Swal.fire({ title: 'Error', text: res.data.message, icon: 'error', background: '#161b22', color: '#fff' });
                    }
                });
        }

        // ── Return Entire Order ───────────────────────────────────────────────
        function handleReturnEntireOrder() {
            Swal.fire({
                title: 'Return Entire Order?',
                html: `
                    <div class="text-left px-2">
                        <p class="text-gray-400 text-[0.7rem] font-bold uppercase tracking-widest mb-3">Select a reason for return</p>
                        <select id="swalReturnReason" class="swal2-select w-full !m-0 !flex" style="background:#1a1f2e; color:#fff; border:1px solid rgba(255,255,255,0.1); border-radius:12px; font-size:0.85rem; padding: 10px;">
                            <option value="" disabled selected>Choose a reason...</option>
                            <option value="Defective product">Product is defective</option>
                            <option value="Not as described">Product not as described</option>
                            <option value="Wrong item">Received wrong item</option>
                            <option value="others">Others</option>
                        </select>
                        <div id="swalOthersWrapper" style="display:none; margin-top:20px;">
                            <p class="text-gray-400 text-[0.7rem] font-bold uppercase tracking-widest mb-3">Please specify your reason</p>
                            <textarea id="swalOthersInput" class="swal2-textarea !m-0 !w-full" style="background:#1a1f2e; color:#fff; border:1px solid rgba(255,255,255,0.1); border-radius:12px; font-size:0.85rem; height: 100px; padding: 12px;" placeholder="Describe why you want to return..."></textarea>
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonColor: '#f59e0b',
                cancelButtonColor: '#334155',
                confirmButtonText: 'Submit Return Request',
                cancelButtonText: 'Go Back',
                background: '#161b22',
                color: '#fff',
                didOpen: () => {
                    const select = document.getElementById('swalReturnReason');
                    const wrapper = document.getElementById('swalOthersWrapper');
                    select.addEventListener('change', () => {
                        if (select.value === 'others') {
                            wrapper.style.display = 'block';
                            setTimeout(() => document.getElementById('swalOthersInput').focus(), 100);
                        } else {
                            wrapper.style.display = 'none';
                        }
                    });
                },
                preConfirm: () => {
                    const select = document.getElementById('swalReturnReason');
                    const others = document.getElementById('swalOthersInput');
                    if (!select.value) {
                        Swal.showValidationMessage('Please select a reason');
                        return false;
                    }
                    if (select.value === 'others' && !others.value.trim()) {
                        Swal.showValidationMessage('Please describe your reason');
                        return false;
                    }
                    return select.value === 'others' ? others.value.trim() : select.value;
                }
            }).then(result => {
                if (result.isConfirmed) {
                    submitReturnOrder(result.value);
                }
            });
        }

        function submitReturnOrder(reason) {
            axios.post('/return-order', { orderId: selectedOrder, reason })
                .then(res => {
                    if (res.data.success) {
                        Swal.fire({ title: 'Return Requested!', text: 'Your return request has been submitted.', icon: 'success', background: '#161b22', color: '#fff' })
                            .then(() => location.reload());
                    } else {
                        Swal.fire({ title: 'Error', text: res.data.message, icon: 'error', background: '#161b22', color: '#fff' });
                    }
                });
        }

        // ── Retry Payment ─────────────────────────────────────────────────────
        function handleRetryPayment(orderId, btn) {
            const originalContent = btn.innerHTML;

            Swal.fire({
                title: 'Initiating Retry',
                text: 'Preparing your payment...',
                allowOutsideClick: false,
                background: '#161b22',
                color: '#fff',
                showCancelButton: true,
                confirmButtonText: 'Yes, Retry',
                cancelButtonText: 'Cancel'
            }).then(r => {
                if (r.isConfirmed) {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';

                    axios.post('/retry-payment', { orderId })
                        .then(res => {
                            if (res.data.success) {
                                const options = {
                                    key: res.data.key,
                                    amount: res.data.order.amount,
                                    currency: res.data.order.currency,
                                    name: "Zyrox",
                                    description: "Order Retry Payment",
                                    order_id: res.data.order.id,
                                    handler: function (response) {
                                        Swal.fire({
                                            title: 'Verifying...',
                                            text: 'Please wait while we confirm your payment',
                                            allowOutsideClick: false,
                                            didOpen: () => { Swal.showLoading(); },
                                            background: '#161b22',
                                            color: '#fff'
                                        });

                                        axios.post('/confirm-retry-payment', {
                                            orderId: orderId,
                                            razorpay_payment_id: response.razorpay_payment_id,
                                            razorpay_order_id: response.razorpay_order_id,
                                            razorpay_signature: response.razorpay_signature
                                        })
                                        .then(confirmRes => {
                                            if (confirmRes.data.success) {
                                                window.location.href = `/order-success/${orderId}`;
                                            } else {
                                                btn.disabled = false;
                                                btn.innerHTML = originalContent;
                                                Swal.fire({ title: 'Error', text: confirmRes.data.message, icon: 'error', background: '#161b22', color: '#fff' });
                                            }
                                        }).catch(() => {
                                            btn.disabled = false;
                                            btn.innerHTML = originalContent;
                                            Swal.fire({ title: 'Error', text: 'Verification failed', icon: 'error', background: '#161b22', color: '#fff' });
                                        });
                                    },
                                    modal: {
                                        ondismiss: function() {
                                            btn.disabled = false;
                                            btn.innerHTML = originalContent;
                                        }
                                    },
                                    prefill: {
                                        name: "<%= user.fullName %>",
                                        email: "<%= user.email %>",
                                        contact: "<%= user.phone %>"
                                    },
                                    theme: { color: "#4f6ef7" }
                                };
                                const rzp = new Razorpay(options);
                                rzp.on('payment.failed', function (response) {
                                    btn.disabled = false;
                                    btn.innerHTML = originalContent;
                                    Swal.fire({
                                        title: 'Payment Failed',
                                        text: response.error.description || 'Retry attempt was unsuccessful',
                                        icon: 'error',
                                        background: '#161b22',
                                        color: '#fff'
                                    });
                                });
                                rzp.open();
                            } else {
                                btn.disabled = false;
                                btn.innerHTML = originalContent;
                                Swal.fire({ title: 'Error', text: res.data.message, icon: 'error', background: '#161b22', color: '#fff' });
                            }
                        })
                        .catch(err => {
                            btn.disabled = false;
                            btn.innerHTML = originalContent;
                            Swal.fire({ title: 'Error', text: 'Something went wrong', icon: 'error', background: '#161b22', color: '#fff' });
                        });
                }
            });
        }

        function updateTimers() {
            // 1. Payment Retry Timers
            document.querySelectorAll('.retry-timer-text').forEach(container => {
                const expiry = new Date(container.dataset.expiry);
                const now = new Date();
                const diff = expiry - now;

                if (diff <= 0) {
                    const parent = container.parentElement;
                    if (parent) {
                        const retryBtn = parent.querySelector('.retry-btn');
                        if (retryBtn) retryBtn.remove();
                    }
                    container.innerHTML = '<span class="text-danger" style="font-size: 10px;"><i class="fas fa-exclamation-triangle"></i> Retry Expired</span>';
                } else {
                    const minutes = Math.floor(diff / 1000 / 60);
                    const seconds = Math.floor((diff / 1000) % 60);
                    const timerSpan = container.querySelector('.retry-timer');
                    if (timerSpan) {
                        timerSpan.textContent = `${minutes}m ${seconds}s`;
                    }
                }
            });

            // 2. Return Window Timers
            document.querySelectorAll('.return-timer-text').forEach(container => {
                const expiry = new Date(container.dataset.expiry);
                const now = new Date();
                const diff = expiry - now;

                if (diff <= 0) {
                    const parent = container.parentElement;
                    if (parent) {
                        const returnBtn = parent.querySelector('.return-btn');
                        if (returnBtn) returnBtn.remove();
                    }
                    container.innerHTML = 'RETURN EXPIRED';
                } else {
                    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
                    const minutes = Math.floor((diff / (1000 * 60)) % 60);
                    const seconds = Math.floor((diff / 1000) % 60);

                    const timerSpan = container.querySelector('.return-timer');
                    if (timerSpan) {
                        let text = '';
                        if (days > 0) text += `${days}d `;
                        text += `${hours}h ${minutes}m ${seconds}s`;
                        timerSpan.textContent = text;
                    }
                }
            });
        }

        setInterval(updateTimers, 1000);
        updateTimers();
    </script>
</body>

</html>
