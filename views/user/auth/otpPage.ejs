<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/userStyles/auth/otpPage.css">
    <link rel="stylesheet" href="/userStyles/global/background.css">
    <%- include('../../partials/alerts') %>
</head>

<body data-otp-swal="<%= otpSwal %>" data-otp-success="<%= otpSuccess %>" data-otp-error="<%= otpError %>"
    data-purpose="<%= purpose %>" data-email="<%= Email %>">

    <!-- Global Space Background Element -->
    <div class="space-background">
        <div class="stars"></div>
        <div class="stars2"></div>
        <div class="stars3"></div>
        <div class="nebula"></div>
    </div>

    <div class="otp-card <%= otpError ? 'animate__animated animate__shakeX' : '' %>">

        <h1 class="otp-title">
            <%= purpose==="signup" ? "Verify Your Email" : "Verify OTP" %>
        </h1>

        <p class="otp-subtitle">
            We sent a 6-digit verification code to<br>
            <%= Email %>
        </p>

        <!-- OTP FORM -->
        <form
            action="<%= purpose === 'signup' ? '/verify-otp' : purpose === 'reset' ? '/verify-reset-otp' : '/verify-edit-email-otp' %>"
            method="post" autocomplete="off">

            <!-- <input type="hidden" name="Email" value="<%= Email %>"> -->

            <div class="otp-input-container">
                <input name="A" class="otp-input" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
                <input name="B" class="otp-input" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
                <input name="C" class="otp-input" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
                <input name="D" class="otp-input" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
                <input name="E" class="otp-input" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
                <input name="F" class="otp-input" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
            </div>

            <div class="timer-text">
                <p id="otpText">
                    OTP expires in <span id="otpTimer">03:00</span>
                </p>
            </div>

            <button type="submit" id="verifyButton" class="btn-verify">
                Verify
            </button>

        </form>

        <!-- RESEND -->
        <div class="resend-text">
            <form
                action="<%= purpose === 'signup' ? '/resend-otp' : purpose === 'reset' ? '/resend-reset-otp' : '/resend-edit-email-otp' %>"
                method="post">
                <p>Didn't receive the code?
                    <button class="resend-link disabled" type="submit" id="resendButton" disabled readonly>
                        Resend
                    </button>
                </p>
            </form>
        </div>

        <a href="<%= purpose === 'signup' ? '/signup' :purpose==='reset' ? '/forgot-password' :'/edit-email' %>"
            class="change-email">
            Change email
        </a>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const data = document.body.dataset;
            const otpSwal = data.otpSwal === 'true';
            const otpSuccess = data.otpSuccess;
            const otpError = data.otpError;
            const purpose = data.purpose;
            const userEmail = data.email;

            // --- FEEDBACK HANDLING (Swals) ---

            // 1. Success with Redirection
            if (otpSwal && otpSuccess) {
                Swal.fire({
                    icon: 'success',
                    title: 'Verified!',
                    text: otpSuccess,
                    showConfirmButton: false,
                    timer: 1500,
                    background: '#0f172a',
                    color: '#fff',
                    iconColor: '#10b981',
                    showClass: { popup: 'animate__animated animate__fadeInDown' }
                }).then(() => {
                    if (purpose === "signup") {
                        window.location.href = '/';
                    } else if (purpose === "reset") {
                        window.location.href = '/new-password';
                    }
                    else {
                        window.location.href = "/edit-email"
                    }
                });
            }
            // 2. Normal Success Toast (e.g. Resend)
            else if (otpSuccess) {
                showToast('success', otpSuccess);
            }
            // 3. Error Modal
            else if (otpError) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: otpError,
                    background: '#0f172a',
                    color: '#fff',
                    confirmButtonColor: '#ef4444',
                    iconColor: '#ef4444',
                    showClass: { popup: 'animate__animated animate__shakeX' }
                });
            }

            // --- TIMER LOGIC ---

            const otpTimer = document.getElementById("otpTimer");
            const otpText = document.getElementById("otpText");
            const verifyButton = document.getElementById("verifyButton");
            const resendButton = document.getElementById("resendButton");

            const timerKey = `otpExpiry_${userEmail}_${purpose}`;
            let expiryTime = localStorage.getItem(timerKey);
            let seconds;

            const currentTime = Math.floor(Date.now() / 1000);

            if (expiryTime && parseInt(expiryTime) > currentTime) {
                seconds = parseInt(expiryTime) - currentTime;
            } else {
                seconds = 180; // 3 minutes
                expiryTime = currentTime + seconds;
                localStorage.setItem(timerKey, expiryTime);
            }

            function updateTimerDisplay() {
                let minutes = Math.floor(seconds / 60);
                let secs = seconds % 60;
                otpTimer.textContent =
                    (minutes < 10 ? "0" + minutes : minutes) + ":" +
                    (secs < 10 ? "0" + secs : secs);

                if (seconds <= 30) {
                    otpTimer.style.color = "red";
                }
            }

            function handleExpiry() {
                otpText.textContent = "OTP Expired";
                otpText.style.color = "red";
                otpTimer.textContent = "00:00";

                verifyButton.disabled = true;
                verifyButton.textContent = "Expired";
                verifyButton.style.backgroundColor = "gray";

                resendButton.disabled = false;
                resendButton.classList.remove("disabled");
                resendButton.style.color = "#00ff88";
            }

            function startTimer() {
                updateTimerDisplay();
                if (seconds <= 0) {
                    handleExpiry();
                    return;
                }

                const timerInterval = setInterval(() => {
                    if (seconds > 0) {
                        seconds--;
                        updateTimerDisplay();
                    } else {
                        clearInterval(timerInterval);
                        handleExpiry();
                    }
                }, 1000);
            }

            startTimer();

            // Clear timer logic
            document.querySelector('.resend-text form').addEventListener('submit', () => {
                localStorage.removeItem(timerKey);
            });

            document.querySelector('.change-email').addEventListener('click', () => {
                localStorage.removeItem(timerKey);
            });

            const inputs = document.querySelectorAll(".otp-input");
            inputs.forEach((input, index) => {
                input.addEventListener('paste', (e) => {
                    e.preventDefault();
                    const pasteData = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, "");
                    
                    if (pasteData) {
                        // If it's a full 6-digit OTP, always fill from the start.
                        // Otherwise, fill starting from the currently focused field.
                        const startIdx = (pasteData.length === inputs.length) ? 0 : index;
                        
                        let currentIdx = startIdx;
                        for (let i = 0; i < pasteData.length && currentIdx < inputs.length; i++) {
                            inputs[currentIdx].value = pasteData[i];
                            currentIdx++;
                        }
                        
                        // Focus the next available field or the last one
                        const nextFocusIdx = Math.min(currentIdx, inputs.length - 1);
                        inputs[nextFocusIdx].focus();
                        
                        // Auto-submit if all 6 digits are present
                        const allFilled = Array.from(inputs).every(inp => inp.value !== "");
                        if (allFilled) {
                            const form = input.closest('form');
                            if (form) form.submit();
                        }
                    }
                });

                input.addEventListener("input", (e) => {
                    // Only allow numbers
                    e.target.value = e.target.value.replace(/[^0-9]/g, "");
                    
                    // Move to next field if value is entered
                    if (e.target.value && index < inputs.length - 1) {
                        inputs[index + 1].focus();
                    }
                });

                input.addEventListener("keydown", (e) => {
                    // Backspace to move to previous field
                    if (e.key === "Backspace" && !e.target.value && index > 0) {
                        inputs[index - 1].focus();
                    }
                    // Enter key to submit
                    if (e.key === "Enter") {
                        e.preventDefault();
                        const form = input.closest('form');
                        if (form) form.submit();
                    }
                });
            });

            if (inputs.length > 0) inputs[0].focus();

            // --- LOADING STATE & AJAX ---
            const verifyForm = document.querySelector('form[action*="verify"]');
            if (verifyForm) {
                verifyForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    
                    const formData = new FormData(verifyForm);
                    const data = Object.fromEntries(formData.entries());

                    verifyButton.textContent = "Verifying...";
                    verifyButton.classList.add('btn-loading');
                    verifyButton.disabled = true;

                    fetch(verifyForm.action, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "Accept": "application/json",
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: JSON.stringify(data)
                    })
                    .then(response => response.json())
                    .then(result => {
                        if (result.success) {
                            localStorage.removeItem(timerKey);
                            Swal.fire({
                                icon: 'success',
                                title: 'Verified!',
                                text: result.message,
                                showConfirmButton: false,
                                timer: 1500,
                                background: '#0f172a',
                                color: '#fff',
                                iconColor: '#10b981',
                                showClass: { popup: 'animate__animated animate__fadeInDown' }
                            }).then(() => {
                                window.location.href = result.redirect;
                            });
                        } else {
                            verifyButton.textContent = "Verify";
                            verifyButton.classList.remove('btn-loading');
                            verifyButton.disabled = false;

                            if (result.redirect) {
                                window.location.href = result.redirect;
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Verification Failed',
                                    text: result.message,
                                    background: '#0f172a',
                                    color: '#fff',
                                    confirmButtonColor: '#ef4444',
                                    iconColor: '#ef4444',
                                    showClass: { popup: 'animate__animated animate__shakeX' }
                                });
                            }
                        }
                    })
                    .catch(error => {
                        verifyButton.textContent = "Verify";
                        verifyButton.classList.remove('btn-loading');
                        verifyButton.disabled = false;
                        console.error("Verification Error:", error);
                        showToast('error', "An unexpected error occurred");
                    });
                });
            }

            const resendForm = document.querySelector('.resend-text form');
            if (resendForm) {
                resendForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    
                    resendButton.textContent = "Sending...";
                    resendButton.classList.add('btn-loading');
                    resendButton.disabled = true;

                    fetch(resendForm.action, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "Accept": "application/json",
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    })
                    .then(response => response.json())
                    .then(result => {
                        if (result.success) {
                            showToast('success', result.message);
                            // Reset timer
                            localStorage.removeItem(timerKey);
                            location.reload(); // Reload to restart timer and clear inputs easily
                        } else {
                            resendButton.textContent = "Resend";
                            resendButton.classList.remove('btn-loading');
                            resendButton.disabled = false;
                            showToast('error', result.message);
                            if (result.redirect) window.location.href = result.redirect;
                        }
                    })
                    .catch(error => {
                        resendButton.textContent = "Resend";
                        resendButton.classList.remove('btn-loading');
                        resendButton.disabled = false;
                        console.error("Resend Error:", error);
                        showToast('error', "An unexpected error occurred");
                    });
                });
            }
        });
    </script>
</body>

</html>