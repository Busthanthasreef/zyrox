<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>

    <link rel="stylesheet" href="/userStyles/auth/resetPassword.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <%- include('../../partials/alerts') %>
</head>

<body>
    <!-- Global Space Background Element -->
    <div class="space-background">
        <div class="stars"></div>
        <div class="stars2"></div>
        <div class="stars3"></div>
        <div class="nebula"></div>
    </div>

    <div class="reset-container">
        <div class="reset-card">

            <h2>Reset Password</h2>
            <p class="subtitle">
                Enter your new password below.
            </p>

            <!-- FORM -->
            <form action="/new-password" method="POST" id="resetForm">

                <!-- NEW PASSWORD -->
                <div class="form-group">
                    <label for="Password">New Password</label>
                    <div class="input-wrapper">
                        <input type="password" id="Password" name="Password" placeholder="Enter new password"
                            autocomplete="new-password">
                        <div class="password-toggle-icon" id="togglePassword">
                            <i class="bi bi-eye-slash"></i>
                        </div>
                    </div>
                    <!-- Strength Meter -->
                    <div class="strength-meter" id="strengthMeter">
                        <div class="strength-meter-fill" id="strengthMeterFill"></div>
                    </div>
                    <!-- Password Requirements Checklist -->
                    <ul class="password-requirements" id="passwordRequirements">
                        <li class="requirement" data-req="length"><i class="bi bi-circle"></i> At least 8 characters</li>
                        <li class="requirement" data-req="uppercase"><i class="bi bi-circle"></i> At least one uppercase letter</li>
                        <li class="requirement" data-req="lowercase"><i class="bi bi-circle"></i> At least one lowercase letter</li>
                        <li class="requirement" data-req="number"><i class="bi bi-circle"></i> At least one number</li>
                        <li class="requirement" data-req="symbol"><i class="bi bi-circle"></i> At least one symbol</li>
                    </ul>
                    <p id="passwordError" class="error-message"></p>
                </div>

                <!-- CONFIRM PASSWORD -->
                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <div class="input-wrapper">
                        <input type="password" id="confirmPassword" name="confirmPassword"
                            placeholder="Confirm new password" autocomplete="new-password">
                        <div class="password-toggle-icon" id="toggleConfirmPassword">
                            <i class="bi bi-eye-slash"></i>
                        </div>
                    </div>
                    <p id="confirmPasswordError" class="error-message"></p>

                    <% if (passError) { %>
                        <p class="error-message">
                            <%= passError %>
                        </p>
                        <% } %>
                </div>

                <button type="submit" class="reset-btn">
                    Reset Password
                </button>

            </form>

        </div>
    </div>

    <% if (passSwal) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                showToast('success', "Password reset successfully");
                setTimeout(() => {
                    window.location.href = "/signin";
                }, 1500);
            });
        </script>
        <% } %>

            <script>
                document.addEventListener("DOMContentLoaded", () => {

                    const form = document.getElementById("resetForm");
                    const passwordInput = document.getElementById("Password");
                    const confirmPasswordInput = document.getElementById("confirmPassword");
                    const passwordError = document.getElementById("passwordError");
                    const confirmPasswordError = document.getElementById("confirmPasswordError");

                    const togglePassword = document.getElementById("togglePassword");
                    const toggleConfirmPassword = document.getElementById("toggleConfirmPassword");

                    if (togglePassword) {
                        togglePassword.addEventListener("click", function () {
                            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
                            passwordInput.setAttribute("type", type);

                            const icon = this.querySelector("i");
                            if (type === "text") {
                                icon.classList.remove("bi-eye-slash");
                                icon.classList.add("bi-eye");
                            } else {
                                icon.classList.remove("bi-eye");
                                icon.classList.add("bi-eye-slash");
                            }
                        });
                    }

                    if (toggleConfirmPassword) {
                        toggleConfirmPassword.addEventListener("click", function () {
                            const type = confirmPasswordInput.getAttribute("type") === "password" ? "text" : "password";
                            confirmPasswordInput.setAttribute("type", type);

                            const icon = this.querySelector("i");
                            if (type === "text") {
                                icon.classList.remove("bi-eye-slash");
                                icon.classList.add("bi-eye");
                            } else {
                                icon.classList.remove("bi-eye");
                                icon.classList.add("bi-eye-slash");
                            }
                        });
                    }
                    function clearErrors() {
                        passwordError.textContent = "";
                        confirmPasswordError.textContent = "";
                    }

                    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
                    
                    passwordInput.addEventListener('input', function() {
                        if (passwordRegex.test(this.value.trim())) {
                            if (passwordError.textContent && passwordError.textContent !== "New password is required") {
                                passwordError.textContent = "";
                            }
                            if (confirmPasswordInput.value.trim() === this.value.trim()) {
                                confirmPasswordError.textContent = "";
                            }
                        }
                    });

                    confirmPasswordInput.addEventListener('input', function() {
                        if (this.value.trim() === passwordInput.value.trim()) {
                            confirmPasswordError.textContent = "";
                        }
                    });
                    form.addEventListener("submit", function (e) {
                        clearErrors();
                        let isValid = true;

                        const password = passwordInput.value.trim();
                        const confirmPassword = confirmPasswordInput.value.trim();

                        if (!passwordRegex.test(password)) {
                            passwordError.textContent = "Password must be at least 8 characters long and include at least one uppercase letter, one lowercase letter, one number, and one special character.";
                            isValid = false;
                        }
                        if (!password) {
                            passwordError.textContent = "New password is required";
                            isValid = false;
                        } else if (password.length < 8) {
                            passwordError.textContent = "Password must be at least 8 characters long";
                            isValid = false;
                        }

                        if (!confirmPassword) {
                            confirmPasswordError.textContent = "Please confirm your password";
                            isValid = false;
                        } else if (password !== confirmPassword) {
                            confirmPasswordError.textContent = "Passwords do not match";
                            isValid = false;
                        }

                        if (!isValid) {
                            e.preventDefault();
                        }
                    });

                    // Password strength logic
                    const strengthMeter = document.getElementById("strengthMeter");
                    const strengthMeterFill = document.getElementById("strengthMeterFill");
                    const requirementsList = document.getElementById("passwordRequirements");
                    const requirements = {
                        length: { re: /.{8,}/, el: document.querySelector('[data-req="length"]') },
                        uppercase: { re: /[A-Z]/, el: document.querySelector('[data-req="uppercase"]') },
                        lowercase: { re: /[a-z]/, el: document.querySelector('[data-req="lowercase"]') },
                        number: { re: /[0-9]/, el: document.querySelector('[data-req="number"]') },
                        symbol: { re: /[\W_]/, el: document.querySelector('[data-req="symbol"]') }
                    };

                    passwordInput.addEventListener("input", function () {
                        const val = passwordInput.value;
                        if (val.length > 0) {
                            strengthMeter.style.display = "block";
                            requirementsList.style.display = "block";
                        } else {
                            strengthMeter.style.display = "none";
                            requirementsList.style.display = "none";
                        }

                        let metCount = 0;
                        Object.keys(requirements).forEach(key => {
                            const req = requirements[key];
                            const isMet = req.re.test(val);
                            if (isMet) {
                                metCount++;
                                req.el.classList.add("met");
                                req.el.querySelector("i").className = "bi bi-check-circle-fill";
                            } else {
                                req.el.classList.remove("met");
                                req.el.querySelector("i").className = "bi bi-circle";
                            }
                        });

                        // Update meter
                        const percent = (metCount / 5) * 100;
                        strengthMeterFill.style.width = percent + "%";

                        if (metCount <= 2) {
                            strengthMeterFill.style.backgroundColor = "#ef4444"; // Red
                        } else if (metCount <= 4) {
                            strengthMeterFill.style.backgroundColor = "#f59e0b"; // Yellow
                        } else {
                            strengthMeterFill.style.backgroundColor = "#4CAF50"; // Green
                        }
                    });
                });
            </script>

</body>

</html>