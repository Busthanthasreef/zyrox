<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link rel="stylesheet" href="/userStyles/auth/signUpPage.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div class="space-background">
        <div class="stars"></div>
        <div class="stars2"></div>
        <div class="stars3"></div>
        <div class="nebula"></div>
    </div>

    <div class="signup-card">
        <h1 class="h4 fw-bold mb-1">SIGN UP</h1>
        <p class="text-secondary small mb-4">Enter your information to get started</p>

        <form action="/signup" method="post">

            <!-- Full Name -->
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" id="fullName" name="name" class="form-control" placeholder="Enter Full Name"
                    value="<%= typeof Name !== 'undefined' ? Name : '' %>">
            </div>
            <p style="color:red; font-size: small;" id="nameError">
                <%= typeof nameError !=='undefined' && nameError ? nameError : '' %>
            </p>

            <!-- Email -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" id="Email" name="email" class="form-control" placeholder="Enter your Email Address"
                    value="<%= typeof Email !== 'undefined' ? Email : '' %>">
            </div>

            <!-- Email Error -->
            <p style="color:red; font-size: small;" id="emailError">
                <%= typeof emailError !=='undefined' && emailError ? emailError : '' %>
            </p>
            <!-- Phone Number -->
            <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input type="tel" id="Phone" name="phone" class="form-control" placeholder="Enter your Phone Number"
                    inputmode="numeric" pattern="[0-9+]*" maxlength="14"
                    value="<%= (typeof Phone !== 'undefined' && Phone !== '') ? (Phone.includes('+91') ? Phone : '+91' + Phone) : '+91' %>">
            </div>
            <p style="color:red; font-size: small;" id="phoneError">
                <%= typeof phoneError !=='undefined' && phoneError ? phoneError : '' %>
            </p>


            <!-- Password -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="password-wrapper">
                    <input type="password" id="Password" name="password" class="form-control"
                        placeholder="Enter your password"
                        value="<%= typeof Password !== 'undefined' ? Password : '' %>">
                    <div class="password-toggle-icon" id="togglePassword">
                        <i class="bi bi-eye-slash"></i>
                    </div>
                </div>
                <!-- Strength Meter -->
                <div class="strength-meter" id="strengthMeter">
                    <div class="strength-meter-fill" id="strengthMeterFill"></div>
                </div>
                <!-- Password Requirements Checklist -->
                <ul class="password-requirements" id="passwordRequirements">
                    <li class="requirement" data-req="length"><i class="bi bi-circle"></i> At least 8 characters</li>
                    <li class="requirement" data-req="uppercase"><i class="bi bi-circle"></i> At least one uppercase letter</li>
                    <li class="requirement" data-req="lowercase"><i class="bi bi-circle"></i> At least one lowercase letter</li>
                    <li class="requirement" data-req="number"><i class="bi bi-circle"></i> At least one number</li>
                    <li class="requirement" data-req="symbol"><i class="bi bi-circle"></i> At least one symbol</li>
                </ul>
            </div>

            <!-- Confirm Password -->
            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <div class="password-wrapper">
                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-control"
                        placeholder="Confirm password"
                        value="<%= typeof confirmPassword !== 'undefined' ? confirmPassword : '' %>">
                    <div class="password-toggle-icon" id="toggleConfirmPassword">
                        <i class="bi bi-eye-slash"></i>
                    </div>
                </div>
            </div>

            <!-- Password Error -->
            <p style="color:red; font-size: small;" id="passError">
                <%= typeof passError !=='undefined' && passError ? passError : '' %>
            </p>

            <!-- Referral Code (Optional) -->
            <div class="mb-3">
                <label class="form-label">Referral Code <span class="text-muted" style="font-size:0.8em;">(Optional –
                        get ₹500 wallet bonus)</span></label>
                <input type="text" id="referralCode" name="referralCode" class="form-control"
                    placeholder="Enter referral code (e.g. A1B2C3D4)"
                    value="<%= typeof referralCode !== 'undefined' ? referralCode : '' %>" maxlength="8"
                    style="text-transform:uppercase;">
            </div>
            <p style="color:red; font-size: small;" id="referralError"></p>

            <button type="submit" class="btn btn-create w-100">Create Account</button>
        </form>

        <div class="divider">Or continue with</div>

        <a href="/auth/google" class="btn-google" style="text-decoration: none;">
            <svg class="google-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
                <path fill="#EA4335"
                    d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                <path fill="#4285F4"
                    d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                <path fill="#FBBC05"
                    d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                <path fill="#34A853"
                    d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                <path fill="none" d="M0 0h48v48H0z" />
            </svg>
            Google
        </a>

        <div class="footer-divider mt-3">
            Already have an account? <a href="/signin">Log in</a>
        </div>

    </div>

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const formElement = document.querySelector("form");
            const submitBtn = formElement.querySelector(".btn-create");

            const togglePassword = document.getElementById("togglePassword");
            const password = document.getElementById("Password");

            if (togglePassword) {
                togglePassword.addEventListener("click", function () {
                    const type = password.getAttribute("type") === "password" ? "text" : "password";
                    password.setAttribute("type", type);

                    const icon = this.querySelector('i');
                    if (type === 'text') {
                        icon.classList.remove('bi-eye-slash');
                        icon.classList.add('bi-eye');
                    } else {
                        icon.classList.remove('bi-eye');
                        icon.classList.add('bi-eye-slash');
                    }
                });
            }

            const toggleConfirmPassword = document.getElementById("toggleConfirmPassword");
            const confirmPassword = document.getElementById("confirmPassword");
            const fullNameInput = document.getElementById("fullName");
            const emailInput = document.getElementById("Email");
            const phoneInput = document.getElementById("Phone");

            if (toggleConfirmPassword) {
                toggleConfirmPassword.addEventListener("click", function () {
                    const type = confirmPassword.getAttribute("type") === "password" ? "text" : "password";
                    confirmPassword.setAttribute("type", type);

                    const icon = this.querySelector('i');
                    if (type === 'text') {
                        icon.classList.remove('bi-eye-slash');
                        icon.classList.add('bi-eye');
                    } else {
                        icon.classList.remove('bi-eye');
                        icon.classList.add('bi-eye-slash');
                    }
                });
            }

            formElement.addEventListener("submit", function (event) {
                const Name = fullNameInput.value.trim();
                const emailValue = emailInput.value.trim();
                const phoneValue = phoneInput.value.trim();
                const passwordValue = password.value.trim();
                const confirmPasswordValue = confirmPassword.value.trim();


                const nameRegex = /^[a-zA-Z\s]{3,50}$/;
                const emailRegex = /^(?!.*\.\.)(?!\.)(?!.*\.$)[A-Za-z0-9._%+-]{1,64}@[A-Za-z0-9-]+(\.[A-Za-z]{2,})+$/;
                const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
                const phoneRegex = /^(?:\+91|91|0)?[6-9]\d{9}$/;

                const nameError = document.getElementById("nameError");
                const emailError = document.getElementById("emailError");
                const phoneError = document.getElementById("phoneError");
                const passError = document.getElementById("passError");

                nameError.textContent = "";
                emailError.textContent = "";
                phoneError.textContent = "";
                passError.textContent = "";

                let hasError = false;

                // Name validation
                if (!Name) {
                    nameError.textContent = "Full name is required";
                    hasError = true;
                } else if (!nameRegex.test(Name)) {
                    nameError.textContent = "Full name must be 3-50 characters long and contain only letters";
                    hasError = true;
                }

                // Email validation
                if (!emailValue) {
                    emailError.textContent = "Email is required";
                    hasError = true;
                } else if (!emailRegex.test(emailValue)) {
                    emailError.textContent = "Invalid email, please enter a valid email address";
                    hasError = true;
                }

                // Phone validation
                if (!phoneValue) {
                    phoneError.textContent = "Phone number is required";
                    hasError = true;
                } else if (!phoneRegex.test(phoneValue)) {
                    phoneError.textContent = "Invalid phone number, it must be a valid 10-digit Indian phone number";
                    hasError = true;
                }

                // Password validation
                if (!passwordValue) {
                    passError.textContent = "Password is required";
                    hasError = true;
                } else if (!passwordRegex.test(passwordValue)) {
                    passError.textContent = "Password must be at least 8 characters long and include at least one uppercase letter, one lowercase letter, one number, and one special character.";
                    hasError = true;
                } else if (!confirmPasswordValue) {
                    passError.textContent = "Please confirm your password";
                    hasError = true;
                } else if (passwordValue !== confirmPasswordValue) {
                    passError.textContent = "Passwords do not match";
                    hasError = true;
                }

                if (hasError) {
                    event.preventDefault();
                    return;
                }

                // Show Loading State
                submitBtn.textContent = "Loading...";
                submitBtn.classList.add("btn-loading");
                submitBtn.disabled = true;

                localStorage.removeItem("otp_timer_expiry");
            });

            // Dynamic validation clearing
            function clearPasswordErrorWhenValid() {
                const passwordValue = password.value.trim();
                const confirmPasswordValue = confirmPassword.value.trim();
                const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
                const passError = document.getElementById("passError");

                if (passwordRegex.test(passwordValue) && (!confirmPasswordValue || confirmPasswordValue === passwordValue)) {
                    passError.textContent = "";
                    return;
                }

                if (confirmPasswordValue && confirmPasswordValue !== passwordValue) {
                    passError.textContent = "Passwords do not match";
                }
            }

            fullNameInput.addEventListener('input', function() {
                document.getElementById("nameError").textContent = "";
            });

            emailInput.addEventListener('input', function() {
                document.getElementById("emailError").textContent = "";
            });

            phoneInput.addEventListener('input', function() {
                document.getElementById("phoneError").textContent = "";
            });

            // Block non-numeric characters (allow +, digits, Backspace, Delete, Tab, Arrow keys)
            phoneInput.addEventListener('keydown', function(e) {
                const allowedKeys = ['Backspace', 'Delete', 'Tab', 'ArrowLeft', 'ArrowRight', 'Home', 'End'];
                const isDigit = e.key >= '0' && e.key <= '9';
                const isPlus = e.key === '+' && this.selectionStart === 0;
                const isCtrlCmd = e.ctrlKey || e.metaKey; // allow copy/paste shortcuts
                if (!isDigit && !isPlus && !allowedKeys.includes(e.key) && !isCtrlCmd) {
                    e.preventDefault();
                }
            });

            // Strip any non-numeric chars on paste (except leading +)
            phoneInput.addEventListener('paste', function(e) {
                e.preventDefault();
                const pasted = (e.clipboardData || window.clipboardData).getData('text');
                const cleaned = pasted.replace(/[^0-9+]/g, '').replace(/(?!^)\+/g, '');
                const start = this.selectionStart;
                const end = this.selectionEnd;
                const current = this.value;
                this.value = current.slice(0, start) + cleaned + current.slice(end);
            });

            confirmPassword.addEventListener('input', function() {
                clearPasswordErrorWhenValid();
            });

            // Password strength logic
            const strengthMeter = document.getElementById("strengthMeter");
            const strengthMeterFill = document.getElementById("strengthMeterFill");
            const requirementsList = document.getElementById("passwordRequirements");
            const requirements = {
                length: { re: /.{8,}/, el: document.querySelector('[data-req="length"]') },
                uppercase: { re: /[A-Z]/, el: document.querySelector('[data-req="uppercase"]') },
                lowercase: { re: /[a-z]/, el: document.querySelector('[data-req="lowercase"]') },
                number: { re: /[0-9]/, el: document.querySelector('[data-req="number"]') },
                symbol: { re: /[\W_]/, el: document.querySelector('[data-req="symbol"]') }
            };

            password.addEventListener("input", function () {
                const val = password.value;
                if (val.length > 0) {
                    strengthMeter.style.display = "block";
                    requirementsList.style.display = "block";
                } else {
                    strengthMeter.style.display = "none";
                    requirementsList.style.display = "none";
                }

                let metCount = 0;
                Object.keys(requirements).forEach(key => {
                    const req = requirements[key];
                    const isMet = req.re.test(val);
                    if (isMet) {
                        metCount++;
                        req.el.classList.add("met");
                        req.el.querySelector("i").className = "bi bi-check-circle-fill";
                    } else {
                        req.el.classList.remove("met");
                        req.el.querySelector("i").className = "bi bi-circle";
                    }
                });

                // Update meter
                const percent = (metCount / 5) * 100;
                strengthMeterFill.style.width = percent + "%";

                if (metCount <= 2) {
                    strengthMeterFill.style.backgroundColor = "#ef4444"; // Red
                } else if (metCount <= 4) {
                    strengthMeterFill.style.backgroundColor = "#f59e0b"; // Yellow
                } else {
                    strengthMeterFill.style.backgroundColor = "#10b981"; // Green
                }

                // Dynamic validation for password
                const passError = document.getElementById("passError");
                const confirmPasswordValue = confirmPassword.value.trim();
                if (val.length >= 8 && metCount === 5) { // Regex passed roughly
                    if (!confirmPasswordValue || val === confirmPasswordValue) {
                        passError.textContent = "";
                    } else if (confirmPasswordValue && val !== confirmPasswordValue) {
                        passError.textContent = "Passwords do not match";
                    }
                }
                clearPasswordErrorWhenValid();
            });
        });

        // Parallax Effect
        document.addEventListener('mousemove', (e) => {
            const planets = document.querySelectorAll('.planet');
            const x = (window.innerWidth - e.pageX * 2) / 100;
            const y = (window.innerHeight - e.pageY * 2) / 100;

            planets.forEach(planet => {
                const speed = planet.classList.contains('earth') ? 2 : 
                              planet.classList.contains('mars') ? 4 : 1;
                planet.style.transform = `translateX(${x * speed}px) translateY(${y * speed}px)`;
            });
        });
    </script>
    <% if (typeof emailError !=='undefined' && emailError && (emailError.toLowerCase().includes('exist') ||
        emailError.toLowerCase().includes('in use'))) { %>
        <script>

            Swal.fire({
                toast: true,
                position: 'top',
                icon: 'error',
                title: '<%= emailError %>',
                showConfirmButton: false,
                timer: 1500,
                timerProgressBar: true,
                background: '#1a2a30',
                color: '#fff'
            });
        </script>
        <% } %>

</body>

</html>