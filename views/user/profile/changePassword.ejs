<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password – Zyrox</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
</head>

<body>
    <%- include('../../partials/user/navigationbar') %>
    <div class="main-container">
        <!-- Sidebar Partial -->
        <%- include('../../partials/user/profileSidebar', {activePage: 'profile' }) %>

            <!-- Main Content -->
            <main class="main-wrapper">
                <div id="profile-card-container" class="w-100 d-flex justify-content-center">
                    <div class="card col-12 col-sm-10 col-md-8">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <h3 class="m-0">
                                <% if(hasPassword){ %>
                                    Update Password
                                    <% } else { %>
                                        Add Password
                                        <% } %>
                            </h3>
                            <a href="/profile" class="btn btn-custom change-pass-btn ajax-link" data-url="/profile">
                                <i class="fa-solid fa-arrow-left"></i> Back
                            </a>
                        </div>

                        <% if (!hasPassword) { %>
                            <div class="alert bg-primary-subtle text-primary border-primary-subtle mb-5">
                                <i class="bi bi-info-circle me-2"></i> Set a secure password for your Zyrox account to
                                sign in directly next time.
                            </div>
                            <% } %>

                                <!-- Global flash messages -->
                                <% if (typeof successMessage !=='undefined' && successMessage) { %>
                                    <div class="alert alert-success d-flex align-items-center mb-4">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        <%= successMessage %>
                                    </div>
                                    <% } %>

                                        <% if (typeof errorMessage !=='undefined' && errorMessage) { %>
                                            <div class="alert alert-danger d-flex align-items-center mb-4"
                                                style="background: rgba(255, 77, 109, 0.1); border: 1px solid rgba(255, 77, 109, 0.3); color: #ff8fa3;">
                                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                <%= errorMessage %>
                                            </div>
                                            <% } %>

                                                <!-- Form -->
                                                <form action="<%= hasPassword ? '/change-password' : '/add-password' %>"
                                                    method="POST" novalidate>
                                                    <div class="row g-4">
                                                        <% if (hasPassword) { %>
                                                            <div class="col-12">
                                                                <div class="form-group">
                                                                    <label>Current Password</label>
                                                                    <div class="position-relative">
                                                                        <input type="password" id="currentPassword"
                                                                            name="currentPassword" class="form-control"
                                                                            placeholder="Enter your current password"
                                                                            autocomplete="current-password">
                                                                        <button type="button"
                                                                            class="btn border-0 position-absolute end-0 top-50 translate-middle-y me-2 text-muted"
                                                                            onclick="toggleVisibility('currentPassword', this)">
                                                                            <i class="fa-regular fa-eye"></i>
                                                                        </button>
                                                                    </div>
                                                                    <% if (typeof errors !=='undefined' &&
                                                                        errors.currentPassword) { %>
                                                                        <p class="text-danger small mt-1 mb-0">
                                                                            <%= errors.currentPassword %>
                                                                        </p>
                                                                        <% } %>
                                                                </div>
                                                            </div>
                                                            <% } %>

                                                                <div class="col-md-6">
                                                                    <div class="form-group">
                                                                        <label>New Password</label>
                                                                        <div class="position-relative">
                                                                            <input type="password" id="newPassword"
                                                                                name="newPassword" class="form-control"
                                                                                placeholder="Create new password"
                                                                                autocomplete="new-password">
                                                                            <button type="button"
                                                                                class="btn border-0 position-absolute end-0 top-50 translate-middle-y me-2 text-muted"
                                                                                onclick="toggleVisibility('newPassword', this)">
                                                                                <i class="fa-regular fa-eye"></i>
                                                                            </button>
                                                                        </div>
                                                                        <!-- Strength Meter -->
                                                                        <div class="strength-meter" id="strengthMeter">
                                                                            <div class="strength-meter-fill" id="strengthMeterFill"></div>
                                                                        </div>
                                                                        <!-- Password Requirements Checklist -->
                                                                        <ul class="password-requirements" id="passwordRequirements">
                                                                            <li class="requirement" data-req="length"><i class="bi bi-circle"></i> At least 8 characters</li>
                                                                            <li class="requirement" data-req="uppercase"><i class="bi bi-circle"></i> At least one uppercase letter</li>
                                                                            <li class="requirement" data-req="lowercase"><i class="bi bi-circle"></i> At least one lowercase letter</li>
                                                                            <li class="requirement" data-req="number"><i class="bi bi-circle"></i> At least one number</li>
                                                                            <li class="requirement" data-req="symbol"><i class="bi bi-circle"></i> At least one symbol</li>
                                                                        </ul>
                                                                        <% if (typeof errors !=='undefined' &&
                                                                            errors.newPassword) { %>
                                                                            <p class="text-danger small mt-1 mb-0">
                                                                                <%= errors.newPassword %>
                                                                            </p>
                                                                            <% } %>
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-6">
                                                                    <div class="form-group">
                                                                        <label>Confirm Password</label>
                                                                        <div class="position-relative">
                                                                            <input type="password" id="confirmPassword"
                                                                                name="confirmPassword"
                                                                                class="form-control"
                                                                                placeholder="Repeat new password"
                                                                                autocomplete="new-password">
                                                                            <button type="button"
                                                                                class="btn border-0 position-absolute end-0 top-50 translate-middle-y me-2 text-muted"
                                                                                onclick="toggleVisibility('confirmPassword', this)">
                                                                                <i class="fa-regular fa-eye"></i>
                                                                            </button>
                                                                        </div>
                                                                        <% if (typeof errors !=='undefined' &&
                                                                            errors.confirmPassword) { %>
                                                                            <p class="text-danger small mt-1 mb-0">
                                                                                <%= errors.confirmPassword %>
                                                                            </p>
                                                                            <% } %>
                                                                    </div>
                                                                </div>
                                                    </div>

                                                    <button type="submit"
                                                        class="btn btn-custom edit-btn bg-primary text-white w-100 mt-5">
                                                        <i class="bi bi-shield-lock me-2"></i>
                                                        <%= hasPassword ? 'Update' : 'Add' %> Password
                                                    </button>
                                                </form>
                    </div>
                </div>
            </main>
    </div>

    <script>
        // Toggle password visibility
        function toggleVisibility(fieldId, btn) {
            const input = document.getElementById(fieldId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fa-regular fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'fa-regular fa-eye';
            }
        }

        // Form Validation
        document.addEventListener('submit', function (e) {
            const form = e.target.closest('form[action="/change-password"], form[action="/add-password"]');
            if (!form) return;

            const currentPass = form.querySelector('#currentPassword');
            const newPass = form.querySelector('#newPassword');
            const confirmPass = form.querySelector('#confirmPassword');

            let isValid = true;
            const errors = {};

            // Clear previous errors
            form.querySelectorAll('.text-danger.small').forEach(el => el.remove());
            form.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));

            if (currentPass && !currentPass.value) {
                isValid = false;
                errors.currentPassword = "Current password is required";
            }

            if (!newPass.value) {
                isValid = false;
                errors.newPassword = "New password is required";
            } else if (!/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/.test(newPass.value)) {
                isValid = false;
                errors.newPassword = "Password must be at least 8 characters long and include at least one uppercase letter, one lowercase letter, one number, and one special character.";
            }

            if (newPass.value !== confirmPass.value) {
                isValid = false;
                errors.confirmPassword = "Passwords do not match";
            }

            if (!isValid) {
                e.preventDefault();
                e.stopImmediatePropagation();

                Object.keys(errors).forEach(key => {
                    const field = form.querySelector(`#${key}`);
                    if (field) {
                        field.classList.add('is-invalid');
                        const errorMsg = document.createElement('p');
                        errorMsg.className = 'text-danger small mt-1 mb-0';
                        errorMsg.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> ${errors[key]}`;
                        field.parentNode.after(errorMsg);
                    }
                });
            }
        }, true);

        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form[action="/change-password"], form[action="/add-password"]');
            if (!form) return;

            const currentPass = form.querySelector('#currentPassword');
            const newPass = form.querySelector('#newPassword');
            const confirmPass = form.querySelector('#confirmPassword');
            const strongRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;

            function clearFieldError(field) {
                if (!field) return;
                field.classList.remove('is-invalid');
                const parentError = field.parentNode.nextElementSibling;
                if (parentError && parentError.classList.contains('text-danger')) {
                    parentError.remove();
                }
            }

            if (currentPass) {
                currentPass.addEventListener('input', function () {
                    if (this.value.trim()) clearFieldError(this);
                });
            }

            if (newPass) {
                newPass.addEventListener('input', function () {
                    if (strongRegex.test(this.value.trim())) clearFieldError(this);

                    if (confirmPass && confirmPass.value.trim() && confirmPass.value.trim() === this.value.trim()) {
                        clearFieldError(confirmPass);
                    }
                });
            }

            if (confirmPass) {
                confirmPass.addEventListener('input', function () {
                    if (newPass && this.value.trim() && this.value.trim() === newPass.value.trim()) {
                        clearFieldError(this);
                    }
                });
            }
        });

        // Password strength logic
        document.addEventListener('DOMContentLoaded', function() {
            const newPass = document.getElementById("newPassword");
            const strengthMeter = document.getElementById("strengthMeter");
            const strengthMeterFill = document.getElementById("strengthMeterFill");
            const requirementsList = document.getElementById("passwordRequirements");
            
            if (newPass) {
                const requirements = {
                    length: { re: /.{8,}/, el: document.querySelector('[data-req="length"]') },
                    uppercase: { re: /[A-Z]/, el: document.querySelector('[data-req="uppercase"]') },
                    lowercase: { re: /[a-z]/, el: document.querySelector('[data-req="lowercase"]') },
                    number: { re: /[0-9]/, el: document.querySelector('[data-req="number"]') },
                    symbol: { re: /[\W_]/, el: document.querySelector('[data-req="symbol"]') }
                };

                newPass.addEventListener("input", function () {
                    const val = newPass.value;
                    if (val.length > 0) {
                        strengthMeter.style.display = "block";
                        requirementsList.style.display = "block";
                    } else {
                        strengthMeter.style.display = "none";
                        requirementsList.style.display = "none";
                    }

                    let metCount = 0;
                    Object.keys(requirements).forEach(key => {
                        const req = requirements[key];
                        if (req.el) {
                            const isMet = req.re.test(val);
                            if (isMet) {
                                metCount++;
                                req.el.classList.add("met");
                                req.el.querySelector("i").className = "bi bi-check-circle-fill";
                            } else {
                                req.el.classList.remove("met");
                                req.el.querySelector("i").className = "bi bi-circle";
                            }
                        }
                    });

                    // Update meter
                    const percent = (metCount / 5) * 100;
                    strengthMeterFill.style.width = percent + "%";

                    if (metCount <= 2) {
                        strengthMeterFill.style.backgroundColor = "#ff4d6d"; // Danger
                    } else if (metCount <= 4) {
                        strengthMeterFill.style.backgroundColor = "#f59e0b"; // Yellow
                    } else {
                        strengthMeterFill.style.backgroundColor = "#00d4aa"; // Success
                    }
                });
            }
        });
    </script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Logic for Card Switching -->
    <script src="/js/userProfile.js"></script>
</body>

</html>