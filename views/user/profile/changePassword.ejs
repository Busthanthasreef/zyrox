<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password – Zyrox</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
</head>

<body>

    <div class="main-container">
        <!-- Sidebar Partial -->
        <%- include('../../partials/user/profileSidebar', {activePage: 'profile' }) %>

            <!-- Main Content -->
            <main class="main-wrapper">
                <div id="profile-card-container" class="w-100 d-flex justify-content-center">
                    <div class="card col-12 col-sm-10 col-md-8">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3><i class="fa-solid fa-shield-halved me-2"></i>
                                <% if(hasPassword){ %>
                                    Change Password
                                    <%} else{ %>
                                        Add Password
                                        <br>

                                        <p class="small ms-4" style="color:gray;font-weight: 400;">add a new password
                                            for zyrox</p>
                                        <%}%>
                            </h3>
                            <a href="/profile" class="btn btn-back ajax-link" data-url="/profile">
                                <i class="fa-solid fa-arrow-left"></i> Back to Profile
                            </a>
                        </div>

                        <!-- Global flash messages -->
                        <% if (typeof successMessage !=='undefined' && successMessage) { %>
                            <div class="alert alert-success d-flex align-items-center mb-4">
                                <i class="fa-solid fa-circle-check me-2"></i>
                                <%= successMessage %>
                            </div>
                            <% } %>

                                <% if (typeof errorMessage !=='undefined' && errorMessage) { %>
                                    <div class="alert alert-danger d-flex align-items-center mb-4"
                                        style="background: rgba(255, 77, 109, 0.1); border: 1px solid rgba(255, 77, 109, 0.3); color: #ff8fa3;">
                                        <i class="fa-solid fa-circle-exclamation me-2"></i>
                                        <%= errorMessage %>
                                    </div>
                                    <% } %>

                                        <!-- Form -->
                                        <% if (hasPassword) { %>
                                            <form action="/change-password" method="POST" novalidate>
                                                <% } else { %>
                                                    <form action="/add-password" method="POST" novalidate>
                                                        <%}%>

                                                            <% if (hasPassword) { %>
                                                                <!-- Current Password -->
                                                                <div class="form-group">
                                                                    <label for="currentPassword">Current
                                                                        Password</label>
                                                                    <div class="position-relative">
                                                                        <i
                                                                            class="fa-solid fa-lock position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                                                                        <input type="password" id="currentPassword"
                                                                            name="currentPassword"
                                                                            class="form-control ps-5 pe-5"
                                                                            placeholder="Enter your current password"
                                                                            autocomplete="current-password" />
                                                                        <button type="button"
                                                                            class="btn border-0 position-absolute end-0 top-50 translate-middle-y me-2 text-muted"
                                                                            onclick="toggleVisibility('currentPassword', this)">
                                                                            <i class="fa-regular fa-eye"></i>
                                                                        </button>
                                                                    </div>
                                                                    <% if (typeof errors!=='undefined' && errors.currentPassword) { %>
                                                                    <p class="text-danger small mt-1 mb-0">
                                                                        <i class="fa-solid fa-triangle-exclamation"></i>
                                                                        <%= errors.currentPassword %>
                                                                    </p>
                                                                    <% } %>
                                                                </div>


                                                                <% } %>



                                                                    <!-- New Password -->
                                                                    <div class="form-group">
                                                                        <label for="newPassword">New Password</label>
                                                                        <div class="position-relative">
                                                                            <i
                                                                                class="fa-solid fa-key position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                                                                            <input type="password" id="newPassword"
                                                                                name="newPassword"
                                                                                class="form-control ps-5 pe-5"
                                                                                placeholder="Enter a strong new password"
                                                                                autocomplete="new-password" />
                                                                            <button type="button"
                                                                                class="btn border-0 position-absolute end-0 top-50 translate-middle-y me-2 text-muted"
                                                                                onclick="toggleVisibility('newPassword', this)">
                                                                                <i class="fa-regular fa-eye"></i>
                                                                            </button>
                                                                        </div>

                                                                        <% if (typeof errors !=='undefined' &&
                                                                            errors.newPassword) { %>
                                                                            <p class="text-danger small mt-1 mb-0">
                                                                                <i
                                                                                    class="fa-solid fa-triangle-exclamation"></i>
                                                                                <%= errors.newPassword %>
                                                                            </p>
                                                                            <% } %>
                                                                    </div>

                                                                    <!-- Confirm Password -->
                                                                    <div class="form-group">
                                                                        <label for="confirmPassword">Confirm New
                                                                            Password</label>
                                                                        <div class="position-relative">
                                                                            <i
                                                                                class="fa-solid fa-shield-halved position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                                                                            <input type="password" id="confirmPassword"
                                                                                name="confirmPassword"
                                                                                class="form-control ps-5 pe-5"
                                                                                placeholder="Re-enter your new password"
                                                                                autocomplete="new-password" />
                                                                            <button type="button"
                                                                                class="btn border-0 position-absolute end-0 top-50 translate-middle-y me-2 text-muted"
                                                                                onclick="toggleVisibility('confirmPassword', this)">
                                                                                <i class="fa-regular fa-eye"></i>
                                                                            </button>
                                                                        </div>

                                                                        <% if (typeof errors !=='undefined' &&
                                                                            errors.confirmPassword) { %>
                                                                            <p class="text-danger small mt-1 mb-0">
                                                                                <i
                                                                                    class="fa-solid fa-triangle-exclamation"></i>
                                                                                <%= errors.confirmPassword %>
                                                                            </p>
                                                                            <% } %>
                                                                    </div>

                                                                    <button type="submit"
                                                                        class="btn btn-custom btn-submit w-100 mt-2">
                                                                        <i class="fa-solid fa-shield-halved me-2"></i>
                                                                        <%if(hasPassword){ %>
                                                                            Update Password
                                                                            <%} else{ %>
                                                                                Add Password
                                                                                <%}%>
                                                                    </button>

                                                    </form>
                    </div>
                </div>
            </main>
    </div>

    <script>
        // Toggle password visibility
        function toggleVisibility(fieldId, btn) {
            const input = document.getElementById(fieldId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fa-regular fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'fa-regular fa-eye';
            }
        }

        // Form Validation
        document.addEventListener('submit', function (e) {
            const form = e.target.closest('form[action="/change-password"], form[action="/add-password"]');
            if (!form) return;

            const currentPass = form.querySelector('#currentPassword');
            const newPass = form.querySelector('#newPassword');
            const confirmPass = form.querySelector('#confirmPassword');

            let isValid = true;
            const errors = {};

            // Clear previous errors
            form.querySelectorAll('.text-danger.small').forEach(el => el.remove());
            form.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));

            if (currentPass && !currentPass.value) {
                isValid = false;
                errors.currentPassword = "Current password is required";
            }

            if (!newPass.value) {
                isValid = false;
                errors.newPassword = "New password is required";
            } else if (!/^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d]{8,}$/.test(newPass.value)) {
                isValid = false;
                errors.newPassword = "Password must be at least 8 characters long and contain at least one letter and one number";
            }

            if (newPass.value !== confirmPass.value) {
                isValid = false;
                errors.confirmPassword = "Passwords do not match";
            }

            if (!isValid) {
                e.preventDefault();
                e.stopImmediatePropagation();

                Object.keys(errors).forEach(key => {
                    const field = form.querySelector(`#${key}`);
                    if (field) {
                        field.classList.add('is-invalid');
                        const errorMsg = document.createElement('p');
                        errorMsg.className = 'text-danger small mt-1 mb-0';
                        errorMsg.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> ${errors[key]}`;
                        field.parentNode.after(errorMsg);
                    }
                });
            }
        }, true);
    </script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Logic for Card Switching -->
    <script src="/js/userProfile.js"></script>
</body>

</html>