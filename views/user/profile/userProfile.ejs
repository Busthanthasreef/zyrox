<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Profile - Zyrox</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
</head>

<body>

    <div class="main-container">
        <!-- Sidebar Partial -->
        <%- include('../../partials/user/profileSidebar', { activePage: 'profile' }) %>

            <!-- Main Content -->
            <main class="main-wrapper">
                <div id="profile-card-container">
                    <div class="profile-card">

                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <h3 class="m-0">User Profile</h3>
                            <div class="d-flex gap-2">
                                <button class="btn btn-custom edit-btn ajax-link" data-url="/profile-edit">
                                    <i class="bi bi-pencil-square"></i> Edit Profile
                                </button>
                                <button class="btn btn-custom logout-btn" onclick="confirmLogout()">
                                    <i class="bi bi-box-arrow-right"></i>
                                </button>
                            </div>
                        </div>

                        <% if (user) { %>
                            <div class="text-center">
                                <div class="profile-img-container">
                                    <img class="profile-img " src="<%= userProfileImage%>" alt="Profile Image">

                                </div>
                                <div class="mb-5">
                                    <h4 class="fw-bold mb-1">
                                        <%= user.Name %>
                                    </h4>
                                    <p class="text small">Member since <%= new
                                            Date(user.createdAt).toLocaleDateString('en-US', { month: 'long' ,
                                            year: 'numeric' }) %>
                                    </p>
                                </div>
                            </div>

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="info-box">
                                        <label>Full Name</label>
                                        <p class="mb-0 fw-bold">
                                            <%= user.Name %>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box">
                                        <label>Referral Code</label>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <p class="mb-0 fw-bold font-monospace" id="referralCodeText">
                                                <%= user.referralCode || '—' %>
                                            </p>
                                            <% if (user.referralCode) { %>
                                                <button type="button" id="copyReferralBtn"
                                                    class="btn btn-sm btn-outline-secondary py-0 px-2"
                                                    title="Copy referral code" onclick="copyReferralCode()">
                                                    <i class="bi bi-clipboard" id="copyIcon"></i>
                                                </button>
                                                <button type="button" id="shareReferralBtn"
                                                    class="btn btn-sm btn-outline-primary py-0 px-2"
                                                    title="Copy referral link" onclick="copyReferralLink()">
                                                    <i class="bi bi-link-45deg" id="shareLinkIcon"></i> Share Link
                                                </button>
                                                <% } %>
                                        </div>
                                    </div>
                                </div>
                                <%if(!isGoogleUser){%>
                                    <div class="col-md-6">
                                        <div class="info-box">
                                            <label>Phone Number</label>
                                            <p class="mb-0 fw-bold">+91 <%= user.Phone_number %>
                                            </p>

                                        </div>
                                    </div>
                                    <%}%>
                                        <div class="col-md-6">
                                            <div class="info-box">
                                                <label>Verification Status</label>
                                                <p class="mb-0">
                                                    <% if (isGoogleUser) { %>
                                                        <span
                                                            class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2">
                                                            <i class="bi bi-google me-1"></i> Google Verified
                                                        </span>
                                                        <% } else { %>
                                                            <span
                                                                class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                                <i class="bi bi-shield-check me-1"></i> Zyrox Verified
                                                            </span>
                                                            <% } %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="info-box">
                                                <label>Email Address</label>
                                                <div class="d-flex align-items-center gap-2 mt-1">
                                                    <div
                                                        class="flex-grow-1 py-2 px-3 bg-dark-subtle rounded border border-secondary-subtle text-dark opacity-75">
                                                        <%= user.Email %>
                                                    </div>
                                                    <%if(isGoogleUser){%>
                                                        <p style="color: yellow;"><span
                                                                style="color: rgb(255, 0, 0);">CAN'T EDIT
                                                            </span><br>This acccont is managed by google </p>
                                                        <%}%>
                                                </div>
                                            </div>
                                        </div>
                            </div>

                            <div class="mt-5 pt-3 border-top border-secondary-subtle">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-bold">Security</h6>
                                        <p class="text-muted small mb-0">Edit Password</p>
                                    </div>
                                    <% if(isGoogleUser && !hasPassword) { %>
                                        <button class="btn btn-custom change-pass-btn ajax-link"
                                            data-url="/add-password">
                                            <i class="bi bi-shield-plus"></i> Add Password
                                        </button>
                                        <% } else { %>
                                            <button class="btn btn-custom change-pass-btn ajax-link"
                                                data-url="/change-password">
                                                <i class="bi bi-shield-lock"></i> Update Password
                                            </button>
                                            <% } %>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Logic for Card Switching -->
    <script src="/js/userProfile.js"></script>
    <script>
        function copyReferralCode() {
            const code = document.getElementById('referralCodeText').textContent.trim();
            navigator.clipboard.writeText(code).then(() => {
                const icon = document.getElementById('copyIcon');
                icon.classList.remove('bi-clipboard');
                icon.classList.add('bi-clipboard-check');
                const btn = document.getElementById('copyReferralBtn');
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-success');
                setTimeout(() => {
                    icon.classList.remove('bi-clipboard-check');
                    icon.classList.add('bi-clipboard');
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-outline-secondary');
                }, 2000);
            }).catch(() => {
                // Fallback for older browsers
                const el = document.createElement('textarea');
                el.value = code;
                document.body.appendChild(el);
                el.select();
                document.execCommand('copy');
                document.body.removeChild(el);
            });
        }

        function copyReferralLink() {
            const code = document.getElementById('referralCodeText').textContent.trim();
            const link = window.location.origin + '/signup?ref=' + code;
            navigator.clipboard.writeText(link).then(() => {
                const icon = document.getElementById('shareLinkIcon');
                const btn = document.getElementById('shareReferralBtn');
                icon.classList.remove('bi-link-45deg');
                icon.classList.add('bi-check-lg');
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-success');
                btn.innerHTML = '<i class="bi bi-check-lg"></i> Copied!';
                setTimeout(() => {
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-outline-primary');
                    btn.innerHTML = '<i class="bi bi-link-45deg" id="shareLinkIcon"></i> Share Link';
                }, 2000);
            }).catch(() => {
                // Fallback: show the link in a SweetAlert
                Swal.fire({
                    title: 'Your Referral Link',
                    text: link,
                    icon: 'info',
                    background: '#1a1a2e',
                    color: '#fff',
                    confirmButtonText: 'OK'
                });
            });
        }
    </script>
