<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>User Profile - Zyrox</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
</head>

<body>

    <div class="main-container">
        <!-- Sidebar Partial -->
        <%- include('../../partials/user/profileSidebar', {activePage: 'profile' }) %>

            <!-- Main Content -->
            <main class="main-wrapper">
                <div id="profile-card-container" class="w-100 d-flex justify-content-center">
                    <div class="profile-card col-12 col-sm-10 col-md-8">

                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                            <h3>My Profile</h3>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-custom logout-btn">
                                    <a onclick="confirmLogout()" style="text-decoration: none; color: inherit;">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </button>
                                <button class="btn btn-custom edit-btn ajax-link" data-url="/profile-edit">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </button>
                            </div>
                        </div>

                        <% if (user) { %>
                            <div class="text-center mb-4">
                                <img src="<%= user.Profile_image%>" class="profile-img">
                                <p class="mt-3 text-light opacity-75">Joined At: <%= user.createdAt %>
                                </p>
                            </div>

                            <div class="info-box">
                                <label>Full Name</label>
                                <p class="mb-0 fw-bold">
                                    <%= user.Name %>
                                </p>
                            </div>

                            <div class="info-box">
                                <label>Phone Number</label>
                                <p class="mb-0 fw-bold">
                                    +91 <%= user.Phone_number %>
                                </p>
                            </div>

                            <div class="info-box">
                                <label>Email Address</label>
                                <div class="d-flex align-items-center gap-2">
                                    <input type="text" class="form-control" value="<%= user.Email %>" disabled>
                                    <% if (isGoogleUser) { %>
                                        <span class="badge bg-warning text-dark">Google Account</span>
                                        <% }%>
                                            <% if (!isGoogleUser) { %>
                                                <span class="badge bg-success text-light">Zyrox Account</span>
                                                <% }%>

                                </div>
                            </div>
                            <% } %>
                                <div class="text-end mt-4">
                                    <% if(isGoogleUser && !hasPassword) { %>
                                        <button class="pass btn btn-custom change-pass-btn ajax-link"
                                            data-url="/add-password">
                                            <i class="bi bi-shield-lock"></i> Add a Password
                                        </button>
                                        <% } else { %>
                                            <button class="pass btn btn-custom change-pass-btn ajax-link"
                                                data-url="/change-password">
                                                <i class="bi bi-shield-lock"></i> Change Password
                                            </button>
                                            <% } %>
                                </div>
                                <% if (typeof passwordToast !=='undefined' && passwordToast) { %>
                                    <input type="hidden" id="showPasswordToast" value="true">
                                    <% } %>
                    </div>
                </div>
            </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Logic for Card Switching -->
    <script src="/js/userProfile.js"></script>
    <script>
        function confirmLogout() {

            swal.fire({
                icon: 'warning',
                text: "are you sure you want to logout?",
                showCancelButton: true,
                confirmButtonText: "yes,iam sure",
                cancelButtonText: "NO"
            }).then((isconfirm) => {
                if (isconfirm.isConfirmed) {
                    window.location.href = "/logout"
                }
            })

        }


    </script>
</body>

</html>