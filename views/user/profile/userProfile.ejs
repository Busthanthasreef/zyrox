<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Profile - Zyrox</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
</head>

<body>

    <div class="main-container">
        <!-- Sidebar Partial -->
        <%- include('../../partials/user/profileSidebar', { activePage: 'profile' }) %>

            <!-- Main Content -->
            <main class="main-wrapper">
                <div id="profile-card-container">
                    <div class="profile-card">

                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <h3 class="m-0">User Profile</h3>
                            <div class="d-flex gap-2">
                                <button class="btn btn-custom edit-btn ajax-link" data-url="/profile-edit">
                                    <i class="bi bi-pencil-square"></i> Edit Profile
                                </button>
                                <button class="btn btn-custom logout-btn" onclick="confirmLogout()">
                                    <i class="bi bi-box-arrow-right"></i>
                                </button>
                            </div>
                        </div>

                        <% if (user) { %>
                            <div class="text-center">
                                <div class="profile-img-container">
                                    <img src="<%= user.Profile_image || '/images/default-avatar.png' %>"
                                        class="profile-img" alt="Profile">
                                </div>
                                <div class="mb-5">
                                    <h4 class="fw-bold mb-1">
                                        <%= user.Name %>
                                    </h4>
                                    <p class="text-muted small">Member since <%= new
                                            Date(user.createdAt).toLocaleDateString('en-US', { month: 'long' ,
                                            year: 'numeric' }) %>
                                    </p>
                                </div>
                            </div>

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="info-box">
                                        <label>First Name</label>
                                        <p class="mb-0 fw-bold">
                                            <%= user.Name.split(' ')[0] %></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-box">
                                    <label>Last Name</label>
                                    <p class="mb-0 fw-bold"><%= user.Name.split(' ').slice(1).join(' ') || ' —' %>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box">
                                        <label>Phone Number</label>
                                        <p class="mb-0 fw-bold">+91 <%= user.Phone_number %>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box">
                                        <label>Verification Status</label>
                                        <p class="mb-0">
                                            <% if (isGoogleUser) { %>
                                                <span
                                                    class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2">
                                                    <i class="bi bi-google me-1"></i> Google Verified
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                        <i class="bi bi-shield-check me-1"></i> Zyrox Verified
                                                    </span>
                                                    <% } %>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="info-box">
                                        <label>Email Address</label>
                                        <div class="d-flex align-items-center gap-2 mt-1">
                                            <div
                                                class="flex-grow-1 py-2 px-3 bg-dark-subtle rounded border border-secondary-subtle text-dark opacity-75">
                                                <%= user.Email %>
                                            </div>
                                            <%if(isGoogleUser){%>
                                           <p style="color: yellow;">This acccont is managed by google <br> can't edit</p>
                                            <%}else{%>
                                                <button class="btn btn-outline-secondary btn-sm rounded-pill ajax-link" disabled aria-readonly="true">
                                                Change
                                            </button> 
                                            <%}%>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 pt-3 border-top border-secondary-subtle">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-bold">Security</h6>
                                        <p class="text-muted small mb-0">Edit Password</p>
                                    </div>
                                    <% if(isGoogleUser && !hasPassword) { %>
                                        <button class="btn btn-custom change-pass-btn ajax-link"
                                            data-url="/add-password">
                                            <i class="bi bi-shield-plus"></i> Add Password
                                        </button>
                                        <% } else { %>
                                            <button class="btn btn-custom change-pass-btn ajax-link"
                                                data-url="/change-password">
                                                <i class="bi bi-shield-lock"></i> Update Password
                                            </button>
                                            <% } %>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Logic for Card Switching -->
    <script src="/js/userProfile.js"></script>
