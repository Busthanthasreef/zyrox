<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Profile - Zyrox</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=3">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">

    <link rel="stylesheet" href="/userStyles/profile/userProfileSpecific.css">
</head>

<body>
    <%- include('../../partials/user/navigationbar') %>
    <div class="page-wrapper">
        <%- include('../../partials/user/profileSidebar', { activePage: 'profile' }) %>
        <main class="main-wrapper">

            <div class="content-container" id="profile-card-container">
                <% if (typeof profileSuccess !== 'undefined' && profileSuccess) { %>
                    <input type="hidden" id="showProfileSuccessToast" value="<%= profileSuccess %>">
                <% } %>
                <% if (typeof passwordToast !== 'undefined' && passwordToast) { %>
                    <input type="hidden" id="showPasswordSetToast" value="true">
                <% } %>
                <% if (typeof successMessage !== 'undefined' && successMessage) { %>
                    <input type="hidden" id="showPasswordUpdateToast" value="<%= successMessage %>">
                <% } %>
                <div class="profile-header-row">
                    <h3 class="profile-main-title">User Profile</h3>
                    <div class="top-action-btns">
                        <button class="btn-edit-profile" onclick="window.location.href='/profile-edit'">
                            <i class="far fa-edit"></i> Edit Profile
                        </button>
                        <button class="btn-logout-icon" onclick="confirmLogout()">
                            <i class="fas fa-sign-out-alt"></i>
                        </button>
                    </div>
                </div>

                <% if (user) { %>
                    <div class="avatar-section">
                        <div class="avatar-glow-wrap">
                            <div class="avatar-outer-ring">
                                <div class="avatar-inner-ring">
                                    <img src="<%= userProfileImage || '/images/default-avatar.png' %>" alt="Profile" class="main-avatar-img">
                                </div>
                            </div>
                        </div>
                        <h2 class="user-display-name"><%= user.Name %></h2>
                        <p class="member-since">Member since <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
                    </div>

                    <div class="info-cards-grid">
                        <div class="profile-info-card">
                            <label class="card-field-label">FULL NAME</label>
                            <div class="card-field-value"><%= user.Name %></div>
                        </div>

                        <div class="profile-info-card">
                            <label class="card-field-label">REFERRAL CODE</label>
                            <div class="card-field-row">
                                <div class="card-field-value font-monospace" id="referralCodeText"><%= user.referralCode || '—' %></div>
                                <div class="card-row-actions">
                                    <button class="icon-action-btn" onclick="copyReferralCode()" title="Copy Code">
                                        <i class="far fa-copy"></i>
                                    </button>
                                    <button class="btn-share-link" onclick="copyReferralLink()">
                                        <i class="fas fa-link"></i> Share Link
                                    </button>
                                </div>
                            </div>
                        </div>

                        <% if(!isGoogleUser) { %>
                        <div class="profile-info-card">
                            <label class="card-field-label">PHONE NUMBER</label>
                            <div class="card-field-value">+91 <%= user.Phone_number %></div>
                        </div>
                        <% } %>

                        <div class="profile-info-card">
                            <label class="card-field-label">VERIFICATION STATUS</label>
                            <div class="verification-badge-wrap">
                                <% if (isGoogleUser) { %>
                                    <span class="v-badge badge-google"><i class="fab fa-google"></i> Google Verified</span>
                                <% } else { %>
                                    <span class="v-badge badge-zyrox"><i class="fas fa-shield-alt"></i> Zyrox Verified</span>
                                <% } %>
                            </div>
                        </div>

                        <div class="profile-info-card full-width">
                            <label class="card-field-label">EMAIL ADDRESS</label>
                            <div class="email-display-box"><%= user.Email %></div>
                            <% if(isGoogleUser) { %>
                                <div class="google-managed-hint"><i class="fas fa-info-circle"></i> Managed by Google</div>
                            <% } %>
                        </div>
                    </div>

                    <div class="security-section">
                        <h4 class="security-title">Security</h4>
                        <% if (isGoogleUser && !hasPassword) { %>
                            <!-- Google user with NO password yet -->
                            <div class="google-add-pass-hint">
                                <i class="fab fa-google google-icon"></i>
                                <div class="google-hint-text">
                                    <span class="hint-title">Your account is managed by Google</span>
                                    <span class="hint-sub">You can set a Zyrox password to log in directly without Google.</span>
                                </div>
                            </div>
                            <button class="btn-add-password" data-bs-toggle="modal" data-bs-target="#passwordModal">
                                <i class="fas fa-plus-circle"></i> Add Password
                            </button>
                        <% } else { %>
                            <button class="btn-update-password" data-bs-toggle="modal" data-bs-target="#passwordModal">
                                <i class="fas fa-shield-alt"></i> Update Password
                            </button>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <%- include('../../partials/user/bottomNav', { activePage: 'profile' }) %>

    <!-- ===== PASSWORD MODAL ===== -->
    <div class="modal fade" id="passwordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background:#111422;border:1px solid #252a42;border-radius:16px;overflow:hidden;">
                <div style="height:4px;background:linear-gradient(90deg,#4f6ef7,#00d4aa);"></div>
                <div class="modal-header border-0 px-4 pt-4 pb-2">
                    <div>
                        <h5 class="modal-title fw-bold mb-1" style="color:#f0f2ff;">
                            <% if (isGoogleUser && !hasPassword) { %>
                                <i class="fab fa-google me-2" style="color:#4285F4;"></i> Add a Password
                            <% } else { %>
                                <i class="bi bi-shield-lock me-2" style="color:#4f6ef7;"></i> Update Password
                            <% } %>
                        </h5>
                        <p class="mb-0 small" style="color:#8b92b8;">
                            <% if (isGoogleUser && !hasPassword) { %>
                                Set a Zyrox password to also log in without Google
                            <% } else { %>
                                Keep your account secure with a strong password
                            <% } %>
                        </p>
                    </div>
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4 pb-2 pt-3">
                    <form action="<%= hasPassword ? '/change-password' : '/add-password' %>" method="POST" id="passwordModalForm">
                        <% if (hasPassword) { %>
                            <div id="currentPasswordSection">
                                <div class="mb-3">
                                    <label class="modal-field-label">Current Password</label>
                                    <div class="modal-input-wrap">
                                        <input type="password" id="modal_currentPassword" name="currentPassword" class="modal-field-input" placeholder="Enter your current password">
                                        <button type="button" class="modal-eye-btn" onclick="modalToggleVis('modal_currentPassword', this)"><i class="fa-regular fa-eye"></i></button>
                                    </div>
                                    <p class="modal-field-error" id="modal_currentPasswordError"></p>
                                </div>
                                <button type="button" class="modal-submit-btn w-100 mb-3" id="verifyCurrentPasswordBtn">
                                    <i class="bi bi-shield-check me-2"></i> Verify Password
                                </button>
                            </div>
                        <% } %>

                        <div id="newPasswordSection" style="<%= hasPassword ? 'display: none;' : '' %>">
                            <div class="mb-2">
                                <label class="modal-field-label">New Password</label>
                                <div class="modal-input-wrap">
                                    <input type="password" id="modal_newPassword" name="newPassword" class="modal-field-input" placeholder="Create a strong new password">
                                    <button type="button" class="modal-eye-btn" onclick="modalToggleVis('modal_newPassword', this)"><i class="fa-regular fa-eye"></i></button>
                                </div>
                                <div class="modal-strength-bar" id="modal_strengthBar"><div class="modal-strength-fill" id="modal_strengthFill"></div></div>
                                <ul class="modal-req-list" id="modal_reqList">
                                    <li class="modal-req" data-req="length"><i class="bi bi-circle"></i> At least 8 characters</li>
                                    <li class="modal-req" data-req="uppercase"><i class="bi bi-circle"></i> One uppercase letter</li>
                                    <li class="modal-req" data-req="lowercase"><i class="bi bi-circle"></i> One lowercase letter</li>
                                    <li class="modal-req" data-req="number"><i class="bi bi-circle"></i> One number</li>
                                    <li class="modal-req" data-req="symbol"><i class="bi bi-circle"></i> One symbol</li>
                                </ul>
                                <p class="modal-field-error" id="modal_newPasswordError"></p>
                            </div>
                            <div class="mb-3">
                                <label class="modal-field-label">Confirm Password</label>
                                <div class="modal-input-wrap">
                                    <input type="password" id="modal_confirmPassword" name="confirmPassword" class="modal-field-input" placeholder="Repeat your new password">
                                    <button type="button" class="modal-eye-btn" onclick="modalToggleVis('modal_confirmPassword', this)"><i class="fa-regular fa-eye"></i></button>
                                </div>
                                <p class="modal-field-error" id="modal_confirmPasswordError"></p>
                            </div>
                            <button type="submit" class="modal-submit-btn w-100">
                                <i class="bi bi-shield-lock-fill me-2"></i> <%= hasPassword ? 'Update Password' : 'Set Password' %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════ FOOTER ═══════════ -->
    <footer class="footer-zyrax">
        <div class="row g-4 container-fluid mx-0">
            <div class="col-12 col-md-3">
                <div class="footer-brand"><i class="bi bi-hexagon-fill me-1"></i>Zy<span>rox</span></div>
                <p class="footer-tagline">Your trusted destination for genuine smartphones. Secure payments and exceptional service.</p>
                <div class="footer-social">
                    <a href="#" class="social-btn"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
            <div class="col-6 col-md-2 offset-md-1">
                <div class="footer-col-title">Shop by Brand</div>
                <a href="#" class="footer-link">Apple iPhones</a>
                <a href="#" class="footer-link">Samsung Galaxy</a>
                <a href="#" class="footer-link">Xiaomi Phones</a>
            </div>
            <div class="col-6 col-md-2">
                <div class="footer-col-title">Support</div>
                <a href="#" class="footer-link">Contact Us</a>
                <a href="#" class="footer-link">Track Order</a>
                <a href="#" class="footer-link">FAQs</a>
            </div>
            <div class="col-6 col-md-2">
                <div class="footer-col-title">Company</div>
                <a href="#" class="footer-link">About Us</a>
                <a href="#" class="footer-link">Privacy Policy</a>
                <a href="#" class="footer-link">Terms</a>
            </div>
        </div>
        <hr class="footer-divider" />
        <div class="d-flex justify-content-between align-items-center container-fluid">
            <span class="footer-copy">© 2024 Zyrox. All rights reserved.</span>
            <span class="footer-copy">Made with <i class="bi bi-heart-fill text-danger"></i></span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ── Referral Code Logic ──
        function copyReferralCode() {
            const code = document.getElementById('referralCodeText')?.textContent.trim();
            if (!code || code === '—') return;
            navigator.clipboard.writeText(code).then(() => {
                Swal.fire({ icon: 'success', title: 'Code Copied', toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, background: '#141824', color: '#e8eaf6' });
            });
        }
        function copyReferralLink() {
            const code = document.getElementById('referralCodeText')?.textContent.trim();
            if (!code || code === '—') return;
            const link = window.location.origin + '/signup?ref=' + code;
            navigator.clipboard.writeText(link).then(() => {
                Swal.fire({ icon: 'success', title: 'Link Copied', toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, background: '#141824', color: '#e8eaf6' });
            });
        }

        <% /* profileSuccess handled via hidden input */ %>

        <% /* passwordToast handled via hidden input */ %>

        <% /* successMessage handled via hidden input */ %>

        // ── Password Modal Logic ──
        function modalToggleVis(id, btn) {
            const el = document.getElementById(id);
            const icon = btn.querySelector('i');
            if (el.type === 'password') { el.type = 'text'; icon.className = 'fa-regular fa-eye-slash'; }
            else { el.type = 'password'; icon.className = 'fa-regular fa-eye'; }
        }

        const _modalReqs = {
            length: { re: /.{8,}/, el: document.querySelector('.modal-req[data-req="length"]') },
            uppercase: { re: /[A-Z]/, el: document.querySelector('.modal-req[data-req="uppercase"]') },
            lowercase: { re: /[a-z]/, el: document.querySelector('.modal-req[data-req="lowercase"]') },
            number: { re: /[0-9]/, el: document.querySelector('.modal-req[data-req="number"]') },
            symbol: { re: /[\W_]/, el: document.querySelector('.modal-req[data-req="symbol"]') }
        };

        const _modalNewPass = document.getElementById('modal_newPassword');
        if (_modalNewPass) {
            _modalNewPass.addEventListener('input', function() {
                const val = this.value;
                const bar = document.getElementById('modal_strengthBar');
                const fill = document.getElementById('modal_strengthFill');
                const list = document.getElementById('modal_reqList');
                bar.style.display = list.style.display = val.length > 0 ? 'block' : 'none';
                let met = 0;
                Object.keys(_modalReqs).forEach(k => {
                    const r = _modalReqs[k];
                    if (r.re.test(val)) { met++; r.el.classList.add('met'); r.el.querySelector('i').className = 'bi bi-check-circle-fill'; }
                    else { r.el.classList.remove('met'); r.el.querySelector('i').className = 'bi bi-circle'; }
                });
                fill.style.width = (met / 5 * 100) + '%';
                fill.style.backgroundColor = met <= 2 ? '#ff4d6d' : met <= 4 ? '#f59e0b' : '#00d4aa';
            });
        }

        const verifyBtn = document.getElementById('verifyCurrentPasswordBtn');
        if (verifyBtn) {
            verifyBtn.addEventListener('click', async function() {
                const currentPassword = document.getElementById('modal_currentPassword').value;
                const errorEl = document.getElementById('modal_currentPasswordError');
                errorEl.textContent = '';
                if (!currentPassword) { errorEl.textContent = 'Please enter your current password.'; return; }
                try {
                    verifyBtn.disabled = true;
                    verifyBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Verifying...';
                    const res = await fetch('/verify-current-password', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ currentPassword }) });
                    const data = await res.json();
                    if (data.success) {
                        document.getElementById('currentPasswordSection').style.display = 'none';
                        const newPassSec = document.getElementById('newPasswordSection');
                        newPassSec.style.display = 'block'; newPassSec.classList.add('animate-fade-in');
                    } else {
                        errorEl.textContent = data.message || 'Incorrect password.';
                        verifyBtn.disabled = false; verifyBtn.innerHTML = '<i class="bi bi-shield-check me-2"></i> Verify Password';
                    }
                } catch (e) { errorEl.textContent = 'Something went wrong.'; verifyBtn.disabled = false; verifyBtn.innerHTML = '<i class="bi bi-shield-check me-2"></i> Verify Password'; }
            });
        }

        const _modalForm = document.getElementById('passwordModalForm');
        if (_modalForm) {
            _modalForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                const newIn = document.getElementById('modal_newPassword');
                const confIn = document.getElementById('modal_confirmPassword');
                const newErr = document.getElementById('modal_newPasswordError');
                const confErr = document.getElementById('modal_confirmPasswordError');
                newErr.textContent = confErr.textContent = '';
                let ok = true;
                if (!newIn.value) { newErr.textContent = 'New password is required.'; ok = false; }
                else if (!/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/.test(newIn.value)) { newErr.textContent = 'Password is not strong enough.'; ok = false; }
                if (newIn.value !== confIn.value) { confErr.textContent = 'Passwords do not match.'; ok = false; }
                if (!ok) return;
                const submitBtn = _modalForm.querySelector('button[type="submit"]');
                const originalHtml = submitBtn.innerHTML;
                const isAddFlow = _modalForm.action.includes('/add-password');
                try {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> ${isAddFlow ? 'Setting Password...' : 'Updating...'}`;
                    // Collect only the visible / relevant fields manually to avoid hidden section issues
                    const payload = {
                        newPassword: document.getElementById('modal_newPassword').value,
                        confirmPassword: document.getElementById('modal_confirmPassword').value
                    };
                    // Include currentPassword only for the change-password flow
                    const currentPassEl = document.getElementById('modal_currentPassword');
                    if (currentPassEl) payload.currentPassword = currentPassEl.value;

                    const res = await fetch(_modalForm.action, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const result = await res.json();
                    if (result.success) {
                        bootstrap.Modal.getInstance(document.getElementById('passwordModal')).hide();
                        Swal.fire({
                            icon: 'success',
                            title: isAddFlow ? '🎉 Password Set!' : 'Password Updated!',
                            text: result.message,
                            confirmButtonText: 'OK',
                            confirmButtonColor: '#4f6ef7',
                            background: '#141824',
                            color: '#e8eaf6'
                        }).then(() => window.location.reload());
                    } else {
                        newErr.textContent = result.message || (isAddFlow ? 'Failed to set password.' : 'Update failed.');
                        submitBtn.disabled = false; submitBtn.innerHTML = originalHtml;
                    }
                } catch (err) { submitBtn.disabled = false; submitBtn.innerHTML = originalHtml; }
            });
        }

        function confirmLogout() {
            Swal.fire({ background: '#111827', color: '#f0f2ff', icon: 'warning', title: 'Logout?', text: "Are you sure?", showCancelButton: true, confirmButtonText: "Yes", cancelButtonText: "No", confirmButtonColor: '#ff4d6d', reverseButtons: true })
            .then((r) => { if (r.isConfirmed) window.location.href = "/logout"; });
        }
    </script>
</body>
</html>