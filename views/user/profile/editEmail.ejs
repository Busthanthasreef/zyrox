<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Email – Zyrox</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
</head>

<body>

    <div class="main-container">
        <!-- Sidebar Partial -->
        <%- include('../../partials/user/profileSidebar', { activePage: 'profile' }) %>

            <!-- Main Content -->
            <main class="main-wrapper">
                <div id="profile-card-container" class="w-100 d-flex justify-content-center">
                    <div class="card col-12 col-sm-10 col-md-8">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <h3 class="m-0">Update Email</h3>
                            <a href="/profile" class="btn btn-custom change-pass-btn ajax-link" data-url="/profile">
                                <i class="fa-solid fa-arrow-left"></i> Back
                            </a>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Current Email</label>
                                    <div
                                        class="py-2 px-3 bg-dark-subtle rounded border border-secondary-subtle text-white opacity-50">
                                        <%= user ? user.Email : '' %>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <form action="/edit-email" method="POST">
                                    <div class="form-group">
                                        <label>New Email Address</label>
                                        <input type="email" id="Email" name="Email" class="form-control"
                                            placeholder="Enter new email address" required>
                                        <% if (errors && errors.email) { %>
                                            <p class="text-danger small mt-1 mb-0">
                                                <%= errors.email %>
                                            </p>
                                            <% } %>
                                    </div>
                                    <button type="submit"
                                        class="btn btn-custom edit-btn bg-primary text-white w-100 mt-4">
                                        Verify Email
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="mt-5 p-4 rounded bg-info-subtle text-info-emphasis border border-info-subtle">
                            <h6 class="fw-bold mb-2"><i class="bi bi-info-circle-fill me-2"></i> Important Note</h6>
                            <p class="small mb-0">We will send a verification OTP to your new email address. Please make
                                sure the email is active and you have access to it.</p>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Show Swal Toast for Email Errors (like Duplicate Email)
        <% if (typeof errors !== 'undefined' && errors.email && (errors.email.toLowerCase().includes('exist') || errors.email.toLowerCase().includes('in use'))) { %>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    toast: true,
                    position: 'top',
                    icon: 'error',
                    title: '<%= errors.email %>',
                    showConfirmButton: false,
                    timer: 1500,
                    timerProgressBar: true,
                    background: '#1a2a30',
                    color: '#fff'
                });
            });
        <% } %>
    </script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Logic for Card Switching -->
    <script src="/js/userProfile.js"></script>

</body>

</html>