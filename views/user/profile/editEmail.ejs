<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Email – Zyrox</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <link rel="stylesheet" href="/userStyles/profile/profileShared.css">
</head>

<body>

    <div class="main-container">
        <!-- Sidebar Partial -->
        <%- include('../../partials/user/profileSidebar', { activePage: 'profile' }) %>

            <!-- Main Content -->
            <main class="main-wrapper">
                <div id="profile-card-container" class="w-100 d-flex justify-content-center">
                    <div class="card col-12 col-sm-10 col-md-8">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3>
                                <i class="fa-solid fa-envelope me-2"></i>
                                Edit Email
                            </h3>
                            <a href="/profile" class="btn btn-back ajax-link" data-url="/profile">
                                <i class="fa-solid fa-arrow-left"></i> Back to Profile
                            </a>
                        </div>

                        <div class="form-group">
                            <label for="currentEmail">Current Email</label>
                            <div class="position-relative">
                                <i
                                    class="fa-solid fa-envelope position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                                <% if(user){%>
                                    <input id="currentEmail" class="form-control ps-5 disabled" value="<%=user.Email %>"
                                        disabled readonly />
                                    <%}%>
                            </div>
                        </div>

                        <form action="/edit-email" method="POST">

                            <!-- New Email -->
                            <div class="form-group ">
                                <label for="newEmail">New Email</label>
                                <div class="position-relative">
                                    <i
                                        class="fa-solid fa-at position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                                    <input id="Email" name="Email" class="form-control ps-5"
                                        placeholder="Enter your new email address" autocomplete="email" />
                                </div>

                                <% if (errors.email) { %>
                                    <p class="text-danger small mt-1 mb-0">
                                        <i class="fa-solid fa-triangle-exclamation"></i>
                                        <%= errors.email %>
                                    </p>
                                    <% } %>
                            </div>
                            <div class="d-flex justify-content-center">
                                <button type="submit" class="btn btn-custom btn-submit  w-50 mt-2">
                                    Verify Email
                                </button>
                            </div>

                        </form>

                    </div>
                </div>
            </main>
    </div>

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Show Swal Toast for Email Errors (like Duplicate Email)
        <% if (typeof errors !== 'undefined' && errors.email && (errors.email.toLowerCase().includes('exist') || errors.email.toLowerCase().includes('in use'))) { %>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    toast: true,
                    position: 'top',
                    icon: 'error',
                    title: '<%= errors.email %>',
                    showConfirmButton: false,
                    timer: 1500,
                    timerProgressBar: true,
                    background: '#1a2a30',
                    color: '#fff'
                });
            });
        <% } %>
    </script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX Logic for Card Switching -->
    <script src="/js/userProfile.js"></script>

</body>

</html>