        <script>
            function scrollGrid(gridId, amount) {
                const grid = document.getElementById(gridId);
                if (grid) {
                    grid.scrollBy({ left: amount, behavior: 'smooth' });
                }
            }

            function copyCoupon() {
                const code = document.getElementById('couponCode')?.textContent;
                if (!code) return;
                navigator.clipboard.writeText(code).then(() => {
                    const icon = document.getElementById('copyIcon');
                    if (icon) {
                        icon.classList.remove('bi-copy');
                        icon.classList.add('bi-check-lg');
                        setTimeout(() => {
                            icon.classList.remove('bi-check-lg');
                            icon.classList.add('bi-copy');
                        }, 1500);
                    }
                }).catch(() => {
                    Swal.fire({ icon: 'info', title: code, text: 'Copy this coupon code!', timer: 2000, showConfirmButton: false });
                });
            }

            function copyRefCode(btn) {
                const code = document.getElementById('refCodeText')?.textContent?.trim();
                if (!code) return;
                navigator.clipboard.writeText(code).then(() => {
                    btn.classList.add('copied');
                    btn.innerHTML = '<i class="bi bi-check2"></i> Copied!';
                    setTimeout(() => {
                        btn.classList.remove('copied');
                        btn.innerHTML = '<i class="bi bi-copy"></i> Copy';
                    }, 2000);
                }).catch(() => {
                    Swal.fire({ icon: 'info', title: 'Your Code', text: code, timer: 2000, showConfirmButton: false, background: '#0f172a', color: '#fff' });
                });
            }

            function openShareMenu() {
                const overlay = document.getElementById('shareMenuOverlay');
                const popup   = document.getElementById('shareMenuPopup');
                if (!overlay || !popup) return;
                overlay.style.display = 'block';
                popup.style.display   = 'block';
                popup.style.animation = 'slideUp 0.35s cubic-bezier(0.34,1.56,0.64,1) forwards';
            }

            function closeShareMenu() {
                const overlay = document.getElementById('shareMenuOverlay');
                const popup   = document.getElementById('shareMenuPopup');
                if (overlay) overlay.style.display = 'none';
                if (popup)   popup.style.display   = 'none';
            }

            function shareVia(platform) {
                const code    = document.getElementById('refCodeText')?.textContent?.trim();
                const link    = 'https://zyrox.busthan.shop/signup?ref=' + code;
                const message = `🎁 Use my referral code *${code}* on Zyrox and get an exclusive reward!\n\n${link}`;

                const urls = {
                    whatsapp:  `https://wa.me/?text=${encodeURIComponent(message)}`,
                    telegram:  `https://t.me/share/url?url=${encodeURIComponent(link)}&text=${encodeURIComponent('🎁 Use my Zyrox referral code: ' + code)}`,
                    twitter:   `https://twitter.com/intent/tweet?text=${encodeURIComponent('🎁 Use my Zyrox referral code: ' + code + ' ' + link)}`,
                    facebook:  `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(link)}`,
                    sms:       `sms:?body=${encodeURIComponent(message)}`,
                    email:     `mailto:?subject=${encodeURIComponent('Join Zyrox with my referral code!')}&body=${encodeURIComponent(message)}`,
                };

                if (platform === 'copy') {
                    navigator.clipboard.writeText(link).then(() => {
                        const btn = document.getElementById('copyLinkBtn');
                        const lbl = btn?.querySelector('.share-app-label');
                        if (lbl) { lbl.textContent = 'Copied!'; setTimeout(() => { lbl.textContent = 'Copy Link'; }, 2000); }
                    });
                    return;
                }

                if (urls[platform]) {
                    window.open(urls[platform], '_blank', 'noopener,noreferrer');
                    closeShareMenu();
                }
            }

            const swalBase = {
                background: '#0f172a',
                color: '#fff',
                confirmButtonColor: '#4ade80',
                cancelButtonColor: '#334155',
            };

            async function addToCartListing(btn, productId, variantId) {
                try {
                    if (btn.disabled) return;
                    
                    const originalContent = btn.innerHTML;
                    btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i>';
                    btn.disabled = true;

                    const response = await fetch('/cart/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId, variantId, quantity: 1 })
                    });

                    const result = await response.json();
                    btn.innerHTML = originalContent;
                    btn.disabled = false;

                    if (result.requiresAuth || response.status === 401) {
                        return Swal.fire({
                            ...swalBase,
                            icon: 'info',
                            title: 'Sign In Required',
                            text: 'Please log in to add items to your cart.',
                            confirmButtonText: 'Sign In',
                            showCancelButton: true,
                            cancelButtonText: 'Do it later'
                        }).then(r => {
                            if (r.isConfirmed) {
                                btn.disabled = true;
                                btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                                redirectTo(`/signin`);
                            }
                        });
                    }

                    if (result.success) {
                        Swal.fire({
                            ...swalBase,
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: 'Added to cart!',
                            showConfirmButton: false,
                            timer: 2500,
                            timerProgressBar: true,
                            iconColor: '#4ade80',
                        });

                        // Update cart count dynamically from server response
                        const cartBadge = document.querySelector('.cart-badge');
                        if (cartBadge && result.cartCount !== undefined) {
                            cartBadge.textContent = result.cartCount;
                            cartBadge.style.display = 'flex';
                        }
                    } else {
                        Swal.fire({
                            ...swalBase,
                            icon: 'error',
                            title: 'Oops...',
                            text: result.message || 'Failed to add to cart'
                        });
                    }
                } catch (error) {
                    console.error("Add to Cart Error:", error);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-cart-plus"></i>';
                }
            }

            // Scroll Reveal Intersection Observer
            document.addEventListener('DOMContentLoaded', () => {
                const observerOptions = {
                    threshold: 0.15,
                    rootMargin: '0px 0px -50px 0px'
                };

                const revealObserver = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('active');
                            revealObserver.unobserve(entry.target);
                        }
                    });
                }, observerOptions);

                // Target sections and cards
                const sections = document.querySelectorAll('.hero, .categories, .products, .footer');
                const productCards = document.querySelectorAll('.product-card');

                sections.forEach(sec => {
                    sec.classList.add('reveal');
                    revealObserver.observe(sec);
                });

                productCards.forEach((card, idx) => {
                    card.classList.add('reveal');
                    // Add staggered delay class (cycle 1-4)
                    card.classList.add(`stagger-${(idx % 4) + 1}`);
                    revealObserver.observe(card);
                });
            });
        </script>

        <!-- ═══ TRENDING PRODUCTS ANIMATION ENGINE ═══ -->
        <script>
        (function () {
            'use strict';

            function initTrendingAnimation() {
                const section = document.querySelector('.trending-section');
                if (!section) return;

                const header = section.querySelector('.section-header');
                const cards  = section.querySelectorAll('.product-card');
                if (!cards.length) return;

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (!entry.isIntersecting) return;
                        observer.unobserve(entry.target);

                        // Fade in header
                        if (header) {
                            requestAnimationFrame(() => header.classList.add('zyx-header-in'));
                        }

                        // Fade in cards with stagger
                        cards.forEach((card, i) => {
                            setTimeout(() => {
                                card.classList.add('zyx-spread');
                                setTimeout(() => card.classList.add('zyx-idle'), 600);
                            }, i * 100);
                        });
                    });
                }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

                observer.observe(section);
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initTrendingAnimation);
            } else {
                initTrendingAnimation();
            }
        })();
        </script>

</body>

