<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zyrox - Smartphone Store</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="userStyles/home/landingPage.css">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
    <%-include('../../partials/user/navigationbar',{user,currentPage:"home" , categories})%>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <div class="hero-text">
                    <h1>Discover the Latest Smartphones from Zyrox</h1>
                    <p>Stay ahead with the newest smartphone releases from top brands like Apple, Samsung, and more.
                        Explore
                        cutting-edge features and unbeatable prices.</p>
                    <a href="/products"><button class="shop-now-btn">Shop Now</button></a>
                </div>

                <img src="https://images.unsplash.com/photo-1592286927505-c6d69682b5f1?w=400&h=500&fit=crop"
                    alt="Smartphone" class="hero-image" style="opacity: 0.7;">

                <div class="hero-offer">
                    <div class="hero-offer-title">Our Offer</div>
                    <div class="hero-offer-model">NOTE 20 Ultra</div>
                    <div class="hero-offer-discount">and get 10% Off</div>
                </div>
            </div>
        </section>

        <!-- Categories -->
        <section class="categories">
            <div class="section-header">
                <h2 class="section-title">Shop by category</h2>
                <a href="/products" class="view-all-link">View all categories →</a>
            </div>

            <div class="categories-grid">
                <div class="category-item">
                    <div class="category-icon"><i class="fab fa-apple"></i></div>
                    <div class="category-name">Apple</div>
                </div>
                <div class="category-item">
                    <div class="category-icon"><i class="fas fa-laptop"></i></div>
                    <div class="category-name">Samsung</div>
                </div>
                <div class="category-item">
                    <div class="category-icon"><i class="fas fa-basketball-ball" style="color: #ff9800;"></i></div>
                    <div class="category-name">Realme</div>
                </div>
                <div class="category-item">
                    <div class="category-icon"><i class="fas fa-mobile-alt" style="color: #9e9e9e;"></i></div>
                    <div class="category-name">Oppo</div>
                </div>
                <div class="category-item">
                    <div class="category-icon"><i class="fas fa-sun" style="color: #ffc107;"></i></div>
                    <div class="category-name">Xiaomi</div>
                </div>
                <div class="category-item">
                    <div class="category-icon"><i class="fas fa-moon" style="color: #2196f3;"></i></div>
                    <div class="category-name">Vivo</div>
                </div>
            </div>
        </section>

        <!-- Trending Products -->
        <section class="products">
            <div class="section-header">
                <h2 class="section-title">Trending Products</h2>
                <a href="/products" class="view-all-link">View all →</a>
            </div>

            <div class="products-grid">
                <% if(trendingVariants && trendingVariants.length> 0) { %>
                    <% trendingVariants.forEach((item, index)=> { %>
                        <div class="product-card"
                            onclick="window.location.href='/product/<%= item.product._id %>?variant=<%= item.variant._id %>'"
                            style="cursor: pointer;">
                            <% if(index===0) { %>
                                <div class="product-badge">10% OFF</div>
                                <% } %>
                                    <% if(index===1) { %>
                                        <div class="product-badge new">NEW</div>
                                        <% } %>
                                            <button class="wishlist-btn"
                                                onclick="event.stopPropagation(); window.location.href='/product/<%= item.product._id %>?variant=<%= item.variant._id %>'"><i
                                                    class="far fa-heart"></i></button>
                                            <img src="<%= (item.variant.images && item.variant.images.length > 0) ? item.variant.images[0] : 'https://via.placeholder.com/300' %>"
                                                alt="<%= item.product.productName %>" class="product-image"
                                                style="object-fit: cover;">
                                            <div class="product-name">
                                                <%= item.product.productName %>
                                            </div>
                                            <div class="product-price">₹<%= item.variant.price.toLocaleString('en-IN')
                                                    %>.00</div>
                                            <button class="buy-now-btn"
                                                onclick="event.stopPropagation(); window.location.href='/product/<%= item.product._id %>?variant=<%= item.variant._id %>'">Buy
                                                now</button>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <p style="text-align: center; width: 100%; color: #999; padding: 40px 0;">Explore our
                                    latest arrivals in the Shop section!</p>
                                <% } %>
            </div>
        </section>


        <!-- Footer -->
        <footer class="footer">
            <div class="footer-content">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <i class="fas fa-mobile-alt"></i>
                        Zyrox
                    </div>
                    <p class="footer-description">
                        Discover the latest smartphones from top brands. We offer a wide range of mobile phones with
                        cutting-edge technology and competitive prices. Your trusted partner for all your mobile needs.
                    </p>
                    <div class="social-links">
                        <a href="/products" class="social-link"><i class="fab fa-facebook-f"></i></a>
                        <a href="/products" class="social-link"><i class="fab fa-twitter"></i></a>
                        <a href="/products" class="social-link"><i class="fab fa-instagram"></i></a>
                        <a href="/products" class="social-link"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                <div class="footer-column">
                    <h3 onclick="window.location.href='/products'">Shop Now</h3>
                    <ul class="footer-links">
                        <li><a href="/products">Apple</a></li>
                        <li><a href="/products">Samsung</a></li>
                        <li><a href="/products">Realme</a></li>
                        <li><a href="/products">Oppo</a></li>
                        <li><a href="/products">Xiaomi</a></li>
                        <li><a href="/products">Vivo</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h3>Customer Support</h3>
                    <ul class="footer-links">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Track Order</a></li>
                        <li><a href="#">Returns</a></li>
                        <li><a href="#">Warranty</a></li>
                        <li><a href="#">Shipping Info</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h3>Company</h3>
                    <ul class="footer-links">
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Sitemap</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                © 2025 Zyrox. All rights reserved.
            </div>
        </footer>


</body>

</html>