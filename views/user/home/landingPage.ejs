<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zyrox - Smartphone Store</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="userStyles/home/landingPage.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Trending Products Animation -->
    <link rel="stylesheet" href="userStyles/home/trendingAnimation.css">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        accent: '#4ade80',
                        deep: '#0a0a0a',
                    },
                    fontFamily: {
                        sans: ['"Cabinet Grotesk"', 'sans-serif'],
                        heading: ['"Clash Display"', 'sans-serif'],
                        display: ['"Clash Display"', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        .bi-spin {
            display: inline-block;
            animation: bi-spin 1s linear infinite;
        }
        @keyframes bi-spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
</head>

<body>
    <%- include('../../partials/user/navigationbar',{user,currentPage:"home" , categories})%>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <div class="hero-text">
                    <h1>Discover the Latest Smartphones from Zyrox</h1>
                    <p>Stay ahead with the newest smartphone releases from top brands like Apple, Samsung, and more.
                        Explore
                        cutting-edge features and unbeatable prices.</p>
                    <a href="/products"><button class="shop-now-btn">Shop Now</button></a>
                </div>

                

                <% if (latestCoupon) { %>
                    <div class="hero-offer">
                        <div class="hero-offer-title"><i class="bi bi-gift"></i> Latest Offer</div>
                        <div class="hero-offer-code">
                            <span id="couponCode">
                                <%= latestCoupon.code %>
                            </span>
                            <button class="copy-btn" onclick="copyCoupon()" title="Copy code">
                                <i class="bi bi-copy" id="copyIcon"></i>
                            </button>
                        </div>
                        <div class="hero-offer-discount">
                            Get <%= latestCoupon.discountType==='percentage' ? latestCoupon.discountValue + '% Off'
                                : '₹' + latestCoupon.discountValue + ' Off' %>
                        </div>
                        <% if (latestCoupon.minCartValue> 0) { %>
                            <div class="hero-offer-min">Min. order ₹<%=
                                    latestCoupon.minCartValue.toLocaleString('en-IN') %>
                            </div>
                            <% } %>
                    </div>
                    <% } else { %>
                        <div class="hero-offer">
                            <div class="hero-offer-title"><i class="bi bi-tag"></i> Special Deals</div>
                            <div class="hero-offer-model">Shop Now</div>
                            <div class="hero-offer-discount">Explore our latest offers</div>
                        </div>
                        <% } %>
            </div>
        </section>

        <!-- Categories Section -->
        <section class="max-w-[1750px] mx-auto px-10 my-16">
            <div class="flex justify-between items-center mb-8">
                <h2 class="text-2xl font-bold text-white">Shop by Brand</h2>
                <a href="/products" class="text-accent hover:text-green-400 transition-colors text-sm font-medium">View all brands →</a>
            </div>

            <div class="flex flex-nowrap overflow-x-auto gap-4 md:gap-6 justify-start md:justify-center py-4 no-scrollbar">
                <% if(typeof categories !== 'undefined' && categories.length > 0) { %>
                    <% categories.forEach(category => { %>
                        <div onclick="window.location.href='/products?brand=<%= category.categoryName %>'" 
                             class="group cursor-pointer bg-[#1a1a1a] border border-white/5 hover:border-accent/50 p-4 sm:p-6 md:p-8 rounded-xl md:rounded-2xl text-center transition-all duration-300 hover:-translate-y-2 hover:bg-[#222] min-w-[120px] sm:min-w-[150px] md:min-w-[180px] flex-shrink-0 backdrop-blur-sm">
                            <div class="text-2xl sm:text-3xl md:text-4xl mb-3 md:mb-4 text-white/80 group-hover:text-accent transition-colors">
                                    <i class="bi bi-tag text-accent"></i>
                            </div>
                            <div class="text-xs sm:text-sm font-semibold text-gray-300 group-hover:text-white"><%= category.categoryName %></div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="bg-[#1a1a1a] p-4 sm:p-6 md:p-8 rounded-xl md:rounded-2xl text-center min-w-[120px] sm:min-w-[150px] md:min-w-[180px] flex-shrink-0">
                        <div class="text-2xl sm:text-3xl md:text-4xl mb-3 md:mb-4 text-accent"><i class="bi bi-phone"></i></div>
                        <div class="text-xs sm:text-sm font-semibold text-gray-300">New Brands Coming</div>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Trending Products -->
        <section class="products trending-section">
            <div class="section-header">
                <h2 class="section-title">Trending Products</h2>
                <a href="/products" class="view-all-link">View all →</a>
            </div>

            <div class="products-container">
                <button class="scroll-arrow left" onclick="scrollGrid('trending-grid', -200)" aria-label="Scroll left">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div class="products-grid no-scrollbar" id="trending-grid">
                    <% if(trendingVariants && trendingVariants.length> 0) { %>
                        <% trendingVariants.forEach((item, index)=> { %>
                            <div class="product-card"
                                onclick="window.location.href='/product/<%= item.product._id %>?variant=<%= item.variant._id %>'"
                                style="cursor: pointer;">
                                <% if(index===0) { %>
                                    <div class="product-badge">10% OFF</div>
                                    <% } %>
                                        <% if(index===1) { %>
                                            <div class="product-badge new">NEW</div>
                                            <% } %>
                                                
                                                <% 
                                                    let imgPath = (item.variant.images && item.variant.images.length > 0) ? item.variant.images[0] : 'https://via.placeholder.com/300';
                                                    if (!imgPath.startsWith('http') && !imgPath.startsWith('/')) {
                                                        imgPath = '/' + imgPath.replace(/\\/g, '/');
                                                    }
                                                %>
                                                <img src="<%= imgPath %>" alt="<%= item.product.productName %>" class="product-image">
                                                <div class="product-name">
                                                    <%= item.product.productName %>
                                                </div>
                                                <div class="product-price">₹<%= item.variant.price.toLocaleString('en-IN')
                                                        %>.00</div>
                                                <div style="display:flex; gap:8px; width:100%; margin-top:10px;">
                                                    <button class="buy-now-btn" style="flex:1;"
                                                        onclick="event.stopPropagation(); window.location.href='/product/<%= item.product._id %>?variant=<%= item.variant._id %>'">View</button>
                                                    <button class="cart-icon-btn" 
                                                        onclick="event.stopPropagation(); addToCartListing(this, '<%= item.product._id %>', '<%= item.variant._id %>')"
                                                        style="width:42px; height:42px; border:1px solid #4ade80; border-radius:8px; background:transparent; color:#4ade80; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; justify-content:center;"
                                                        onmouseover="this.style.background='#4ade80'; this.style.color='#0a0a0a'"
                                                        onmouseout="this.style.background='transparent'; this.style.color='#4ade80'">
                                                        <i class="bi bi-cart-plus"></i>
                                                    </button>
                                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p style="text-align: center; width: 100%; color: #999; padding: 40px 0;">Explore our
                                        latest arrivals in the Shop section!</p>
                                    <% } %>
                </div>
                <button class="scroll-arrow right" onclick="scrollGrid('trending-grid', 200)" aria-label="Scroll right">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </section>

        <!-- All Products -->
        <section class="products" style="margin-top: 0;">
            <div class="section-header">
                <h2 class="section-title">Explore Our Collection</h2>
            </div>

            <div class="products-container">
                <button class="scroll-arrow left" onclick="scrollGrid('collection-grid', -200)" aria-label="Scroll left">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <div class="products-grid no-scrollbar" id="collection-grid">
                    <% if(typeof allVariants !== 'undefined' && allVariants.length > 0) { %>
                        <% allVariants.forEach((item, index)=> { %>
                            <div class="product-card"
                                onclick="window.location.href='/product/<%= item.product._id %>?variant=<%= item.variant._id %>'"
                                style="cursor: pointer;">
                                                <% 
                                                    let imgPath = (item.variant.images && item.variant.images.length > 0) ? item.variant.images[0] : 'https://via.placeholder.com/300';
                                                    if (!imgPath.startsWith('http') && !imgPath.startsWith('/')) {
                                                        imgPath = '/' + imgPath.replace(/\\/g, '/');
                                                    }
                                                %>
                                                <img src="<%= imgPath %>" alt="<%= item.product.productName %>" class="product-image">
                                                <div class="product-name">
                                                    <%= item.product.productName %>
                                                </div>
                                                <div class="product-price">₹<%= item.variant.price.toLocaleString('en-IN')
                                                        %>.00</div>
                                                <div style="display:flex; gap:8px; width:100%; margin-top:10px;">
                                                    <button class="buy-now-btn" style="flex:1;"
                                                        onclick="event.stopPropagation(); window.location.href='/product/<%= item.product._id %>?variant=<%= item.variant._id %>'">View</button>
                                                    <button class="cart-icon-btn" 
                                                        onclick="event.stopPropagation(); addToCartListing(this, '<%= item.product._id %>', '<%= item.variant._id %>')"
                                                        style="width:42px; height:42px; border:1px solid #4ade80; border-radius:8px; background:transparent; color:#4ade80; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; justify-content:center;"
                                                        onmouseover="this.style.background='#4ade80'; this.style.color='#0a0a0a'"
                                                        onmouseout="this.style.background='transparent'; this.style.color='#4ade80'">
                                                        <i class="bi bi-cart-plus"></i>
                                                    </button>
                                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p style="text-align: center; width: 100%; color: #999; padding: 40px 0;">Our full collection is coming soon!</p>
                                    <% } %>
                </div>
                <button class="scroll-arrow right" onclick="scrollGrid('collection-grid', 200)" aria-label="Scroll right">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </section>


        <!-- Footer -->
        <footer class="footer">
            <div class="footer-content">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <i class="bi bi-phone"></i>
                        Zyrox
                    </div>
                    <p class="footer-description">
                        Discover the latest smartphones from top brands. We offer a wide range of mobile phones with
                        cutting-edge technology and competitive prices. Your trusted partner for all your mobile needs.
                    </p>
                    <div class="social-links">
                        <a href="https://www.instagram.com/busthan_c/" target="_blank" class="social-link instagram"><i class="bi bi-instagram"></i></a>
                        <a href="https://www.instagram.com/busthan_c/" target="_blank" class="social-link instagram"><i class="bi bi-instagram"></i></a>
                        <a href="https://www.instagram.com/busthan_c/" target="_blank" class="social-link instagram"><i class="bi bi-instagram"></i></a>
                        <a href="https://github.com/busthanthasreef/" target="_blank" class="social-link github"><i class="bi bi-github"></i></a>
                    </div>
                </div>

                <div class="footer-column">
                    <h3 class="cursor-pointer hover:text-accent transition-colors" onclick="window.location.href='/products'">Shop Brands</h3>
                    <ul class="footer-links">
                        <% if(typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.slice(0, 6).forEach(category => { %>
                                <li><a href="/products?brand=<%= category.categoryName %>" class="hover:text-accent transition-colors"><%= category.categoryName %></a></li>
                            <% }) %>
                        <% } else { %>
                            <li><a href="/products">All Smartphones</a></li>
                        <% } %>
                    </ul>
                </div>

                <div class="footer-column">
                    <h3>Customer Support</h3>
                    <ul class="footer-links">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Track Order</a></li>
                        <li><a href="#">Returns</a></li>
                        <li><a href="#">Warranty</a></li>
                        <li><a href="#">Shipping Info</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h3>Company</h3>
                    <ul class="footer-links">
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Sitemap</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                © 2025 Zyrox. All rights reserved.
            </div>
        </footer>


        <script>
            function scrollGrid(gridId, amount) {
                const grid = document.getElementById(gridId);
                if (grid) {
                    grid.scrollBy({ left: amount, behavior: 'smooth' });
                }
            }

            function copyCoupon() {
                const code = document.getElementById('couponCode')?.textContent;
                if (!code) return;
                navigator.clipboard.writeText(code).then(() => {
                    const icon = document.getElementById('copyIcon');
                    if (icon) {
                        icon.classList.remove('bi-copy');
                        icon.classList.add('bi-check-lg');
                        setTimeout(() => {
                            icon.classList.remove('bi-check-lg');
                            icon.classList.add('bi-copy');
                        }, 1500);
                    }
                }).catch(() => {
                    Swal.fire({ icon: 'info', title: code, text: 'Copy this coupon code!', timer: 2000, showConfirmButton: false });
                });
            }

            const swalBase = {
                background: '#0f172a',
                color: '#fff',
                confirmButtonColor: '#4ade80',
                cancelButtonColor: '#334155',
            };

            async function addToCartListing(btn, productId, variantId) {
                try {
                    if (btn.disabled) return;
                    
                    const originalContent = btn.innerHTML;
                    btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i>';
                    btn.disabled = true;

                    const response = await fetch('/cart/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId, variantId, quantity: 1 })
                    });

                    const result = await response.json();
                    btn.innerHTML = originalContent;
                    btn.disabled = false;

                    if (result.requiresAuth || response.status === 401) {
                        return Swal.fire({
                            ...swalBase,
                            icon: 'info',
                            title: 'Sign In Required',
                            text: 'Please log in to add items to your cart.',
                            confirmButtonText: 'Sign In',
                            showCancelButton: true,
                            cancelButtonText: 'Do it later'
                        }).then(r => {
                            if (r.isConfirmed) {
                                btn.disabled = true;
                                btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i> Processing...';
                                redirectTo(`/signin?returnTo=${encodeURIComponent(currentPath)}`);
                            }
                        });
                    }

                    if (result.success) {
                        Swal.fire({
                            ...swalBase,
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: 'Added to cart!',
                            showConfirmButton: false,
                            timer: 2500,
                            timerProgressBar: true,
                            iconColor: '#4ade80',
                        });

                        // Update cart count dynamically from server response
                        const cartBadge = document.querySelector('.cart-badge');
                        if (cartBadge && result.cartCount !== undefined) {
                            cartBadge.textContent = result.cartCount;
                            cartBadge.style.display = 'flex';
                        }
                    } else {
                        Swal.fire({
                            ...swalBase,
                            icon: 'error',
                            title: 'Oops...',
                            text: result.message || 'Failed to add to cart'
                        });
                    }
                } catch (error) {
                    console.error("Add to Cart Error:", error);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-cart-plus"></i>';
                }
            }

            // Scroll Reveal Intersection Observer
            document.addEventListener('DOMContentLoaded', () => {
                const observerOptions = {
                    threshold: 0.15,
                    rootMargin: '0px 0px -50px 0px'
                };

                const revealObserver = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('active');
                            revealObserver.unobserve(entry.target);
                        }
                    });
                }, observerOptions);

                // Target sections and cards
                const sections = document.querySelectorAll('.hero, .categories, .products, .footer');
                const productCards = document.querySelectorAll('.product-card');

                sections.forEach(sec => {
                    sec.classList.add('reveal');
                    revealObserver.observe(sec);
                });

                productCards.forEach((card, idx) => {
                    card.classList.add('reveal');
                    // Add staggered delay class (cycle 1-4)
                    card.classList.add(`stagger-${(idx % 4) + 1}`);
                    revealObserver.observe(card);
                });
            });
        </script>

        <!-- ═══ TRENDING PRODUCTS ANIMATION ENGINE ═══
             Pure CSS + minimal JS. No libraries. Intersection Observer fires once.
             Fragment effect: image sliced into 5×2 grid, scattered, reassembled.
        ══════════════════════════════════════════════ -->
        <script>
        (function () {
            'use strict';

            const COLS = 5, ROWS = 2;          // fragment grid
            const SCATTER_DIST = 38;           // px each piece flies out
            const isMobile = window.innerWidth <= 768;
            const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            /* ── Utility: build fragment overlay on a card ── */
            function buildFragments(card) {
                if (isMobile || prefersReduced) return;

                const img = card.querySelector('.product-image');
                if (!img || !img.src) return;

                const wrap = document.createElement('div');
                wrap.className = 'zyx-fragment-wrap';
                wrap.style.position = 'absolute';
                wrap.style.inset = '0';

                // Position wrap relative to card (card already has position:relative)
                for (let r = 0; r < ROWS; r++) {
                    for (let c = 0; c < COLS; c++) {
                        const piece = document.createElement('div');
                        piece.className = 'zyx-piece';
                        // Use background-image + background-position to slice the image
                        piece.style.backgroundImage = `url(${img.src})`;
                        piece.style.backgroundSize  = `${COLS * 100}% ${ROWS * 100}%`;
                        piece.style.backgroundPosition = `${(c / (COLS - 1)) * 100}% ${(r / (ROWS - 1)) * 100}%`;
                        // Determine scatter direction (vector from center of grid)
                        const dx = (c - (COLS - 1) / 2);
                        const dy = (r - (ROWS - 1) / 2);
                        piece.dataset.dx = dx;
                        piece.dataset.dy = dy;
                        piece.style.transition = `transform 4.0s cubic-bezier(0.22, 1, 0.36, 1) ${(r * COLS + c) * 35}ms,
                                                  opacity 0.75s ease ${(r * COLS + c) * 25}ms`;
                        wrap.appendChild(piece);
                    }
                }

                // Insert behind text, over image
                const imgParent = img.parentNode;
                imgParent.style.position = 'relative';
                img.parentNode.insertBefore(wrap, img.nextSibling);
                return wrap;
            }

            /* ── Play fragment animation on a card ── */
            function playFragment(card) {
                if (isMobile || prefersReduced) return;

                const wrap = card.querySelector('.zyx-fragment-wrap');
                if (!wrap) return;

                const pieces = wrap.querySelectorAll('.zyx-piece');

                // Phase 1: show overlay + scatter pieces
                wrap.classList.add('active');
                pieces.forEach(p => {
                    const dx = parseFloat(p.dataset.dx);
                    const dy = parseFloat(p.dataset.dy);
                    p.style.transform = `translate(${dx * SCATTER_DIST}px, ${dy * SCATTER_DIST}px) scale(0.85)`;
                    p.style.opacity   = '0';
                });

                // Phase 2: reassemble (after scatter settles)
                setTimeout(() => {
                    pieces.forEach(p => {
                        p.style.transform = 'translate(0,0) scale(1)';
                        p.style.opacity   = '1';
                    });
                }, 650); // Delayed joining (Phase 2)

                // Phase 3: remove overlay so real image shows clean
                setTimeout(() => {
                    wrap.classList.remove('active');
                    wrap.style.opacity = '0';
                }, 5000); // Extended finish (Phase 3) for 4s transition
            }

            /* ── Main: set up Intersection Observer ── */
            function initTrendingAnimation() {
                const section = document.querySelector('.trending-section');
                if (!section) return;

                const header = section.querySelector('.section-header');
                const cards  = section.querySelectorAll('.product-card');

                if (!cards.length) return;

                // Build fragment overlays now (before animation fires)
                cards.forEach(card => buildFragments(card));

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (!entry.isIntersecting) return;
                        observer.unobserve(entry.target); // fires only once

                        // Animate header in
                        if (header) {
                            requestAnimationFrame(() => header.classList.add('zyx-header-in'));
                        }

                        // Spread cards in with stagger
                        cards.forEach((card, i) => {
                            setTimeout(() => {
                                card.classList.add('zyx-spread');

                                // Play fragment effect after card has arrived
                                setTimeout(() => playFragment(card), 300);

                                // Enable idle swing after everything settles
                                setTimeout(() => card.classList.add('zyx-idle'), 900);
                            }, i * 100);
                        });
                    });
                }, {
                    threshold: 0.12,
                    rootMargin: '0px 0px -40px 0px'
                });

                observer.observe(section);
            }

            // Boot after DOM ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initTrendingAnimation);
            } else {
                initTrendingAnimation();
            }
        })();
        </script>

</body>

</html>